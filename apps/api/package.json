{
  "name": "@tgo/api",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --env-file=../../.env --watch --import tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node --env-file-if-exists=../../.env dist/apps/api/src/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.test.json --noEmit",
    "test": "npm run test:integration",
    "test:integration": "node --env-file-if-exists=../../.env --env-file=../../.env.example --import tsx --test --test-concurrency=1 test/**/*.test.ts",
    "validate-env": "node --env-file-if-exists=../../.env --import tsx src/scripts/validate-env.ts",
    "bootstrap-admin": "node --env-file=../../.env --import tsx src/scripts/bootstrap-admin.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1019.0",
    "@aws-sdk/s3-request-presigner": "^3.1019.0",
    "@hono/node-server": "^1.14.0",
    "@tgo/db": "workspace:*",
    "@tgo/shared": "workspace:*",
    "better-auth": "^1.3.7",
    "drizzle-orm": "^0.41.0",
    "hono": "^4.7.4"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
