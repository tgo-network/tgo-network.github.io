{
  "name": "@tgo/site",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "astro dev --host localhost --port 4321",
    "build": "astro build && node ./scripts/prune-dist.mjs",
    "preview": "astro preview --host localhost --port 4321",
    "typecheck": "astro check && tsc -p tsconfig.test.json --noEmit",
    "test": "node --import tsx --test test/**/*.test.ts"
  },
  "dependencies": {
    "@tgo/shared": "workspace:*",
    "astro": "^5.6.1"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.4",
    "@types/node": "^22.13.10",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
