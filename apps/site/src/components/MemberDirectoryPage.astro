---
import { getPublicWriteApiBaseUrl } from "../lib/public-api.js";
import type { MemberDirectoryPageData } from "../lib/member-directory.js";
import BaseLayout from "../layouts/BaseLayout.astro";

interface Props extends MemberDirectoryPageData {}

const { items, cityLinks, branchLinks, currentCity, currentBranch, currentBranchSlug, page, pageCount, total, prevHref, nextHref, canonical, title, description } =
  Astro.props as Props;
const heading = currentBranch ? `${currentBranch}成员` : currentCity ? `${currentCity}成员` : "成员列表";
const summary = currentBranch
  ? `当前筛选 ${currentBranch}，共 ${total} 位成员。`
  : currentCity
    ? `当前筛选 ${currentCity}，共 ${total} 位成员。`
    : `当前共展示 ${total} 位成员。`;
const searchApiBase = getPublicWriteApiBaseUrl() ?? "";
const searchPlaceholder = currentBranch
  ? `搜索 ${currentBranch} 的名字、公司或头衔`
  : currentCity
    ? `搜索 ${currentCity} 的名字、公司或头衔`
    : "搜索名字、公司或头衔";
---

<BaseLayout title={title} description={description} canonical={canonical}>
  <main class="page-shell page-stack member-directory-shell">
    <section class="section member-directory-section">
      <div class="directory-heading">
        <div>
          <h1>{heading}</h1>
          <p class="card-copy" data-member-directory-summary>{summary}</p>
        </div>
      </div>

      <div class="panel member-directory-toolbar">
        <form
          class="directory-search-form"
          data-member-search-form
          data-api-base={searchApiBase}
          data-current-city={currentCity ?? ""}
          data-current-branch-slug={currentBranchSlug ?? ""}
          data-search-index-path="/members/search-index.json"
        >
          <label for="member-directory-search">
            <span class="directory-filter-label">关键词搜索</span>
            <span class="sr-only">支持搜索名字、公司或头衔</span>
          </label>
          <div class="directory-search-controls">
            <input
              id="member-directory-search"
              name="q"
              type="search"
              placeholder={searchPlaceholder}
              autocomplete="off"
              enterkeyhint="search"
              data-member-search-input
            />
            <button class="button secondary" type="submit">
              搜索
            </button>
            <button class="button secondary directory-search-reset" type="button" data-member-search-reset hidden>
              清除
            </button>
          </div>
          <p class="card-copy directory-search-hint">支持搜索名字、公司或头衔，且会保留当前城市或分会筛选。</p>
          <p class="card-copy directory-search-status" data-member-search-status aria-live="polite"></p>
        </form>

        <div class="directory-filter-stack">
          <div class="directory-filter-group">
            <p class="directory-filter-label">按城市</p>
            <nav class="filter-bar" aria-label="成员城市筛选">
              {
                cityLinks.map((link) => (
                  <a class:list={["filter-chip", link.active && "is-active"]} href={link.href} aria-current={link.active ? "page" : undefined}>
                    {link.label}
                  </a>
                ))
              }
            </nav>
          </div>

          <div class="directory-filter-group">
            <p class="directory-filter-label">按分会</p>
            <nav class="filter-bar" aria-label="成员分会筛选">
              {
                branchLinks.map((link) => (
                  <a class:list={["filter-chip", link.active && "is-active"]} href={link.href} aria-current={link.active ? "page" : undefined}>
                    {link.label}
                  </a>
                ))
              }
            </nav>
          </div>
        </div>
      </div>

      <div class="member-directory-grid" data-member-directory-grid>
        {
          items.map((member) => (
            <a class="panel member-directory-card" href={`/members/${member.slug}`}>
              <div class="member-directory-head">
                {
                  member.avatar ? (
                    <img class="member-directory-avatar" src={member.avatar.url} alt={member.avatar.alt} loading="lazy" />
                  ) : (
                    <div class="member-directory-avatar member-directory-avatar-fallback" aria-hidden="true">
                      {member.name.slice(0, 1)}
                    </div>
                  )
                }

                <div class="member-directory-copy">
                  <p class="member-directory-branch">{member.branch?.name ?? "未标注分会"}</p>
                  <h2>{member.name}</h2>
                  <p class="member-directory-company">{member.company}</p>
                  <p class="member-directory-title">{member.title}</p>
                </div>
              </div>
            </a>
          ))
        }
      </div>

      <div class="panel panel-soft empty-state" data-member-directory-empty-state hidden={items.length > 0}>
        <div class="card-label" data-member-directory-empty-title>暂无成员</div>
        <p class="card-copy" data-member-directory-empty-copy>当前筛选下暂无可展示的成员。</p>
      </div>

      <div class="pagination-bar member-pagination-bar" aria-label="成员分页" data-member-directory-pagination>
        {
          prevHref ? (
            <a class="button secondary pagination-button" href={prevHref} rel="prev">
              上一页
            </a>
          ) : (
            <button class="button secondary pagination-button" type="button" disabled>
              上一页
            </button>
          )
        }

        <p class="member-directory-page-indicator">第 {page} / {pageCount} 页</p>

        {
          nextHref ? (
            <a class="button secondary pagination-button" href={nextHref} rel="next">
              下一页
            </a>
          ) : (
            <button class="button secondary pagination-button" type="button" disabled>
              下一页
            </button>
          )
        }
      </div>
    </section>
  </main>

  <script>
    import { setupMemberDirectorySearch } from "../scripts/member-directory-search";

    setupMemberDirectorySearch();
  </script>
</BaseLayout>

<style>
  .member-directory-shell {
    padding-top: 18px;
    padding-bottom: 48px;
  }

  .member-directory-section,
  .member-directory-toolbar,
  .directory-heading,
  .directory-search-form,
  .directory-search-controls,
  .directory-filter-stack,
  .directory-filter-group {
    display: grid;
    gap: 18px;
  }

  .directory-heading h1,
  .directory-filter-label {
    margin: 0;
  }

  .directory-heading .card-copy {
    margin: 0;
  }

  .directory-search-form {
    padding-bottom: 18px;
    border-bottom: 1px solid rgba(138, 106, 67, 0.12);
  }

  .directory-search-controls {
    grid-template-columns: minmax(0, 1fr) auto auto;
    align-items: center;
  }

  .directory-search-hint,
  .directory-search-status {
    margin: 0;
  }

  .directory-search-status {
    min-height: 1.7em;
  }

  .directory-search-reset[hidden] {
    display: none;
  }

  .directory-filter-label {
    color: var(--muted);
    font-size: 0.78rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .member-directory-grid {
    display: grid;
    gap: 20px;
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .member-directory-card {
    display: grid;
    min-height: 100%;
    padding: 24px;
    background:
      radial-gradient(circle at top right, rgba(138, 106, 67, 0.08), transparent 28%),
      linear-gradient(180deg, rgba(255, 252, 246, 0.98), rgba(245, 238, 227, 0.92));
    transition: transform 180ms ease, border-color 180ms ease, box-shadow 180ms ease;
  }

  .member-directory-card:hover {
    transform: translateY(-2px);
    border-color: rgba(138, 106, 67, 0.18);
    box-shadow: 0 20px 40px rgba(35, 28, 21, 0.1);
  }

  .member-directory-head {
    display: grid;
    gap: 16px;
    grid-template-columns: 76px minmax(0, 1fr);
    align-items: start;
  }

  .member-directory-copy {
    display: grid;
    gap: 8px;
    align-content: start;
  }

  .member-directory-branch {
    display: inline-flex;
    align-items: center;
    width: fit-content;
    min-height: 28px;
    margin: 0;
    padding: 0 10px;
    border-radius: 999px;
    border: 1px solid rgba(138, 106, 67, 0.16);
    background: rgba(255, 248, 238, 0.72);
    color: var(--accent-strong);
    font-size: 0.76rem;
    letter-spacing: 0.04em;
  }

  .member-directory-copy h2,
  .member-directory-company,
  .member-directory-title {
    margin: 0;
  }

  .member-directory-company,
  .member-directory-title,
  .member-directory-page-indicator {
    color: var(--muted);
    line-height: 1.7;
  }

  .member-directory-avatar {
    width: 76px;
    height: 76px;
    border-radius: 20px;
    object-fit: cover;
    background: rgba(27, 23, 19, 0.06);
  }

  .member-directory-avatar-fallback {
    display: grid;
    place-items: center;
    border: 1px solid rgba(27, 23, 19, 0.08);
    background: linear-gradient(180deg, rgba(255, 254, 252, 0.96), rgba(239, 231, 220, 0.92));
    color: var(--accent-strong);
    font-family: var(--font-display);
    font-size: 1.56rem;
  }

  .member-pagination-bar {
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 12px;
    align-items: center;
  }

  .member-directory-page-indicator {
    margin: 0;
    text-align: center;
  }

  @media (max-width: 980px) {
    .member-directory-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 720px) {
    .member-directory-shell {
      padding-top: 8px;
    }

    .directory-search-controls,
    .member-directory-grid,
    .member-pagination-bar {
      grid-template-columns: 1fr;
    }

    .member-directory-card {
      padding: 18px;
    }

    .member-directory-page-indicator {
      order: -1;
    }
  }
</style>
