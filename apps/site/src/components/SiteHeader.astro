---
import { getSiteConfig } from "../lib/public-api";

interface Props {
  config?: Awaited<ReturnType<typeof getSiteConfig>>;
}

const pathname = Astro.url.pathname.replace(/\/$/, "") || "/";
const { config: providedConfig } = Astro.props as Props;
const config = providedConfig ?? (await getSiteConfig());
const isActive = (href: string) => {
  if (href === "/") {
    return pathname === "/";
  }

  return pathname === href || pathname.startsWith(`${href}/`);
};
---

<header class="site-header">
  <div class="page-shell site-header-inner">
    <a class="site-brand" href="/">
      <span class="site-brand-mark">TGO</span>
      <span class="site-brand-text">
        <strong>{config.platformName}</strong>
        <small>科技领导者社区</small>
      </span>
    </a>

    <nav class="site-nav" aria-label="主导航">
      {
        config.navigation.map((item) => (
          <a
            class:list={[
              "site-nav-link",
              {
                active: isActive(item.href),
                "site-nav-link-cta": item.href === "/join",
                "site-nav-link-secondary": item.href === "/faq"
              }
            ]}
            href={item.href}
          >
            {item.label}
          </a>
        ))
      }
    </nav>
  </div>
</header>
