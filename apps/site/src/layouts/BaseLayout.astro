---
import SiteHeader from "../components/SiteHeader.astro";
import { getSiteConfig } from "../lib/public-api";
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = "TGO 鲲鹏会公开站：以静态优先方式呈现组织介绍、分会、成员、活动与内容。"
} = Astro.props;
const config = await getSiteConfig();
const footerGroups = [
  {
    title: "组织结构",
    links: [
      { label: "首页总览", href: "/" },
      { label: "分会网络", href: "/branches" },
      { label: "成员档案", href: "/members" }
    ]
  },
  {
    title: "学习活动",
    links: [
      { label: "活动日历", href: "/events" },
      { label: "社区文章", href: "/articles" },
      { label: "加入说明", href: "/join" }
    ]
  },
  {
    title: "关于与条款",
    links: [
      { label: "关于 TGO", href: "/about" },
      { label: "隐私说明", href: "/privacy" },
      { label: "使用条款", href: "/terms" }
    ]
  }
] as const;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
  </head>
  <body>
    <SiteHeader config={config} />
    <slot />

    <footer class="site-footer">
      <div class="page-shell site-footer-shell">
        <div class="site-footer-brand">
          <a class="site-brand site-footer-brand-link" href="/">
            <span class="site-brand-mark">TGO</span>
            <span class="site-brand-text">
              <strong>{config.platformName}</strong>
              <small>科技领导者社区</small>
            </span>
          </a>
          <p>{config.footerTagline}</p>
          {config.supportEmail && <a class="site-footer-email" href={`mailto:${config.supportEmail}`}>{config.supportEmail}</a>}
        </div>

        <div class="site-footer-grid">
          {
            footerGroups.map((group) => (
              <div class="site-footer-group">
                <h2>{group.title}</h2>
                <div class="site-footer-links">
                  {group.links.map((link) => <a href={link.href}>{link.label}</a>)}
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </footer>
  </body>
</html>
