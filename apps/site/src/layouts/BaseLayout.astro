---
import SiteHeader from "../components/SiteHeader.astro";
import { getSiteConfig } from "../lib/public-api";
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = "TGO 鲲鹏会，展示组织介绍、分会、成员、活动与内容。"
} = Astro.props;
const config = await getSiteConfig();
const currentYear = new Date().getFullYear();
const legalLinks = [
  { label: "隐私说明", href: "/privacy" },
  { label: "使用条款", href: "/terms" }
] as const;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
  </head>
  <body>
    <SiteHeader config={config} />
    <slot />

    <footer class="site-footer">
      <div class="page-shell site-footer-shell">
        <div class="site-footer-top">
          <a class="site-footer-brand-link" href="/">
            <span class="site-brand-mark">TGO</span>
            <span class="site-footer-brand-name">{config.platformName}</span>
          </a>

          <div class="site-footer-legal-links" aria-label="页脚导航">
            {legalLinks.map((link) => <a href={link.href}>{link.label}</a>)}
          </div>
        </div>

        <p class="site-footer-copy">版权所有 © {currentYear} {config.platformName}</p>
      </div>
    </footer>
  </body>
</html>
