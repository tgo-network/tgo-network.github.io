---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="页面未找到 | TGO 鲲鹏会" description="你访问的页面不存在或已调整。" noindex={true}>
  <main class="page-shell page-stack">
    <section class="hero">
      <div class="hero-card panel stack-sm">
        <h1>页面未找到</h1>
        <p>你访问的页面可能已调整、下线，或地址输入有误。</p>
        <div class="hero-actions">
          <a class="button primary" href="/">返回首页</a>
          <a class="text-link" href="/faq">查看 FAQ</a>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
