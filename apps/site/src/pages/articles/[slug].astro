---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { formatDate } from "../../lib/format";
import { getArticle, listArticles } from "../../lib/public-api";

export const getStaticPaths = async () => {
  const articles = await listArticles();

  return articles.map((article) => ({
    params: {
      slug: article.slug
    }
  }));
};

const slug = Astro.params.slug!;
const article = await getArticle(slug);

if (!article) {
  throw new Error(`文章不存在：${slug}`);
}

const estimatedReadMinutes = Math.max(3, Math.round(article.body.join("").length / 220));
const [leadParagraph, ...remainingParagraphs] = article.body;
const bodyParagraphs = remainingParagraphs.length > 0 ? remainingParagraphs : article.body;
---

<BaseLayout title={`${article.title} | 文章 | TGO 鲲鹏会`} description={article.excerpt}>
  <main class="page-shell page-stack detail-page-shell article-detail-shell">
    <section class="section">
      <article class:list={["panel detail-hero-card article-detail-head-card", !article.coverImage && "detail-hero-card-single"]}>
        <div class="detail-hero-copy article-detail-copy">
          <h1>{article.title}</h1>
          <p class="detail-summary article-detail-summary">{article.excerpt}</p>
          <div class="detail-meta-row article-detail-meta">
            <span class="detail-meta-item">{formatDate(article.publishedAt)}</span>
            <span class="detail-meta-item">{article.author.name}</span>
            <span class="detail-meta-item">{estimatedReadMinutes} 分钟阅读</span>
          </div>

          <div class="hero-actions article-hero-actions">
            {article.branch && <a class="button primary" href={`/branches#${article.branch.slug}`}>查看相关分会</a>}
            <a class="text-link" href="/articles">返回文章列表</a>
          </div>
        </div>

        {
          article.coverImage && (
            <figure class="detail-hero-figure">
              <img class="detail-hero-image article-detail-image" src={article.coverImage.url} alt={article.coverImage.alt} />
            </figure>
          )
        }
      </article>
    </section>

    <section class="section">
      <div class="detail-content-grid article-detail-layout">
        <article class="panel prose-panel detail-body-panel article-body-panel">
          <div class="article-body-intro">
            <p class="article-body-lead">{leadParagraph ?? article.excerpt}</p>
          </div>

          <div class="article-body-content">
            {bodyParagraphs.map((paragraph) => <p>{paragraph}</p>)}
          </div>
        </article>

        <aside class="detail-side-stack article-side-stack detail-sticky">
          <article class="panel detail-side-card article-context-card">
            <h2>作者</h2>
            <strong>{article.author.name}</strong>
            <p>{article.author.role}</p>
          </article>

          <article class="panel detail-side-card article-context-card">
            <h2>发布时间</h2>
            <strong>{formatDate(article.publishedAt)}</strong>
            <p>预计阅读 {estimatedReadMinutes} 分钟</p>
          </article>

          {
            article.branch && (
              <article class="panel detail-side-card article-context-card article-branch-panel">
                <h2>相关分会</h2>
                <strong>{article.branch.name}</strong>
                <a class="text-link" href={`/branches#${article.branch.slug}`}>查看相关分会</a>
              </article>
            )
          }

          <article class="panel detail-side-card article-context-card article-back-card">
            <h2>继续浏览</h2>
            <strong>返回文章列表</strong>
            <p>查看更多技术管理与组织实践内容。</p>
            <a class="text-link" href="/articles">查看全部文章</a>
          </article>
        </aside>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .article-detail-head-card {
    grid-template-columns: minmax(0, 1.12fr) minmax(320px, 0.88fr);
    align-items: center;
  }

  .article-detail-copy {
    gap: 18px;
  }

  .article-detail-summary {
    max-width: 58ch;
  }

  .article-detail-meta {
    max-width: 760px;
  }

  .article-hero-actions {
    margin-top: 2px;
  }

  .article-detail-layout {
    grid-template-columns: minmax(0, 1.08fr) minmax(280px, 0.92fr);
  }

  .article-body-panel {
    display: grid;
    gap: 24px;
    padding: clamp(22px, 2.6vw, 32px);
  }

  .article-body-intro {
    padding-bottom: 20px;
    border-bottom: 1px solid rgba(27, 23, 19, 0.08);
  }

  .article-body-intro::before {
    content: "";
    display: block;
    width: 78px;
    height: 3px;
    margin-bottom: 18px;
    border-radius: 999px;
    background: linear-gradient(90deg, rgba(185, 138, 66, 0.95), rgba(185, 138, 66, 0.12));
  }

  .article-body-content {
    display: grid;
    gap: 6px;
  }

  .article-body-lead,
  .article-body-panel p:first-of-type {
    color: var(--ink);
    font-size: 1.06rem;
  }

  .article-body-lead {
    margin: 0;
    max-width: 62ch;
    line-height: 1.9;
  }

  .article-side-stack {
    gap: 16px;
  }

  .article-context-card {
    display: grid;
    gap: 10px;
    padding: 20px;
  }

  .article-context-card h2,
  .article-context-card strong {
    margin: 0;
  }

  .article-context-card strong {
    line-height: 1.7;
  }

  .article-context-card p {
    margin: 0;
    color: var(--muted);
    line-height: 1.8;
  }

  .article-branch-panel .text-link,
  .article-back-card .text-link {
    width: fit-content;
  }

  .article-back-card p {
    max-width: 24ch;
  }

  @media (max-width: 980px) {
    .article-detail-head-card,
    .article-detail-layout {
      grid-template-columns: 1fr;
    }

    .article-detail-image {
      min-height: 260px;
    }
  }

  @media (max-width: 720px) {
    .article-detail-image {
      min-height: 220px;
    }
  }
</style>
