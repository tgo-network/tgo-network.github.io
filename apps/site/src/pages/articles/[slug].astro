---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { formatDate } from "../../lib/format";
import { getArticle, listArticles } from "../../lib/public-api";

export const getStaticPaths = async () => {
  const articles = await listArticles();

  return articles.map((article) => ({
    params: {
      slug: article.slug
    }
  }));
};

const slug = Astro.params.slug!;
const article = await getArticle(slug);

if (!article) {
  throw new Error(`文章不存在：${slug}`);
}
---

<BaseLayout title={`${article.title} | 文章 | TGO Network`} description={article.excerpt}>
  <main class="page-shell page-stack">
    <section class="hero">
      <div class:list={["hero-card", { "hero-split": Boolean(article.coverImage), "hero-card-media": Boolean(article.coverImage) }]}>
        <div>
          <span class="eyebrow">文章详情</span>
          <h1>{article.title}</h1>
          <p>{article.excerpt}</p>
          <ul class="stat-row">
            <li>{formatDate(article.publishedAt)}</li>
            <li>{article.author.name}</li>
            <li>{article.citySummary.name}</li>
          </ul>
        </div>

        {
          article.coverImage && (
            <figure class="hero-figure">
              <img class="hero-image" src={article.coverImage.url} alt={article.coverImage.alt} />
            </figure>
          )
        }
      </div>
    </section>

    <section class="section detail-grid">
      <article class="panel prose-panel">
        <div class="card-label">正文</div>
        {article.body.map((paragraph) => <p>{paragraph}</p>)}
      </article>

      <aside class="panel panel-soft stack-sm">
        <div>
          <div class="card-label">作者</div>
          <h2 class="card-title">{article.author.name}</h2>
          <p class="card-copy">{article.author.role}</p>
        </div>

        <div>
          <div class="card-label">城市语境</div>
          <p class="card-copy">
            <a class="text-link" href={`/cities/${article.citySummary.slug}`}>{article.citySummary.name}</a>
            {" "}
            - {article.citySummary.summary}
          </p>
        </div>

        <div>
          <div class="card-label">关联主题</div>
          <div class="chip-row">
            {
              article.topics.map((topic) => (
                <a class="chip" href={`/topics/${topic.slug}`}>
                  {topic.title}
                </a>
              ))
            }
          </div>
        </div>
      </aside>
    </section>
  </main>
</BaseLayout>
