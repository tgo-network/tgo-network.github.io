---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { formatDate } from "../../lib/format";
import { getArticle, listArticles } from "../../lib/public-api";

export const getStaticPaths = async () => {
  const articles = await listArticles();

  return articles.map((article) => ({
    params: {
      slug: article.slug
    }
  }));
};

const slug = Astro.params.slug!;
const article = await getArticle(slug);

if (!article) {
  throw new Error(`文章不存在：${slug}`);
}

const estimatedReadMinutes = Math.max(3, Math.round(article.body.join("").length / 220));
const branchName = article.branch?.name ?? "社区内容";
const articleSignals = [
  {
    label: "内容来源",
    value: branchName,
    summary: article.branch
      ? `这篇文章来自 ${article.branch.name} 的公开内容沉淀，与城市分会和活动视角保持关联。`
      : "这篇文章由社区统一发布，用于继续沉淀活动与组织经验。"
  },
  {
    label: "作者角色",
    value: article.author.role,
    summary: "作者角色会帮助访客理解文章是从编辑、运营还是城市项目视角写出来的。"
  },
  {
    label: "阅读定位",
    value: `${estimatedReadMinutes} 分钟阅读`,
    summary: "建议先读完正文，再回到活动或分会页查看文章对应的组织现场。"
  }
];

const nextPaths = [
  {
    title: "返回文章列表",
    summary: "继续查看更多技术管理、活动复盘与组织观察内容。",
    href: "/articles",
    action: "查看全部文章"
  },
  {
    title: article.branch ? `查看 ${article.branch.name}` : "查看分会董事会",
    summary: article.branch
      ? `继续理解这篇文章背后的城市节点与分会结构。`
      : "继续回到分会页，理解内容背后的组织结构。",
    href: article.branch ? `/branches#${article.branch.slug}` : "/branches",
    action: article.branch ? "浏览所属分会" : "浏览分会"
  },
  {
    title: "回到活动现场",
    summary: "文章往往来自活动与社区实践，回到活动页会更容易理解它为何被写出来。",
    href: "/events",
    action: "查看活动"
  }
];
---

<BaseLayout title={`${article.title} | 文章 | TGO 鲲鹏会`} description={article.excerpt}>
  <main class="page-shell page-stack">
    <section class="hero">
      <div class="hero-card article-detail-hero">
        <div class="article-detail-main">
          <span class="eyebrow">文章详情</span>
          <h1>{article.title}</h1>
          <p class="article-detail-lead">{article.excerpt}</p>
          <ul class="stat-row">
            <li>{formatDate(article.publishedAt)}</li>
            <li>{article.author.name}</li>
            <li>{estimatedReadMinutes} 分钟阅读</li>
          </ul>

          <div class="article-signal-grid">
            {
              articleSignals.map((item) => (
                <article class="article-signal-card">
                  <div class="article-signal-label">{item.label}</div>
                  <strong>{item.value}</strong>
                  <p>{item.summary}</p>
                </article>
              ))
            }
          </div>
        </div>

        <aside class="article-detail-side">
          <div class="article-detail-side-card">
            <div class="card-label card-label-on-dark">文章信息</div>
            <ul class="article-side-list">
              <li>
                <span>作者</span>
                <strong>{article.author.name}</strong>
              </li>
              <li>
                <span>角色</span>
                <strong>{article.author.role}</strong>
              </li>
              <li>
                <span>发布时间</span>
                <strong>{formatDate(article.publishedAt)}</strong>
              </li>
              {article.branch?.name && (
                <li>
                  <span>相关分会</span>
                  <strong>{article.branch.name}</strong>
                </li>
              )}
            </ul>
          </div>

          {
            article.coverImage && (
              <figure class="article-detail-figure">
                <img class="article-detail-image" src={article.coverImage.url} alt={article.coverImage.alt} />
              </figure>
            )
          }
        </aside>
      </div>
    </section>

    <section class="section article-detail-grid">
      <article class="panel prose-panel article-body-panel">
        <div class="card-label">正文</div>
        <h2 class="card-title">从活动与组织问题延伸出来的公开内容</h2>
        {article.body.map((paragraph) => <p>{paragraph}</p>)}
      </article>

      <aside class="panel panel-soft article-notes-panel">
        <div>
          <div class="card-label">内容说明</div>
          <p class="card-copy">
            文章由工作人员统一发布，但它的价值并不只在“发出来”，而在于把分会活动、成员经验和组织实践继续沉淀为可长期阅读的内容资产。
          </p>
        </div>

        <div>
          <div class="card-label">阅读线索</div>
          <ul class="meta-list vertical-list">
            <li>先理解文章想回应的管理或组织问题</li>
            <li>再看作者角色与分会来源，理解它来自什么场景</li>
            <li>最后回到活动或分会页，连接内容与真实组织现场</li>
          </ul>
        </div>

        <div>
          <div class="card-label">继续浏览</div>
          <div class="article-next-links">
            <a class="button secondary" href="/articles">返回文章列表</a>
            <a class="button secondary" href="/events">查看活动</a>
            <a class="button secondary" href="/branches">浏览分会</a>
          </div>
        </div>
      </aside>
    </section>

    <section class="section">
      <div class="article-next-grid">
        {
          nextPaths.map((item) => (
            <a class="panel article-next-card" href={item.href}>
              <h2>{item.title}</h2>
              <p class="card-copy">{item.summary}</p>
              <span class="text-link">{item.action}</span>
            </a>
          ))
        }
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .article-detail-hero {
    display: grid;
    gap: 22px;
    grid-template-columns: minmax(0, 1.15fr) minmax(320px, 0.85fr);
    background:
      radial-gradient(circle at top right, rgba(215, 179, 117, 0.18), transparent 24%),
      linear-gradient(135deg, #171717 0%, #201c17 100%);
    border-color: rgba(215, 179, 117, 0.14);
    color: #f8f1e8;
  }

  .article-detail-hero h1,
  .article-detail-hero h2 {
    color: #fff7ef;
  }

  .article-detail-hero p {
    color: rgba(248, 241, 232, 0.76);
  }

  .article-detail-hero .eyebrow {
    color: #f1d5a0;
    border-color: rgba(215, 179, 117, 0.28);
    background: rgba(255, 255, 255, 0.06);
  }

  .article-detail-main h1 {
    max-width: 11ch;
    line-height: 1;
  }

  .article-detail-lead {
    max-width: 58ch;
    font-size: 1.05rem;
    line-height: 1.86;
  }

  .article-detail-main,
  .article-detail-side,
  .article-signal-grid,
  .article-next-grid {
    display: grid;
    gap: 18px;
  }

  .article-detail-side {
    position: sticky;
    top: 104px;
    align-content: start;
  }

  .article-signal-grid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .article-signal-card {
    display: grid;
    gap: 8px;
    padding: 18px;
    border-radius: 20px;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(215, 179, 117, 0.12);
  }

  .article-signal-label {
    color: rgba(248, 241, 232, 0.58);
    font-size: 0.78rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .article-signal-card strong {
    color: #fff7ef;
    line-height: 1.5;
  }

  .article-signal-card p {
    margin: 0;
    font-size: 0.92rem;
    line-height: 1.7;
  }

  .article-detail-side-card {
    padding: 22px;
    border-radius: 24px;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(215, 179, 117, 0.14);
  }

  .article-side-list {
    display: grid;
    gap: 14px;
    list-style: none;
    padding: 0;
    margin: 18px 0 0;
  }

  .article-side-list li {
    display: grid;
    gap: 4px;
  }

  .article-side-list span {
    color: rgba(248, 241, 232, 0.6);
    font-size: 0.84rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .article-side-list strong {
    color: #fff7ef;
    line-height: 1.6;
  }

  .article-detail-figure {
    margin: 0;
  }

  .article-detail-image {
    display: block;
    width: 100%;
    aspect-ratio: 16 / 10;
    object-fit: cover;
    border-radius: 24px;
    box-shadow: var(--shadow-strong);
  }

  .article-detail-grid,
  .article-next-grid {
    display: grid;
    gap: 18px;
  }

  .article-detail-grid {
    grid-template-columns: minmax(0, 1.2fr) minmax(0, 0.8fr);
  }

  .article-body-panel {
    min-height: 100%;
    background: linear-gradient(180deg, rgba(255, 252, 246, 0.96), rgba(247, 241, 232, 0.94));
  }

  .article-body-panel p {
    max-width: 68ch;
    font-size: 1.02rem;
    line-height: 1.92;
  }

  .article-body-panel p:first-of-type {
    font-size: 1.08rem;
    color: var(--ink);
  }

  .article-body-panel p + p {
    margin-top: 6px;
  }

  .article-notes-panel {
    display: grid;
    gap: 18px;
    align-content: start;
    background: linear-gradient(180deg, rgba(255, 249, 239, 0.96), rgba(245, 237, 226, 0.94));
  }

  .vertical-list {
    display: grid;
    gap: 10px;
  }

  .article-next-links {
    display: grid;
    gap: 12px;
    margin-top: 16px;
  }

  .article-next-grid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .article-next-card {
    display: grid;
    gap: 12px;
    transition: transform 180ms ease, border-color 180ms ease;
  }

  .article-next-card:hover {
    transform: translateY(-3px);
    border-color: rgba(157, 111, 49, 0.24);
  }

  .article-next-card h2 {
    margin: 0;
    font-size: 1.25rem;
    color: var(--ink);
  }

  @media (max-width: 980px) {
    .article-detail-hero,
    .article-detail-grid,
    .article-next-grid,
    .article-signal-grid {
      grid-template-columns: 1fr;
    }

    .article-detail-side {
      position: static;
    }
  }
</style>
