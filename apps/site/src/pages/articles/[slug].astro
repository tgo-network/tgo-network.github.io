---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { formatDate } from "../../lib/format";
import { getArticle, listArticles } from "../../lib/public-api";

export const getStaticPaths = async () => {
  const articles = await listArticles();

  return articles.map((article) => ({
    params: {
      slug: article.slug
    }
  }));
};

const slug = Astro.params.slug!;
const article = await getArticle(slug);

if (!article) {
  throw new Error(`文章不存在：${slug}`);
}

const estimatedReadMinutes = Math.max(3, Math.round(article.body.join("").length / 220));
---

<BaseLayout title={`${article.title} | 文章 | TGO 鲲鹏会`} description={article.excerpt}>
  <main class="page-shell page-stack">
    <section class="hero">
      <div class="hero-card article-detail-hero">
        <div class="article-detail-main">
          <span class="eyebrow">文章详情</span>
          <h1>{article.title}</h1>
          <p>{article.excerpt}</p>
          <ul class="stat-row">
            <li>{formatDate(article.publishedAt)}</li>
            <li>{article.author.name}</li>
            <li>{estimatedReadMinutes} 分钟阅读</li>
          </ul>
        </div>

        <aside class="article-detail-side">
          <div class="article-detail-side-card">
            <div class="card-label card-label-on-dark">文章信息</div>
            <ul class="article-side-list">
              <li>
                <span>作者</span>
                <strong>{article.author.name}</strong>
              </li>
              <li>
                <span>角色</span>
                <strong>{article.author.role}</strong>
              </li>
              <li>
                <span>发布时间</span>
                <strong>{formatDate(article.publishedAt)}</strong>
              </li>
              {article.branch?.name && (
                <li>
                  <span>相关分会</span>
                  <strong>{article.branch.name}</strong>
                </li>
              )}
            </ul>
          </div>

          {
            article.coverImage && (
              <figure class="article-detail-figure">
                <img class="article-detail-image" src={article.coverImage.url} alt={article.coverImage.alt} />
              </figure>
            )
          }
        </aside>
      </div>
    </section>

    <section class="section article-detail-grid">
      <article class="panel prose-panel article-body-panel">
        <div class="card-label">正文</div>
        <h2 class="card-title">从活动与组织问题延伸出来的公开内容</h2>
        {article.body.map((paragraph) => <p>{paragraph}</p>)}
      </article>

      <aside class="panel panel-soft article-notes-panel">
        <div>
          <div class="card-label">内容说明</div>
          <p class="card-copy">
            文章由工作人员统一发布，但它的价值并不只在“发出来”，而在于把分会活动、成员经验和组织实践继续沉淀为可长期阅读的内容资产。
          </p>
        </div>

        <div>
          <div class="card-label">继续浏览</div>
          <div class="article-next-links">
            <a class="button secondary" href="/articles">返回文章列表</a>
            <a class="button secondary" href="/events">查看活动</a>
            <a class="button secondary" href="/branches">浏览分会</a>
          </div>
        </div>
      </aside>
    </section>
  </main>
</BaseLayout>

<style>
  .article-detail-hero {
    display: grid;
    gap: 22px;
    grid-template-columns: minmax(0, 1.15fr) minmax(320px, 0.85fr);
    background:
      radial-gradient(circle at top right, rgba(215, 179, 117, 0.18), transparent 24%),
      linear-gradient(135deg, #171717 0%, #201c17 100%);
    border-color: rgba(215, 179, 117, 0.14);
    color: #f8f1e8;
  }

  .article-detail-hero h1,
  .article-detail-hero h2 {
    color: #fff7ef;
  }

  .article-detail-hero p {
    color: rgba(248, 241, 232, 0.76);
  }

  .article-detail-hero .eyebrow {
    color: #f1d5a0;
    border-color: rgba(215, 179, 117, 0.28);
    background: rgba(255, 255, 255, 0.06);
  }

  .article-detail-side {
    display: grid;
    gap: 18px;
    align-content: start;
  }

  .article-detail-side-card {
    padding: 22px;
    border-radius: 24px;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(215, 179, 117, 0.14);
  }

  .article-side-list {
    display: grid;
    gap: 14px;
    list-style: none;
    padding: 0;
    margin: 18px 0 0;
  }

  .article-side-list li {
    display: grid;
    gap: 4px;
  }

  .article-side-list span {
    color: rgba(248, 241, 232, 0.6);
    font-size: 0.84rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .article-side-list strong {
    color: #fff7ef;
    line-height: 1.6;
  }

  .article-detail-figure {
    margin: 0;
  }

  .article-detail-image {
    display: block;
    width: 100%;
    aspect-ratio: 16 / 10;
    object-fit: cover;
    border-radius: 24px;
    box-shadow: var(--shadow-strong);
  }

  .article-detail-grid {
    display: grid;
    gap: 18px;
    grid-template-columns: minmax(0, 1.2fr) minmax(0, 0.8fr);
  }

  .article-body-panel {
    min-height: 100%;
  }

  .article-notes-panel {
    display: grid;
    gap: 18px;
    align-content: start;
  }

  .article-next-links {
    display: grid;
    gap: 12px;
    margin-top: 16px;
  }

  @media (max-width: 980px) {
    .article-detail-hero,
    .article-detail-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
