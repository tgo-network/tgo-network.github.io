---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { formatDate } from "../../lib/format";
import { getArticle, listArticles } from "../../lib/public-api";

export const getStaticPaths = async () => {
  const articles = await listArticles();

  return articles.map((article) => ({
    params: {
      slug: article.slug
    }
  }));
};

const slug = Astro.params.slug!;
const article = await getArticle(slug);

if (!article) {
  throw new Error(`文章不存在：${slug}`);
}

const estimatedReadMinutes = Math.max(3, Math.round(article.body.join("").length / 220));
---

<BaseLayout title={`${article.title} | 文章 | TGO 鲲鹏会`} description={article.excerpt}>
  <main class="page-shell page-stack">
    <section class="section article-detail-layout">
      <article class="panel prose-panel article-body-panel">
        <div class="card-label">文章正文</div>
        {article.body.map((paragraph) => <p>{paragraph}</p>)}
      </article>

      <aside class="panel panel-soft article-detail-side">
        <div class="card-label">文章</div>
        <h1>{article.title}</h1>
        <p class="article-detail-excerpt">{article.excerpt}</p>

        <ul class="article-detail-list">
          <li>
            <span>发布时间</span>
            <strong>{formatDate(article.publishedAt)}</strong>
          </li>
          <li>
            <span>作者</span>
            <strong>{article.author.name}</strong>
          </li>
          <li>
            <span>作者角色</span>
            <strong>{article.author.role}</strong>
          </li>
          <li>
            <span>阅读时长</span>
            <strong>{estimatedReadMinutes} 分钟</strong>
          </li>
          {article.branch?.name && (
            <li>
              <span>相关分会</span>
              <strong>{article.branch.name}</strong>
            </li>
          )}
        </ul>

        {
          article.coverImage && (
            <figure class="article-detail-figure">
              <img class="article-detail-image" src={article.coverImage.url} alt={article.coverImage.alt} />
            </figure>
          )
        }

        <div class="article-detail-actions">
          <a class="button secondary" href="/articles">返回文章列表</a>
          {article.branch && <a class="button primary" href={`/branches#${article.branch.slug}`}>查看相关分会</a>}
        </div>
      </aside>
    </section>
  </main>
</BaseLayout>

<style>
  .article-detail-layout {
    display: grid;
    gap: 20px;
    grid-template-columns: minmax(0, 1.2fr) minmax(320px, 0.8fr);
    align-items: start;
  }

  .article-body-panel {
    padding: clamp(22px, 3vw, 32px);
  }

  .article-body-panel p:last-child {
    margin-bottom: 0;
  }

  .article-detail-side {
    display: grid;
    gap: 18px;
    position: sticky;
    top: 104px;
  }

  .article-detail-side h1 {
    margin: 0;
    font-size: clamp(2rem, 4vw, 3rem);
    line-height: 1.04;
  }

  .article-detail-excerpt {
    margin: 0;
    color: var(--muted);
    line-height: 1.85;
  }

  .article-detail-list {
    display: grid;
    gap: 12px;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .article-detail-list li {
    display: grid;
    gap: 6px;
    padding: 14px 16px;
    border-radius: 18px;
    border: 1px solid rgba(31, 26, 23, 0.08);
    background: rgba(255, 255, 255, 0.6);
  }

  .article-detail-list span {
    color: var(--muted);
    font-size: 0.86rem;
  }

  .article-detail-figure {
    margin: 0;
  }

  .article-detail-image {
    display: block;
    width: 100%;
    border-radius: 22px;
    object-fit: cover;
  }

  .article-detail-actions {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }

  @media (max-width: 900px) {
    .article-detail-layout {
      grid-template-columns: 1fr;
    }

    .article-detail-side {
      position: static;
    }
  }
</style>
