---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { formatDate } from "../../lib/format";
import { getArticle, listArticles } from "../../lib/public-api";

export const getStaticPaths = async () => {
  const articles = await listArticles();

  return articles.map((article) => ({
    params: {
      slug: article.slug
    }
  }));
};

const slug = Astro.params.slug!;
const article = await getArticle(slug);

if (!article) {
  throw new Error(`文章不存在：${slug}`);
}

const estimatedReadMinutes = Math.max(3, Math.round(article.body.join("").length / 220));
---

<BaseLayout title={`${article.title} | 文章 | TGO 鲲鹏会`} description={article.excerpt}>
  <main class="page-shell page-stack article-detail-shell">
    <section class="section article-detail-head-section">
      <article class:list={["panel article-detail-head-card", !article.coverImage && "article-detail-head-card-single"]}>
        <div class="article-detail-head-copy">
          <p class="page-eyebrow">文章</p>
          <h1>{article.title}</h1>
          <p class="article-detail-excerpt">{article.excerpt}</p>
          <div class="article-detail-meta">
            <span>{formatDate(article.publishedAt)}</span>
            <span>{article.author.name}</span>
            <span>{estimatedReadMinutes} 分钟阅读</span>
          </div>
        </div>

        {
          article.coverImage && (
            <figure class="article-detail-figure">
              <img class="article-detail-image" src={article.coverImage.url} alt={article.coverImage.alt} />
            </figure>
          )
        }
      </article>
    </section>

    <section class="section article-detail-content-section">
      <div class="article-detail-layout">
        <article class="panel prose-panel article-body-panel">
          {article.body.map((paragraph) => <p>{paragraph}</p>)}
        </article>

        <aside class="panel panel-soft article-context-panel">
          <ul class="article-context-list">
            <li>
              <span>作者</span>
              <strong>{article.author.name}</strong>
              <small>{article.author.role}</small>
            </li>
            <li>
              <span>发布时间</span>
              <strong>{formatDate(article.publishedAt)}</strong>
              <small>预计阅读 {estimatedReadMinutes} 分钟</small>
            </li>
            {
              article.branch?.name && (
                <li>
                  <span>相关分会</span>
                  <strong>{article.branch.name}</strong>
                </li>
              )
            }
          </ul>

          <div class="article-detail-actions">
            <a class="button secondary" href="/articles">返回文章列表</a>
            {article.branch && <a class="button primary" href={`/branches#${article.branch.slug}`}>查看相关分会</a>}
          </div>
        </aside>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .article-detail-shell {
    padding-top: 10px;
    padding-bottom: 48px;
  }

  .article-detail-layout {
    display: grid;
    gap: 18px;
    grid-template-columns: minmax(0, 1.08fr) minmax(300px, 0.92fr);
    align-items: start;
  }

  .article-detail-head-card {
    display: grid;
    gap: 22px;
    grid-template-columns: minmax(0, 1.04fr) minmax(320px, 0.96fr);
    align-items: start;
    background: linear-gradient(180deg, rgba(255, 252, 246, 0.98), rgba(245, 238, 227, 0.92));
  }

  .article-detail-head-card-single {
    grid-template-columns: 1fr;
  }

  .article-detail-head-copy,
  .article-context-panel {
    display: grid;
    gap: 14px;
  }

  .article-detail-head-copy h1 {
    margin: 0;
    font-size: clamp(2.1rem, 4.2vw, 3.5rem);
    line-height: 1.06;
  }

  .article-detail-excerpt,
  .article-context-list small {
    margin: 0;
    color: var(--muted);
    line-height: 1.84;
  }

  .article-detail-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 10px 14px;
    color: var(--muted);
    font-size: 0.84rem;
    letter-spacing: 0.03em;
  }

  .article-detail-figure {
    margin: 0;
  }

  .article-detail-image {
    display: block;
    width: 100%;
    min-height: 280px;
    border-radius: 18px;
    object-fit: cover;
  }

  .article-body-panel {
    background: rgba(255, 255, 255, 0.78);
  }

  .article-body-panel p {
    max-width: 72ch;
    line-height: 1.92;
  }

  .article-body-panel p:first-of-type {
    color: var(--ink);
    font-size: 1.06rem;
  }

  .article-context-panel {
    position: sticky;
    top: 104px;
    background: linear-gradient(180deg, rgba(255, 252, 246, 0.98), rgba(245, 238, 227, 0.92));
  }

  .article-context-list {
    display: grid;
    gap: 12px;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .article-context-list li {
    display: grid;
    gap: 6px;
    padding: 16px 18px;
    border-radius: 18px;
    border: 1px solid rgba(27, 23, 19, 0.08);
    background: rgba(255, 255, 255, 0.72);
  }

  .article-context-list span {
    color: var(--muted);
    font-size: 0.84rem;
    letter-spacing: 0.04em;
  }

  .article-detail-actions {
    display: grid;
    gap: 12px;
  }

  @media (max-width: 980px) {
    .article-detail-head-card,
    .article-detail-layout {
      grid-template-columns: 1fr;
    }

    .article-context-panel {
      position: static;
    }
  }

  @media (max-width: 720px) {
    .article-detail-shell {
      padding-top: 4px;
    }

    .article-detail-image {
      min-height: 220px;
    }
  }
</style>
