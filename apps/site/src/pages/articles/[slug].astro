---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { formatDate } from "../../lib/format";
import { getArticle, listArticles } from "../../lib/public-api";

export const getStaticPaths = async () => {
  const articles = await listArticles();

  return articles.map((article) => ({
    params: {
      slug: article.slug
    }
  }));
};

const slug = Astro.params.slug!;
const article = await getArticle(slug);

if (!article) {
  throw new Error(`文章不存在：${slug}`);
}

const estimatedReadMinutes = Math.max(3, Math.round(article.body.join("").length / 220));
const [leadParagraph, ...remainingParagraphs] = article.body;
const bodyParagraphs = remainingParagraphs.length > 0 ? remainingParagraphs : article.body;
---

<BaseLayout title={`${article.title} | 文章 | TGO 鲲鹏会`} description={article.excerpt}>
  <main class="page-shell page-stack detail-page-shell article-detail-shell">
    <section class="section">
      <article class:list={["panel detail-hero-card article-detail-head-card", !article.coverImage && "detail-hero-card-single"]}>
        <div class="detail-hero-copy">
          <p class="page-eyebrow">文章</p>
          <h1>{article.title}</h1>
          <p class="detail-summary">{article.excerpt}</p>
          <div class="detail-meta-row">
            <span class="detail-meta-item">{formatDate(article.publishedAt)}</span>
            <span class="detail-meta-item">{article.author.name}</span>
            <span class="detail-meta-item">{estimatedReadMinutes} 分钟阅读</span>
          </div>

          <div class="hero-actions article-hero-actions">
            {article.branch && <a class="button primary" href={`/branches#${article.branch.slug}`}>查看相关分会</a>}
            <a class="text-link" href="/articles">返回文章列表</a>
          </div>
        </div>

        {
          article.coverImage && (
            <figure class="detail-hero-figure">
              <img class="detail-hero-image article-detail-image" src={article.coverImage.url} alt={article.coverImage.alt} />
            </figure>
          )
        }
      </article>
    </section>

    <section class="section">
      <div class="article-detail-stack">
        <article class="panel prose-panel detail-body-panel article-body-panel">
          <div class="article-body-intro">
            <p class="article-body-lead">{leadParagraph ?? article.excerpt}</p>
          </div>

          <div class="article-body-content">
            {bodyParagraphs.map((paragraph) => <p>{paragraph}</p>)}
          </div>
        </article>

        <div class="article-context-grid">
          <article class="panel detail-section-card article-context-card">
            <h2>作者</h2>
            <strong>{article.author.name}</strong>
            <p>{article.author.role}</p>
          </article>

          <article class="panel detail-section-card article-context-card">
            <h2>发布时间</h2>
            <strong>{formatDate(article.publishedAt)}</strong>
            <p>预计阅读 {estimatedReadMinutes} 分钟</p>
          </article>

          {
            article.branch && (
              <article class="panel detail-section-card article-context-card article-branch-panel">
                <h2>相关分会</h2>
                <strong>{article.branch.name}</strong>
                <a class="text-link" href={`/branches#${article.branch.slug}`}>查看相关分会</a>
              </article>
            )
          }
        </div>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .article-hero-actions {
    margin-top: 2px;
  }

  .article-detail-stack,
  .article-context-grid {
    display: grid;
    gap: 18px;
  }

  .article-body-panel {
    display: grid;
    gap: 22px;
  }

  .article-body-intro {
    padding-bottom: 18px;
    border-bottom: 1px solid rgba(27, 23, 19, 0.08);
  }

  .article-body-content {
    display: grid;
    gap: 4px;
  }

  .article-body-lead,
  .article-body-panel p:first-of-type {
    color: var(--ink);
    font-size: 1.06rem;
  }

  .article-body-lead {
    margin: 0;
    max-width: 62ch;
    line-height: 1.9;
  }

  .article-context-grid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .article-context-card {
    display: grid;
    gap: 10px;
    padding: 18px;
  }

  .article-context-card strong {
    line-height: 1.7;
  }

  .article-context-card p {
    margin: 0;
    color: var(--muted);
    line-height: 1.8;
  }

  .article-branch-panel .text-link {
    width: fit-content;
  }

  @media (max-width: 980px) {
    .article-context-grid {
      grid-template-columns: 1fr;
    }

    .article-detail-image {
      min-height: 260px;
    }
  }

  @media (max-width: 720px) {
    .article-detail-image {
      min-height: 220px;
    }
  }
</style>
