---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { formatDate } from "../../lib/format";
import { getArticle, listArticles } from "../../lib/public-api";

export const getStaticPaths = async () => {
  const articles = await listArticles();

  return articles.map((article) => ({
    params: {
      slug: article.slug
    }
  }));
};

const slug = Astro.params.slug!;
const article = await getArticle(slug);

if (!article) {
  throw new Error(`文章不存在：${slug}`);
}

const estimatedReadMinutes = Math.max(3, Math.round(article.body.join("").length / 220));
---

<BaseLayout title={`${article.title} | 文章 | TGO 鲲鹏会`} description={article.excerpt}>
  <main class="page-shell page-stack">
    <section class="section article-detail-stack">
      <article class:list={["panel article-header-panel", !article.coverImage && "article-header-panel-single"]}>
        <div class="article-header-copy">
          <h1>{article.title}</h1>
          <p class="article-detail-excerpt">{article.excerpt}</p>
          <ul class="meta-list article-header-meta">
            <li>{formatDate(article.publishedAt)}</li>
            <li>{article.author.name}</li>
            <li>{estimatedReadMinutes} 分钟</li>
          </ul>
        </div>

        {
          article.coverImage && (
            <figure class="article-header-figure">
              <img class="article-header-image" src={article.coverImage.url} alt={article.coverImage.alt} />
            </figure>
          )
        }
      </article>

      <div class="article-content-layout">
        <article class="panel prose-panel article-body-panel">
          {article.body.map((paragraph) => <p>{paragraph}</p>)}
        </article>

        <aside class="panel panel-soft article-context-panel">
          <ul class="article-context-list">
            <li>
              <span>作者</span>
              <strong>{article.author.name}</strong>
              <small>{article.author.role}</small>
            </li>
            <li>
              <span>发布时间</span>
              <strong>{formatDate(article.publishedAt)}</strong>
              <small>预计阅读 {estimatedReadMinutes} 分钟</small>
            </li>
            {
              article.branch?.name && (
                <li>
                  <span>相关分会</span>
                  <strong>{article.branch.name}</strong>
                </li>
              )
            }
          </ul>

          <div class="article-detail-actions">
            <a class="button secondary" href="/articles">返回文章列表</a>
            {article.branch && <a class="button primary" href={`/branches#${article.branch.slug}`}>查看相关分会</a>}
          </div>
        </aside>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .article-detail-stack {
    display: grid;
    gap: 18px;
  }

  .article-content-layout {
    display: grid;
    gap: 18px;
    grid-template-columns: minmax(0, 1.15fr) minmax(280px, 0.85fr);
    align-items: start;
  }

  .article-header-panel {
    display: grid;
    gap: 20px;
    grid-template-columns: minmax(0, 1.08fr) minmax(300px, 0.92fr);
    align-items: start;
    background: linear-gradient(180deg, rgba(255, 252, 246, 0.98), rgba(247, 239, 229, 0.96));
  }

  .article-header-panel-single {
    grid-template-columns: 1fr;
  }

  .article-header-copy,
  .article-context-panel {
    display: grid;
    gap: 16px;
  }

  .article-header-copy h1 {
    margin: 0;
    font-size: clamp(2.1rem, 4.4vw, 3.5rem);
    line-height: 1.03;
  }

  .article-detail-excerpt {
    margin: 0;
    max-width: 42em;
    color: var(--muted);
    line-height: 1.85;
  }

  .article-header-meta {
    margin-top: 2px;
  }

  .article-header-figure {
    margin: 0;
    height: 100%;
  }

  .article-header-image {
    display: block;
    width: 100%;
    height: 100%;
    min-height: 280px;
    border-radius: 24px;
    object-fit: cover;
  }

  .article-body-panel {
    padding: clamp(22px, 3vw, 32px);
    background: rgba(255, 255, 255, 0.86);
  }

  .article-body-panel p {
    max-width: 72ch;
    line-height: 1.9;
  }

  .article-body-panel p:first-of-type {
    color: var(--ink);
    font-size: 1.06rem;
  }

  .article-body-panel p:last-child {
    margin: 0;
  }

  .article-context-panel {
    position: sticky;
    top: 104px;
    background: linear-gradient(180deg, rgba(255, 250, 242, 0.96), rgba(246, 239, 229, 0.94));
  }

  .article-context-list {
    display: grid;
    gap: 14px;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .article-context-list li {
    display: grid;
    gap: 6px;
    padding: 16px 18px;
    border-radius: 18px;
    border: 1px solid rgba(31, 26, 23, 0.08);
    background: rgba(255, 255, 255, 0.62);
  }

  .article-context-list span {
    color: var(--muted);
    font-size: 0.84rem;
    letter-spacing: 0.04em;
  }

  .article-context-list small {
    color: var(--muted);
    line-height: 1.6;
  }

  .article-detail-actions {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  @media (max-width: 900px) {
    .article-header-panel,
    .article-content-layout {
      grid-template-columns: 1fr;
    }

    .article-header-image {
      min-height: 220px;
    }

    .article-context-panel {
      position: static;
    }
  }

  @media (max-width: 640px) {
    .article-detail-actions {
      align-items: stretch;
    }
  }
</style>
