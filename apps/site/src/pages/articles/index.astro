---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { formatDate } from "../../lib/format";
import { listArticles } from "../../lib/public-api";

const articles = await listArticles();
---

<BaseLayout title="文章 | TGO 鲲鹏会" description="查看由后台发布的文章内容。">
  <main class="page-shell page-stack">
    <section class="section article-list-section">
      <h1 class="sr-only">文章列表</h1>
      {
        articles.length > 0 ? (
          <div class="article-list-grid">
            {
              articles.map((article) => (
                <a class="panel article-list-card" href={`/articles/${article.slug}`}>
                  <div class:list={["article-list-media-wrap", !article.coverImage && "article-list-media-wrap-placeholder"]}>
                    {
                      article.coverImage ? (
                        <img class="article-list-media" src={article.coverImage.url} alt={article.coverImage.alt} loading="lazy" />
                      ) : (
                        <div class="article-list-media article-list-media-placeholder" aria-hidden="true"></div>
                      )
                    }
                  </div>
                  <div class="card-label">{formatDate(article.publishedAt)}</div>
                  <h3>{article.title}</h3>
                  <p class="card-copy">{article.excerpt}</p>
                  <ul class="meta-list article-list-meta">
                    <li>{article.authorName}</li>
                    {article.branch?.cityName && <li>{article.branch.cityName}</li>}
                  </ul>
                </a>
              ))
            }
          </div>
        ) : (
          <div class="panel panel-soft empty-article-state">
            <div class="card-label">暂无更多文章</div>
            <p class="card-copy">当前仅展示一篇文章，后续内容会继续发布。</p>
          </div>
        )
      }
    </section>
  </main>
</BaseLayout>

<style>
  .article-list-section {
    display: grid;
    gap: 18px;
  }

  .article-list-grid {
    display: grid;
    gap: 18px;
    align-items: start;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
  }

  .article-list-card {
    display: grid;
    gap: 12px;
    align-content: start;
    padding: 0;
    overflow: hidden;
    transition: transform 180ms ease, border-color 180ms ease, box-shadow 180ms ease;
  }

  .article-list-card:hover {
    transform: translateY(-3px);
    border-color: rgba(157, 111, 49, 0.24);
    box-shadow: 0 24px 42px rgba(40, 28, 18, 0.12);
  }

  .article-list-media-wrap {
    min-height: 180px;
    border-bottom: 1px solid rgba(31, 26, 23, 0.08);
    background: linear-gradient(180deg, rgba(255, 252, 246, 0.96), rgba(247, 239, 229, 0.94));
  }

  .article-list-media-wrap-placeholder {
    background:
      radial-gradient(circle at top right, rgba(200, 161, 93, 0.16), transparent 30%),
      repeating-linear-gradient(135deg, rgba(157, 111, 49, 0.04) 0 1px, transparent 1px 28px),
      linear-gradient(180deg, rgba(250, 244, 235, 0.96), rgba(244, 236, 224, 0.92));
  }

  .article-list-media {
    display: block;
    width: 100%;
    height: 100%;
    min-height: 180px;
    object-fit: cover;
  }

  .article-list-media-placeholder {
    position: relative;
    display: block;
    width: 100%;
    min-height: 180px;
  }

  .article-list-media-placeholder::before {
    content: "";
    position: absolute;
    left: 18px;
    right: 18px;
    bottom: 18px;
    height: 2px;
    border-radius: 999px;
    background: linear-gradient(90deg, rgba(157, 111, 49, 0.32), rgba(157, 111, 49, 0));
  }

  .article-list-card .card-label,
  .article-list-card h3,
  .article-list-card .card-copy,
  .article-list-card .article-list-meta {
    padding-left: 20px;
    padding-right: 20px;
  }

  .article-list-card .card-label {
    padding-top: 20px;
  }

  .article-list-card h3 {
    margin: 0;
    font-size: 1.26rem;
    line-height: 1.38;
  }

  .article-list-card .card-copy {
    display: -webkit-box;
    overflow: hidden;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 3;
    margin: 0;
  }

  .article-list-meta {
    margin-top: auto;
    padding-bottom: 20px;
  }

  @media (max-width: 900px) {
    .article-list-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
