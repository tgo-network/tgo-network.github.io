---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { formatDate } from "../../lib/format";
import { listArticles } from "../../lib/public-api";

const articles = await listArticles();
---

<BaseLayout title="文章 | TGO 鲲鹏会" description="查看由后台发布的文章内容。">
  <main class="page-shell page-stack article-directory-shell">
    <section class="section article-list-section">
      {
        articles.length > 0 ? (
          <div class="article-list-grid">
            {
              articles.map((article) => (
                <a
                  class:list={[
                    "panel article-list-card",
                    !article.coverImage && "article-list-card-no-cover"
                  ]}
                  href={`/articles/${article.slug}`}
                >
                  {
                    article.coverImage && (
                      <div class="article-list-media-wrap">
                        <img class="article-list-media" src={article.coverImage.url} alt={article.coverImage.alt} loading="lazy" />
                      </div>
                    )
                  }

                  <div class="article-list-body">
                    <div class="article-list-meta">
                      <span>{formatDate(article.publishedAt)}</span>
                      <span>{article.authorName}</span>
                    </div>
                    <h2>{article.title}</h2>
                    <p class="card-copy">{article.excerpt}</p>

                    <div class="article-list-footer">
                      {article.branch?.cityName ? <p class="article-list-branch">{article.branch.cityName}</p> : <span />}
                      <span class="text-link">阅读全文</span>
                    </div>
                  </div>
                </a>
              ))
            }
          </div>
        ) : (
          <div class="panel panel-soft empty-article-state">
            <div class="card-label">暂无文章</div>
            <p class="card-copy">后续内容会继续发布。</p>
          </div>
        )
      }
    </section>
  </main>
</BaseLayout>

<style>
  .article-directory-shell {
    padding-top: 10px;
    padding-bottom: 48px;
  }

  .article-list-section {
    display: grid;
    gap: 18px;
  }

  .article-list-grid {
    display: grid;
    gap: 20px;
    align-items: start;
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .article-list-card {
    display: grid;
    gap: 0;
    padding: 0;
    overflow: hidden;
    background: linear-gradient(180deg, rgba(255, 252, 246, 0.98), rgba(245, 238, 227, 0.92));
    transition: transform 180ms ease, border-color 180ms ease, box-shadow 180ms ease;
  }

  .article-list-card:hover {
    transform: translateY(-2px);
    border-color: rgba(138, 106, 67, 0.18);
    box-shadow: 0 20px 40px rgba(35, 28, 21, 0.1);
  }

  .article-list-card-no-cover {
    background:
      radial-gradient(circle at top right, rgba(138, 106, 67, 0.1), transparent 24%),
      linear-gradient(180deg, rgba(255, 251, 244, 0.98), rgba(246, 239, 229, 0.94));
  }

  .article-list-media-wrap {
    min-height: 200px;
    border-bottom: 1px solid rgba(27, 23, 19, 0.08);
    background: linear-gradient(180deg, rgba(255, 251, 244, 0.96), rgba(246, 239, 229, 0.94));
  }

  .article-list-media {
    display: block;
    width: 100%;
    height: 100%;
    min-height: 200px;
    object-fit: cover;
  }

  .article-list-body {
    display: grid;
    gap: 10px;
    align-content: start;
    padding: 22px;
  }

  .article-list-card-no-cover .article-list-body {
    position: relative;
    gap: 12px;
    padding-top: 30px;
  }

  .article-list-card-no-cover .article-list-body::before,
  .article-list-card-no-cover .article-list-body::after {
    content: "";
    position: absolute;
    left: 22px;
    height: 2px;
    border-radius: 999px;
    background: linear-gradient(90deg, rgba(138, 106, 67, 0.34), rgba(138, 106, 67, 0));
  }

  .article-list-card-no-cover .article-list-body::before {
    top: 18px;
    width: 96px;
  }

  .article-list-card-no-cover .article-list-body::after {
    top: 26px;
    width: 136px;
  }

  .article-list-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 10px 14px;
    color: var(--muted);
    font-size: 0.84rem;
    letter-spacing: 0.03em;
  }

  .article-list-body h2 {
    margin: 0;
    display: -webkit-box;
    overflow: hidden;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
    font-size: 1.16rem;
    line-height: 1.46;
  }

  .article-list-body .card-copy {
    display: -webkit-box;
    overflow: hidden;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 3;
    margin: 0;
  }

  .article-list-footer {
    display: flex;
    gap: 12px;
    align-items: center;
    justify-content: space-between;
    margin-top: auto;
  }

  .article-list-branch {
    display: inline-flex;
    align-items: center;
    min-height: 30px;
    margin: 0;
    padding: 0 11px;
    border-radius: 999px;
    border: 1px solid rgba(138, 106, 67, 0.14);
    background: rgba(255, 248, 238, 0.76);
    color: var(--accent-strong);
    font-size: 0.82rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  @media (max-width: 980px) {
    .article-list-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 720px) {
    .article-directory-shell {
      padding-top: 4px;
    }

    .article-list-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
