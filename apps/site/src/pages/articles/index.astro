---
import CollectionCard from "../../components/CollectionCard.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { formatDate } from "../../lib/format";
import { listArticles } from "../../lib/public-api";

const articles = await listArticles();
---

<BaseLayout title="文章 | TGO 鲲鹏会" description="由工作人员在后台发布的文章内容与社区观点。">
  <main class="page-shell page-stack">
    <section class="hero">
      <div class="hero-card">
        <span class="eyebrow">文章</span>
        <h1>文章</h1>
        <p>
          文章由工作人员后台统一发布，前台以静态优先方式呈现技术管理、组织实践与社区观察等内容，
          让成员和访客都能持续了解 TGO 鲲鹏会的活动进展与组织思考。
        </p>
      </div>
    </section>

    <section class="section">
      <div class="grid grid-2">
        {
          articles.map((article) => (
            <CollectionCard
              href={`/articles/${article.slug}`}
              label={formatDate(article.publishedAt)}
              title={article.title}
              summary={article.excerpt}
              image={article.coverImage}
              meta={[article.authorName, "工作人员发布"]}
            />
          ))
        }
      </div>
    </section>
  </main>
</BaseLayout>
