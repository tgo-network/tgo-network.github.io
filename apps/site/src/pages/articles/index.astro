---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { listPublicEditorialArticles } from "../../lib/editorial-order";
import { formatDate } from "../../lib/format";
import { listArticles } from "../../lib/public-api";

const articles = listPublicEditorialArticles(await listArticles());

const [leadArticle, ...otherArticles] = articles;
---

<BaseLayout title="文章 | TGO 鲲鹏会" description="查看由后台发布的文章内容。">
  <main class="page-shell page-stack">
    <section class="page-intro">
      <div class="page-intro-copy">
        <div class="card-label">文章</div>
        <h1>技术管理与组织实践文章</h1>
        <p>沉淀社区活动观察、组织实践与技术管理经验，形成可持续复用的内容资产。</p>
      </div>
      <p class="page-intro-meta">{articles.length} 篇已发布文章</p>
    </section>

    {
      leadArticle && (
        <section class="section">
          <a class="panel article-lead-card" href={`/articles/${leadArticle.slug}`}>
            <div class="article-lead-copy">
              <div class="card-label">最新发布</div>
              <h2>{leadArticle.title}</h2>
              <p class="card-copy">{leadArticle.excerpt}</p>
            </div>
            <ul class="meta-list article-lead-meta">
              <li>{formatDate(leadArticle.publishedAt)}</li>
              <li>{leadArticle.authorName}</li>
              {leadArticle.branch?.name && <li>{leadArticle.branch.name}</li>}
            </ul>
          </a>
        </section>
      )
    }

    <section class="section article-list-section">
        <div class="section-head section-head-stack">
          <div>
            <div class="card-label">全部文章</div>
            <h2>持续更新的社区内容</h2>
          </div>
        </div>

      {
        otherArticles.length > 0 ? (
          <div class="article-list-grid">
            {
              otherArticles.map((article) => (
                <a class="panel article-list-card" href={`/articles/${article.slug}`}>
                  <div class="card-label">{formatDate(article.publishedAt)}</div>
                  <h3>{article.title}</h3>
                  <p class="card-copy">{article.excerpt}</p>
                  <ul class="meta-list article-list-meta">
                    <li>{article.authorName}</li>
                    {article.branch?.cityName && <li>{article.branch.cityName}</li>}
                  </ul>
                </a>
              ))
            }
          </div>
        ) : (
          <div class="panel panel-soft empty-article-state">
            <div class="card-label">暂无更多文章</div>
            <p class="card-copy">当前仅展示一篇文章，后续内容会继续发布。</p>
          </div>
        )
      }
    </section>
  </main>
</BaseLayout>

<style>
  .article-lead-card {
    display: grid;
    gap: 20px;
    grid-template-columns: minmax(0, 1.15fr) minmax(320px, 0.85fr);
    align-items: end;
    background: linear-gradient(180deg, rgba(255, 252, 246, 0.98), rgba(247, 239, 229, 0.96));
  }

  .article-lead-copy {
    display: grid;
    gap: 10px;
  }

  .article-lead-card h2 {
    margin: 0;
    font-size: clamp(2rem, 4vw, 3rem);
    line-height: 1.02;
  }

  .article-lead-card .card-copy {
    margin: 0;
    max-width: 40em;
  }

  .article-lead-meta {
    margin-top: 0;
    justify-content: flex-end;
  }

  .article-list-section {
    display: grid;
    gap: 18px;
  }

  .article-list-grid {
    display: grid;
    gap: 18px;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
  }

  .article-list-card {
    display: grid;
    gap: 12px;
    min-height: 100%;
    transition: transform 180ms ease, border-color 180ms ease, box-shadow 180ms ease;
  }

  .article-list-card:hover {
    transform: translateY(-3px);
    border-color: rgba(157, 111, 49, 0.24);
    box-shadow: 0 24px 42px rgba(40, 28, 18, 0.12);
  }

  .article-list-card h3 {
    margin: 0;
    font-size: 1.26rem;
    line-height: 1.38;
  }

  .article-list-card .card-copy {
    display: -webkit-box;
    overflow: hidden;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 3;
  }

  .article-list-meta {
    margin-top: auto;
  }

  @media (max-width: 900px) {
    .article-lead-card,
    .article-list-grid {
      grid-template-columns: 1fr;
    }

    .article-lead-meta {
      justify-content: flex-start;
    }
  }
</style>
