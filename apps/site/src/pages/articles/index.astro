---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { formatDate } from "../../lib/format";
import { listArticles } from "../../lib/public-api";

const articles = (await listArticles()).slice().sort((left, right) => {
  return new Date(right.publishedAt).getTime() - new Date(left.publishedAt).getTime();
});

const [leadArticle, ...otherArticles] = articles;
const authorCount = new Set(articles.map((article) => article.authorName)).size;
const branchCount = new Set(articles.map((article) => article.branch?.name).filter((value): value is string => Boolean(value))).size;
const articleThemes = [
  {
    title: "组织实践",
    summary: "围绕技术团队协作、组织治理与管理节奏沉淀可以复用的经验。"
  },
  {
    title: "活动复盘",
    summary: "把活动中的观点、讨论和案例继续沉淀为长期可阅读的公开内容。"
  },
  {
    title: "社区观察",
    summary: "从分会、成员和一线技术管理问题出发，形成更具组织感的内容表达。"
  }
];

const readingGuides = [
  {
    label: "先看最新",
    title: "从最新文章开始理解当前社区叙事",
    summary: "最新文章通常最能反映当前活动、分会与组织问题是如何被继续沉淀为内容的。"
  },
  {
    label: "再看来源",
    title: "关注作者与分会视角",
    summary: "文章不只是资讯列表，更带有明确的作者角色、城市视角与社区背景。"
  },
  {
    label: "最后跳转",
    title: "从文章继续回到分会和活动",
    summary: "当你理解了文章的来源，再回到活动与分会页，会更容易看清这个站点的组织结构。"
  }
];
---

<BaseLayout title="文章 | TGO 鲲鹏会" description="由工作人员在后台发布的文章内容与社区观点。">
  <main class="page-shell page-stack">
    <section class="hero">
      <div class="hero-card article-hero-card">
        <div class="article-hero-main">
          <span class="eyebrow">文章</span>
          <h1>围绕技术管理、组织实践与社区观察的内容沉淀</h1>
          <p>
            文章不是孤立的媒体栏目，而是把活动、成员观点与组织经验继续转化为可以长期阅读的公开内容，
            让社区价值不只停留在线下交流现场。
          </p>
          <ul class="stat-row article-hero-stats">
            <li>{articles.length} 篇文章</li>
            <li>{authorCount} 位作者</li>
            <li>{branchCount} 个分会视角</li>
          </ul>
        </div>

        <aside class="article-hero-aside">
          <div>
            <div class="card-label card-label-on-dark">内容定位</div>
            <h2>内容服务于社区，而不是反过来</h2>
            <p>
              当前文章页会更强调“组织经验沉淀”和“活动后延伸阅读”，而不是做成泛化的信息流或资讯页。
            </p>
          </div>

          <div class="article-theme-grid">
            {
              articleThemes.map((item) => (
                <article class="article-theme-card">
                  <h3>{item.title}</h3>
                  <p>{item.summary}</p>
                </article>
              ))
            }
          </div>
        </aside>
      </div>
    </section>

    {
      leadArticle && (
        <section class="section lead-section">
          <div class="section-head">
            <div>
              <div class="card-label">最新内容</div>
              <h2>从最新一篇文章开始了解社区观察</h2>
            </div>
          </div>

          <div class="lead-section-grid">
            <article class="panel lead-article-card">
              <div class="lead-article-copy">
                <div class="card-label">{formatDate(leadArticle.publishedAt)}</div>
                <h2>{leadArticle.title}</h2>
                <p class="lead-article-excerpt">{leadArticle.excerpt}</p>
                <ul class="meta-list">
                  <li>{leadArticle.authorName}</li>
                  {leadArticle.branch?.name && <li>{leadArticle.branch.name}</li>}
                  {leadArticle.branch?.cityName && <li>{leadArticle.branch.cityName}</li>}
                </ul>
                <a class="button primary" href={`/articles/${leadArticle.slug}`}>阅读全文</a>
              </div>
            </article>

            <aside class="lead-article-side">
              <div class="panel lead-article-note">
                <div class="card-label">阅读提示</div>
                <p class="card-copy">
                  如果你是第一次访问，建议先从这篇文章开始，再继续查看活动和分会页，会更容易理解这个站点为什么强调“社区组织结构”。
                </p>
              </div>

              <div class="panel panel-soft lead-article-route">
                <div class="card-label">继续浏览</div>
                <div class="lead-route-links">
                  <a class="button secondary" href="/events">查看活动</a>
                  <a class="button secondary" href="/branches">浏览分会</a>
                  <a class="button secondary" href="/members">查看成员</a>
                </div>
              </div>
            </aside>
          </div>
        </section>
      )
    }

    <section class="section">
      <div class="section-head">
        <div>
          <div class="card-label">阅读建议</div>
          <h2>把文章当作活动与组织经验的延伸阅读</h2>
        </div>
      </div>

      <div class="article-guide-grid">
        {
          readingGuides.map((item) => (
            <article class="panel article-guide-card">
              <div class="card-label">{item.label}</div>
              <h3>{item.title}</h3>
              <p class="card-copy">{item.summary}</p>
            </article>
          ))
        }
      </div>
    </section>

    <section class="section">
      <div class="section-head section-head-stack">
        <div>
          <div class="card-label">全部文章</div>
          <h2>持续更新的技术管理与组织实践内容</h2>
        </div>
        <p class="section-note">文章列表不是简单信息流，而是让访客继续理解分会、成员与活动如何被沉淀为长期内容资产。</p>
      </div>

      {
        otherArticles.length > 0 ? (
          <div class="article-grid">
            {
              otherArticles.map((article) => (
                <a class="panel article-card" href={`/articles/${article.slug}`}>
                  <div class="card-label">{formatDate(article.publishedAt)}</div>
                  <h2 class="article-card-title">{article.title}</h2>
                  <p class="card-copy">{article.excerpt}</p>
                  <ul class="meta-list article-meta-list">
                    <li>{article.authorName}</li>
                    {article.branch?.cityName && <li>{article.branch.cityName}</li>}
                  </ul>
                  <span class="text-link">继续阅读</span>
                </a>
              ))
            }
          </div>
        ) : (
          <div class="panel panel-soft empty-article-state">
            <div class="card-label">暂无更多文章</div>
            <p class="card-copy">当前仅展示一篇文章，后续由工作人员继续在后台发布并沉淀更多内容。</p>
          </div>
        )
      }
    </section>

    <section class="section">
      <div class="panel article-cta-panel">
        <div>
          <div class="card-label">继续浏览</div>
          <h2>文章解决的是“如何沉淀经验”，下一步可以回到组织现场</h2>
          <p class="card-copy">
            如果你想继续理解文章的来源，可以回到活动和分会页；如果你已经认同这种社区方式，也可以继续进入加入申请页。
          </p>
        </div>
        <div class="article-cta-actions">
          <a class="button primary" href="/events">查看活动</a>
          <a class="button secondary" href="/branches">浏览分会</a>
          <a class="button secondary" href="/join">加入申请</a>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .article-hero-card {
    display: grid;
    gap: 22px;
    grid-template-columns: minmax(0, 1.15fr) minmax(320px, 0.85fr);
    background:
      radial-gradient(circle at top right, rgba(215, 179, 117, 0.18), transparent 24%),
      linear-gradient(135deg, #171717 0%, #201c17 100%);
    border-color: rgba(215, 179, 117, 0.14);
    color: #f8f1e8;
  }

  .article-hero-card h1,
  .article-hero-card h2,
  .article-theme-card h3 {
    color: #fff7ef;
  }

  .article-hero-card p,
  .article-theme-card p {
    color: rgba(248, 241, 232, 0.76);
  }

  .article-hero-card .eyebrow {
    color: #f1d5a0;
    border-color: rgba(215, 179, 117, 0.28);
    background: rgba(255, 255, 255, 0.06);
  }

  .article-hero-stats {
    margin-top: 24px;
  }

  .article-hero-aside,
  .article-theme-grid,
  .article-guide-grid,
  .lead-route-links {
    display: grid;
    gap: 16px;
  }

  .article-hero-aside {
    padding: 24px;
    border-radius: 24px;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(215, 179, 117, 0.12);
  }

  .article-theme-card,
  .article-guide-card {
    padding: 14px 16px;
    border-radius: 18px;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(215, 179, 117, 0.1);
  }

  .article-theme-card h3,
  .lead-article-card h2,
  .article-card-title,
  .article-guide-card h3,
  .article-cta-panel h2 {
    margin: 0 0 10px;
  }

  .lead-section-grid,
  .article-grid,
  .article-guide-grid {
    display: grid;
    gap: 18px;
  }

  .lead-section-grid {
    grid-template-columns: minmax(0, 1.12fr) minmax(280px, 0.88fr);
  }

  .lead-article-card {
    background: linear-gradient(180deg, rgba(255, 249, 239, 0.96), rgba(245, 237, 226, 0.94));
  }

  .lead-article-copy {
    display: grid;
    gap: 14px;
    align-content: start;
  }

  .lead-article-excerpt {
    margin: 0;
    font-size: 1.06rem;
    line-height: 1.9;
    color: var(--ink);
  }

  .lead-article-side {
    display: grid;
    gap: 18px;
    align-content: start;
  }

  .lead-article-note,
  .lead-article-route {
    height: 100%;
  }

  .article-guide-grid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .article-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .article-card {
    display: grid;
    gap: 12px;
    min-height: 100%;
    transition: transform 180ms ease, border-color 180ms ease;
  }

  .article-card:hover {
    transform: translateY(-3px);
    border-color: rgba(157, 111, 49, 0.22);
  }

  .article-meta-list {
    margin-top: auto;
  }

  .article-card .text-link {
    font-weight: 600;
  }

  .empty-article-state {
    max-width: 720px;
  }

  .article-cta-panel {
    display: grid;
    gap: 18px;
    grid-template-columns: minmax(0, 1.05fr) minmax(320px, 0.95fr);
    align-items: center;
    background: linear-gradient(180deg, rgba(255, 250, 242, 0.96), rgba(247, 241, 232, 0.94));
  }

  .article-cta-actions {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    justify-content: flex-end;
  }

  @media (max-width: 980px) {
    .article-hero-card,
    .lead-section-grid,
    .article-guide-grid,
    .article-grid,
    .article-cta-panel {
      grid-template-columns: 1fr;
    }

    .article-cta-actions {
      justify-content: flex-start;
    }
  }
</style>
