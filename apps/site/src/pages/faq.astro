---
import BaseLayout from "../layouts/BaseLayout.astro";
import { officialFaqItems } from "../lib/official-content";
---

<BaseLayout title="常见问题 | TGO 鲲鹏会" description="查看加入、活动、董事会和会费相关的常见问题。">
  <main class="page-shell page-stack">
    <section class="section">
      <article class="panel faq-intro-card">
        <h1>常见问题</h1>
        <p>集中查看加入标准、活动参与方式、董事会职责与会费相关问题。</p>
      </article>
    </section>

    <section class="section faq-section">
      <div class="faq-list">
        {
          officialFaqItems.map((item, index) => {
            const externalLink = item.link?.href.startsWith("http");

            return (
              <details class="panel faq-item">
                <summary>
                  <span class="faq-index">{String(index + 1).padStart(2, "0")}</span>
                  <span>{item.question}</span>
                </summary>

                <div class="faq-answer">
                  {item.paragraphs?.map((paragraph) => <p>{paragraph}</p>)}

                  {item.keyValues?.length ? (
                    <div class="faq-key-value-list">
                      {item.keyValues.map((entry) => (
                        <div class="faq-key-value-item">
                          <strong>{entry.label}</strong>
                          <span>{entry.value}</span>
                        </div>
                      ))}
                    </div>
                  ) : null}

                  {item.visual?.type === "cards" ? (
                    <div class="faq-visual-panel">
                      <p class="faq-visual-caption">{item.visual.caption}</p>
                      <div class="faq-card-grid">
                        {item.visual.items.map((entry) => (
                          <article class="faq-card-item">
                            <strong>{entry.title}</strong>
                            <p>{entry.body}</p>
                          </article>
                        ))}
                      </div>
                    </div>
                  ) : null}

                  {item.visual?.type === "steps" ? (
                    <div class="faq-visual-panel">
                      <p class="faq-visual-caption">{item.visual.caption}</p>
                      <ol class="faq-step-list">
                        {item.visual.items.map((step, stepIndex) => (
                          <li class="faq-step-item">
                            <span class="faq-step-index">{stepIndex + 1}</span>
                            <div>
                              <strong>{step.title}</strong>
                              {step.body ? <p>{step.body}</p> : null}
                            </div>
                          </li>
                        ))}
                      </ol>
                    </div>
                  ) : null}

                  {item.visual?.type === "table" ? (
                    <div class="faq-visual-panel">
                      <p class="faq-visual-caption">{item.visual.caption}</p>
                      <div class="faq-table-wrap">
                        <table class="faq-comparison-table">
                          <thead>
                            <tr>
                              <th scope="col">项目</th>
                              {item.visual.columns.map((column) => (
                                <th scope="col">{column}</th>
                              ))}
                            </tr>
                          </thead>
                          <tbody>
                            {item.visual.rows.map((row) => (
                              <tr>
                                <th scope="row">{row.label}</th>
                                {row.values.map((value) => (
                                  <td>{value}</td>
                                ))}
                              </tr>
                            ))}
                          </tbody>
                        </table>
                      </div>
                    </div>
                  ) : null}

                  {item.link ? (
                    <a class="text-link" href={item.link.href} target={externalLink ? "_blank" : undefined} rel={externalLink ? "noreferrer" : undefined}>
                      {item.link.label}
                    </a>
                  ) : null}
                </div>
              </details>
            );
          })
        }
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .faq-intro-card,
  .faq-section,
  .faq-list {
    display: grid;
    gap: 22px;
  }

  .faq-intro-card {
    gap: 12px;
    padding: clamp(22px, 3vw, 28px);
    background:
      radial-gradient(circle at top right, rgba(200, 161, 93, 0.14), transparent 28%),
      linear-gradient(180deg, rgba(255, 251, 243, 0.98), rgba(246, 238, 226, 0.96));
    border-color: rgba(157, 111, 49, 0.14);
  }

  .faq-intro-card h1 {
    margin: 0;
    font-size: clamp(2rem, 4vw, 3rem);
  }

  .faq-intro-card p {
    margin: 0;
    max-width: 48rem;
    color: var(--muted);
    line-height: 1.78;
  }

  .faq-item {
    padding: 0;
    overflow: hidden;
  }

  .faq-item[open] {
    border-color: rgba(157, 111, 49, 0.14);
    box-shadow:
      0 28px 60px rgba(40, 28, 18, 0.12),
      inset 0 1px 0 rgba(255, 255, 255, 0.42);
  }

  .faq-item summary {
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 14px;
    align-items: center;
    padding: 22px 24px;
    cursor: pointer;
    list-style: none;
    font-weight: 700;
    font-size: 1.02rem;
  }

  .faq-item summary::-webkit-details-marker {
    display: none;
  }

  .faq-item summary::after {
    content: "+";
    color: var(--accent-strong);
    font-size: 1.35rem;
    line-height: 1;
    transition: transform 180ms ease;
  }

  .faq-item[open] summary::after {
    content: "−";
  }

  .faq-index {
    display: inline-grid;
    place-items: center;
    min-width: 42px;
    height: 42px;
    padding: 0 10px;
    border-radius: 999px;
    background: rgba(200, 161, 93, 0.12);
    color: var(--accent-strong);
    font-size: 0.9rem;
    letter-spacing: 0.04em;
  }

  .faq-answer {
    display: grid;
    gap: 14px;
    padding: 0 24px 24px;
  }

  .faq-answer .text-link {
    width: fit-content;
  }

  .faq-answer p {
    margin: 0;
    color: var(--muted);
    line-height: 1.82;
  }

  .faq-key-value-list {
    display: grid;
    gap: 12px;
  }

  .faq-key-value-item {
    display: grid;
    gap: 6px;
    padding: 16px 18px;
    border-radius: 18px;
    border: 1px solid rgba(31, 26, 23, 0.08);
    background: rgba(255, 255, 255, 0.68);
  }

  .faq-key-value-item strong {
    color: var(--ink);
  }

  .faq-key-value-item span {
    color: var(--muted);
    line-height: 1.72;
  }

  .faq-visual-panel {
    display: grid;
    gap: 14px;
    padding: 18px;
    border-radius: 22px;
    border: 1px solid rgba(31, 26, 23, 0.08);
    background:
      radial-gradient(circle at top right, rgba(200, 161, 93, 0.12), transparent 28%),
      rgba(255, 255, 255, 0.72);
  }

  .faq-visual-caption {
    margin: 0;
    font-size: 0.76rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(93, 82, 72, 0.72);
  }

  .faq-card-grid {
    display: grid;
    gap: 12px;
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .faq-card-item {
    display: grid;
    gap: 8px;
    padding: 16px 18px;
    border-radius: 18px;
    border: 1px solid rgba(31, 26, 23, 0.08);
    background: rgba(255, 255, 255, 0.68);
  }

  .faq-card-item strong,
  .faq-step-item strong {
    color: var(--ink);
  }

  .faq-card-item p,
  .faq-step-item p {
    margin: 0;
  }

  .faq-step-list {
    list-style: none;
    display: grid;
    gap: 12px;
    margin: 0;
    padding: 0;
  }

  .faq-step-item {
    display: grid;
    gap: 14px;
    grid-template-columns: auto 1fr;
    align-items: start;
    padding: 14px 0;
    border-bottom: 1px solid rgba(31, 26, 23, 0.08);
  }

  .faq-step-item:last-child {
    border-bottom: 0;
    padding-bottom: 0;
  }

  .faq-step-index {
    display: inline-grid;
    place-items: center;
    width: 30px;
    height: 30px;
    border-radius: 999px;
    background: rgba(200, 161, 93, 0.16);
    color: var(--accent-strong);
    font-size: 0.84rem;
    font-weight: 700;
  }

  .faq-table-wrap {
    overflow-x: auto;
  }

  .faq-comparison-table {
    width: 100%;
    min-width: 760px;
    border-collapse: collapse;
  }

  .faq-comparison-table thead th {
    padding: 14px 12px;
    border-bottom: 1px solid rgba(31, 26, 23, 0.12);
    text-align: left;
    font-size: 0.88rem;
    color: var(--ink);
    white-space: nowrap;
  }

  .faq-comparison-table tbody th,
  .faq-comparison-table tbody td {
    padding: 14px 12px;
    border-bottom: 1px solid rgba(31, 26, 23, 0.08);
    text-align: left;
    vertical-align: top;
    line-height: 1.72;
  }

  .faq-comparison-table tbody tr:last-child th,
  .faq-comparison-table tbody tr:last-child td {
    border-bottom: 0;
  }

  .faq-comparison-table tbody th {
    width: 170px;
    color: var(--muted);
    font-size: 0.84rem;
    font-weight: 600;
  }

  @media (max-width: 640px) {
    .faq-item summary,
    .faq-answer {
      padding-left: 18px;
      padding-right: 18px;
    }

    .faq-item summary {
      grid-template-columns: auto 1fr auto;
      align-items: start;
    }

    .faq-card-grid {
      grid-template-columns: 1fr;
    }

    .faq-step-item {
      gap: 12px;
      grid-template-columns: 1fr;
    }
  }
</style>
