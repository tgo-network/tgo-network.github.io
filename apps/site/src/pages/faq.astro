---
import BaseLayout from "../layouts/BaseLayout.astro";
import { officialFaqItems } from "../lib/official-content";
---

<BaseLayout title="常见问题 | TGO 鲲鹏会" description="查看加入、活动、董事会和会费相关的常见问题。">
  <main class="page-shell page-stack faq-page-shell">
    <section class="section">
      <article class="panel page-lead-card faq-page-intro">
        <p class="page-eyebrow">FAQ</p>
        <h1>常见问题</h1>
        <p>集中查看加入标准、活动参与方式、董事会职责与会费相关问题。</p>
      </article>
    </section>

    <section class="section faq-section">
      <div class="faq-list">
        {
          officialFaqItems.map((item) => {
            const externalLink = item.link?.href.startsWith("http");
            const cardsVisual = item.visual?.type === "cards" ? item.visual : null;
            const stepsVisual = item.visual?.type === "steps" ? item.visual : null;
            const tableVisual = item.visual?.type === "table" ? item.visual : null;

            return (
              <details class="panel faq-item">
                <summary>
                  <span>{item.question}</span>
                </summary>

                <div class="faq-answer">
                  {item.paragraphs?.map((paragraph) => <p>{paragraph}</p>)}

                  {item.keyValues?.length ? (
                    <div class="faq-key-value-list">
                      {item.keyValues.map((entry) => (
                        <div class="faq-key-value-item">
                          <strong>{entry.label}</strong>
                          <span>{entry.value}</span>
                        </div>
                      ))}
                    </div>
                  ) : null}

                  {cardsVisual ? (
                    <div class="faq-visual-panel">
                      <div class="faq-card-grid">
                        {cardsVisual.items.map((entry) => (
                          <article class="faq-card-item">
                            <strong>{entry.title}</strong>
                            <p>{entry.body}</p>
                          </article>
                        ))}
                      </div>
                    </div>
                  ) : null}

                  {stepsVisual ? (
                    <div class="faq-visual-panel">
                      <ol class="faq-step-list">
                        {stepsVisual.items.map((step, stepIndex) => (
                          <li class="faq-step-item">
                            <span class="faq-step-index">{stepIndex + 1}</span>
                            <div>
                              <strong>{step.title}</strong>
                              {step.body ? <p>{step.body}</p> : null}
                            </div>
                          </li>
                        ))}
                      </ol>
                    </div>
                  ) : null}

                  {tableVisual ? (
                    <div class="faq-visual-panel">
                      <div class="faq-table-wrap">
                        <table class="faq-comparison-table">
                          <thead>
                            <tr>
                              <th scope="col">项目</th>
                              {tableVisual.columns.map((column) => (
                                <th scope="col">{column}</th>
                              ))}
                            </tr>
                          </thead>
                          <tbody>
                            {tableVisual.rows.map((row) => (
                              <tr>
                                <th scope="row">{row.label}</th>
                                {row.values.map((value) => (
                                  <td>{value}</td>
                                ))}
                              </tr>
                            ))}
                          </tbody>
                        </table>
                      </div>

                      <div class="faq-comparison-cards">
                        {tableVisual.columns.map((column, columnIndex) => (
                          <article class="faq-comparison-card">
                            <h3>{column}</h3>
                            <dl>
                              {tableVisual.rows.map((row) => (
                                <div class="faq-comparison-card-row">
                                  <dt>{row.label}</dt>
                                  <dd>{row.values[columnIndex]}</dd>
                                </div>
                              ))}
                            </dl>
                          </article>
                        ))}
                      </div>
                    </div>
                  ) : null}

                  {item.link ? (
                    <a class="text-link" href={item.link.href} target={externalLink ? "_blank" : undefined} rel={externalLink ? "noreferrer" : undefined}>
                      {item.link.label}
                    </a>
                  ) : null}
                </div>
              </details>
            );
          })
        }
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .faq-page-shell {
    padding-top: 10px;
    padding-bottom: 48px;
  }

  .faq-page-intro,
  .faq-section,
  .faq-list {
    display: grid;
    gap: 18px;
  }

  .faq-section {
    width: min(980px, 100%);
    margin: 0 auto;
  }

  .faq-page-intro {
    gap: 10px;
  }

  .faq-item {
    padding: 0;
    overflow: hidden;
    background: linear-gradient(180deg, rgba(255, 252, 246, 0.98), rgba(245, 238, 227, 0.92));
  }

  .faq-item[open] {
    border-color: rgba(138, 106, 67, 0.16);
    box-shadow: 0 20px 40px rgba(35, 28, 21, 0.1);
  }

  .faq-item summary {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 16px;
    align-items: center;
    padding: 18px 22px;
    cursor: pointer;
    list-style: none;
    font-weight: 700;
    font-size: 1rem;
    line-height: 1.5;
  }

  .faq-item summary::-webkit-details-marker {
    display: none;
  }

  .faq-item summary::after {
    content: "+";
    color: var(--accent-strong);
    font-size: 1.35rem;
    line-height: 1;
  }

  .faq-item[open] summary::after {
    content: "−";
  }

  .faq-item[open] summary {
    border-bottom: 1px solid rgba(27, 23, 19, 0.08);
  }

  .faq-answer {
    display: grid;
    gap: 16px;
    padding: 20px 22px 24px;
  }

  .faq-answer p {
    margin: 0;
    color: var(--muted);
    line-height: 1.84;
  }

  .faq-answer .text-link {
    width: fit-content;
  }

  .faq-key-value-list,
  .faq-card-grid,
  .faq-comparison-cards {
    display: grid;
    gap: 12px;
  }

  .faq-key-value-item,
  .faq-card-item,
  .faq-comparison-card {
    padding: 16px 18px;
    border-radius: 18px;
    border: 1px solid rgba(27, 23, 19, 0.08);
    background: rgba(255, 255, 255, 0.72);
  }

  .faq-key-value-item,
  .faq-card-item {
    display: grid;
    gap: 6px;
  }

  .faq-step-list {
    display: grid;
    gap: 12px;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .faq-step-item {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 14px;
    align-items: start;
    padding: 16px 18px;
    border-radius: 18px;
    border: 1px solid rgba(27, 23, 19, 0.08);
    background: rgba(255, 255, 255, 0.72);
  }

  .faq-step-index {
    display: inline-grid;
    place-items: center;
    width: 28px;
    height: 28px;
    border-radius: 999px;
    background: rgba(138, 106, 67, 0.1);
    color: var(--accent-strong);
    font-size: 0.8rem;
    font-weight: 700;
  }

  .faq-step-item strong,
  .faq-card-item strong,
  .faq-key-value-item strong,
  .faq-comparison-card h3 {
    margin: 0;
  }

  .faq-step-item p,
  .faq-card-item p {
    margin-top: 6px;
  }

  .faq-table-wrap {
    overflow-x: auto;
    border-radius: 18px;
    border: 1px solid rgba(27, 23, 19, 0.08);
    background: rgba(255, 255, 255, 0.72);
  }

  .faq-comparison-table {
    width: 100%;
    border-collapse: collapse;
    min-width: 640px;
  }

  .faq-comparison-table th,
  .faq-comparison-table td {
    padding: 14px 16px;
    border-bottom: 1px solid rgba(27, 23, 19, 0.08);
    text-align: left;
    line-height: 1.7;
    vertical-align: top;
  }

  .faq-comparison-table tbody tr:last-child th,
  .faq-comparison-table tbody tr:last-child td {
    border-bottom: 0;
  }

  .faq-comparison-table th {
    color: var(--ink);
    font-weight: 700;
  }

  .faq-comparison-table td {
    color: var(--muted);
  }

  .faq-comparison-cards {
    display: none;
  }

  .faq-comparison-card dl {
    display: grid;
    gap: 12px;
    margin: 0;
  }

  .faq-comparison-card-row {
    display: grid;
    gap: 4px;
  }

  .faq-comparison-card-row dt {
    color: var(--ink);
    font-weight: 600;
  }

  .faq-comparison-card-row dd {
    margin: 0;
    color: var(--muted);
    line-height: 1.76;
  }

  @media (max-width: 720px) {
    .faq-page-shell {
      padding-top: 4px;
    }

    .faq-item summary {
      padding: 16px 18px;
      font-size: 0.96rem;
    }

    .faq-answer {
      padding: 18px 18px 22px;
    }

    .faq-table-wrap {
      display: none;
    }

    .faq-comparison-cards {
      display: grid;
    }
  }
</style>
