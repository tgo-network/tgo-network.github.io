---
import CollectionCard from "../../components/CollectionCard.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { formatCount, formatDate, formatDateRange } from "../../lib/format";
import { getTopic, listTopics } from "../../lib/public-api";

export const getStaticPaths = async () => {
  const topics = await listTopics();

  return topics.map((topic) => ({
    params: {
      slug: topic.slug
    }
  }));
};

const slug = Astro.params.slug!;
const topic = await getTopic(slug);

if (!topic) {
  throw new Error(`Topic not found: ${slug}`);
}
---

<BaseLayout title={`${topic.title} | Topics | TGO Network`} description={topic.summary}>
  <main class="page-shell page-stack">
    <section class="hero">
      <div class:list={["hero-card", { "hero-split": Boolean(topic.coverImage), "hero-card-media": Boolean(topic.coverImage) }]}>
        <div>
          <span class="eyebrow">Topic Detail</span>
          <h1>{topic.title}</h1>
          <p>{topic.summary}</p>
          <ul class="stat-row">
            <li>{formatCount(topic.articleCount, "article")}</li>
            <li>{formatCount(topic.eventCount, "event")}</li>
          </ul>
        </div>

        {
          topic.coverImage && (
            <figure class="hero-figure">
              <img class="hero-image" src={topic.coverImage.url} alt={topic.coverImage.alt} />
            </figure>
          )
        }
      </div>
    </section>

    <section class="section detail-grid">
      <article class="panel prose-panel">
        <div class="card-label">Editorial Framing</div>
        <p>{topic.body}</p>
      </article>

      <aside class="panel panel-soft">
        <div class="card-label">Why it matters</div>
        <h2 class="card-title">This topic can drive multiple public surfaces.</h2>
        <p class="card-copy">
          The same topic can power a hub page, related article blocks, featured event placement, and city-level
          curation.
        </p>
      </aside>
    </section>

    <section class="section">
      <div class="section-head">
        <div>
          <div class="card-label">Related Articles</div>
          <h2>Published pieces already linked to this topic</h2>
        </div>
      </div>
      <div class="grid grid-2">
        {
          topic.relatedArticles.map((article) => (
            <CollectionCard
              href={`/articles/${article.slug}`}
              label={formatDate(article.publishedAt)}
              title={article.title}
              summary={article.excerpt}
              image={article.coverImage}
              meta={[article.authorName, article.city.name]}
            />
          ))
        }
      </div>
    </section>

    <section class="section">
      <div class="section-head">
        <div>
          <div class="card-label">Related Events</div>
          <h2>Event pages that reinforce this theme</h2>
        </div>
      </div>
      <div class="grid grid-2">
        {
          topic.relatedEvents.map((event) => (
            <CollectionCard
              href={`/events/${event.slug}`}
              label={event.city.name}
              title={event.title}
              summary={event.summary}
              image={event.coverImage}
              meta={[formatDateRange(event.startsAt, event.endsAt), event.venueName]}
            />
          ))
        }
      </div>
    </section>
  </main>
</BaseLayout>
