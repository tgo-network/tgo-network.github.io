---
import CollectionCard from "../../components/CollectionCard.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { formatCount, formatDate, formatDateRange } from "../../lib/format";
import { getTopic, listTopics } from "../../lib/public-api";

export const getStaticPaths = async () => {
  const topics = await listTopics();

  return topics.map((topic) => ({
    params: {
      slug: topic.slug
    }
  }));
};

const slug = Astro.params.slug!;
const topic = await getTopic(slug);

if (!topic) {
  throw new Error(`主题不存在：${slug}`);
}
---

<BaseLayout title={`${topic.title} | 主题 | TGO Network`} description={topic.summary}>
  <main class="page-shell page-stack">
    <section class="hero">
      <div class:list={["hero-card", { "hero-split": Boolean(topic.coverImage), "hero-card-media": Boolean(topic.coverImage) }]}>
        <div>
          <span class="eyebrow">主题详情</span>
          <h1>{topic.title}</h1>
          <p>{topic.summary}</p>
          <ul class="stat-row">
            <li>{formatCount(topic.articleCount, "篇文章")}</li>
            <li>{formatCount(topic.eventCount, "场活动")}</li>
          </ul>
        </div>

        {
          topic.coverImage && (
            <figure class="hero-figure">
              <img class="hero-image" src={topic.coverImage.url} alt={topic.coverImage.alt} />
            </figure>
          )
        }
      </div>
    </section>

    <section class="section detail-grid">
      <article class="panel prose-panel">
        <div class="card-label">编辑视角</div>
        <p>{topic.body}</p>
      </article>

      <aside class="panel panel-soft">
        <div class="card-label">为什么重要</div>
        <h2 class="card-title">一个主题可以驱动多个面向用户的展示层。</h2>
        <p class="card-copy">
          同一个主题既可以成为主题页本身，也可以驱动相关文章区块、精选活动位置，以及城市级别的内容策展。
        </p>
      </aside>
    </section>

    <section class="section">
      <div class="section-head">
        <div>
          <div class="card-label">关联文章</div>
          <h2>已经与该主题绑定的已发布内容</h2>
        </div>
      </div>
      <div class="grid grid-2">
        {
          topic.relatedArticles.map((article) => (
            <CollectionCard
              href={`/articles/${article.slug}`}
              label={formatDate(article.publishedAt)}
              title={article.title}
              summary={article.excerpt}
              image={article.coverImage}
              meta={[article.authorName, article.city.name]}
            />
          ))
        }
      </div>
    </section>

    <section class="section">
      <div class="section-head">
        <div>
          <div class="card-label">关联活动</div>
          <h2>与这一主题相互强化的活动页面</h2>
        </div>
      </div>
      <div class="grid grid-2">
        {
          topic.relatedEvents.map((event) => (
            <CollectionCard
              href={`/events/${event.slug}`}
              label={event.city.name}
              title={event.title}
              summary={event.summary}
              image={event.coverImage}
              meta={[formatDateRange(event.startsAt, event.endsAt), event.venueName]}
            />
          ))
        }
      </div>
    </section>
  </main>
</BaseLayout>
