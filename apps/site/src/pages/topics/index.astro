---
import CollectionCard from "../../components/CollectionCard.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { formatCount } from "../../lib/format";
import { listTopics } from "../../lib/public-api";

const topics = await listTopics();
---

<BaseLayout title="主题 | TGO Network" description="由 TGO 公开 API 契约支撑的已发布主题页。">
  <main class="page-shell page-stack">
    <section class="hero">
      <div class="hero-card">
        <span class="eyebrow">公开路由</span>
        <h1>主题</h1>
        <p>
          主题页承担内容中枢的角色。每个主题都可以汇总关联文章、活动以及未来的精选区块，而不需要改变公开站整体结构。
        </p>
      </div>
    </section>

    <section class="section">
      <div class="grid grid-3">
        {
          topics.map((topic) => (
            <CollectionCard
              href={`/topics/${topic.slug}`}
              label={formatCount(topic.articleCount, "篇文章")}
              title={topic.title}
              summary={topic.summary}
              image={topic.coverImage}
              meta={[formatCount(topic.eventCount, "场活动")]}
            />
          ))
        }
      </div>
    </section>
  </main>
</BaseLayout>
