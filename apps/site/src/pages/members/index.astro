---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { formatDate } from "../../lib/format";
import { listMembers } from "../../lib/public-api";

const members = (await listMembers()).slice().sort((left, right) => {
  const leftTime = Date.parse(left.joinedAt);
  const rightTime = Date.parse(right.joinedAt);

  if (Number.isNaN(leftTime) && Number.isNaN(rightTime)) {
    return left.name.localeCompare(right.name, "zh-CN");
  }

  if (Number.isNaN(leftTime)) {
    return 1;
  }

  if (Number.isNaN(rightTime)) {
    return -1;
  }

  return rightTime - leftTime || left.name.localeCompare(right.name, "zh-CN");
});

const pageSize = 48;
const cityOptions = Array.from(new Set(members.map((member) => member.branch?.cityName || "未标注分会"))).sort((left, right) =>
  left.localeCompare(right, "zh-CN")
);
const initialMembers = members.slice(0, pageSize);
---

<BaseLayout title="成员列表 | TGO 鲲鹏会" description="查看 TGO 鲲鹏会成员资料。">
  <main class="page-shell page-stack">
    <section class="page-intro">
      <div class="page-intro-copy">
        <div class="card-label">成员列表</div>
        <h1>TGO 鲲鹏会成员</h1>
        <p>展示成员的头像、姓名、公司、职务与加入时间，支持按城市分会筛选与分页浏览。</p>
      </div>
      <p class="page-intro-meta">{members.length} 位成员</p>
    </section>

    <section class="section member-directory-section">
      <div class="member-toolbar">
        <div class="filter-bar" data-member-filters>
          <button class="filter-chip is-active" type="button" data-member-city="all">全部成员</button>
          {
            cityOptions.map((city) => (
              <button class="filter-chip" type="button" data-member-city={city}>
                {city}
              </button>
            ))
          }
        </div>
        <p class="results-summary" data-member-summary>
          第 1 / {Math.max(1, Math.ceil(members.length / pageSize))} 页，当前显示 {initialMembers.length} 位，共 {members.length} 位
        </p>
      </div>

      <div class="member-directory-grid" data-member-grid>
        {
          initialMembers.map((member) => (
            <a class="panel member-directory-card" href={`/members/${member.slug}`}>
              <div class="member-directory-head">
                {
                  member.avatar ? (
                    <img class="member-directory-avatar" src={member.avatar.url} alt={member.avatar.alt} loading="lazy" />
                  ) : (
                    <div class="member-directory-avatar member-directory-avatar-fallback" aria-hidden="true">
                      {member.name.slice(0, 1)}
                    </div>
                  )
                }

                <div>
                  <div class="card-label">{member.branch?.cityName ?? "未标注分会"}</div>
                  <h2>{member.name}</h2>
                  <p class="member-directory-company">{member.company}</p>
                </div>
              </div>

              <p class="member-directory-title">{member.title}</p>

              <ul class="meta-list member-directory-meta">
                <li>{member.branch?.name ?? "成员"}</li>
                <li>{formatDate(member.joinedAt)}</li>
              </ul>
            </a>
          ))
        }
      </div>

      <div class="panel panel-soft empty-state" data-member-empty hidden={initialMembers.length > 0}>
        <div class="card-label">暂无结果</div>
        <p class="card-copy">当前筛选条件下没有可显示的成员，请切换其他城市继续查看。</p>
      </div>

      <div class="pagination-bar">
        <button class="button secondary pagination-button" type="button" data-member-prev disabled>
          上一页
        </button>
        <span class="pagination-indicator" data-member-page>第 1 / {Math.max(1, Math.ceil(members.length / pageSize))} 页</span>
        <button
          class="button secondary pagination-button"
          type="button"
          data-member-next
          disabled={members.length <= pageSize}
        >
          下一页
        </button>
      </div>
    </section>
  </main>

  <script define:vars={{ initialMembers: members, pageSize }} is:inline>
    const members = Array.isArray(initialMembers) ? initialMembers : [];
    const memberGrid = document.querySelector("[data-member-grid]");
    const memberEmpty = document.querySelector("[data-member-empty]");
    const memberSummary = document.querySelector("[data-member-summary]");
    const memberPage = document.querySelector("[data-member-page]");
    const prevButton = document.querySelector("[data-member-prev]");
    const nextButton = document.querySelector("[data-member-next]");
    const filterRoot = document.querySelector("[data-member-filters]");
    const filterButtons = filterRoot instanceof HTMLElement ? Array.from(filterRoot.querySelectorAll("[data-member-city]")) : [];

    let currentCity = "all";
    let currentPage = 1;

    const escapeHtml = (value) =>
      String(value ?? "")
        .replaceAll("&", "&amp;")
        .replaceAll("<", "&lt;")
        .replaceAll(">", "&gt;")
        .replaceAll('"', "&quot;")
        .replaceAll("'", "&#39;");

    const formatDate = (value) => {
      const date = new Date(value);
      if (Number.isNaN(date.getTime())) {
        return "时间待补充";
      }

      return new Intl.DateTimeFormat("zh-CN", {
        year: "numeric",
        month: "numeric",
        day: "numeric"
      }).format(date);
    };

    const getMemberCity = (member) => member.branch?.cityName || "未标注分会";
    const getMemberBranch = (member) => member.branch?.name || "成员";

    const renderCard = (member) => {
      const avatar = member.avatar
        ? `<img class="member-directory-avatar" src="${escapeHtml(member.avatar.url)}" alt="${escapeHtml(member.avatar.alt)}" loading="lazy" />`
        : `<div class="member-directory-avatar member-directory-avatar-fallback" aria-hidden="true">${escapeHtml((member.name || "成").slice(0, 1))}</div>`;

      return `
        <a class="panel member-directory-card" href="/members/${encodeURIComponent(member.slug)}">
          <div class="member-directory-head">
            ${avatar}
            <div>
              <div class="card-label">${escapeHtml(getMemberCity(member))}</div>
              <h2>${escapeHtml(member.name)}</h2>
              <p class="member-directory-company">${escapeHtml(member.company)}</p>
            </div>
          </div>
          <p class="member-directory-title">${escapeHtml(member.title)}</p>
          <ul class="meta-list member-directory-meta">
            <li>${escapeHtml(getMemberBranch(member))}</li>
            <li>${escapeHtml(formatDate(member.joinedAt))}</li>
          </ul>
        </a>
      `;
    };

    const syncFilters = () => {
      filterButtons.forEach((button) => {
        button.classList.toggle("is-active", button.dataset.memberCity === currentCity);
      });
    };

    const getFilteredMembers = () => {
      if (currentCity === "all") {
        return members;
      }

      return members.filter((member) => getMemberCity(member) === currentCity);
    };

    const render = () => {
      if (!(memberGrid instanceof HTMLElement) || !(memberEmpty instanceof HTMLElement)) {
        return;
      }

      const filteredMembers = getFilteredMembers();
      const pageCount = Math.max(1, Math.ceil(filteredMembers.length / pageSize));
      currentPage = Math.min(currentPage, pageCount);
      const start = (currentPage - 1) * pageSize;
      const pageItems = filteredMembers.slice(start, start + pageSize);

      memberGrid.innerHTML = pageItems.map((member) => renderCard(member)).join("");
      memberEmpty.hidden = pageItems.length > 0;

      if (memberSummary instanceof HTMLElement) {
        memberSummary.textContent = `第 ${currentPage} / ${pageCount} 页，当前显示 ${pageItems.length} 位，共 ${filteredMembers.length} 位`;
      }

      if (memberPage instanceof HTMLElement) {
        memberPage.textContent = `第 ${currentPage} / ${pageCount} 页`;
      }

      if (prevButton instanceof HTMLButtonElement) {
        prevButton.disabled = currentPage <= 1;
      }

      if (nextButton instanceof HTMLButtonElement) {
        nextButton.disabled = currentPage >= pageCount;
      }
    };

    syncFilters();
    render();

    filterButtons.forEach((button) => {
      button.addEventListener("click", () => {
        currentCity = button.dataset.memberCity || "all";
        currentPage = 1;
        syncFilters();
        render();
      });
    });

    prevButton?.addEventListener("click", () => {
      if (currentPage <= 1) {
        return;
      }

      currentPage -= 1;
      render();
    });

    nextButton?.addEventListener("click", () => {
      currentPage += 1;
      render();
    });
  </script>
</BaseLayout>

<style>
  .member-directory-section {
    display: grid;
    gap: 18px;
  }

  .member-toolbar {
    display: grid;
    gap: 14px;
  }

  .filter-bar {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
  }

  .filter-chip {
    padding: 10px 16px;
    border-radius: 999px;
    border: 1px solid rgba(31, 26, 23, 0.1);
    background: rgba(255, 255, 255, 0.84);
    color: inherit;
    font: inherit;
    cursor: pointer;
    transition: transform 180ms ease, border-color 180ms ease, background 180ms ease;
  }

  .filter-chip:hover {
    transform: translateY(-1px);
    border-color: rgba(157, 111, 49, 0.32);
  }

  .filter-chip.is-active {
    background: linear-gradient(135deg, rgba(157, 111, 49, 0.95), rgba(200, 161, 93, 0.92));
    border-color: transparent;
    color: #fff7ef;
  }

  .results-summary {
    margin: 0;
    color: var(--muted);
    font-size: 0.95rem;
  }

  .member-directory-grid {
    display: grid;
    gap: 18px;
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .member-directory-card {
    display: grid;
    gap: 18px;
    min-height: 100%;
    transition: transform 180ms ease, border-color 180ms ease, box-shadow 180ms ease;
  }

  .member-directory-card:hover {
    transform: translateY(-3px);
    border-color: rgba(157, 111, 49, 0.24);
    box-shadow: 0 24px 42px rgba(40, 28, 18, 0.12);
  }

  .member-directory-head {
    display: grid;
    gap: 14px;
    grid-template-columns: 76px minmax(0, 1fr);
    align-items: center;
  }

  .member-directory-avatar {
    width: 76px;
    height: 76px;
    border-radius: 24px;
    object-fit: cover;
    box-shadow: 0 14px 28px rgba(40, 28, 18, 0.12);
  }

  .member-directory-avatar-fallback {
    display: grid;
    place-items: center;
    background: linear-gradient(135deg, rgba(200, 161, 93, 0.94), rgba(157, 111, 49, 0.94));
    color: #fff7ef;
    font-family: var(--font-display);
    font-size: 1.5rem;
  }

  .member-directory-head h2 {
    margin: 8px 0 6px;
    font-size: 1.24rem;
  }

  .member-directory-company,
  .member-directory-title {
    margin: 0;
    color: var(--muted);
    line-height: 1.7;
  }

  .member-directory-title {
    min-height: 3.4em;
  }

  .member-directory-meta {
    margin-top: 0;
  }

  @media (max-width: 1000px) {
    .member-directory-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 720px) {
    .member-directory-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
