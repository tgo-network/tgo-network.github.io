---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { formatDate } from "../../lib/format";
import { listMembers } from "../../lib/public-api";

const members = await listMembers();
const uniqueBranches = Array.from(new Set(members.map((member) => member.branch?.name).filter((value): value is string => Boolean(value))));
const uniqueCities = Array.from(new Set(members.map((member) => member.branch?.cityName).filter((value): value is string => Boolean(value))));
const uniqueCompanies = Array.from(new Set(members.map((member) => member.company))).length;
---

<BaseLayout title="成员列表 | TGO 鲲鹏会" description="查看 TGO 鲲鹏会成员的公开资料。">
  <main class="page-shell page-stack">
    <section class="hero">
      <div class="hero-card member-hero-card">
        <div class="member-hero-main">
          <span class="eyebrow">成员列表</span>
          <h1>来自不同公司与城市分会的技术领导者</h1>
          <p>
            当前展示为公开可见的成员资料，包含头像、姓名、公司、职称与加入时间。
            这里强调真实的人与组织结构，而不只是栏目式内容浏览。
          </p>
        </div>

        <aside class="member-hero-aside">
          <article>
            <strong>{members.length}</strong>
            <span>公开成员</span>
          </article>
          <article>
            <strong>{uniqueBranches.length}</strong>
            <span>覆盖分会</span>
          </article>
          <article>
            <strong>{uniqueCompanies}</strong>
            <span>所在公司</span>
          </article>
        </aside>
      </div>
    </section>

    <section class="section">
      <div class="section-head">
        <div>
          <div class="card-label">分会覆盖</div>
          <h2>成员来自不同城市节点与技术团队</h2>
        </div>
      </div>

      <div class="member-chip-row">
        {uniqueCities.map((city) => <span class="member-chip">{city}</span>)}
      </div>
    </section>

    <section class="section">
      <div class="member-grid">
        {
          members.map((member) => (
            <a class="panel member-card" href={`/members/${member.slug}`}>
              <div class="member-card-head">
                {
                  member.avatar ? (
                    <img class="member-avatar" src={member.avatar.url} alt={member.avatar.alt} loading="lazy" />
                  ) : (
                    <div class="member-avatar member-avatar-fallback" aria-hidden="true">
                      {member.name.slice(0, 1)}
                    </div>
                  )
                }

                <div>
                  <div class="card-label">{member.branch?.name ?? "成员"}</div>
                  <h2 class="member-name">{member.name}</h2>
                  <p class="member-company">{member.company}</p>
                </div>
              </div>

              <p class="member-title">{member.title}</p>

              <ul class="meta-list member-meta-list">
                {member.branch?.cityName && <li>{member.branch.cityName}</li>}
                <li>{formatDate(member.joinedAt)}</li>
              </ul>
            </a>
          ))
        }
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .member-hero-card {
    display: grid;
    gap: 22px;
    grid-template-columns: minmax(0, 1.2fr) minmax(260px, 0.8fr);
    background:
      radial-gradient(circle at top right, rgba(215, 179, 117, 0.16), transparent 24%),
      linear-gradient(180deg, rgba(255, 252, 246, 0.96), rgba(247, 241, 232, 0.94));
  }

  .member-hero-aside {
    display: grid;
    gap: 12px;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    align-content: start;
  }

  .member-hero-aside article {
    display: grid;
    gap: 4px;
    padding: 18px 14px;
    border-radius: 20px;
    background: rgba(255, 255, 255, 0.72);
    border: 1px solid rgba(31, 26, 23, 0.08);
    text-align: center;
  }

  .member-hero-aside strong {
    font-family: var(--font-display);
    font-size: 1.7rem;
  }

  .member-hero-aside span {
    color: var(--muted);
    font-size: 0.9rem;
  }

  .member-chip-row {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
  }

  .member-chip {
    display: inline-flex;
    align-items: center;
    min-height: 40px;
    padding: 0 14px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.8);
    border: 1px solid rgba(31, 26, 23, 0.08);
    color: var(--muted);
  }

  .member-grid {
    display: grid;
    gap: 18px;
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .member-card {
    display: grid;
    gap: 18px;
    min-height: 100%;
    transition: transform 180ms ease, border-color 180ms ease;
  }

  .member-card:hover {
    transform: translateY(-3px);
    border-color: rgba(157, 111, 49, 0.22);
  }

  .member-card-head {
    display: flex;
    gap: 16px;
    align-items: center;
  }

  .member-avatar {
    width: 72px;
    height: 72px;
    border-radius: 22px;
    object-fit: cover;
    flex: 0 0 auto;
    background: rgba(31, 26, 23, 0.08);
  }

  .member-avatar-fallback {
    display: inline-grid;
    place-items: center;
    color: #fff7ef;
    background: linear-gradient(135deg, rgba(157, 111, 49, 0.95), rgba(200, 161, 93, 0.9));
    font-weight: 700;
    font-size: 1.3rem;
  }

  .member-name {
    margin: 10px 0 8px;
    font-size: 1.35rem;
  }

  .member-company,
  .member-title {
    margin: 0;
    color: var(--muted);
    line-height: 1.7;
  }

  .member-title {
    min-height: 3.4em;
  }

  .member-meta-list {
    margin-top: auto;
  }

  @media (max-width: 980px) {
    .member-hero-card,
    .member-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 720px) {
    .member-hero-aside {
      grid-template-columns: 1fr;
    }
  }
</style>
