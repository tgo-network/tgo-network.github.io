---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { orderBranchCities } from "../../lib/branch-order";
import { listMembers } from "../../lib/public-api";

const members = (await listMembers()).slice().sort((left, right) => {
  const leftTime = Date.parse(left.joinedAt);
  const rightTime = Date.parse(right.joinedAt);

  if (Number.isNaN(leftTime) && Number.isNaN(rightTime)) {
    return left.name.localeCompare(right.name, "zh-CN");
  }

  if (Number.isNaN(leftTime)) {
    return 1;
  }

  if (Number.isNaN(rightTime)) {
    return -1;
  }

  return rightTime - leftTime || left.name.localeCompare(right.name, "zh-CN");
});

const pageSize = 12;
const cityOptions = orderBranchCities(Array.from(new Set(members.map((member) => member.branch?.cityName || "未标注分会"))));
const initialMembers = members.slice(0, pageSize);
---

<BaseLayout title="成员列表 | TGO 鲲鹏会" description="查看 TGO 鲲鹏会成员资料。">
  <main class="page-shell page-stack member-directory-shell">
    <h1 class="sr-only">成员列表</h1>
    <section class="section member-directory-section">
      <div class="panel member-directory-toolbar">
        <div class="filter-bar" data-member-filters>
          <button class="filter-chip is-active" type="button" data-member-city="all">全部</button>
          {
            cityOptions.map((city) => (
              <button class="filter-chip" type="button" data-member-city={city}>
                {city}
              </button>
            ))
          }
        </div>
      </div>

      <div class="member-directory-grid" data-member-grid>
        {
          initialMembers.map((member) => (
            <a class="panel member-directory-card" href={`/members/${member.slug}`}>
              <div class="member-directory-head">
                {
                  member.avatar ? (
                    <img class="member-directory-avatar" src={member.avatar.url} alt={member.avatar.alt} loading="lazy" />
                  ) : (
                    <div class="member-directory-avatar member-directory-avatar-fallback" aria-hidden="true">
                      {member.name.slice(0, 1)}
                    </div>
                  )
                }

                <div class="member-directory-copy">
                  <p class="member-directory-branch">{member.branch?.name ?? "未标注分会"}</p>
                  <h2>{member.name}</h2>
                  <p class="member-directory-company">{member.company}</p>
                  <p class="member-directory-title">{member.title}</p>
                </div>
              </div>
            </a>
          ))
        }
      </div>

      <div class="panel panel-soft empty-state" data-member-empty hidden={initialMembers.length > 0}>
        <div class="card-label">暂无成员</div>
        <p class="card-copy">当前分会下暂无可展示的成员。</p>
      </div>

      <div class="pagination-bar member-pagination-bar">
        <button class="button secondary pagination-button" type="button" data-member-prev disabled>
          上一页
        </button>
        <button
          class="button secondary pagination-button"
          type="button"
          data-member-next
          disabled={members.length <= pageSize}
        >
          下一页
        </button>
      </div>
    </section>
  </main>

  <script define:vars={{ initialMembers: members, pageSize }} is:inline>
    const members = Array.isArray(initialMembers) ? initialMembers : [];
    const memberGrid = document.querySelector("[data-member-grid]");
    const memberEmpty = document.querySelector("[data-member-empty]");
    const prevButton = document.querySelector("[data-member-prev]");
    const nextButton = document.querySelector("[data-member-next]");
    const filterRoot = document.querySelector("[data-member-filters]");
    const filterButtons = filterRoot instanceof HTMLElement ? Array.from(filterRoot.querySelectorAll("[data-member-city]")) : [];

    let currentCity = "all";
    let currentPage = 1;

    const escapeHtml = (value) =>
      String(value ?? "")
        .replaceAll("&", "&amp;")
        .replaceAll("<", "&lt;")
        .replaceAll(">", "&gt;")
        .replaceAll('"', "&quot;")
        .replaceAll("'", "&#39;");

    const getMemberCity = (member) => member.branch?.cityName || "未标注分会";

    const renderCard = (member) => {
      const avatar = member.avatar
        ? `<img class="member-directory-avatar" src="${escapeHtml(member.avatar.url)}" alt="${escapeHtml(member.avatar.alt)}" loading="lazy" />`
        : `<div class="member-directory-avatar member-directory-avatar-fallback" aria-hidden="true">${escapeHtml((member.name || "成").slice(0, 1))}</div>`;

      return `
        <a class="panel member-directory-card" href="/members/${encodeURIComponent(member.slug)}">
          <div class="member-directory-head">
            ${avatar}
            <div class="member-directory-copy">
              <p class="member-directory-branch">${escapeHtml(member.branch?.name || "未标注分会")}</p>
              <h2>${escapeHtml(member.name)}</h2>
              <p class="member-directory-company">${escapeHtml(member.company)}</p>
              <p class="member-directory-title">${escapeHtml(member.title)}</p>
            </div>
          </div>
        </a>
      `;
    };

    const syncFilters = () => {
      filterButtons.forEach((button) => {
        button.classList.toggle("is-active", button.dataset.memberCity === currentCity);
      });
    };

    const getFilteredMembers = () => {
      if (currentCity === "all") {
        return members;
      }

      return members.filter((member) => getMemberCity(member) === currentCity);
    };

    const render = () => {
      if (!(memberGrid instanceof HTMLElement) || !(memberEmpty instanceof HTMLElement)) {
        return;
      }

      const filteredMembers = getFilteredMembers();
      const pageCount = Math.max(1, Math.ceil(filteredMembers.length / pageSize));
      currentPage = Math.min(currentPage, pageCount);
      const start = (currentPage - 1) * pageSize;
      const pageItems = filteredMembers.slice(start, start + pageSize);

      memberGrid.innerHTML = pageItems.map((member) => renderCard(member)).join("");
      memberEmpty.hidden = pageItems.length > 0;

      if (prevButton instanceof HTMLButtonElement) {
        prevButton.disabled = currentPage <= 1;
      }

      if (nextButton instanceof HTMLButtonElement) {
        nextButton.disabled = currentPage >= pageCount;
      }
    };

    syncFilters();
    render();

    filterButtons.forEach((button) => {
      button.addEventListener("click", () => {
        currentCity = button.dataset.memberCity || "all";
        currentPage = 1;
        syncFilters();
        render();
      });
    });

    prevButton?.addEventListener("click", () => {
      if (currentPage <= 1) {
        return;
      }

      currentPage -= 1;
      render();
    });

    nextButton?.addEventListener("click", () => {
      currentPage += 1;
      render();
    });
  </script>
</BaseLayout>

<style>
  .member-directory-shell {
    padding-top: 18px;
    padding-bottom: 48px;
  }

  .member-directory-section,
  .member-directory-toolbar {
    display: grid;
    gap: 18px;
  }

  :global(.member-directory-grid) {
    display: grid;
    gap: 20px;
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  :global(.member-directory-card) {
    display: grid;
    min-height: 100%;
    padding: 24px;
    background:
      radial-gradient(circle at top right, rgba(138, 106, 67, 0.08), transparent 28%),
      linear-gradient(180deg, rgba(255, 252, 246, 0.98), rgba(245, 238, 227, 0.92));
    transition: transform 180ms ease, border-color 180ms ease, box-shadow 180ms ease;
  }

  :global(.member-directory-card:hover) {
    transform: translateY(-2px);
    border-color: rgba(138, 106, 67, 0.18);
    box-shadow: 0 20px 40px rgba(35, 28, 21, 0.1);
  }

  :global(.member-directory-head) {
    display: grid;
    gap: 16px;
    grid-template-columns: 76px minmax(0, 1fr);
    align-items: start;
  }

  :global(.member-directory-copy) {
    display: grid;
    gap: 8px;
    align-content: start;
  }

  :global(.member-directory-branch) {
    display: inline-flex;
    align-items: center;
    width: fit-content;
    min-height: 28px;
    margin: 0;
    padding: 0 10px;
    border-radius: 999px;
    border: 1px solid rgba(138, 106, 67, 0.16);
    background: rgba(255, 248, 238, 0.72);
    color: var(--accent-strong);
    font-size: 0.76rem;
    letter-spacing: 0.04em;
  }

  :global(.member-directory-avatar) {
    width: 76px;
    height: 76px;
    border-radius: 18px;
    object-fit: cover;
    background: rgba(27, 23, 19, 0.06);
  }

  :global(.member-directory-avatar-fallback) {
    display: grid;
    place-items: center;
    border: 1px solid rgba(27, 23, 19, 0.08);
    background: linear-gradient(180deg, rgba(255, 254, 252, 0.96), rgba(239, 231, 220, 0.92));
    color: var(--accent-strong);
    font-family: var(--font-display);
    font-size: 1.46rem;
  }

  :global(.member-directory-copy h2) {
    margin: 0;
    font-size: 1.08rem;
    line-height: 1.38;
  }

  :global(.member-directory-company),
  :global(.member-directory-title) {
    margin: 0;
    color: var(--muted);
    line-height: 1.72;
  }

  :global(.member-directory-company) {
    color: var(--ink);
    font-weight: 600;
    display: -webkit-box;
    overflow: hidden;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
  }

  :global(.member-directory-title) {
    display: -webkit-box;
    overflow: hidden;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
  }

  @media (max-width: 1100px) {
    :global(.member-directory-grid) {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 720px) {
    .member-directory-shell {
      padding-top: 8px;
    }

    :global(.member-directory-card) {
      padding: 18px;
    }

    :global(.member-directory-grid) {
      grid-template-columns: 1fr;
    }
  }
</style>
