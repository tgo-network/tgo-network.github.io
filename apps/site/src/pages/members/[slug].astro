---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { formatDate } from "../../lib/format";
import { getBranch, getMember, listMembers } from "../../lib/public-api";

export const getStaticPaths = async () => {
  const members = await listMembers();

  return members.map((member) => ({
    params: {
      slug: member.slug
    }
  }));
};

const slug = Astro.params.slug!;
const member = await getMember(slug);
const branch = member?.branch ? await getBranch(member.branch.slug) : null;

if (!member) {
  throw new Error(`成员不存在：${slug}`);
}

const branchBodyExcerpt = branch
  ? branch.body
      .split(/(?<=[。！？])/u)
      .map((item) => item.trim())
      .filter(Boolean)
      .slice(0, 2)
      .join("")
  : "";
---

<BaseLayout title={`${member.name} | 成员 | TGO 鲲鹏会`} description={`${member.company} · ${member.title}`}>
  <main class="page-shell page-stack">
    <section class="page-intro">
      <div class="page-intro-copy">
        <div class="card-label">成员详情</div>
        <h1>{member.name}</h1>
        <p>{member.company} · {member.title}</p>
      </div>
      <p class="page-intro-meta">
        {member.branch ? `${member.branch.name} · ` : ""}加入时间：{formatDate(member.joinedAt)}
      </p>
    </section>

    <section class="section member-profile-layout">
      <article class="panel member-profile-main">
        <div class="member-profile-head">
          {
            member.avatar ? (
              <img class="member-profile-avatar" src={member.avatar.url} alt={member.avatar.alt} />
            ) : (
              <div class="member-profile-avatar member-profile-avatar-fallback" aria-hidden="true">
                {member.name.slice(0, 1)}
              </div>
            )
          }

          <div class="member-profile-copy">
            <div class="card-label">成员资料</div>
            <h2>{member.name}</h2>
            <p>{member.company} · {member.title}</p>
            <ul class="meta-list member-profile-meta">
              <li>{member.branch?.name ?? "成员"}</li>
              <li>{member.branch?.cityName ?? "城市待补充"}</li>
              <li>{formatDate(member.joinedAt)}</li>
            </ul>
          </div>
        </div>

        <div class="member-profile-body">
          <div class="card-label">个人简介</div>
          <p>{member.bio}</p>
        </div>
      </article>

      <aside class="panel panel-soft member-profile-side">
        <div>
          <div class="card-label">成员档案</div>
          <ul class="member-profile-list">
            <li>
              <span>姓名</span>
              <strong>{member.name}</strong>
            </li>
            <li>
              <span>公司</span>
              <strong>{member.company}</strong>
            </li>
            <li>
              <span>职务</span>
              <strong>{member.title}</strong>
            </li>
            <li>
              <span>所属分会</span>
              <strong>{member.branch?.name ?? "待补充"}</strong>
            </li>
            <li>
              <span>加入时间</span>
              <strong>{formatDate(member.joinedAt)}</strong>
            </li>
          </ul>
        </div>

        <div class="member-profile-actions">
          {member.branch && <a class="button primary" href={`/branches#${member.branch.slug}`}>查看所属分会</a>}
          <a class="button secondary" href="/members">返回成员列表</a>
        </div>
      </aside>
    </section>

    {branch && (
      <section class="section member-context-grid">
        <article class="panel prose-panel member-branch-panel">
          <div class="card-label">所属分会</div>
          <h2>{branch.name}</h2>
          <p>{branch.summary}</p>
          {branchBodyExcerpt && <p>{branchBodyExcerpt}</p>}
          <ul class="meta-list member-branch-meta">
            <li>{branch.cityName}</li>
            <li>{branch.region}</li>
            <li>{branch.boardMemberCount} 位董事会成员</li>
          </ul>
          <a class="text-link" href={`/branches#${branch.slug}`}>查看分会董事会</a>
        </article>

        <aside class="panel panel-soft member-board-panel">
          <div>
            <div class="card-label">董事会成员</div>
            <h2>与 {member.name} 同属 {branch.name} 的董事会</h2>
          </div>

          <div class="member-board-list">
            {
              branch.boardMembers.slice(0, 4).map((boardMember) => (
                <article class="member-board-card">
                  <strong>{boardMember.displayName}</strong>
                  <span>{boardMember.title}</span>
                  <small>{boardMember.company}</small>
                </article>
              ))
            }
          </div>
        </aside>
      </section>
    )}
  </main>
</BaseLayout>

<style>
  .member-profile-layout {
    display: grid;
    gap: 20px;
    grid-template-columns: minmax(0, 1.2fr) minmax(300px, 0.8fr);
    align-items: start;
  }

  .member-profile-main,
  .member-profile-side {
    display: grid;
    gap: 22px;
  }

  .member-profile-head {
    display: grid;
    gap: 20px;
    grid-template-columns: 132px minmax(0, 1fr);
    align-items: center;
  }

  .member-profile-avatar {
    width: 132px;
    height: 132px;
    border-radius: 32px;
    object-fit: cover;
    box-shadow: 0 18px 36px rgba(40, 28, 18, 0.14);
  }

  .member-profile-avatar-fallback {
    display: grid;
    place-items: center;
    background: linear-gradient(135deg, rgba(200, 161, 93, 0.94), rgba(157, 111, 49, 0.94));
    color: #fff7ef;
    font-family: var(--font-display);
    font-size: 2.4rem;
  }

  .member-profile-copy h2 {
    margin: 10px 0 8px;
    font-size: clamp(1.8rem, 3vw, 2.5rem);
  }

  .member-profile-copy p,
  .member-profile-body p {
    margin: 0;
    color: var(--muted);
    line-height: 1.85;
  }

  .member-profile-meta {
    margin-top: 18px;
  }

  .member-profile-body {
    display: grid;
    gap: 12px;
  }

  .member-profile-list {
    display: grid;
    gap: 12px;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .member-profile-list li {
    display: grid;
    gap: 6px;
    padding: 14px 16px;
    border-radius: 18px;
    border: 1px solid rgba(31, 26, 23, 0.08);
    background: rgba(255, 255, 255, 0.6);
  }

  .member-profile-list span {
    color: var(--muted);
    font-size: 0.86rem;
  }

  .member-profile-actions {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }

  .member-context-grid {
    display: grid;
    gap: 20px;
    grid-template-columns: minmax(0, 1.1fr) minmax(320px, 0.9fr);
  }

  .member-branch-panel,
  .member-board-panel {
    display: grid;
    gap: 16px;
    min-height: 100%;
  }

  .member-branch-panel h2,
  .member-board-panel h2 {
    margin: 0;
    font-size: clamp(1.45rem, 2.4vw, 2rem);
  }

  .member-branch-panel p {
    margin: 0;
  }

  .member-branch-meta {
    margin-top: 4px;
  }

  .member-board-list {
    display: grid;
    gap: 12px;
  }

  .member-board-card {
    display: grid;
    gap: 4px;
    padding: 14px 16px;
    border-radius: 18px;
    border: 1px solid rgba(31, 26, 23, 0.08);
    background: rgba(255, 255, 255, 0.66);
  }

  .member-board-card span,
  .member-board-card small {
    color: var(--muted);
    line-height: 1.6;
  }

  @media (max-width: 900px) {
    .member-profile-layout,
    .member-profile-head,
    .member-context-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
