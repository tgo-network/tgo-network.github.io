---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { formatDate } from "../../lib/format";
import { getMember, listMembers } from "../../lib/public-api";

export const getStaticPaths = async () => {
  const members = await listMembers();

  return members.map((member) => ({
    params: {
      slug: member.slug
    }
  }));
};

const slug = Astro.params.slug!;
const member = await getMember(slug);

if (!member) {
  throw new Error(`成员不存在：${slug}`);
}
---

<BaseLayout title={`${member.name} | 成员 | TGO 鲲鹏会`} description={`${member.company} · ${member.title}`}>
  <main class="page-shell page-stack">
    <section class="hero">
      <div class="hero-card member-detail-hero">
        <div class="member-detail-main">
          <span class="eyebrow">成员详情</span>
          <h1>{member.name}</h1>
          <p>{member.company} · {member.title}</p>
          <ul class="stat-row">
            <li>{member.branch?.name ?? "未分配分会"}</li>
            <li>{member.branch?.cityName ?? "待补充城市"}</li>
            <li>{formatDate(member.joinedAt)}</li>
          </ul>
        </div>

        <aside class="member-detail-side">
          {
            member.avatar ? (
              <img class="member-detail-avatar" src={member.avatar.url} alt={member.avatar.alt} />
            ) : (
              <div class="member-detail-avatar member-detail-avatar-fallback" aria-hidden="true">
                {member.name.slice(0, 1)}
              </div>
            )
          }

          <div class="member-detail-side-card">
            <div class="card-label card-label-on-dark">成员档案</div>
            <ul class="member-detail-info">
              <li>
                <span>所属分会</span>
                <strong>{member.branch?.name ?? "待补充"}</strong>
              </li>
              <li>
                <span>所在城市</span>
                <strong>{member.branch?.cityName ?? "待补充"}</strong>
              </li>
              <li>
                <span>加入时间</span>
                <strong>{formatDate(member.joinedAt)}</strong>
              </li>
            </ul>
          </div>
        </aside>
      </div>
    </section>

    <section class="section member-detail-grid">
      <article class="panel prose-panel">
        <div class="card-label">个人简介</div>
        <h2 class="card-title">关于这位成员</h2>
        <p>{member.bio}</p>
      </article>

      <aside class="panel panel-soft member-note-panel">
        <div>
          <div class="card-label">组织位置</div>
          <p class="card-copy">
            当前公开成员页用于展示真实的人与组织结构，帮助访客理解这个社区覆盖了哪些城市、哪些公司，以及哪些技术管理角色。
          </p>
        </div>

        <div>
          <div class="card-label">参与方式</div>
          <ul class="meta-list vertical-list">
            <li>可参与分会活动与公开学习活动</li>
            <li>可通过长期交流沉淀同侪连接</li>
            <li>成员与工作人员是完全分开的两套身份</li>
          </ul>
        </div>
      </aside>
    </section>
  </main>
</BaseLayout>

<style>
  .member-detail-hero {
    display: grid;
    gap: 22px;
    grid-template-columns: minmax(0, 1.15fr) minmax(320px, 0.85fr);
    background:
      radial-gradient(circle at top right, rgba(215, 179, 117, 0.16), transparent 24%),
      linear-gradient(135deg, #171717 0%, #211d18 100%);
    border-color: rgba(215, 179, 117, 0.14);
    color: #f8f1e8;
  }

  .member-detail-hero h1,
  .member-detail-hero h2 {
    color: #fff7ef;
  }

  .member-detail-hero p {
    color: rgba(248, 241, 232, 0.76);
  }

  .member-detail-hero .eyebrow {
    color: #f1d5a0;
    border-color: rgba(215, 179, 117, 0.28);
    background: rgba(255, 255, 255, 0.06);
  }

  .member-detail-side {
    display: grid;
    gap: 18px;
    align-content: start;
  }

  .member-detail-avatar {
    width: 100%;
    aspect-ratio: 1 / 1;
    object-fit: cover;
    border-radius: 28px;
    box-shadow: var(--shadow-strong);
    background: rgba(255, 255, 255, 0.08);
  }

  .member-detail-avatar-fallback {
    display: inline-grid;
    place-items: center;
    color: #fff7ef;
    background: linear-gradient(135deg, rgba(157, 111, 49, 0.95), rgba(200, 161, 93, 0.9));
    font-size: clamp(3rem, 7vw, 4.8rem);
    font-weight: 700;
  }

  .member-detail-side-card {
    padding: 22px;
    border-radius: 24px;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(215, 179, 117, 0.14);
  }

  .member-detail-info {
    display: grid;
    gap: 14px;
    list-style: none;
    padding: 0;
    margin: 18px 0 0;
  }

  .member-detail-info li {
    display: grid;
    gap: 4px;
  }

  .member-detail-info span {
    color: rgba(248, 241, 232, 0.6);
    font-size: 0.84rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .member-detail-info strong {
    color: #fff7ef;
    line-height: 1.6;
  }

  .member-detail-grid {
    display: grid;
    gap: 18px;
    grid-template-columns: minmax(0, 1.2fr) minmax(0, 0.8fr);
  }

  .member-note-panel {
    display: grid;
    gap: 18px;
    align-content: start;
  }

  .vertical-list {
    display: grid;
    gap: 10px;
  }

  @media (max-width: 980px) {
    .member-detail-hero,
    .member-detail-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
