---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { formatDate } from "../../lib/format";
import { getBranch, getMember, listMembers } from "../../lib/public-api";

export const getStaticPaths = async () => {
  const members = await listMembers();

  return members.map((member) => ({
    params: {
      slug: member.slug
    }
  }));
};

const slug = Astro.params.slug!;
const member = await getMember(slug);
const branch = member?.branch ? await getBranch(member.branch.slug) : null;

if (!member) {
  throw new Error(`成员不存在：${slug}`);
}

const branchBodyExcerpt = branch
  ? branch.body
      .split(/(?<=[。！？])/u)
      .map((item) => item.trim())
      .filter(Boolean)
      .slice(0, 2)
      .join("")
  : "";
const showBranchBodyExcerpt = Boolean(branchBodyExcerpt && branchBodyExcerpt !== branch?.summary);
const memberMetaItems = [
  `所属分会 · ${member.branch?.name ?? "待补充"}`,
  `加入时间 · ${formatDate(member.joinedAt)}`,
  "公开身份 · TGO 鲲鹏会成员"
];
---

<BaseLayout title={`${member.name} | 成员 | TGO 鲲鹏会`} description={`${member.company} · ${member.title}`}>
  <main class="page-shell page-stack detail-page-shell member-detail-shell">
    <section class="section">
      <article class="panel detail-hero-card detail-hero-card-single member-detail-hero-card">
        <div class="detail-hero-copy">
          <div class="member-profile-head">
            {
              member.avatar ? (
                <img class="member-profile-avatar" src={member.avatar.url} alt={member.avatar.alt} />
              ) : (
                <div class="member-profile-avatar member-profile-avatar-fallback" aria-hidden="true">
                  {member.name.slice(0, 1)}
                </div>
              )
            }

            <div class="member-profile-copy">
              <p class="page-eyebrow member-profile-eyebrow">{member.branch?.name ?? "TGO 鲲鹏会成员"}</p>
              <h1>{member.name}</h1>
              <p class="member-profile-role">{member.company} · {member.title}</p>
            </div>
          </div>

          <p class="detail-summary member-profile-summary">{member.bio}</p>

          <div class="detail-meta-row">
            {memberMetaItems.map((item) => <span class="detail-meta-item">{item}</span>)}
          </div>

          <div class="hero-actions member-profile-actions">
            {member.branch && <a class="button primary" href={`/branches#${member.branch.slug}`}>查看所属分会</a>}
            <a class="button secondary" href="/members">返回成员列表</a>
          </div>
        </div>
      </article>
    </section>

    {branch && (
      <section class="section member-context-section">
        <div class="member-context-grid">
          <article class="panel detail-section-card member-context-branch">
            <h2>{branch.name}</h2>

            {
              branch.coverImage && (
                <figure class="member-branch-figure">
                  <img class="member-branch-image" src={branch.coverImage.url} alt={branch.coverImage.alt} loading="lazy" />
                </figure>
              )
            }

            <p>{branch.summary}</p>
            {showBranchBodyExcerpt && <p>{branchBodyExcerpt}</p>}

            <a class="text-link" href={`/branches#${branch.slug}`}>查看分会董事会</a>
          </article>

          <article class="panel detail-section-card member-context-board">
            <div class="member-context-board-head">
              <h2>董事会成员</h2>
              <a class="text-link" href={`/branches#${branch.slug}`}>查看完整列表</a>
            </div>

            <div class="member-board-list">
              {
                branch.boardMembers.slice(0, 4).map((boardMember) => (
                  <article class="member-board-card">
                    <div class="member-board-head">
                      {
                        boardMember.avatar ? (
                          <img class="member-board-avatar" src={boardMember.avatar.url} alt={boardMember.avatar.alt} loading="lazy" />
                        ) : (
                          <div class="member-board-avatar member-board-avatar-fallback" aria-hidden="true">
                            {boardMember.displayName.slice(0, 1)}
                          </div>
                        )
                      }

                      <div class="member-board-copy">
                        <strong>{boardMember.displayName}</strong>
                        <span>{boardMember.title}</span>
                        <small>{boardMember.company}</small>
                      </div>
                    </div>
                  </article>
                ))
              }
            </div>
          </article>
        </div>
      </section>
    )}
  </main>
</BaseLayout>

<style>
  .member-context-grid {
    display: grid;
    gap: 18px;
    grid-template-columns: minmax(0, 1fr) minmax(320px, 0.94fr);
    align-items: start;
  }

  .member-profile-head {
    display: grid;
    gap: 20px;
    grid-template-columns: 132px minmax(0, 1fr);
    align-items: start;
  }

  .member-profile-copy h1,
  .member-context-branch h2,
  .member-context-board h2 {
    margin: 0;
  }

  .member-profile-avatar {
    width: 132px;
    height: 132px;
    border-radius: 24px;
    object-fit: cover;
    background: rgba(27, 23, 19, 0.06);
  }

  .member-profile-avatar-fallback,
  .member-board-avatar-fallback {
    display: grid;
    place-items: center;
    border: 1px solid rgba(27, 23, 19, 0.08);
    background: linear-gradient(180deg, rgba(255, 254, 252, 0.96), rgba(239, 231, 220, 0.92));
    color: var(--accent-strong);
    font-family: var(--font-display);
  }

  .member-profile-avatar-fallback {
    font-size: 2.3rem;
  }

  .member-profile-copy {
    display: grid;
    gap: 10px;
  }

  .member-profile-role,
  .member-context-branch p,
  .member-board-copy span,
  .member-board-copy small {
    margin: 0;
    color: var(--muted);
    line-height: 1.8;
  }

  .member-profile-role {
    color: var(--ink);
    font-weight: 600;
  }

  .member-profile-summary {
    max-width: 72ch;
  }

  .member-profile-actions {
    margin-top: 2px;
  }

  .member-branch-figure {
    margin: 0;
  }

  .member-branch-image {
    display: block;
    width: 100%;
    border-radius: 18px;
    object-fit: cover;
  }

  .member-context-board-head {
    display: flex;
    gap: 12px;
    align-items: center;
    justify-content: space-between;
  }

  .member-board-list {
    display: grid;
    gap: 12px;
  }

  .member-board-card {
    padding: 16px 18px;
    border-radius: 18px;
    border: 1px solid rgba(27, 23, 19, 0.08);
    background: rgba(255, 255, 255, 0.72);
  }

  .member-board-head {
    display: grid;
    gap: 12px;
    grid-template-columns: 60px minmax(0, 1fr);
    align-items: center;
  }

  .member-board-avatar {
    width: 60px;
    height: 60px;
    border-radius: 16px;
    object-fit: cover;
    background: rgba(27, 23, 19, 0.06);
  }

  .member-board-avatar-fallback {
    font-size: 1.2rem;
  }

  .member-board-copy {
    display: grid;
    gap: 4px;
  }

  @media (max-width: 980px) {
    .member-context-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 720px) {
    .member-profile-head {
      grid-template-columns: 1fr;
    }

    .member-profile-avatar {
      width: 96px;
      height: 96px;
    }
  }
</style>
