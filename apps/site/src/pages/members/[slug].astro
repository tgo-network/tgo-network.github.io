---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { formatDate } from "../../lib/format";
import { getBranch, getMember, listMembers } from "../../lib/public-api";

export const getStaticPaths = async () => {
  const members = await listMembers();

  return members.map((member) => ({
    params: {
      slug: member.slug
    }
  }));
};

const slug = Astro.params.slug!;
const member = await getMember(slug);
const branch = member?.branch ? await getBranch(member.branch.slug) : null;

if (!member) {
  throw new Error(`成员不存在：${slug}`);
}

const branchBodyExcerpt = branch
  ? branch.body
      .split(/(?<=[。！？])/u)
      .map((item) => item.trim())
      .filter(Boolean)
      .slice(0, 2)
      .join("")
  : "";
const showBranchBodyExcerpt = Boolean(branchBodyExcerpt && branchBodyExcerpt !== branch?.summary);
---

<BaseLayout title={`${member.name} | 成员 | TGO 鲲鹏会`} description={`${member.company} · ${member.title}`}>
  <main class="page-shell page-stack">
    <section class="section member-profile-layout">
      <article class="panel member-profile-main">
        <div class="card-label">成员详情</div>
        <div class="member-profile-head">
          {
            member.avatar ? (
              <img class="member-profile-avatar" src={member.avatar.url} alt={member.avatar.alt} />
            ) : (
              <div class="member-profile-avatar member-profile-avatar-fallback" aria-hidden="true">
                {member.name.slice(0, 1)}
              </div>
            )
          }

          <div class="member-profile-copy">
            <h1>{member.name}</h1>
            <p>{member.company} · {member.title}</p>
            <ul class="meta-list member-profile-meta">
              <li>{member.branch?.name ?? "成员"}</li>
              <li>{member.branch?.cityName ?? "城市待补充"}</li>
              <li>{formatDate(member.joinedAt)}</li>
            </ul>
          </div>
        </div>

        <div class="member-profile-body">
          <div class="card-label">个人简介</div>
          <p>{member.bio}</p>
        </div>
      </article>

      <aside class="panel panel-soft member-profile-side">
        <div>
          <div class="card-label">成员档案</div>
          <ul class="member-profile-list">
            <li>
              <span>姓名</span>
              <strong>{member.name}</strong>
            </li>
            <li>
              <span>公司</span>
              <strong>{member.company}</strong>
            </li>
            <li>
              <span>职务</span>
              <strong>{member.title}</strong>
            </li>
            <li>
              <span>所属分会</span>
              <strong>{member.branch?.name ?? "待补充"}</strong>
            </li>
            <li>
              <span>加入时间</span>
              <strong>{formatDate(member.joinedAt)}</strong>
            </li>
          </ul>
        </div>

        <div class="member-profile-actions">
          {member.branch && <a class="button primary" href={`/branches#${member.branch.slug}`}>查看所属分会</a>}
          <a class="button secondary" href="/members">返回成员列表</a>
        </div>
      </aside>
    </section>

    {branch && (
      <section class="section">
        <div class="panel member-context-panel">
          <article class="member-context-branch">
            <div class="card-label">所属分会</div>
            <h2>{branch.name}</h2>

            {
              branch.coverImage && (
                <figure class="member-branch-figure">
                  <img class="member-branch-image" src={branch.coverImage.url} alt={branch.coverImage.alt} loading="lazy" />
                </figure>
              )
            }

            <p>{branch.summary}</p>
            {showBranchBodyExcerpt && <p>{branchBodyExcerpt}</p>}

            <div class="member-branch-footer">
              <span class="member-branch-chip">{branch.cityName}</span>
              <a class="text-link" href={`/branches#${branch.slug}`}>查看分会董事会</a>
            </div>
          </article>

          <aside class="member-context-board">
            <div>
              <div class="card-label">分会董事会</div>
              <h2>{branch.name}董事会成员</h2>
            </div>

            <div class="member-board-list">
              {
                branch.boardMembers.slice(0, 4).map((boardMember) => (
                  <article class="member-board-card">
                    <div class="member-board-head">
                      {
                        boardMember.avatar ? (
                          <img
                            class="member-board-avatar"
                            src={boardMember.avatar.url}
                            alt={boardMember.avatar.alt}
                            loading="lazy"
                          />
                        ) : (
                          <div class="member-board-avatar member-board-avatar-fallback" aria-hidden="true">
                            {boardMember.displayName.slice(0, 1)}
                          </div>
                        )
                      }

                      <div class="member-board-copy">
                        <strong>{boardMember.displayName}</strong>
                        <span>{boardMember.title}</span>
                        <small>{boardMember.company}</small>
                      </div>
                    </div>
                  </article>
                ))
              }
            </div>
          </aside>
        </div>
      </section>
    )}
  </main>
</BaseLayout>

<style>
  .member-profile-layout {
    display: grid;
    gap: 20px;
    grid-template-columns: minmax(0, 1.2fr) minmax(300px, 0.8fr);
    align-items: start;
  }

  .member-profile-main,
  .member-profile-side,
  .member-context-panel,
  .member-context-branch,
  .member-context-board {
    display: grid;
    gap: 20px;
  }

  .member-profile-head {
    display: grid;
    gap: 20px;
    grid-template-columns: 132px minmax(0, 1fr);
    align-items: start;
  }

  .member-profile-avatar {
    width: 132px;
    height: 132px;
    border-radius: 32px;
    object-fit: cover;
    box-shadow: 0 18px 36px rgba(40, 28, 18, 0.14);
  }

  .member-profile-avatar-fallback {
    display: grid;
    place-items: center;
    background: linear-gradient(135deg, rgba(200, 161, 93, 0.94), rgba(157, 111, 49, 0.94));
    color: #fff7ef;
    font-family: var(--font-display);
    font-size: 2.4rem;
  }

  .member-profile-copy h1 {
    margin: 0 0 8px;
    font-size: clamp(1.8rem, 3vw, 2.5rem);
  }

  .member-profile-copy p,
  .member-profile-body p {
    margin: 0;
    color: var(--muted);
    line-height: 1.85;
  }

  .member-profile-meta {
    margin-top: 14px;
  }

  .member-profile-body {
    display: grid;
    gap: 12px;
  }

  .member-profile-body p:first-of-type {
    color: var(--ink);
  }

  .member-profile-list {
    display: grid;
    gap: 12px;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .member-profile-list li {
    display: grid;
    gap: 6px;
    padding: 14px 16px;
    border-radius: 18px;
    border: 1px solid rgba(31, 26, 23, 0.08);
    background: rgba(255, 255, 255, 0.6);
  }

  .member-profile-list span {
    color: var(--muted);
    font-size: 0.86rem;
  }

  .member-profile-actions {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }

  .member-context-panel {
    grid-template-columns: minmax(0, 0.98fr) minmax(0, 1.02fr);
    align-items: start;
    background: linear-gradient(180deg, rgba(255, 252, 246, 0.96), rgba(247, 239, 229, 0.94));
  }

  .member-context-branch,
  .member-context-board {
    min-height: 100%;
  }

  .member-context-branch h2,
  .member-context-board h2 {
    margin: 0;
    font-size: clamp(1.45rem, 2.4vw, 2rem);
  }

  .member-context-branch p {
    margin: 0;
    line-height: 1.82;
  }

  .member-branch-figure {
    margin: 0;
  }

  .member-branch-image {
    display: block;
    width: 100%;
    aspect-ratio: 16 / 9;
    border-radius: 24px;
    object-fit: cover;
    box-shadow: 0 18px 36px rgba(40, 28, 18, 0.12);
  }

  .member-branch-footer {
    display: flex;
    gap: 14px;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
  }

  .member-branch-chip {
    display: inline-flex;
    align-items: center;
    min-height: 36px;
    padding: 0 14px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.76);
    border: 1px solid rgba(31, 26, 23, 0.08);
    color: var(--accent-ink);
    font-weight: 600;
  }

  .member-board-list {
    display: grid;
    gap: 12px;
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .member-board-card {
    display: block;
    padding: 14px 16px;
    border-radius: 18px;
    border: 1px solid rgba(31, 26, 23, 0.08);
    background: rgba(255, 255, 255, 0.66);
  }

  .member-board-head {
    display: grid;
    gap: 12px;
    grid-template-columns: 52px minmax(0, 1fr);
    align-items: start;
  }

  .member-board-avatar {
    width: 52px;
    height: 52px;
    border-radius: 16px;
    object-fit: cover;
    background: rgba(31, 26, 23, 0.08);
  }

  .member-board-avatar-fallback {
    display: grid;
    place-items: center;
    background: linear-gradient(135deg, rgba(200, 161, 93, 0.94), rgba(157, 111, 49, 0.94));
    color: #fff7ef;
    font-family: var(--font-display);
    font-size: 1.2rem;
  }

  .member-board-copy {
    display: grid;
    gap: 4px;
  }

  .member-board-card span,
  .member-board-card small {
    color: var(--muted);
    line-height: 1.6;
  }

  .member-board-card small {
    display: -webkit-box;
    overflow: hidden;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
  }

  @media (max-width: 900px) {
    .member-profile-layout,
    .member-context-panel {
      grid-template-columns: 1fr;
    }

    .member-board-list {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 640px) {
    .member-profile-head {
      grid-template-columns: 1fr;
    }

    .member-profile-avatar,
    .member-profile-avatar-fallback {
      width: 112px;
      height: 112px;
      border-radius: 28px;
    }
  }
</style>
