---
import BaseLayout from "../layouts/BaseLayout.astro";
import { listPublicEditorialArticles } from "../lib/editorial-order";
import { formatDate, formatDateRange } from "../lib/format";
import { getHomePayload, listMembers } from "../lib/public-api";

const [home, members] = await Promise.all([getHomePayload(), listMembers()]);

const pickFeaturedMembers = () => {
  const featured = [] as typeof members;
  const usedCities = new Set<string>();

  for (const member of members) {
    const cityName = member.branch?.cityName ?? "";
    const hasRichProfile = member.company !== "暂未公开" || member.title !== "成员";

    if (!hasRichProfile || !cityName || usedCities.has(cityName)) {
      continue;
    }

    featured.push(member);
    usedCities.add(cityName);

    if (featured.length >= 3) {
      return featured;
    }
  }

  for (const member of members) {
    if (featured.find((item) => item.slug === member.slug)) {
      continue;
    }

    featured.push(member);

    if (featured.length >= 3) {
      break;
    }
  }

  return featured;
};

const featuredMembers = pickFeaturedMembers();
const featuredArticles = listPublicEditorialArticles(home.featuredArticles).slice(0, 3);

const introSignals = [
  {
    title: "组织形式",
    body: "采用学员共建、分会运营的方式，由各地董事会成员与工作人员共同维护长期社区节奏。"
  },
  {
    title: "覆盖人群",
    body: "主要面向 CTO、技术 VP、研发负责人、架构负责人和技术创业者等科技领导者。"
  },
  {
    title: "活动方式",
    body: "围绕私密小组、公开学习、企业参访、专题研讨与峰会交流等形式持续发生。"
  }
];

const testimonialFallbacks: Record<string, string> = {
  "zhou-yang": "真正有价值的，不是一场活动结束时的热闹，而是之后还能继续讨论那些没有标准答案的管理问题。",
  "lin-wen": "当你长期和一群做过复杂业务、复杂组织的人交流，很多判断会更稳，很多问题也会更快看到第二种解法。",
  "shen-lan": "社区最难得的地方，是大家愿意把真实经验、真实代价和真实犹豫拿出来讨论，而不是只讲结果。"
};
const testimonialFallbackRotation = [
  "真正有价值的，不是一场活动结束时的热闹，而是之后还能继续讨论那些没有标准答案的管理问题。",
  "当你长期和一群做过复杂业务、复杂组织的人交流，很多判断会更稳，很多问题也会更快看到第二种解法。",
  "社区最难得的地方，是大家愿意把真实经验、真实代价和真实犹豫拿出来讨论，而不是只讲结果。"
];

const featuredTestimonials = featuredMembers.map((member, index) => ({
  ...member,
  quote:
    testimonialFallbacks[member.slug] ??
    testimonialFallbackRotation[index % testimonialFallbackRotation.length]
}));
const [featuredTestimonial, ...secondaryTestimonials] = featuredTestimonials;
const [featuredEvent, ...secondaryEvents] = home.featuredEvents;
const [featuredArticle, ...secondaryArticles] = featuredArticles;

const joinPanels = [
  {
    title: "加入条件",
    items: [
      "具备明确的技术管理职责，并愿意长期参与高质量交流。",
      "在技术战略、研发管理、架构演进或组织建设方向有真实实践。",
      "认可分享、互助、长期建设与同侪信任的社区价值。"
    ]
  },
  {
    title: "加入流程",
    items: ["在线申请", "工作人员联系", "进一步沟通", "审核确认"]
  }
];

const eventFallbackImages = [
  "/imports/tgo-infoq/branches/banners/shanghai.png",
  "/official/about/y2.c99b8704.png",
  "/imports/tgo-infoq/branches/banners/beijing.png"
];

const heroImage = {
  src: "/official/about/11.a131a302.jpg",
  alt: "TGO 鲲鹏会活动现场"
};
---

<BaseLayout title="TGO 鲲鹏会 | 首页" description="TGO 鲲鹏会面向技术领导者，展示组织介绍、成员推荐、学习活动与加入路径。">
  <main class="page-shell page-stack home-official-shell">
    <section class="home-official-hero">
      <article class="panel home-official-hero-stage">
        <div class="home-official-hero-grid">
          <div class="home-official-hero-copy">
            <p class="home-official-kicker">TGO 鲲鹏会</p>
            <h1>科技领导者的长期学习与交流社区</h1>
            <p class="home-official-summary">{home.hero.summary}</p>

            <div class="hero-actions">
              {
                home.hero.actions.map((action, index) => (
                  <a class:list={["button", index === 0 ? "primary" : "secondary"]} href={action.href}>
                    {action.label}
                  </a>
                ))
              }
            </div>
          </div>

          <div class="home-official-hero-visual">
            <figure class="home-official-hero-image">
              <img src={heroImage.src} alt={heroImage.alt} loading="eager" />
              <figcaption>GTLC 峰会现场</figcaption>
            </figure>
          </div>
        </div>

        <div class="home-official-context-grid">
          <article class="home-official-intro-copy">
            <p class="home-official-intro-label">组织介绍</p>
            <p class="home-official-intro-lead">{home.intro.summary}</p>
            <p>由各地分会、董事会成员与工作人员共同维护公开活动、成员连接与长期社区节奏。</p>
          </article>

          <div class="home-official-signal-grid">
            {
              introSignals.map((item) => (
                <article class="home-official-signal-card">
                  <h3>{item.title}</h3>
                  <p>{item.body}</p>
                </article>
              ))
            }
          </div>
        </div>
      </article>
    </section>

    <section class="section">
      <div class="section-head section-head-stack home-official-section-head">
        <div>
          <p class="home-official-kicker">成员推荐</p>
          <h2>成员的真实反馈，是社区最好的介绍</h2>
        </div>
        <a class="text-link home-official-text-link" href="/members">查看成员列表</a>
      </div>

      <div class="home-official-showcase-grid home-official-testimonial-grid">
        {
          featuredTestimonial && (
            <article class="panel home-official-testimonial-card is-featured">
              <p class="home-official-testimonial-quote">“{featuredTestimonial.quote}”</p>

              <div class="home-official-testimonial-meta">
                <strong>{featuredTestimonial.name}</strong>
                <span>
                  {featuredTestimonial.company}
                  {featuredTestimonial.title ? ` · ${featuredTestimonial.title}` : ""}
                </span>
                <small>{featuredTestimonial.branch?.name ?? "TGO 鲲鹏会成员"}</small>
              </div>
            </article>
          )
        }

        {
          secondaryTestimonials.length > 0 && (
            <div class="home-official-side-stack">
              {secondaryTestimonials.map((member) => (
                <article class="panel home-official-testimonial-card">
                  <p class="home-official-testimonial-quote">“{member.quote}”</p>

                  <div class="home-official-testimonial-meta">
                    <strong>{member.name}</strong>
                    <span>
                      {member.company}
                      {member.title ? ` · ${member.title}` : ""}
                    </span>
                    <small>{member.branch?.name ?? "TGO 鲲鹏会成员"}</small>
                  </div>
                </article>
              ))}
            </div>
          )
        }
      </div>
    </section>

    <section class="section">
      <div class="section-head section-head-stack home-official-section-head">
        <div>
          <p class="home-official-kicker">活动</p>
          <h2>近期公开活动</h2>
        </div>
        <a class="text-link home-official-text-link" href="/events">浏览活动</a>
      </div>

      <div class="home-official-showcase-grid home-official-event-grid">
        {
          featuredEvent && (
            <a class="home-official-card-link home-official-event-link is-featured" href={`/events/${featuredEvent.slug}`}>
              <article class="panel home-official-event-card is-featured">
                <img
                  class="home-official-event-image"
                  src={featuredEvent.coverImage?.url ?? eventFallbackImages[0]}
                  alt={featuredEvent.coverImage?.alt ?? featuredEvent.title}
                  loading="eager"
                />

                <div class="home-official-event-copy">
                  <div class="home-official-event-meta">
                    <span>{featuredEvent.cityName}</span>
                    <span>{formatDateRange(featuredEvent.startsAt, featuredEvent.endsAt)}</span>
                  </div>
                  <h3>{featuredEvent.title}</h3>
                  <p>{featuredEvent.summary}</p>
                </div>
              </article>
            </a>
          )
        }

        {
          secondaryEvents.length > 0 && (
            <div class="home-official-side-stack home-official-event-stack">
              {secondaryEvents.map((event, index) => (
                <a class="home-official-card-link home-official-event-link" href={`/events/${event.slug}`}>
                  <article class="panel home-official-event-card">
                    <img
                      class="home-official-event-image"
                      src={event.coverImage?.url ?? eventFallbackImages[(index + 1) % eventFallbackImages.length]}
                      alt={event.coverImage?.alt ?? event.title}
                      loading="eager"
                    />

                    <div class="home-official-event-copy">
                      <div class="home-official-event-meta">
                        <span>{event.cityName}</span>
                        <span>{formatDateRange(event.startsAt, event.endsAt)}</span>
                      </div>
                      <h3>{event.title}</h3>
                      <p>{event.summary}</p>
                    </div>
                  </article>
                </a>
              ))}
            </div>
          )
        }
      </div>
    </section>

    <section class="section">
      <div class="section-head section-head-stack home-official-section-head">
        <div>
          <p class="home-official-kicker">文章</p>
          <h2>技术管理与组织实践沉淀</h2>
        </div>
        <a class="text-link home-official-text-link" href="/articles">查看文章</a>
      </div>

      <div class="home-official-showcase-grid home-official-article-layout">
        {
          featuredArticle && (
            <a class="home-official-card-link home-official-featured-article-link" href={`/articles/${featuredArticle.slug}`}>
              <article class="panel home-official-featured-article">
                <div class="home-official-article-meta">
                  <span>{formatDate(featuredArticle.publishedAt)}</span>
                  <span>{featuredArticle.authorName}</span>
                </div>

                <div class="home-official-featured-article-copy">
                  <h3>{featuredArticle.title}</h3>
                  <p>{featuredArticle.excerpt}</p>
                </div>
              </article>
            </a>
          )
        }

        {
          secondaryArticles.length > 0 && (
            <div class="home-official-side-stack home-official-article-list">
              {secondaryArticles.map((article) => (
                <a class="home-official-card-link" href={`/articles/${article.slug}`}>
                  <article class="panel home-official-article-item is-compact">
                    <div class="home-official-article-meta">
                      <span>{formatDate(article.publishedAt)}</span>
                      <span>{article.authorName}</span>
                    </div>

                    <div class="home-official-article-copy">
                      <h3>{article.title}</h3>
                      <p>{article.excerpt}</p>
                    </div>
                  </article>
                </a>
              ))}
            </div>
          )
        }
      </div>
    </section>

    <section class="section">
      <div class="panel home-official-join-card">
        <div class="section-head section-head-stack home-official-section-head home-official-join-head">
          <div>
            <p class="home-official-kicker">加入申请</p>
            <h2>适合愿意长期参与社区交流的技术领导者</h2>
            <p class="card-copy">{home.joinCallout.summary}</p>
          </div>
          <a class="button primary" href={home.joinCallout.href}>查看加入方式</a>
        </div>

        <div class="home-official-join-grid">
          {
            joinPanels.map((panel) => (
              <article class="home-official-join-panel">
                <h3>{panel.title}</h3>
                {
                  panel.title === "加入流程" ? (
                    <ol>
                      {panel.items.map((item) => <li>{item}</li>)}
                    </ol>
                  ) : (
                    <ul>
                      {panel.items.map((item) => <li>{item}</li>)}
                    </ul>
                  )
                }
              </article>
            ))
          }
        </div>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .home-official-shell {
    padding-top: 16px;
    padding-bottom: 48px;
  }

  .home-official-hero {
    padding: 18px 0 10px;
  }

  .home-official-hero-stage {
    display: grid;
    gap: 26px;
    padding: clamp(26px, 3vw, 34px);
    background:
      radial-gradient(circle at top right, rgba(200, 161, 93, 0.12), transparent 22%),
      linear-gradient(180deg, rgba(255, 251, 244, 0.98), rgba(246, 239, 229, 0.96));
  }

  .home-official-hero-grid,
  .home-official-context-grid,
  .home-official-join-grid {
    display: grid;
    gap: 24px;
  }

  .home-official-hero-grid {
    grid-template-columns: minmax(0, 1fr) minmax(360px, 0.92fr);
    align-items: center;
  }

  .home-official-kicker,
  .home-official-event-meta,
  .home-official-article-meta {
    margin: 0 0 14px;
    color: var(--accent-strong);
    font-size: 0.82rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .home-official-section-head {
    margin-bottom: 18px;
  }

  .home-official-hero-copy h1,
  .home-official-section-head h2,
  .home-official-join-head h2 {
    margin: 0;
    font-family: var(--font-display);
    font-weight: 600;
    letter-spacing: 0.01em;
  }

  .home-official-hero-copy h1 {
    max-width: 11ch;
    font-size: clamp(2.8rem, 5.6vw, 4.8rem);
    line-height: 0.98;
  }

  .home-official-section-head h2,
  .home-official-join-head h2 {
    max-width: 18ch;
    font-size: clamp(1.8rem, 3vw, 2.8rem);
    line-height: 1.08;
  }

  .home-official-summary,
  .home-official-intro-copy p,
  .home-official-intro-lead,
  .home-official-signal-card p,
  .home-official-testimonial-quote,
  .home-official-event-copy p,
  .home-official-article-copy p,
  .home-official-join-panel li,
  .home-official-join-head .card-copy {
    margin: 0;
    color: var(--muted);
    line-height: 1.8;
  }

  .home-official-summary {
    max-width: 37rem;
    font-size: 1.08rem;
  }

  .home-official-hero-visual {
    min-width: 0;
  }

  .home-official-hero-image {
    margin: 0;
    position: relative;
    overflow: hidden;
    border-radius: 28px;
    box-shadow: 0 24px 50px rgba(35, 28, 21, 0.14);
  }

  .home-official-hero-image img {
    display: block;
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
  }

  .home-official-hero-image figcaption {
    position: absolute;
    left: 18px;
    bottom: 18px;
    margin: 0;
    padding: 9px 12px;
    border-radius: 999px;
    background: rgba(255, 252, 246, 0.88);
    border: 1px solid rgba(27, 23, 19, 0.08);
    color: var(--accent-strong);
    font-size: 0.76rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .home-official-context-grid {
    grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.1fr);
    align-items: start;
    padding-top: 22px;
    border-top: 1px solid rgba(27, 23, 19, 0.08);
  }

  .home-official-testimonial-card,
  .home-official-event-card,
  .home-official-featured-article,
  .home-official-article-item,
  .home-official-join-card,
  .home-official-join-panel {
    background: linear-gradient(180deg, rgba(255, 252, 246, 0.98), rgba(245, 238, 227, 0.92));
  }

  .home-official-intro-copy {
    display: grid;
    gap: 14px;
    padding: 0 10px 0 0;
  }

  .home-official-intro-label {
    margin: 0;
    color: var(--accent-strong);
    font-size: 0.82rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .home-official-intro-lead {
    color: var(--ink);
    font-size: 1.14rem;
    font-weight: 600;
    line-height: 1.74;
  }

  .home-official-signal-grid,
  .home-official-join-grid {
    display: grid;
    gap: 16px;
  }

  .home-official-showcase-grid,
  .home-official-side-stack {
    display: grid;
    gap: 18px;
  }

  .home-official-showcase-grid {
    grid-template-columns: minmax(0, 1.08fr) minmax(320px, 0.92fr);
    align-items: stretch;
  }

  .home-official-signal-grid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .home-official-signal-card {
    min-height: 100%;
    display: grid;
    gap: 10px;
    padding: 20px 18px;
    border-radius: 20px;
    border: 1px solid rgba(27, 23, 19, 0.08);
    background: rgba(255, 255, 255, 0.56);
  }

  .home-official-signal-card h3,
  .home-official-event-copy h3,
  .home-official-article-copy h3,
  .home-official-join-panel h3 {
    margin: 0 0 12px;
  }

  .home-official-text-link {
    font-weight: 500;
  }

  .home-official-testimonial-card {
    display: grid;
    gap: 18px;
    min-height: 100%;
    padding: 24px;
    background:
      radial-gradient(circle at top right, rgba(138, 106, 67, 0.08), transparent 28%),
      linear-gradient(180deg, rgba(255, 252, 246, 0.98), rgba(245, 238, 227, 0.92));
  }

  .home-official-testimonial-quote {
    position: relative;
    font-size: 1.02rem;
  }

  .home-official-testimonial-card.is-featured {
    padding: 28px;
    gap: 22px;
  }

  .home-official-testimonial-card.is-featured .home-official-testimonial-quote {
    font-size: 1.14rem;
    line-height: 1.88;
  }

  .home-official-testimonial-card.is-featured::before {
    content: "“";
    position: absolute;
    top: 14px;
    right: 24px;
    color: rgba(138, 106, 67, 0.18);
    font-family: var(--font-display);
    font-size: 5.2rem;
    line-height: 1;
  }

  .home-official-testimonial-meta {
    display: grid;
    gap: 4px;
  }

  .home-official-testimonial-meta span,
  .home-official-testimonial-meta small {
    color: var(--muted);
  }

  .home-official-card-link {
    display: block;
  }

  .home-official-event-link {
    min-width: 0;
  }

  .home-official-event-stack {
    align-content: start;
  }

  .home-official-event-card {
    display: grid;
    overflow: hidden;
    min-height: 100%;
    border-radius: 26px;
    transition: transform 180ms ease, box-shadow 180ms ease, border-color 180ms ease;
  }

  .home-official-card-link:hover .home-official-event-card,
  .home-official-card-link:hover .home-official-article-item,
  .home-official-card-link:hover .home-official-featured-article {
    transform: translateY(-2px);
    border-color: rgba(157, 111, 49, 0.18);
    box-shadow: 0 22px 48px rgba(40, 28, 18, 0.12);
  }

  .home-official-event-image {
    width: 100%;
    aspect-ratio: 16 / 10;
    object-fit: cover;
    background: rgba(255, 255, 255, 0.72);
  }

  .home-official-event-card.is-featured .home-official-event-image {
    aspect-ratio: 16 / 9;
  }

  .home-official-event-image-placeholder {
    background:
      linear-gradient(rgba(27, 23, 19, 0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(27, 23, 19, 0.04) 1px, transparent 1px),
      linear-gradient(180deg, rgba(255, 255, 255, 0.92), rgba(244, 236, 224, 0.9));
    background-size: 72px 72px, 72px 72px, auto;
  }

  .home-official-event-copy {
    display: grid;
    gap: 12px;
    padding: 20px;
  }

  .home-official-event-card.is-featured .home-official-event-copy {
    gap: 14px;
    padding: 24px;
  }

  .home-official-event-meta,
  .home-official-article-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    margin: 0;
    color: var(--muted);
    letter-spacing: 0.04em;
  }

  .home-official-event-card.is-featured .home-official-event-copy h3 {
    font-size: 1.42rem;
    line-height: 1.32;
  }

  .home-official-event-copy h3,
  .home-official-article-copy h3,
  .home-official-featured-article-copy h3 {
    line-height: 1.38;
  }

  .home-official-event-copy p {
    display: -webkit-box;
    overflow: hidden;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
  }

  .home-official-event-card.is-featured .home-official-event-copy p {
    display: -webkit-box;
    overflow: hidden;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 3;
  }

  .home-official-article-list {
    align-content: start;
  }

  .home-official-featured-article-link {
    min-width: 0;
  }

  .home-official-featured-article {
    display: grid;
    gap: 18px;
    min-height: 100%;
    padding: 28px;
    background:
      radial-gradient(circle at top right, rgba(138, 106, 67, 0.1), transparent 30%),
      linear-gradient(180deg, rgba(255, 251, 244, 0.98), rgba(246, 239, 229, 0.96));
    transition: transform 180ms ease, box-shadow 180ms ease, border-color 180ms ease;
  }

  .home-official-featured-article-copy {
    display: grid;
    gap: 14px;
    align-content: start;
  }

  .home-official-featured-article-copy h3 {
    margin: 0;
    font-size: clamp(1.56rem, 2.4vw, 2.08rem);
  }

  .home-official-featured-article-copy p,
  .home-official-article-item.is-compact .home-official-article-copy p {
    display: -webkit-box;
    overflow: hidden;
    -webkit-box-orient: vertical;
