---
import { platformName, publicModules } from "@tgo/shared";

import CollectionCard from "../components/CollectionCard.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { formatDate, formatDateRange, formatCount } from "../lib/format";
import { getHomePayload } from "../lib/public-api";

const home = await getHomePayload();
---

<BaseLayout
  title={`${platformName} | 首页`}
  description="基于 Astro 构建的 TGO Network 公开站 MVP，围绕主题、文章、活动与城市内容组织。"
>
  <main class="page-shell page-stack">
    <section class="hero">
      <div class="hero-card hero-split">
        <div>
          <span class="eyebrow">{home.hero.eyebrow}</span>
          <h1>{home.hero.title}</h1>
          <p>{home.hero.summary}</p>

          <div class="hero-actions">
            {
              home.hero.actions.map((action, index) => (
                <a class:list={["button", index === 0 ? "primary" : "secondary"]} href={action.href}>
                  {action.label}
                </a>
              ))
            }
          </div>
        </div>

        <aside class="hero-aside panel panel-soft">
          <div class="card-label">当前范围</div>
          <h2 class="card-title">公开路由已经具备真实的列表与详情结构。</h2>
          <p class="card-copy">
            站点在 API 可用时可以直接渲染服务端数据；本地静态构建时，也仍然能够回退到共享演示数据。
          </p>
          <ul class="meta-list">
            <li>主题、文章、活动与城市页面</li>
            <li>API 与 Astro 共享 DTO 契约</li>
            <li>申请表单契约已具备校验能力</li>
          </ul>
        </aside>
      </div>
    </section>

    <section class="section">
      <div class="section-head">
        <div>
          <div class="card-label">精选主题</div>
          <h2>组织首个版本内容结构的核心主题</h2>
        </div>
        <a class="text-link" href="/topics">查看全部主题</a>
      </div>

      <div class="grid grid-3">
        {
          home.featuredTopics.map((topic) => (
            <CollectionCard
              href={`/topics/${topic.slug}`}
              label={formatCount(topic.articleCount, "篇文章")}
              title={topic.title}
              summary={topic.summary}
              image={topic.coverImage}
              meta={[formatCount(topic.eventCount, "场关联活动")]}
            />
          ))
        }
      </div>
    </section>

    <section class="section">
      <div class="section-head">
        <div>
          <div class="card-label">最新文章</div>
          <h2>已经可以面向公众浏览的长内容</h2>
        </div>
        <a class="text-link" href="/articles">浏览文章</a>
      </div>

      <div class="grid grid-3">
        {
          home.featuredArticles.map((article) => (
            <CollectionCard
              href={`/articles/${article.slug}`}
              label={formatDate(article.publishedAt)}
              title={article.title}
              summary={article.excerpt}
              image={article.coverImage}
              meta={[article.authorName, article.city.name]}
            />
          ))
        }
      </div>
    </section>

    <section class="section">
      <div class="section-head">
        <div>
          <div class="card-label">近期活动</div>
          <h2>可感知报名状态的活动页面</h2>
        </div>
        <a class="text-link" href="/events">查看活动</a>
      </div>

      <div class="grid grid-3">
        {
          home.upcomingEvents.map((event) => (
            <CollectionCard
              href={`/events/${event.slug}`}
              label={event.city.name}
              title={event.title}
              summary={event.summary}
              image={event.coverImage}
              meta={[formatDateRange(event.startsAt, event.endsAt), event.venueName]}
            />
          ))
        }
      </div>
    </section>

    <section class="section">
      <div class="section-head">
        <div>
          <div class="card-label">城市亮点</div>
          <h2>每座城市都会汇总活动、主题与文章</h2>
        </div>
        <a class="text-link" href="/cities">进入城市页面</a>
      </div>

      <div class="grid grid-3">
        {
          home.cityHighlights.map((city) => (
            <CollectionCard
              href={`/cities/${city.slug}`}
              label={formatCount(city.topicCount, "个主题")}
              title={city.name}
              summary={city.summary}
              image={city.coverImage}
              meta={[formatCount(city.articleCount, "篇文章"), formatCount(city.eventCount, "场活动")]}
            />
          ))
        }
      </div>
    </section>

    <section class="section">
      <div class="panel promo-panel">
        <div>
          <div class="card-label">申请流程</div>
          <h2>{home.applicationCallout.title}</h2>
          <p class="card-copy">{home.applicationCallout.summary}</p>
        </div>
        <a class="button primary" href={home.applicationCallout.href}>打开申请表</a>
      </div>
    </section>

    <section class="section">
      <div class="section-head">
        <div>
          <div class="card-label">实现形态</div>
          <h2>公开体验坚持静态优先，但不是写死的数据页面。</h2>
        </div>
      </div>

      <div class="grid grid-3">
        {
          publicModules.map((module) => (
            <article class="panel">
              <div class="card-label">{module.phase}</div>
              <h3 class="card-title">{module.name}</h3>
              <p class="card-copy">{module.summary}</p>
            </article>
          ))
        }
      </div>
    </section>
  </main>
</BaseLayout>
