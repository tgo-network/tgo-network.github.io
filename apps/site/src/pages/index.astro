---
import CollectionCard from "../components/CollectionCard.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { listPublicEditorialArticles } from "../lib/editorial-order";
import { formatDate, formatDateRange } from "../lib/format";
import { getHomePayload, listMembers } from "../lib/public-api";

const [home, members] = await Promise.all([getHomePayload(), listMembers()]);

const pickFeaturedMembers = () => {
  const featured = [] as typeof members;
  const usedCities = new Set<string>();

  for (const member of members) {
    const cityName = member.branch?.cityName ?? "";
    const hasRichProfile = member.company !== "暂未公开" || member.title !== "成员";

    if (!hasRichProfile || !cityName || usedCities.has(cityName)) {
      continue;
    }

    featured.push(member);
    usedCities.add(cityName);

    if (featured.length >= 3) {
      return featured;
    }
  }

  for (const member of members) {
    if (featured.find((item) => item.slug === member.slug)) {
      continue;
    }

    featured.push(member);

    if (featured.length >= 3) {
      break;
    }
  }

  return featured;
};

const featuredMembers = pickFeaturedMembers();
const featuredArticles = listPublicEditorialArticles(home.featuredArticles).slice(0, 3);

const heroContent = {
  titleLines: ["面向科技领导者的", "高质量学习社区"],
  summary: "TGO 鲲鹏会聚焦有技术背景的科技领导者，通过闭门讨论、公开学习与跨城交流，建立长期稳定的同行网络。",
  supportingCopy: "围绕技术决策、组织管理与业务协同等真实议题，形成可持续的学习、交流与经验连接。"
};

const heroAudienceRoles = ["CTO", "技术 VP", "研发负责人", "技术创业者"];

const heroSupportCards = [
  {
    label: "适合谁加入",
    title: "科技领导者与技术创业者",
    summary: "面向 CTO、技术 VP、研发负责人，以及具备技术背景的创业者。"
  },
  {
    label: "组织形式",
    title: "小组活动与闭门交流",
    summary: "围绕真实议题进行小范围讨论，沉淀更有判断力的经验与反馈。"
  },
  {
    label: "公开学习",
    title: "跨城活动连接行业经验",
    summary: "通过专题分享、月度活动与城市联动扩展组织视野。"
  }
];

const heroContextItems = [
  {
    label: "闭门交流",
    summary: "围绕真实议题进行更深入的讨论与反馈。"
  },
  {
    label: "跨城活动",
    summary: "持续连接不同城市与行业的一线经验。"
  },
  {
    label: "长期同行",
    summary: "建立稳定、可信、可复用的同侪关系。"
  }
];

const testimonialFallbacks: Record<string, string> = {
  "zhou-yang": "能长期和一线技术管理者交流，很多组织与平台建设问题都更快找到参照系。",
  "lin-wen": "相比一次性的大会曝光，我更看重能持续讨论真实问题、彼此长期反馈的同侪关系。",
  "shen-lan": "无论是工程效率、团队协作还是业务落地，社区交流都能让经验回到更大的视角中重新理解。"
};

const featuredTestimonials = featuredMembers.map((member) => ({
  ...member,
  quote:
    testimonialFallbacks[member.slug] ??
    "可以和真正处在一线的技术管理者持续交流，获得长期稳定的同行反馈。"
}));

const joinSteps = [
  {
    step: "01",
    title: "了解组织定位与加入条件",
    summary: "阅读加入条件、参与方式与审核流程。"
  },
  {
    step: "02",
    title: "在线提交申请信息",
    summary: "填写姓名、电话、微信、邮箱和个人介绍。"
  },
  {
    step: "03",
    title: "等待审核与进一步联系",
    summary: "提交后由工作人员审核，并在需要时进一步联系。"
  }
];
---

<BaseLayout title="TGO 鲲鹏会 | 首页" description="TGO 鲲鹏会面向技术领导者，展示组织介绍、成员推荐、学习活动与加入路径。">
  <main class="page-shell page-stack">
    <section class="hero hero-home">
      <div class="hero-card hero-home-card">
        <div class="hero-home-main">
          <span class="eyebrow">{home.hero.eyebrow}</span>
          <h1 aria-label={heroContent.titleLines.join("")}>
            {heroContent.titleLines.map((line) => <span class="hero-title-line">{line}</span>)}
          </h1>
          <div class="hero-copy-block">
            <p class="hero-summary">{heroContent.summary}</p>
            <p class="hero-supporting-copy">{heroContent.supportingCopy}</p>
          </div>

          <div class="hero-actions">
            {
              home.hero.actions.map((action, index) => (
                <a class:list={["button", index === 0 ? "primary" : "secondary"]} href={action.href}>
                  {action.label}
                </a>
              ))
            }
          </div>

          <div class="hero-context-grid" aria-label="社区特点">
            {
              heroContextItems.map((item) => (
                <article class="hero-context-card">
                  <div class="hero-context-label">{item.label}</div>
                  <p>{item.summary}</p>
                </article>
              ))
            }
          </div>
        </div>

        <aside class="hero-home-aside">
          {
            heroSupportCards.map((item, index) => (
              <article class:list={["hero-support-card", index === 0 && "hero-support-card-accent"]}>
                <div class="card-label card-label-on-dark">{item.label}</div>
                <h3 class="hero-support-title">{item.title}</h3>
                {index === 0 ? (
                  <div class="hero-role-grid" aria-label="适合加入的角色">
                    {heroAudienceRoles.map((role) => <span class="hero-role-chip">{role}</span>)}
                  </div>
                ) : null}
                <p class="hero-aside-copy">{item.summary}</p>
              </article>
            ))
          }
        </aside>
      </div>
    </section>

    <section class="section">
      <div class="section-head section-head-stack">
        <div>
          <div class="card-label">成员推荐</div>
          <h2>成员推荐</h2>
        </div>
        <a class="text-link" href="/members">查看成员列表</a>
      </div>

      <div class="testimonial-grid">
        {
          featuredTestimonials.map((member) => (
            <article class="panel testimonial-card">
              <p class="testimonial-quote">“{member.quote}”</p>

              <div class="testimonial-member">
                {
                  member.avatar ? (
                    <img class="testimonial-avatar" src={member.avatar.url} alt={member.avatar.alt} loading="lazy" />
                  ) : (
                    <div class="testimonial-avatar testimonial-avatar-fallback" aria-hidden="true">
                      {member.name.slice(0, 1)}
                    </div>
                  )
                }

                <div class="testimonial-copy">
                  <strong>{member.name}</strong>
                  <span>{member.company}</span>
                  <small>
                    {member.title}
                    {member.branch ? ` · ${member.branch.name}` : ""}
                  </small>
                </div>
              </div>
            </article>
          ))
        }
      </div>
    </section>

    <section class="section">
      <div class="panel collection-showcase collection-showcase-events">
        <div class="section-head section-head-stack collection-showcase-head">
          <div>
            <div class="card-label">近期活动</div>
            <h2>近期活动</h2>
          </div>
          <a class="text-link" href="/events">浏览活动</a>
        </div>

        <div class="grid grid-3">
          {
            home.featuredEvents.map((event) => (
              <CollectionCard
                href={`/events/${event.slug}`}
                label={event.cityName}
                title={event.title}
                summary={event.summary}
                image={event.coverImage}
                meta={[formatDateRange(event.startsAt, event.endsAt), event.venueName]}
              />
            ))
          }
        </div>
      </div>
    </section>

    <section class="section">
      <div class="panel collection-showcase collection-showcase-articles">
        <div class="section-head section-head-stack collection-showcase-head">
          <div>
            <div class="card-label">文章</div>
            <h2>文章</h2>
          </div>
          <a class="text-link" href="/articles">查看文章</a>
        </div>

        <div class="grid grid-3">
          {
            featuredArticles.map((article) => (
              <CollectionCard
                href={`/articles/${article.slug}`}
                label={formatDate(article.publishedAt)}
                title={article.title}
                summary={article.excerpt}
                image={article.coverImage}
                meta={[article.authorName, "社区文章"]}
              />
            ))
          }
        </div>
      </div>
    </section>

    <section class="section">
      <div class="panel join-panel">
        <div class="join-panel-head">
          <div>
            <div class="card-label">加入申请</div>
            <h2>{home.joinCallout.title}</h2>
            <p class="card-copy">{home.joinCallout.summary}</p>
          </div>
          <a class="button primary" href={home.joinCallout.href}>开始申请</a>
        </div>

        <div class="join-step-grid">
          {
            joinSteps.map((item) => (
              <article class="join-step-card">
                <div class="join-step-index">{item.step}</div>
                <h3>{item.title}</h3>
                <p>{item.summary}</p>
              </article>
            ))
          }
        </div>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .hero-home-card {
    display: grid;
    gap: 20px;
    grid-template-columns: minmax(0, 1.34fr) minmax(280px, 0.66fr);
    padding: clamp(28px, 4vw, 42px);
    background:
      radial-gradient(circle at top right, rgba(215, 179, 117, 0.2), transparent 26%),
      linear-gradient(135deg, #111313 0%, #181714 44%, #231d17 100%);
    border-color: rgba(215, 179, 117, 0.18);
    box-shadow: 0 36px 90px rgba(18, 13, 9, 0.28);
    color: #f7efe3;
    overflow: hidden;
  }

  .hero-home-card :global(.button.secondary) {
    border-color: rgba(255, 255, 255, 0.14);
    background: rgba(255, 255, 255, 0.08);
    color: #f8f1e8;
  }

  .hero-home-card .eyebrow {
    color: #f1d5a0;
    border-color: rgba(215, 179, 117, 0.28);
    background: rgba(255, 255, 255, 0.06);
  }

  .hero-home-card h1 {
    width: min(100%, 9.4em);
    max-width: none;
    margin: 18px 0 14px;
    font-size: clamp(2.45rem, 5.2vw, 4.3rem);
    line-height: 0.98;
  }

  .hero-title-line {
    display: block;
  }

  .hero-title-line + .hero-title-line {
    margin-top: 0.12em;
  }

  .hero-summary {
    margin: 0;
    max-width: 28em;
    color: rgba(247, 239, 227, 0.82);
    font-size: 1rem;
    line-height: 1.78;
  }

  .hero-copy-block {
    display: grid;
    gap: 10px;
  }

  .hero-supporting-copy {
    margin: 0;
    max-width: 32em;
    color: rgba(247, 239, 227, 0.68);
    line-height: 1.72;
  }

  .hero-home-aside {
    display: grid;
    gap: 16px;
    align-self: start;
    padding: 20px;
    border-radius: 24px;
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.08), rgba(255, 255, 255, 0.04));
    border: 1px solid rgba(215, 179, 117, 0.16);
  }

  .join-step-card {
    display: grid;
    gap: 10px;
  }

  .hero-support-card {
    display: grid;
    gap: 10px;
    padding: 18px 18px 16px;
    border-radius: 20px;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(215, 179, 117, 0.1);
  }

  .hero-support-card-accent {
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.08), rgba(255, 255, 255, 0.04));
    border-color: rgba(215, 179, 117, 0.16);
  }

  .hero-support-title {
    margin: 6px 0 0;
    font-size: clamp(1.35rem, 2vw, 1.72rem);
    color: #fff7ee;
    line-height: 1.35;
  }

  .join-step-grid,
  .testimonial-grid {
    display: grid;
    gap: 14px;
  }

  .hero-context-grid {
    display: grid;
    gap: 12px;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    margin-top: 22px;
  }

  .hero-context-card {
    display: grid;
    gap: 8px;
    padding: 14px 16px;
    border-radius: 18px;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(215, 179, 117, 0.1);
  }

  .hero-context-label {
    color: #f1d5a0;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .hero-context-card p {
    margin: 0;
    color: rgba(247, 239, 227, 0.74);
    line-height: 1.68;
    font-size: 0.94rem;
  }

  .hero-role-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .hero-role-chip {
    display: inline-flex;
    padding: 9px 12px;
    border-radius: 999px;
    border: 1px solid rgba(215, 179, 117, 0.16);
    background: rgba(255, 255, 255, 0.06);
    color: rgba(247, 239, 227, 0.86);
    font-size: 0.92rem;
    line-height: 1;
  }

  .hero-aside-copy {
    margin: 0;
    color: rgba(247, 239, 227, 0.76);
    line-height: 1.72;
  }

  .join-step-index {
    color: rgba(215, 179, 117, 0.9);
    font-size: 0.78rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .join-step-card p {
    margin: 0;
    color: rgba(247, 239, 227, 0.72);
    line-height: 1.7;
  }

  .join-step-card h3 {
    margin: 0;
  }

  .testimonial-quote,
  .join-panel-head h2 {
    margin: 0;
  }

  .testimonial-grid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .testimonial-card {
    display: grid;
    gap: 22px;
    min-height: 100%;
    background: linear-gradient(180deg, rgba(255, 250, 244, 0.96), rgba(246, 238, 227, 0.94));
  }

  .testimonial-quote {
    color: var(--ink);
    font-family: var(--font-display);
    font-size: 1.34rem;
    line-height: 1.7;
  }

  .testimonial-member {
    display: flex;
    gap: 14px;
    align-items: center;
    margin-top: auto;
  }

  .testimonial-avatar {
    width: 64px;
    height: 64px;
    border-radius: 20px;
    object-fit: cover;
    flex: 0 0 auto;
    background: rgba(31, 26, 23, 0.08);
  }

  .testimonial-avatar-fallback {
    display: inline-grid;
    place-items: center;
    color: #fff7ef;
    background: linear-gradient(135deg, rgba(157, 111, 49, 0.95), rgba(200, 161, 93, 0.9));
    font-size: 1.15rem;
    font-weight: 700;
  }

  .testimonial-copy {
    display: grid;
    gap: 4px;
  }

  .testimonial-copy strong,
  .testimonial-copy span,
  .testimonial-copy small {
    line-height: 1.5;
  }

  .testimonial-copy span,
  .testimonial-copy small {
    color: var(--muted);
  }

  .collection-showcase {
    display: grid;
    gap: 18px;
    padding: 28px;
    border-radius: 30px;
  }

  .collection-showcase-head {
    margin-bottom: 0;
  }

  .collection-showcase-events {
    background:
      radial-gradient(circle at top right, rgba(215, 179, 117, 0.16), transparent 26%),
      linear-gradient(135deg, #171817 0%, #231d18 100%);
    border-color: rgba(215, 179, 117, 0.16);
    box-shadow: 0 32px 70px rgba(24, 16, 10, 0.18);
  }

  .collection-showcase-events .collection-showcase-head .card-label,
  .collection-showcase-events .collection-showcase-head .text-link,
  .collection-showcase-events .collection-showcase-head h2 {
    color: #fff7ef;
  }

  .collection-showcase-articles {
    background:
      radial-gradient(circle at top left, rgba(215, 179, 117, 0.1), transparent 22%),
      linear-gradient(180deg, rgba(255, 249, 239, 0.96), rgba(245, 237, 226, 0.94));
  }

  .join-panel {
    display: grid;
    gap: 20px;
    background: linear-gradient(180deg, rgba(255, 249, 239, 0.96), rgba(245, 237, 226, 0.94));
  }

  .join-panel-head {
    display: flex;
    gap: 18px;
    align-items: flex-end;
    justify-content: space-between;
  }

  .join-panel-head h2 {
    font-size: clamp(1.6rem, 3vw, 2.2rem);
  }

  .join-step-grid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .join-step-card {
    padding: 18px;
    border-radius: 22px;
    background: rgba(255, 255, 255, 0.72);
    border: 1px solid rgba(31, 26, 23, 0.08);
  }

  .join-step-card h3 {
    color: var(--ink);
    font-size: 1.05rem;
  }

  .join-step-card p {
    color: var(--muted);
  }

  @media (max-width: 1100px) {
    .join-step-grid,
    .testimonial-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .hero-context-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 900px) {
    .hero-home-card,
    .testimonial-grid {
      grid-template-columns: 1fr;
    }

    .join-panel-head {
      flex-direction: column;
      align-items: flex-start;
    }

    .collection-showcase {
      padding: 24px;
    }
  }

  @media (max-width: 720px) {
    .join-step-grid {
      grid-template-columns: 1fr;
    }

    .hero-context-grid {
      grid-template-columns: 1fr;
    }

    .hero-home-card h1 {
      width: min(100%, 8.2em);
    }

    .hero-support-card {
      padding: 16px;
    }

    .hero-role-chip {
      padding-inline: 11px;
      font-size: 0.88rem;
    }
  }
</style>
