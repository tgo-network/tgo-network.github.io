---
import { platformName, publicModules } from "@tgo/shared";

import CollectionCard from "../components/CollectionCard.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { formatDate, formatDateRange } from "../lib/format";
import { getHomePayload } from "../lib/public-api";

const home = await getHomePayload();
---

<BaseLayout
  title={`${platformName} | Public Site`}
  description="Astro-powered public MVP routes backed by the shared TGO public API contract."
>
  <main class="page-shell page-stack">
    <section class="hero">
      <div class="hero-card hero-split">
        <div>
          <span class="eyebrow">{home.hero.eyebrow}</span>
          <h1>{home.hero.title}</h1>
          <p>{home.hero.summary}</p>

          <div class="hero-actions">
            {
              home.hero.actions.map((action, index) => (
                <a class:list={["button", index === 0 ? "primary" : "secondary"]} href={action.href}>
                  {action.label}
                </a>
              ))
            }
          </div>
        </div>

        <aside class="hero-aside panel panel-soft">
          <div class="card-label">Current Scope</div>
          <h2 class="card-title">Public routes are now structured as real collections and details.</h2>
          <p class="card-copy">
            The site can render from the API when it is available, while still falling back to shared demo data for
            local static builds.
          </p>
          <ul class="meta-list">
            <li>Topics, articles, events, and cities</li>
            <li>Shared DTOs between API and Astro</li>
            <li>Application form contract ready for validation</li>
          </ul>
        </aside>
      </div>
    </section>

    <section class="section">
      <div class="section-head">
        <div>
          <div class="card-label">Featured Topics</div>
          <h2>Editorial themes that organize the first release</h2>
        </div>
        <a class="text-link" href="/topics">View all topics</a>
      </div>

      <div class="grid grid-3">
        {
          home.featuredTopics.map((topic) => (
            <CollectionCard
              href={`/topics/${topic.slug}`}
              label={`${topic.articleCount} articles`}
              title={topic.title}
              summary={topic.summary}
              image={topic.coverImage}
              meta={[`${topic.eventCount} linked events`]}
            />
          ))
        }
      </div>
    </section>

    <section class="section">
      <div class="section-head">
        <div>
          <div class="card-label">Latest Articles</div>
          <h2>Long-form content ready for public browsing</h2>
        </div>
        <a class="text-link" href="/articles">Browse articles</a>
      </div>

      <div class="grid grid-3">
        {
          home.featuredArticles.map((article) => (
            <CollectionCard
              href={`/articles/${article.slug}`}
              label={formatDate(article.publishedAt)}
              title={article.title}
              summary={article.excerpt}
              image={article.coverImage}
              meta={[article.authorName, article.city.name]}
            />
          ))
        }
      </div>
    </section>

    <section class="section">
      <div class="section-head">
        <div>
          <div class="card-label">Upcoming Events</div>
          <h2>Registration-aware event pages</h2>
        </div>
        <a class="text-link" href="/events">View events</a>
      </div>

      <div class="grid grid-3">
        {
          home.upcomingEvents.map((event) => (
            <CollectionCard
              href={`/events/${event.slug}`}
              label={event.city.name}
              title={event.title}
              summary={event.summary}
              image={event.coverImage}
              meta={[formatDateRange(event.startsAt, event.endsAt), event.venueName]}
            />
          ))
        }
      </div>
    </section>

    <section class="section">
      <div class="section-head">
        <div>
          <div class="card-label">City Highlights</div>
          <h2>Each city rolls up events, topics, and articles</h2>
        </div>
        <a class="text-link" href="/cities">Visit city pages</a>
      </div>

      <div class="grid grid-3">
        {
          home.cityHighlights.map((city) => (
            <CollectionCard
              href={`/cities/${city.slug}`}
              label={`${city.topicCount} topics`}
              title={city.name}
              summary={city.summary}
              image={city.coverImage}
              meta={[`${city.articleCount} articles`, `${city.eventCount} events`]}
            />
          ))
        }
      </div>
    </section>

    <section class="section">
      <div class="panel promo-panel">
        <div>
          <div class="card-label">Application Flow</div>
          <h2>{home.applicationCallout.title}</h2>
          <p class="card-copy">{home.applicationCallout.summary}</p>
        </div>
        <a class="button primary" href={home.applicationCallout.href}>Open the form</a>
      </div>
    </section>

    <section class="section">
      <div class="section-head">
        <div>
          <div class="card-label">Implementation Shape</div>
          <h2>The public experience stays static-first, but not hard-coded.</h2>
        </div>
      </div>

      <div class="grid grid-3">
        {
          publicModules.map((module) => (
            <article class="panel">
              <div class="card-label">{module.phase}</div>
              <h3 class="card-title">{module.name}</h3>
              <p class="card-copy">{module.summary}</p>
            </article>
          ))
        }
      </div>
    </section>
  </main>
</BaseLayout>
