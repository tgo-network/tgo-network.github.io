---
import { platformName, publicModules } from "@tgo/shared";

import CollectionCard from "../components/CollectionCard.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { formatDate, formatDateRange } from "../lib/format";
import { getHomePayload } from "../lib/public-api";

const home = await getHomePayload();
---

<BaseLayout
  title={`${platformName} | 首页`}
  description="TGO 鲲鹏会面向技术领导者的公开站点，展示组织定位、分会网络、成员、活动与内容。"
>
  <main class="page-shell page-stack">
    <section class="hero">
      <div class="hero-card hero-split">
        <div>
          <span class="eyebrow">{home.hero.eyebrow}</span>
          <h1>{home.hero.title}</h1>
          <p>{home.hero.summary}</p>

          <div class="hero-actions">
            {
              home.hero.actions.map((action, index) => (
                <a class:list={["button", index === 0 ? "primary" : "secondary"]} href={action.href}>
                  {action.label}
                </a>
              ))
            }
          </div>
        </div>

        <aside class="hero-aside panel panel-soft">
          <div class="card-label">组织速览</div>
          <h2 class="card-title">围绕技术管理者成长，连接城市分会、成员网络与高质量活动。</h2>
          <p class="card-copy">前台页面静态优先，真实数据统一来自 API，方便后续由后台持续运营。</p>
          <ul class="meta-list">
            {home.audience.items.map((item) => <li>{item}</li>)}
          </ul>
        </aside>
      </div>
    </section>

    <section class="section">
      <div class="section-head">
        <div>
          <div class="card-label">TGO 介绍</div>
          <h2>{home.intro.title}</h2>
        </div>
      </div>

      <div class="panel-grid-home">
        <article class="panel">
          <p class="card-copy">{home.intro.summary}</p>
        </article>
        <article class="panel">
          <div class="card-label">覆盖人群</div>
          <h3 class="card-title">{home.audience.title}</h3>
          <ul class="meta-list">
            {home.audience.items.map((item) => <li>{item}</li>)}
          </ul>
        </article>
      </div>
    </section>

    <section class="section">
      <div class="section-head">
        <div>
          <div class="card-label">关键指标</div>
          <h2>组织网络与内容运营的当前状态</h2>
        </div>
      </div>

      <div class="grid grid-3">
        {
          home.metrics.map((metric) => (
            <article class="panel stat-card">
              <div class="card-label">{metric.label}</div>
              <h3 class="metric-value">{metric.value}</h3>
              <p class="card-copy">{metric.description}</p>
            </article>
          ))
        }
      </div>
    </section>

    <section class="section">
      <div class="section-head">
        <div>
          <div class="card-label">分会董事会</div>
          <h2>在城市节点中形成长期稳定的同侪连接</h2>
        </div>
        <a class="text-link" href="/branches">查看全部分会</a>
      </div>

      <div class="grid grid-3">
        {
          home.branchHighlights.map((branch) => (
            <CollectionCard
              href={`/branches#${branch.slug}`}
              label={branch.region || branch.cityName}
              title={branch.name}
              summary={branch.summary}
              image={branch.coverImage}
              meta={[branch.cityName, `${branch.boardMemberCount} 位董事会成员`]}
            />
          ))
        }
      </div>
    </section>

    <section class="section">
      <div class="section-head">
        <div>
          <div class="card-label">精彩活动</div>
          <h2>近期活动与线下交流安排</h2>
        </div>
        <a class="text-link" href="/events">浏览活动</a>
      </div>

      <div class="grid grid-3">
        {
          home.featuredEvents.map((event) => (
            <CollectionCard
              href={`/events/${event.slug}`}
              label={event.branch?.cityName ?? "活动"}
              title={event.title}
              summary={event.summary}
              image={event.coverImage}
              meta={[formatDateRange(event.startsAt, event.endsAt), event.venueName]}
            />
          ))
        }
      </div>
    </section>

    <section class="section">
      <div class="section-head">
        <div>
          <div class="card-label">文章</div>
          <h2>来自技术管理与组织实践的一线内容</h2>
        </div>
        <a class="text-link" href="/articles">查看文章</a>
      </div>

      <div class="grid grid-3">
        {
          home.featuredArticles.map((article) => (
            <CollectionCard
              href={`/articles/${article.slug}`}
              label={formatDate(article.publishedAt)}
              title={article.title}
              summary={article.excerpt}
              image={article.coverImage}
              meta={[article.authorName, "公开文章"]}
            />
          ))
        }
      </div>
    </section>

    <section class="section">
      <div class="panel promo-panel">
        <div>
          <div class="card-label">加入申请</div>
          <h2>{home.joinCallout.title}</h2>
          <p class="card-copy">{home.joinCallout.summary}</p>
        </div>
        <a class="button primary" href={home.joinCallout.href}>开始申请</a>
      </div>
    </section>

    <section class="section">
      <div class="section-head">
        <div>
          <div class="card-label">当前交付范围</div>
          <h2>公开站与后台围绕当前 MVP 范围持续推进</h2>
        </div>
      </div>

      <div class="grid grid-3">
        {
          publicModules.map((module) => (
            <article class="panel">
              <div class="card-label">{module.phase}</div>
              <h3 class="card-title">{module.name}</h3>
              <p class="card-copy">{module.summary}</p>
            </article>
          ))
        }
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .panel-grid-home {
    display: grid;
    gap: 18px;
    grid-template-columns: minmax(0, 1.4fr) minmax(0, 1fr);
  }

  .stat-card {
    min-height: 100%;
  }

  .metric-value {
    margin: 16px 0 10px;
    font-size: clamp(2rem, 4vw, 3.2rem);
  }

  @media (max-width: 900px) {
    .panel-grid-home {
      grid-template-columns: 1fr;
    }
  }
</style>
