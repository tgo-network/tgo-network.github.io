---
import BaseLayout from "../layouts/BaseLayout.astro";
import { listPublicEditorialArticles } from "../lib/editorial-order";
import { formatDate, formatDateRange } from "../lib/format";
import { getHomePayload, listMembers } from "../lib/public-api";

const [home, members] = await Promise.all([getHomePayload(), listMembers()]);

const pickFeaturedMembers = () => {
  const featured = [] as typeof members;
  const usedCities = new Set<string>();

  for (const member of members) {
    const cityName = member.branch?.cityName ?? "";
    const hasRichProfile = member.company !== "暂未公开" || member.title !== "成员";

    if (!hasRichProfile || !cityName || usedCities.has(cityName)) {
      continue;
    }

    featured.push(member);
    usedCities.add(cityName);

    if (featured.length >= 3) {
      return featured;
    }
  }

  for (const member of members) {
    if (featured.find((item) => item.slug === member.slug)) {
      continue;
    }

    featured.push(member);

    if (featured.length >= 3) {
      break;
    }
  }

  return featured;
};

const featuredMembers = pickFeaturedMembers();
const featuredArticles = listPublicEditorialArticles(home.featuredArticles).slice(0, 3);

const heroSummary =
  "面向 CTO、技术 VP、研发负责人和关键技术管理者，TGO 鲲鹏会通过城市分会、董事会与成员共建的方式，连接长期交流、活动学习与组织经验沉淀。";
const heroNote = "社区覆盖技术管理者、架构负责人和技术创业者，持续开展闭门交流、企业参访、专题研讨与峰会学习。";

const testimonialFallbacks: Record<string, string> = {
  "zhou-yang": "真正有价值的，不是一场活动结束时的热闹，而是之后还能继续讨论那些没有标准答案的管理问题。",
  "lin-wen": "当你长期和一群做过复杂业务、复杂组织的人交流，很多判断会更稳，很多问题也会更快看到第二种解法。",
  "shen-lan": "社区最难得的地方，是大家愿意把真实经验、真实代价和真实犹豫拿出来讨论，而不是只讲结果。"
};
const testimonialFallbackRotation = [
  "真正有价值的，不是一场活动结束时的热闹，而是之后还能继续讨论那些没有标准答案的管理问题。",
  "当你长期和一群做过复杂业务、复杂组织的人交流，很多判断会更稳，很多问题也会更快看到第二种解法。",
  "社区最难得的地方，是大家愿意把真实经验、真实代价和真实犹豫拿出来讨论，而不是只讲结果。"
];

const featuredTestimonials = featuredMembers.map((member, index) => ({
  ...member,
  quote:
    testimonialFallbacks[member.slug] ??
    testimonialFallbackRotation[index % testimonialFallbackRotation.length]
}));
const featuredEvents = home.featuredEvents.slice(0, 3);

const joinPanels = [
  {
    title: "加入条件",
    items: [
      "具备明确的技术管理职责，并愿意长期参与高质量交流。",
      "在技术战略、研发管理、架构演进或组织建设方向有真实实践。",
      "认可分享、互助、长期建设与同侪信任的社区价值。"
    ]
  },
  {
    title: "加入流程",
    items: ["在线申请", "工作人员联系", "进一步沟通", "审核确认"]
  }
];

const eventFallbackImages = [
  "/imports/tgo-infoq/branches/banners/shanghai.png",
  "/official/about/y2.c99b8704.png",
  "/imports/tgo-infoq/branches/banners/beijing.png"
];

const heroImage = {
  src: "/official/about/11.a131a302.jpg",
  alt: "TGO 鲲鹏会活动现场"
};
---

<BaseLayout title="TGO 鲲鹏会 | 首页" description="TGO 鲲鹏会面向技术领导者，展示组织介绍、成员推荐、学习活动与加入路径。">
  <main class="page-shell page-stack home-official-shell">
    <section class="home-official-hero">
      <article class="panel home-official-hero-stage">
        <div class="home-official-hero-grid">
          <div class="home-official-hero-copy">
            <p class="home-official-kicker">TGO 鲲鹏会</p>
            <h1>科技领导者的长期学习与交流社区</h1>
            <p class="home-official-summary">{heroSummary}</p>
            <p class="home-official-context-note">{heroNote}</p>
          </div>

          <div class="home-official-hero-visual">
            <figure class="home-official-hero-image">
              <img src={heroImage.src} alt={heroImage.alt} loading="eager" />
              <figcaption>GTLC 峰会现场</figcaption>
            </figure>
          </div>
        </div>

      </article>
    </section>

    <section class="section">
      <div class="section-head section-head-stack home-official-section-head">
        <h2>成员推荐</h2>
        <a class="text-link home-official-text-link" href="/members">查看成员列表</a>
      </div>

      <div class="home-official-testimonial-grid">
        {
          featuredTestimonials.map((member) => (
            <article class="panel home-official-testimonial-card">
              <p class="home-official-testimonial-quote">“{member.quote}”</p>

              <div class="home-official-testimonial-meta">
                <strong>{member.name}</strong>
                <span>
                  {member.company}
                  {member.title ? ` · ${member.title}` : ""}
                </span>
                <small>{member.branch?.name ?? "TGO 鲲鹏会成员"}</small>
              </div>
            </article>
          ))
        }
      </div>
    </section>

    <section class="section">
      <div class="section-head section-head-stack home-official-section-head">
        <h2>近期活动</h2>
        <a class="text-link home-official-text-link" href="/events">浏览活动</a>
      </div>

      <div class="home-official-event-grid">
        {
          featuredEvents.map((event, index) => (
            <a class:list={["home-official-card-link", "home-official-event-link"]} href={`/events/${event.slug}`}>
              <article class="panel home-official-event-card">
                <img
                  class="home-official-event-image"
                  src={event.coverImage?.url ?? eventFallbackImages[index % eventFallbackImages.length]}
                  alt={event.coverImage?.alt ?? event.title}
                  loading="eager"
                />

                <div class="home-official-event-copy">
                  <div class="home-official-event-meta">
                    <span>{event.cityName}</span>
                    <span>{formatDateRange(event.startsAt, event.endsAt)}</span>
                  </div>
                  <h3>{event.title}</h3>
                  <p>{event.summary}</p>
                </div>
              </article>
            </a>
          ))
        }
      </div>
    </section>

    <section class="section">
      <div class="section-head section-head-stack home-official-section-head">
        <h2>近期文章</h2>
        <a class="text-link home-official-text-link" href="/articles">查看文章</a>
      </div>

      <div class="home-official-article-grid">
        {
          featuredArticles.map((article) => (
            <a class:list={["home-official-card-link", "home-official-article-link"]} href={`/articles/${article.slug}`}>
              <article class="panel home-official-article-item">
                <div class="home-official-article-meta">
                  <span>{formatDate(article.publishedAt)}</span>
                  <span>{article.authorName}</span>
                </div>

                <div class="home-official-article-copy">
                  <h3>{article.title}</h3>
                  <p>{article.excerpt}</p>
                </div>

                <div class="home-official-article-footer">
                  <span>{article.branch?.name ?? "TGO 鲲鹏会"}</span>
                  <span class="text-link">阅读全文</span>
                </div>
              </article>
            </a>
          ))
        }
      </div>
    </section>

    <section class="section">
      <div class="panel home-official-join-card">
        <div class="section-head section-head-stack home-official-section-head home-official-join-head">
          <div>
            <h2>申请加入 TGO 鲲鹏会</h2>
            <p class="card-copy">符合申请条件后，可先阅读加入方式并提交申请，由工作人员继续联系。</p>
          </div>
          <a class="button primary" href={home.joinCallout.href}>查看加入方式</a>
        </div>

        <div class="home-official-join-grid">
          {
            joinPanels.map((panel) => (
              <article class="home-official-join-panel">
                <h3>{panel.title}</h3>
                {
                  panel.title === "加入流程" ? (
                    <ol>
                      {panel.items.map((item) => <li>{item}</li>)}
                    </ol>
                  ) : (
                    <ul>
                      {panel.items.map((item) => <li>{item}</li>)}
                    </ul>
                  )
                }
              </article>
            ))
          }
        </div>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .home-official-shell {
    padding-top: 16px;
    padding-bottom: 48px;
  }

  .home-official-hero {
    padding: 18px 0 10px;
  }

  .home-official-hero-stage {
    display: grid;
    gap: 26px;
    padding: clamp(26px, 3vw, 34px);
    background:
      radial-gradient(circle at top right, rgba(200, 161, 93, 0.12), transparent 22%),
      linear-gradient(180deg, rgba(255, 251, 244, 0.98), rgba(246, 239, 229, 0.96));
  }

  .home-official-hero-grid,
  .home-official-join-grid {
    display: grid;
    gap: 24px;
  }

  .home-official-hero-grid {
    grid-template-columns: minmax(0, 1fr) minmax(360px, 0.92fr);
    align-items: center;
  }

  .home-official-kicker,
  .home-official-event-meta,
  .home-official-article-meta {
    margin: 0 0 14px;
    color: var(--accent-strong);
    font-size: 0.82rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .home-official-section-head {
    margin-bottom: 18px;
  }

  .home-official-hero-copy h1,
  .home-official-section-head h2,
  .home-official-join-head h2 {
    margin: 0;
    font-family: var(--font-display);
    font-weight: 600;
    letter-spacing: 0.01em;
  }

  .home-official-hero-copy h1 {
    max-width: 11ch;
    font-size: clamp(2.8rem, 5.6vw, 4.8rem);
    line-height: 0.98;
  }

  .home-official-hero-copy {
    display: grid;
    gap: 16px;
    align-content: center;
  }

  .home-official-section-head h2,
  .home-official-join-head h2 {
    max-width: 18ch;
    font-size: clamp(1.8rem, 3vw, 2.8rem);
    line-height: 1.08;
  }

  .home-official-summary,
  .home-official-context-note,
  .home-official-testimonial-quote,
  .home-official-event-copy p,
  .home-official-article-copy p,
  .home-official-join-panel li,
  .home-official-join-head .card-copy {
    margin: 0;
    color: var(--muted);
    line-height: 1.8;
  }

  .home-official-summary {
    max-width: 39rem;
    font-size: 1.08rem;
  }

  .home-official-hero-visual {
    min-width: 0;
  }

  .home-official-hero-image {
    margin: 0;
    position: relative;
    overflow: hidden;
    border-radius: 28px;
    box-shadow: 0 24px 50px rgba(35, 28, 21, 0.14);
  }

  .home-official-hero-image img {
    display: block;
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
  }

  .home-official-hero-image figcaption {
    position: absolute;
    left: 18px;
    bottom: 18px;
    margin: 0;
    padding: 9px 12px;
    border-radius: 999px;
    background: rgba(255, 252, 246, 0.88);
    border: 1px solid rgba(27, 23, 19, 0.08);
    color: var(--accent-strong);
    font-size: 0.76rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .home-official-testimonial-card,
  .home-official-event-card,
  .home-official-article-item,
  .home-official-join-card,
  .home-official-join-panel {
    background: linear-gradient(180deg, rgba(255, 252, 246, 0.98), rgba(245, 238, 227, 0.92));
  }

  .home-official-context-note {
    color: var(--ink);
    font-size: 1.02rem;
    line-height: 1.82;
    max-width: 38rem;
  }

  .home-official-testimonial-grid,
  .home-official-event-grid,
  .home-official-article-grid,
  .home-official-join-grid {
    display: grid;
    gap: 18px;
  }

  .home-official-testimonial-grid,
  .home-official-event-grid,
  .home-official-article-grid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .home-official-event-copy h3,
  .home-official-article-copy h3,
  .home-official-join-panel h3 {
    margin: 0 0 12px;
  }

  .home-official-text-link {
    font-weight: 500;
  }

  .home-official-testimonial-card {
    display: grid;
    gap: 18px;
    padding: 24px;
    background:
      radial-gradient(circle at top right, rgba(138, 106, 67, 0.08), transparent 28%),
      linear-gradient(180deg, rgba(255, 252, 246, 0.98), rgba(245, 238, 227, 0.92));
  }

  .home-official-testimonial-quote {
    font-size: 1.02rem;
    line-height: 1.88;
  }

  .home-official-testimonial-meta {
    display: grid;
    gap: 4px;
  }

  .home-official-testimonial-meta span,
  .home-official-testimonial-meta small {
    color: var(--muted);
  }

  .home-official-card-link {
    display: block;
  }

  .home-official-event-link {
    min-width: 0;
    height: 100%;
  }

  .home-official-event-card {
    display: grid;
    overflow: hidden;
    height: 100%;
    border-radius: 26px;
    transition: transform 180ms ease, box-shadow 180ms ease, border-color 180ms ease;
  }

  .home-official-card-link:hover .home-official-event-card,
  .home-official-card-link:hover .home-official-article-item {
    transform: translateY(-2px);
    border-color: rgba(157, 111, 49, 0.18);
    box-shadow: 0 22px 48px rgba(40, 28, 18, 0.12);
  }

  .home-official-event-image {
    width: 100%;
    aspect-ratio: 16 / 10;
    object-fit: cover;
    background: rgba(255, 255, 255, 0.72);
  }

  .home-official-event-image-placeholder {
    background:
      linear-gradient(rgba(27, 23, 19, 0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(27, 23, 19, 0.04) 1px, transparent 1px),
      linear-gradient(180deg, rgba(255, 255, 255, 0.92), rgba(244, 236, 224, 0.9));
    background-size: 72px 72px, 72px 72px, auto;
  }

  .home-official-event-copy {
    display: grid;
    gap: 12px;
    padding: 20px;
  }

  .home-official-event-meta,
  .home-official-article-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    margin: 0;
    color: var(--muted);
    letter-spacing: 0.04em;
  }

  .home-official-event-copy h3,
  .home-official-article-copy h3 {
    line-height: 1.38;
  }

  .home-official-event-copy p {
    display: -webkit-box;
    overflow: hidden;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
  }

  .home-official-article-link {
    min-width: 0;
    height: 100%;
  }

  .home-official-article-item {
    display: grid;
    gap: 14px;
    height: 100%;
    padding: 22px 24px;
    transition: transform 180ms ease, box-shadow 180ms ease, border-color 180ms ease;
  }

  .home-official-article-copy p {
    display: -webkit-box;
    overflow: hidden;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 3;
  }

  .home-official-article-meta {
    justify-content: flex-start;
  }

  .home-official-article-footer {
    display: flex;
    gap: 12px;
    align-items: center;
    justify-content: space-between;
    margin-top: auto;
    color: var(--muted);
    font-size: 0.84rem;
  }

  .home-official-article-footer span:first-child {
    display: inline-flex;
    align-items: center;
    min-height: 30px;
    padding: 0 11px;
    border-radius: 999px;
    border: 1px solid rgba(138, 106, 67, 0.14);
    background: rgba(255, 248, 238, 0.76);
    color: var(--accent-strong);
    letter-spacing: 0.03em;
  }

  .home-official-join-card {
    padding: 28px;
  }

  .home-official-join-head {
    margin-bottom: 18px;
  }

  .home-official-join-head .card-copy {
    margin-top: 12px;
    max-width: 42rem;
  }

  .home-official-join-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .home-official-join-panel {
    padding: 22px;
    border-radius: 22px;
    border: 1px solid rgba(27, 23, 19, 0.08);
  }

  .home-official-join-panel ul,
  .home-official-join-panel ol {
    margin: 0;
    padding-left: 1.2rem;
  }

  .home-official-join-panel li + li {
    margin-top: 10px;
  }

  @media (max-width: 1100px) {
    .home-official-hero-grid {
      grid-template-columns: 1fr;
      align-items: start;
    }

    .home-official-testimonial-grid,
    .home-official-event-grid,
    .home-official-article-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

  }

  @media (max-width: 820px) {
    .home-official-shell {
      padding-top: 8px;
    }

    .home-official-hero,
    .section {
      padding-top: 24px;
      padding-bottom: 24px;
    }

    .home-official-hero-copy h1 {
      max-width: none;
      font-size: clamp(2.4rem, 10vw, 4rem);
    }

    .home-official-section-head h2,
    .home-official-join-head h2 {
      max-width: none;
    }

    .home-official-testimonial-grid,
    .home-official-event-grid,
    .home-official-article-grid,
    .home-official-join-grid {
      grid-template-columns: 1fr;
    }

    .home-official-join-card {
      padding: 22px;
    }
  }
</style>
