---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getJoinPage, getPublicApiBaseUrl } from "../lib/public-api";

const [page, apiBaseUrl] = await Promise.all([getJoinPage(), Promise.resolve(getPublicApiBaseUrl())]);
const joinHeroSummary = "适合愿意长期参与社区交流的技术领导者。提交申请后，由工作人员继续审核与联系。";

const applicationGuidance = [
  "尽量写清当前职责、团队范围与技术管理工作。",
  "如希望加入特定分会，建议写明目标城市与参与诉求。",
  "留下常用手机号与微信号，便于后续联系。"
];
const joinFaqPreview = page.faq[0];
---

<BaseLayout title="加入申请 | TGO 鲲鹏会" description={page.hero.summary}>
  <main class="page-shell page-stack">
    <section class="hero">
      <div class="hero-card join-hero-card">
        <div class="join-hero-main">
          <h1>{page.hero.title}</h1>
          <p>{joinHeroSummary}</p>

          <div class="hero-actions">
            <a class="button primary" href="#application-form">填写申请表</a>
            <a class="button secondary" href="#conditions">查看加入条件</a>
          </div>
        </div>

        <aside class="join-hero-aside">
          <h2>申请流程</h2>
          <p class="join-hero-note">先确认加入条件，再提交资料，后续由工作人员继续审核与联系。</p>

          <ol class="join-step-list">
            {page.process.map((item) => <li>{item}</li>)}
          </ol>
        </aside>
      </div>
    </section>

    <section id="conditions" class="section">
      <div class="join-info-grid">
        <article class="panel join-info-card">
          <div class="card-label">加入条件</div>
          <ul class="meta-list vertical-list">
            {page.conditions.map((item) => <li>{item}</li>)}
          </ul>
        </article>

        <article class="panel join-info-card">
          <div class="card-label">成员权益</div>
          <ul class="meta-list vertical-list">
            {page.benefits.map((item) => <li>{item}</li>)}
          </ul>
        </article>
      </div>
    </section>

    <section id="application-form" class="section registration-shell">
      <div class="panel registration-panel">
        <h2>填写加入申请</h2>
        <p class="registration-copy">
          请填写姓名、手机号、微信号、邮箱、个人介绍与申请信息。提交后会由工作人员在后台审核并联系你。
        </p>

        <form class="form-panel" data-application-form data-api-base={apiBaseUrl}>
          <div class="form-grid">
            <label>
              <span>姓名</span>
              <input name="name" type="text" required minlength="2" />
            </label>

            <label>
              <span>手机号</span>
              <input name="phoneNumber" type="tel" required inputmode="tel" />
            </label>

            <label>
              <span>微信号</span>
              <input name="wechatId" type="text" />
            </label>

            <label>
              <span>邮箱</span>
              <input name="email" type="email" />
            </label>
          </div>

          <label>
            <span>个人介绍</span>
            <textarea name="introduction" rows="5" required minlength="20"></textarea>
          </label>

          <label>
            <span>申请信息</span>
            <textarea name="applicationMessage" rows="6" required minlength="20"></textarea>
          </label>

          <div class="form-actions">
            <button class="button primary" type="submit">提交申请</button>
            <p class="form-status" data-form-status>提交后会由工作人员进行审核与联系。</p>
          </div>
        </form>
      </div>

      <aside class="panel panel-soft registration-side join-form-support">
        <div>
          <div class="card-label">填写建议</div>
          <ul class="join-rule-list">
            {applicationGuidance.map((item) => <li>{item}</li>)}
          </ul>
        </div>

        {
          joinFaqPreview && (
            <div class="join-faq-preview">
              <div class="card-label">常见问题</div>
              <div class="faq-list faq-list-compact">
                <div class="faq-item">
                  <h3>{joinFaqPreview.question}</h3>
                  <p>{joinFaqPreview.answer}</p>
                </div>
              </div>
            </div>
          )
        }

        <a class="text-link join-support-link" href="/faq">查看全部 FAQ</a>
      </aside>
    </section>
  </main>

  <script>
    const form = document.querySelector("[data-application-form]");
    const status = document.querySelector("[data-form-status]");

    if (form instanceof HTMLFormElement && status instanceof HTMLElement) {
      form.addEventListener("submit", async (event) => {
        event.preventDefault();
        status.textContent = "提交中...";

        const formData = new FormData(form);
        const payload = Object.fromEntries(
          Array.from(formData.entries()).filter(([, value]) => typeof value === "string" && value.trim().length > 0)
        );
        const baseUrl = form.dataset.apiBase ?? "http://127.0.0.1:8787";

        try {
          const response = await fetch(new URL("/api/public/v1/join-applications", baseUrl), {
            method: "POST",
            headers: {
              "Content-Type": "application/json"
            },
            body: JSON.stringify(payload)
          });

          const result = await response.json();

          if (!response.ok) {
            const firstIssue = result.error?.details?.issues?.[0]?.message;
            status.textContent = firstIssue ?? result.error?.message ?? "申请提交失败，请稍后再试。";
            return;
          }

          status.textContent = `申请已提交，编号 ${result.data.id}。`;
          form.reset();
        } catch {
          status.textContent = "API 当前不可用，请先启动 apps/api 以测试完整流程。";
        }
      });
    }
  </script>
</BaseLayout>

<style>
  .join-hero-card {
    display: grid;
    gap: 20px;
    grid-template-columns: minmax(0, 1.32fr) minmax(300px, 0.68fr);
    background:
      radial-gradient(circle at top right, rgba(215, 179, 117, 0.18), transparent 24%),
      linear-gradient(135deg, #171717 0%, #201c17 100%);
    border-color: rgba(215, 179, 117, 0.14);
    color: #f8f1e8;
    scroll-margin-top: 24px;
  }

  .join-hero-card h1,
  .join-hero-card h2 {
    color: #fff7ef;
  }

  .join-hero-card p {
    color: rgba(248, 241, 232, 0.76);
  }

  .join-hero-card :global(.button.secondary) {
    border-color: rgba(255, 255, 255, 0.14);
    background: rgba(255, 255, 255, 0.08);
    color: #f8f1e8;
  }

  .join-hero-main h1 {
    max-width: 10.5ch;
    font-size: clamp(2.25rem, 4.8vw, 3.85rem);
    line-height: 0.98;
  }

  .join-hero-main p {
    max-width: 44rem;
  }

  .join-hero-aside {
    display: grid;
    gap: 18px;
    padding: 22px;
    border-radius: 24px;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(215, 179, 117, 0.12);
  }

  .join-hero-aside h2 {
    margin: 0;
  }

  .join-hero-note {
    margin: 0;
    line-height: 1.75;
  }

  .join-step-list {
    display: grid;
    gap: 12px;
    margin: 0;
    padding-left: 20px;
    color: rgba(248, 241, 232, 0.8);
    line-height: 1.8;
  }

  .join-info-grid,
  .registration-shell {
    display: grid;
    gap: 18px;
  }

  .join-info-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .join-info-card {
    min-height: 100%;
    transition: transform 180ms ease, border-color 180ms ease, box-shadow 180ms ease;
  }

  .join-info-card,
  .join-form-support {
    background: linear-gradient(180deg, rgba(255, 252, 246, 0.96), rgba(247, 241, 232, 0.94));
  }

  .join-info-card:hover {
    transform: translateY(-3px);
    border-color: rgba(157, 111, 49, 0.22);
    box-shadow: 0 24px 44px rgba(40, 28, 18, 0.1);
  }

  .faq-list {
    display: grid;
    gap: 16px;
  }

  .faq-list-compact {
    margin-top: 4px;
  }

  .faq-item h3 {
    margin: 0 0 6px;
    font-size: 1rem;
  }

  .faq-item + .faq-item {
    padding-top: 16px;
    border-top: 1px solid rgba(31, 26, 23, 0.08);
  }

  .faq-item p {
    margin: 0;
    line-height: 1.72;
  }

  .join-faq-preview {
    display: grid;
    gap: 10px;
  }

  .join-form-support .faq-item p {
    display: -webkit-box;
    overflow: hidden;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 4;
  }

  .registration-side {
    display: grid;
    gap: 18px;
    align-content: start;
  }

  .join-rule-list {
    display: grid;
    gap: 8px;
    margin: 14px 0 0;
    padding: 0;
    list-style: none;
  }

  .join-rule-list li {
    padding: 12px 14px;
    border-radius: 18px;
    border: 1px solid rgba(31, 26, 23, 0.08);
    background: rgba(255, 255, 255, 0.62);
    color: var(--muted);
    line-height: 1.68;
  }

  .registration-shell {
    grid-template-columns: minmax(0, 1.45fr) minmax(280px, 0.85fr);
    scroll-margin-top: 24px;
  }

  .registration-panel h2 {
    margin: 14px 0 10px;
    font-size: clamp(1.7rem, 3vw, 2.3rem);
  }

  .registration-copy {
    margin: 0 0 20px;
  }

  .join-form-support {
    position: sticky;
    top: 104px;
  }

  .join-support-link {
    justify-self: start;
  }

  @media (max-width: 1000px) {
    .join-hero-card,
    .join-info-grid,
    .registration-shell {
      grid-template-columns: 1fr;
    }

    .join-form-support {
      position: static;
    }
  }
</style>
