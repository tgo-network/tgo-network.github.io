---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getJoinPage, getPublicApiBaseUrl } from "../lib/public-api";

const [page, apiBaseUrl] = await Promise.all([getJoinPage(), Promise.resolve(getPublicApiBaseUrl())]);

const participationFormats = [
  {
    title: "私密小组交流",
    summary: "围绕真实技术管理问题进行更稳定的小范围深聊，强调长期陪伴而不是一次性活动。"
  },
  {
    title: "公开学习活动",
    summary: "通过更开放的主题活动拓展外部连接，但仍然保持主题、质量与审核机制。"
  },
  {
    title: "标杆企业走访",
    summary: "走进具体团队和业务现场，围绕组织、工程与协作获得更直接的观察。"
  },
  {
    title: "跨城市同侪连接",
    summary: "在不同分会之间建立长期网络，让经验交流不局限于单一城市或单次活动。"
  }
];

const applicationTips = [
  "尽量写清当前负责的技术管理工作。",
  "说明你希望加入后的参与方式与交流诉求。",
  "留下便于联系的手机号与微信号。"
];

const decisionCards = [
  {
    label: "组织匹配",
    title: "先确认你是否认同这种长期社区方式",
    summary: "这里更适合愿意持续参与同侪交流、而不是只寻找一次性活动机会的人。"
  },
  {
    label: "参与预期",
    title: "加入之后仍以真实交流和活动参与为核心",
    summary: "成员权益不只是信息获取，更来自分会活动、私密交流与跨城市连接。"
  },
  {
    label: "审核机制",
    title: "提交申请后会进入工作人员后台继续审核",
    summary: "当前申请不是即时加入，而是由工作人员审核、联系并推进后续安排。"
  }
];

const postSubmitSteps = [
  {
    step: "01",
    title: "进入后台审核",
    summary: "申请资料会先进入工作人员后台，进入待处理队列。"
  },
  {
    step: "02",
    title: "工作人员联系",
    summary: "工作人员会根据资料完整度、分会安排与你继续沟通。"
  },
  {
    step: "03",
    title: "确认参与方式",
    summary: "在理解背景与诉求后，再进入后续分会安排或继续跟进。"
  }
];
---

<BaseLayout title="加入申请 | TGO 鲲鹏会" description={page.hero.summary}>
  <main class="page-shell page-stack">
    <section class="hero">
      <div class="hero-card join-hero-card">
        <div class="join-hero-main">
          <span class="eyebrow">{page.hero.eyebrow}</span>
          <h1>{page.hero.title}</h1>
          <p>{page.hero.summary}</p>

          <div class="hero-actions">
            <a class="button primary" href="#application-form">填写申请表</a>
            <a class="button secondary" href="#conditions">先看加入说明</a>
          </div>
        </div>

        <aside class="join-hero-aside">
          <div>
            <div class="card-label card-label-on-dark">如何开始</div>
            <h2>先理解定位，再提交申请</h2>
            <p>
              这不是一个单纯填写表单的页面，而是先帮助访客理解：这个组织适合谁、提供什么价值，以及申请后会发生什么。
            </p>
          </div>

          <ol class="join-step-list">
            {page.process.map((item) => <li>{item}</li>)}
          </ol>
        </aside>
      </div>
    </section>

    <section class="section">
      <div class="section-head section-head-stack">
        <div>
          <div class="card-label">申请前确认</div>
          <h2>先确认这三件事，再进入正式申请</h2>
          <p class="section-note">这里先校准组织匹配度、参与预期与审核方式，避免把加入申请误解成一个即时通过的表单动作。</p>
        </div>
      </div>

      <div class="decision-grid">
        {
          decisionCards.map((item) => (
            <article class="panel decision-card">
              <div class="card-label">{item.label}</div>
              <h3 class="card-title">{item.title}</h3>
              <p class="card-copy">{item.summary}</p>
            </article>
          ))
        }
      </div>
    </section>

    <section id="conditions" class="section">
      <div class="section-head section-head-stack">
        <div>
          <div class="card-label">加入说明</div>
          <h2>先确认你是否适合当前阶段的组织定位</h2>
          <p class="section-note">加入说明同时覆盖条件、成员权益与审核流程，帮助访客在填写资料前先建立完整预期。</p>
        </div>
      </div>

      <div class="join-info-grid">
        <article class="panel join-info-card">
          <div class="card-label">加入条件</div>
          <ul class="meta-list vertical-list">
            {page.conditions.map((item) => <li>{item}</li>)}
          </ul>
        </article>

        <article class="panel join-info-card">
          <div class="card-label">成员权益</div>
          <ul class="meta-list vertical-list">
            {page.benefits.map((item) => <li>{item}</li>)}
          </ul>
        </article>

        <article class="panel join-info-card">
          <div class="card-label">审核流程</div>
          <ul class="meta-list vertical-list">
            {page.process.map((item) => <li>{item}</li>)}
          </ul>
        </article>
      </div>
    </section>

    <section class="section">
      <div class="section-head section-head-stack">
        <div>
          <div class="card-label">参与形式</div>
          <h2>加入之后，你更可能参与的是这些连接方式</h2>
          <p class="section-note">这些活动并不是平行罗列的栏目，而是同一套社区连接方式在不同场景下的具体表现。</p>
        </div>
      </div>

      <div class="format-grid">
        {
          participationFormats.map((item) => (
            <article class="panel format-card">
              <h3 class="card-title">{item.title}</h3>
              <p class="card-copy">{item.summary}</p>
            </article>
          ))
        }
      </div>
    </section>

    <section class="section detail-grid">
      <article class="panel prose-panel">
        <div class="card-label">常见问题</div>
        <div class="faq-list">
          {
            page.faq.map((item) => (
              <div class="faq-item">
                <h3>{item.question}</h3>
                <p>{item.answer}</p>
              </div>
            ))
          }
        </div>
      </article>

      <aside class="panel panel-soft stack-sm join-side-panel">
        <div>
          <div class="card-label">提交后会发生什么</div>
          <p class="card-copy">申请资料会进入工作人员后台，由工作人员审核、联系并持续跟进后续流程。</p>
        </div>
        <div>
          <div class="card-label">填写建议</div>
          <ul class="meta-list vertical-list">
            {applicationTips.map((item) => <li>{item}</li>)}
          </ul>
        </div>
      </aside>
    </section>

    <section id="application-form" class="section registration-shell">
      <div class="panel registration-panel">
        <div class="card-label">加入申请表</div>
        <h2>{page.cta.label}</h2>
        <p class="registration-copy">
          请填写姓名、手机号、微信号、邮箱、个人介绍与申请信息。提交后会由工作人员在后台审核并联系你。
        </p>

        <div class="submit-flow-grid">
          {
            postSubmitSteps.map((item) => (
              <article class="submit-flow-card">
                <span>{item.step}</span>
                <strong>{item.title}</strong>
                <p>{item.summary}</p>
              </article>
            ))
          }
        </div>

        <form class="form-panel" data-application-form data-api-base={apiBaseUrl}>
          <div class="form-grid">
            <label>
              <span>姓名</span>
              <input name="name" type="text" required minlength="2" />
            </label>

            <label>
              <span>手机号</span>
              <input name="phoneNumber" type="tel" required inputmode="tel" />
            </label>

            <label>
              <span>微信号</span>
              <input name="wechatId" type="text" />
            </label>

            <label>
              <span>邮箱</span>
              <input name="email" type="email" />
            </label>
          </div>

          <label>
            <span>个人介绍</span>
            <textarea name="introduction" rows="5" required minlength="20"></textarea>
          </label>

          <label>
            <span>申请信息</span>
            <textarea name="applicationMessage" rows="6" required minlength="20"></textarea>
          </label>

          <div class="form-actions">
            <button class="button primary" type="submit">提交申请</button>
            <p class="form-status" data-form-status>提交后会由工作人员进行审核与联系。</p>
          </div>
        </form>
      </div>

      <aside class="panel panel-soft registration-side">
        <div>
          <div class="card-label">当前规则</div>
          <ul class="meta-list vertical-list">
            <li>非成员可以直接提交加入申请。</li>
            <li>成员与工作人员是两套独立身份体系。</li>
            <li>当前阶段成员不需要登录即可查看前台公开内容。</li>
          </ul>
        </div>

        <div>
          <div class="card-label">联系预期</div>
          <p class="card-copy">
            如果你的申请进入后续沟通，工作人员会基于分会安排与你继续联系，确认背景、诉求与适合的参与方式。
          </p>
        </div>
      </aside>
    </section>
  </main>

  <script>
    const form = document.querySelector("[data-application-form]");
    const status = document.querySelector("[data-form-status]");

    if (form instanceof HTMLFormElement && status instanceof HTMLElement) {
      form.addEventListener("submit", async (event) => {
        event.preventDefault();
        status.textContent = "提交中...";

        const formData = new FormData(form);
        const payload = Object.fromEntries(
          Array.from(formData.entries()).filter(([, value]) => typeof value === "string" && value.trim().length > 0)
        );
        const baseUrl = form.dataset.apiBase ?? "http://127.0.0.1:8787";

        try {
          const response = await fetch(new URL("/api/public/v1/join-applications", baseUrl), {
            method: "POST",
            headers: {
              "Content-Type": "application/json"
            },
            body: JSON.stringify(payload)
          });

          const result = await response.json();

          if (!response.ok) {
            const firstIssue = result.error?.details?.issues?.[0]?.message;
            status.textContent = firstIssue ?? result.error?.message ?? "申请提交失败，请稍后再试。";
            return;
          }

          status.textContent = `申请已提交，编号 ${result.data.id}。`;
          form.reset();
        } catch {
          status.textContent = "API 当前不可用，请先启动 apps/api 以测试完整流程。";
        }
      });
    }
  </script>
</BaseLayout>

<style>
  .join-hero-card {
    display: grid;
    gap: 22px;
    grid-template-columns: minmax(0, 1.2fr) minmax(320px, 0.8fr);
    background:
      radial-gradient(circle at top right, rgba(215, 179, 117, 0.18), transparent 24%),
      linear-gradient(135deg, #171717 0%, #201c17 100%);
    border-color: rgba(215, 179, 117, 0.14);
    color: #f8f1e8;
    scroll-margin-top: 24px;
  }

  .join-hero-card h1,
  .join-hero-card h2 {
    color: #fff7ef;
  }

  .join-hero-card p {
    color: rgba(248, 241, 232, 0.76);
  }

  .join-hero-card .eyebrow {
    color: #f1d5a0;
    border-color: rgba(215, 179, 117, 0.28);
    background: rgba(255, 255, 255, 0.06);
  }

  .join-hero-card :global(.button.secondary) {
    border-color: rgba(255, 255, 255, 0.14);
    background: rgba(255, 255, 255, 0.08);
    color: #f8f1e8;
  }

  .join-hero-aside {
    display: grid;
    gap: 18px;
    padding: 24px;
    border-radius: 24px;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(215, 179, 117, 0.12);
  }

  .join-step-list {
    display: grid;
    gap: 12px;
    margin: 0;
    padding-left: 20px;
    color: rgba(248, 241, 232, 0.8);
    line-height: 1.8;
  }

  .join-info-grid,
  .decision-grid,
  .format-grid,
  .registration-shell,
  .submit-flow-grid {
    display: grid;
    gap: 18px;
  }

  .decision-grid,
  .join-info-grid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .format-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .join-info-card,
  .format-card,
  .decision-card,
  .submit-flow-card {
    min-height: 100%;
    transition: transform 180ms ease, border-color 180ms ease, box-shadow 180ms ease;
  }

  .join-info-card,
  .decision-card,
  .format-card {
    background: linear-gradient(180deg, rgba(255, 252, 246, 0.96), rgba(247, 241, 232, 0.94));
  }

  .join-info-card:hover,
  .format-card:hover,
  .decision-card:hover,
  .submit-flow-card:hover {
    transform: translateY(-3px);
    border-color: rgba(157, 111, 49, 0.22);
    box-shadow: 0 24px 44px rgba(40, 28, 18, 0.1);
  }

  .vertical-list {
    display: grid;
    gap: 10px;
  }

  .faq-list {
    display: grid;
    gap: 16px;
  }

  .faq-item h3 {
    margin: 0 0 8px;
  }

  .faq-item + .faq-item {
    padding-top: 16px;
    border-top: 1px solid rgba(31, 26, 23, 0.08);
  }

  .faq-item p {
    margin: 0;
  }

  .join-side-panel {
    display: grid;
    gap: 18px;
    align-content: start;
  }

  .registration-shell {
    grid-template-columns: minmax(0, 1.45fr) minmax(280px, 0.85fr);
    scroll-margin-top: 24px;
  }

  .registration-panel h2 {
    margin: 14px 0 10px;
    font-size: clamp(1.7rem, 3vw, 2.3rem);
  }

  .registration-copy {
    margin: 0 0 20px;
  }

  .submit-flow-grid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
    margin-bottom: 22px;
  }

  .submit-flow-card {
    display: grid;
    gap: 8px;
    padding: 16px;
    border-radius: 20px;
    border: 1px solid rgba(31, 26, 23, 0.08);
    background: rgba(255, 255, 255, 0.72);
  }

  .submit-flow-card span {
    color: var(--accent-strong);
    font-size: 0.78rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .submit-flow-card strong,
  .submit-flow-card p {
    margin: 0;
  }

  .submit-flow-card p {
    color: var(--muted);
    line-height: 1.65;
  }

  .registration-side {
    display: grid;
    gap: 18px;
    align-content: start;
    position: sticky;
    top: 104px;
  }

  @media (max-width: 1000px) {
    .join-hero-card,
    .decision-grid,
    .join-info-grid,
    .registration-shell,
    .submit-flow-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 720px) {
    .format-grid {
      grid-template-columns: 1fr;
    }

    .registration-side {
      position: static;
    }
  }
</style>
