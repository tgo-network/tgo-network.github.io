---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getJoinPage, getPublicApiBaseUrl } from "../lib/public-api";

const [page, apiBaseUrl] = await Promise.all([getJoinPage(), Promise.resolve(getPublicApiBaseUrl())]);
const applicationGuidance = [
  "尽量写清当前职责、团队范围与技术管理工作。",
  "如希望加入特定分会，建议写明目标城市与参与诉求。",
  "留下常用手机号与微信号，便于后续联系。"
];
const joinFaqPreview = page.faq[0];
const processPreview = page.process.slice(0, 3);
const processCards = processPreview.map((item, index) => ({
  index: index + 1,
  text: item
}));
---

<BaseLayout title="加入申请 | TGO 鲲鹏会" description={page.hero.summary}>
  <main class="page-shell page-stack detail-page-shell join-page-shell">
    <section class="section join-page-intro-section">
      <article class="panel detail-hero-card join-page-intro-card">
        <div class="detail-hero-copy join-page-intro-copy">
          <h1>加入申请</h1>
          <p class="detail-summary">{page.hero.summary}</p>

          <div class="hero-actions">
            <a class="button primary" href="#application-form">填写申请表</a>
            <a class="text-link" href="#join-overview">查看加入说明</a>
          </div>
        </div>

        <div class="detail-side-card join-page-intro-side">
          <p class="join-page-intro-label">申请流程</p>
          <div class="join-intro-process-grid">
            {
              processCards.map((item) => (
                <article class="join-intro-process-card">
                  <span class="join-intro-process-index">{item.index}</span>
                  <p>{item.text}</p>
                </article>
              ))
            }
          </div>
        </div>
      </article>
    </section>

    <section id="join-overview" class="section join-overview-section">
      <div class="join-overview-grid">
        <article class="panel detail-section-card join-overview-card">
          <h2>加入条件</h2>
          <ul class="join-overview-list">
            {page.conditions.map((item) => <li>{item}</li>)}
          </ul>
        </article>

        <article class="panel detail-section-card join-overview-card">
          <h2>成员权益</h2>
          <ul class="join-overview-list">
            {page.benefits.map((item) => <li>{item}</li>)}
          </ul>
        </article>
      </div>
    </section>

    <section id="application-form" class="section join-application-section">
      <div class="panel detail-section-card join-form-panel">
        <div class="join-form-head">
          <h2>填写申请表</h2>
          <p class="card-copy">请填写姓名、电话、微信号、邮箱、个人介绍与申请信息。提交后由工作人员继续审核与联系。</p>
        </div>

        <form class="form-panel" data-application-form data-api-base={apiBaseUrl}>
          <div class="form-grid">
            <label>
              <span>姓名</span>
              <input name="name" type="text" required minlength="2" />
            </label>

            <label>
              <span>手机号</span>
              <input name="phoneNumber" type="tel" required inputmode="tel" />
            </label>

            <label>
              <span>微信号</span>
              <input name="wechatId" type="text" />
            </label>

            <label>
              <span>邮箱</span>
              <input name="email" type="email" />
            </label>
          </div>

          <label>
            <span>个人介绍</span>
            <textarea name="introduction" rows="5" required minlength="20"></textarea>
          </label>

          <label>
            <span>申请信息</span>
            <textarea name="applicationMessage" rows="6" required minlength="20"></textarea>
          </label>

          <div class="form-actions">
            <button class="button primary" type="submit">提交申请</button>
            <p class="form-status" data-form-status>提交后会由工作人员进行审核与联系。</p>
          </div>
        </form>
      </div>

      <aside class="panel detail-side-card detail-sticky join-form-side">
        <div class="join-form-side-block">
          <h2>填写建议</h2>
          <ul class="join-overview-list join-side-list">
            {applicationGuidance.map((item) => <li>{item}</li>)}
          </ul>
        </div>

        {
          joinFaqPreview && (
            <div class="join-form-side-block join-faq-preview">
              <h2>{joinFaqPreview.question}</h2>
              <p>{joinFaqPreview.answer}</p>
              <a class="text-link" href="/faq">查看全部 FAQ</a>
            </div>
          )
        }
      </aside>
    </section>
  </main>

  <script>
    const form = document.querySelector("[data-application-form]");
    const status = document.querySelector("[data-form-status]");

    if (form instanceof HTMLFormElement && status instanceof HTMLElement) {
      form.addEventListener("submit", async (event) => {
        event.preventDefault();
        status.textContent = "提交中...";

        const formData = new FormData(form);
        const payload = Object.fromEntries(
          Array.from(formData.entries()).filter(([, value]) => typeof value === "string" && value.trim().length > 0)
        );
        const baseUrl = form.dataset.apiBase ?? "http://127.0.0.1:8787";

        try {
          const response = await fetch(new URL("/api/public/v1/join-applications", baseUrl), {
            method: "POST",
            headers: {
              "Content-Type": "application/json"
            },
            body: JSON.stringify(payload)
          });

          const result = await response.json();

          if (!response.ok) {
            const firstIssue = result.error?.details?.issues?.[0]?.message;
            status.textContent = firstIssue ?? result.error?.message ?? "申请提交失败，请稍后再试。";
            return;
          }

          status.textContent = `申请已提交，编号 ${result.data.id}。`;
          form.reset();
        } catch {
          status.textContent = "API 当前不可用，请先启动 apps/api 以测试完整流程。";
        }
      });
    }
  </script>
</BaseLayout>

<style>
  .join-page-intro-card {
    gap: 24px;
    align-items: stretch;
  }

  .join-overview-grid,
  .join-application-section {
    display: grid;
    gap: 18px;
  }

  .join-overview-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .join-page-intro-copy,
  .join-page-intro-side,
  .join-overview-card,
  .join-form-side,
  .join-form-side-block {
    display: grid;
    gap: 14px;
  }

  .join-page-intro-copy {
    align-content: center;
  }

  .join-page-intro-copy h1,
  .join-page-intro-side p,
  .join-overview-card h2,
  .join-form-head h2,
  .join-form-side h2 {
    margin: 0;
  }

  .join-page-intro-side li,
  .join-overview-list {
    color: var(--muted);
    line-height: 1.76;
  }

  .join-page-intro-side {
    padding: 22px;
    border-radius: 20px;
  }

  .join-page-intro-label {
    margin: 0;
    color: var(--accent-strong);
    font-size: 0.8rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .join-intro-process-grid,
  .join-overview-list {
    display: grid;
    gap: 10px;
  }

  .join-intro-process-grid {
    margin: 0;
    padding: 0;
  }

  .join-intro-process-card {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 12px;
    align-items: start;
    padding: 14px 16px;
    border-radius: 18px;
    border: 1px solid rgba(27, 23, 19, 0.08);
    background: rgba(255, 255, 255, 0.72);
  }

  .join-intro-process-card p {
    margin: 0;
    color: var(--muted);
    line-height: 1.76;
  }

  .join-intro-process-index {
    display: inline-grid;
    place-items: center;
    width: 28px;
    height: 28px;
    border-radius: 999px;
    background: rgba(138, 106, 67, 0.1);
    color: var(--accent-strong);
    font-size: 0.8rem;
    font-weight: 700;
  }

  .join-overview-list {
    margin: 0;
    padding-left: 20px;
  }

  .join-overview-card {
    padding: 24px;
  }

  .join-application-section {
    grid-template-columns: minmax(0, 1.12fr) minmax(300px, 0.88fr);
    align-items: start;
  }

  .join-form-panel {
    display: grid;
    gap: 18px;
  }

  .join-form-head {
    display: grid;
    gap: 10px;
    padding-bottom: 4px;
  }

  .join-overview-card h2,
  .join-form-head h2 {
    padding-bottom: 10px;
    border-bottom: 1px solid rgba(27, 23, 19, 0.08);
  }

  .join-faq-preview {
    padding-top: 2px;
  }

  .join-faq-preview p {
    margin: 0;
    color: var(--muted);
    line-height: 1.8;
  }

  .join-form-side-block {
    padding: 18px;
    border-radius: 18px;
    border: 1px solid rgba(27, 23, 19, 0.08);
    background: rgba(255, 255, 255, 0.72);
  }

  @media (max-width: 1100px) {
    .join-overview-grid {
      grid-template-columns: 1fr;
    }

    .join-application-section {
      grid-template-columns: 1fr;
    }
  }
</style>
