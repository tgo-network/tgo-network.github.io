---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getAboutPage } from "../lib/public-api";

const page = await getAboutPage();
const journeySections = page.sections.filter((section) => section.title !== "即刻申请加入 TGO 鲲鹏会");
const applySection = page.sections.find((section) => section.title === "即刻申请加入 TGO 鲲鹏会");
---

<BaseLayout title="关于我们 | TGO 鲲鹏会" description={page.hero.summary}>
  <main class="page-shell page-stack">
    <section class="page-intro about-page-intro">
      <div class="page-intro-copy">
        <div class="card-label">{page.hero.eyebrow}</div>
        <h1>{page.hero.title}</h1>
        <p>{page.hero.summary}</p>
      </div>
    </section>

    <section class="section about-section-overview">
      <div class="section-head section-head-stack">
        <div>
          <div class="card-label">活动模块</div>
          <h2>定义你的 TGO 鲲鹏会之旅</h2>
        </div>
      </div>

      <div class="about-overview-grid">
        {
          journeySections.map((section, index) => (
            <article class="panel about-overview-card">
              <div class="card-label">{String(index + 1).padStart(2, "0")}</div>
              <h3>{section.title}</h3>
            </article>
          ))
        }
      </div>
    </section>

    <section class="section about-content-grid">
      {
        journeySections.map((section) => (
          <article class="panel prose-panel about-content-card">
            <div class="card-label">关于 TGO</div>
            <h2>{section.title}</h2>
            {section.body.map((paragraph) => <p>{paragraph}</p>)}
          </article>
        ))
      }
    </section>

    {applySection && (
      <section class="section">
        <div class="panel about-apply-panel">
          <div>
            <div class="card-label">加入方式</div>
            <h2>{applySection.title}</h2>
            {applySection.body.map((paragraph) => <p class="card-copy">{paragraph}</p>)}
          </div>

          <div class="about-apply-actions">
            <a class="button primary" href="/join">查看加入申请</a>
            <a class="button secondary" href="/branches">浏览分会董事会</a>
          </div>
        </div>
      </section>
    )}
  </main>
</BaseLayout>

<style>
  .about-page-intro {
    padding-bottom: 16px;
  }

  .about-section-overview {
    display: grid;
    gap: 18px;
  }

  .about-overview-grid,
  .about-content-grid {
    display: grid;
    gap: 18px;
  }

  .about-overview-grid {
    grid-template-columns: repeat(4, minmax(0, 1fr));
  }

  .about-overview-card,
  .about-content-card {
    min-height: 100%;
  }

  .about-overview-card h3,
  .about-content-card h2,
  .about-apply-panel h2 {
    margin: 10px 0 0;
  }

  .about-content-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .about-content-card {
    padding: clamp(22px, 3vw, 30px);
  }

  .about-apply-panel {
    display: grid;
    gap: 20px;
    grid-template-columns: minmax(0, 1.1fr) minmax(300px, 0.9fr);
    align-items: center;
    background: linear-gradient(180deg, rgba(255, 251, 243, 0.98), rgba(246, 238, 226, 0.96));
  }

  .about-apply-actions {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    justify-content: flex-end;
  }

  @media (max-width: 900px) {
    .about-overview-grid,
    .about-content-grid,
    .about-apply-panel {
      grid-template-columns: 1fr;
    }

    .about-apply-actions {
      justify-content: flex-start;
    }
  }
</style>
