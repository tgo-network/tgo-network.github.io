---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getAboutPage } from "../lib/public-api.js";
import { officialAboutSections } from "../lib/official-content.js";

const page = await getAboutPage();
const leadSection = page.sections[0] ?? null;
const finalSection = page.sections.at(-1) ?? null;
const trailingSection = finalSection && /加入|申请/u.test(finalSection.title) ? finalSection : null;
const contentSections = (trailingSection ? page.sections.slice(1, -1) : page.sections.slice(1)).map((section, index) => ({
  ...section,
  visuals: officialAboutSections[index] ?? null
}));
const getVisibleImages = (images: (typeof officialAboutSections)[number]["images"]) => images.slice(0, Math.min(images.length, 2));
const ctaTitle = trailingSection?.title ?? "了解加入方式";
const ctaBody = trailingSection?.body[0] ?? "查看加入条件后提交申请，后续由工作人员继续审核与联系。";
---

<BaseLayout title="关于我们 | TGO 鲲鹏会" description={page.hero.summary}>
  <main class="page-shell page-stack detail-page-shell about-page-shell">
    <section class="section">
      <article class="panel detail-hero-card about-page-overview-card">
        <div class="detail-hero-copy about-page-overview-copy">
          <p class="about-page-overview-label">{page.hero.eyebrow}</p>
          <h1>{page.hero.title}</h1>
          <p class="detail-summary">{page.hero.summary}</p>

          <div class="hero-actions about-page-actions">
            <a class="button primary" href="/join">加入申请</a>
            <a class="text-link" href="/faq">查看 FAQ</a>
          </div>
        </div>

        {
          leadSection && (
            <div class="detail-side-card about-page-overview-side">
              <h2>{leadSection.title}</h2>
              {leadSection.body.map((paragraph) => <p>{paragraph}</p>)}
            </div>
          )
        }
      </article>
    </section>

    {
      contentSections.length > 0 && (
        <section class="section about-section-list">
          {
            contentSections.map((section, index) => {
              const externalLink = section.visuals?.link?.href.startsWith("http");
              const visibleImages = section.visuals ? getVisibleImages(section.visuals.images) : [];

              return (
                <article class:list={["panel detail-section-card about-section-card", index % 2 === 1 && "is-reversed"]}>
                  {
                    visibleImages.length > 0 && (
                      <div class:list={["about-section-media", visibleImages.length > 1 && "has-gallery"]}>
                        {visibleImages.map((image) => <img src={image.src} alt={image.alt} loading="lazy" />)}
                      </div>
                    )
                  }

                  <div class="about-section-copy">
                    <h2>{section.title}</h2>
                    {section.body.map((paragraph) => <p>{paragraph}</p>)}
                    {section.visuals?.link && (
                      <a class="text-link" href={section.visuals.link.href} target={externalLink ? "_blank" : undefined} rel={externalLink ? "noreferrer" : undefined}>
                        {section.visuals.link.label}
                      </a>
                    )}
                  </div>
                </article>
              );
            })
          }
        </section>
      )
    }

    <section class="section">
      <article class="panel detail-section-card about-cta-card">
        <div>
          <h2>{ctaTitle}</h2>
          <p class="card-copy">{ctaBody}</p>
        </div>

        <div class="about-cta-actions">
          <a class="button primary" href="/join">加入申请</a>
          <a class="text-link" href="/faq">查看 FAQ</a>
        </div>
      </article>
    </section>
  </main>
</BaseLayout>

<style>
  .about-section-list {
    display: grid;
    gap: 20px;
  }

  .about-page-overview-card {
    gap: 24px;
    align-items: stretch;
  }

  .about-page-overview-copy,
  .about-page-overview-side {
    display: grid;
    gap: 12px;
  }

  .about-page-overview-copy {
    align-content: center;
  }

  .about-page-overview-copy h1,
  .about-page-overview-side h2,
  .about-section-copy h2,
  .about-cta-card h2 {
    margin: 0;
  }

  .about-page-overview-side p,
  .about-section-copy p,
  .about-cta-card p {
    margin: 0;
    color: var(--muted);
    line-height: 1.84;
  }

  .about-page-overview-side {
    padding: 22px;
    border-radius: 20px;
    align-content: start;
    min-height: 100%;
    background: rgba(255, 255, 255, 0.64);
  }

  .about-page-overview-label {
    margin: 0;
    color: var(--accent-strong);
    font-size: 0.8rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .about-section-card {
    grid-template-columns: minmax(0, 0.94fr) minmax(0, 1.06fr);
    gap: 24px;
    align-items: center;
    padding: 24px;
  }

  .about-section-card.is-reversed {
    grid-template-columns: minmax(0, 1.06fr) minmax(0, 0.94fr);
  }

  .about-section-card.is-reversed .about-section-media {
    order: 2;
  }

  .about-section-card.is-reversed .about-section-copy {
    order: 1;
  }

  .about-section-media {
    display: grid;
    gap: 14px;
  }

  .about-section-media img {
    display: block;
    width: 100%;
    height: clamp(228px, 22vw, 300px);
    border-radius: 18px;
    object-fit: cover;
    background: rgba(255, 255, 255, 0.72);
    box-shadow: 0 14px 30px rgba(35, 28, 21, 0.08);
  }

  .about-section-media.has-gallery {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .about-section-media.has-gallery img {
    height: clamp(170px, 17vw, 208px);
  }

  .about-section-copy {
    display: grid;
    gap: 14px;
    align-content: start;
  }

  .about-section-copy p {
    max-width: 42rem;
  }

  .about-cta-card {
    grid-template-columns: minmax(0, 1fr) auto;
    align-items: center;
    padding: 24px;
  }

  .about-cta-actions {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    align-items: center;
    justify-content: flex-end;
  }

  @media (max-width: 980px) {
    .about-section-card,
    .about-section-card.is-reversed,
    .about-cta-card {
      grid-template-columns: 1fr;
    }

    .about-section-card.is-reversed .about-section-media,
    .about-section-card.is-reversed .about-section-copy {
      order: initial;
    }

    .about-cta-actions {
      justify-content: flex-start;
    }
  }

  @media (max-width: 720px) {
    .about-section-media.has-gallery {
      grid-template-columns: 1fr;
    }

    .about-section-media img,
    .about-section-media.has-gallery img {
      height: 210px;
    }
  }
</style>
