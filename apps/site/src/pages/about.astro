---
import BaseLayout from "../layouts/BaseLayout.astro";
import { officialAboutIntro, officialAboutSections } from "../lib/official-content";

const getVisibleImages = (images: typeof officialAboutSections[number]["images"]) => images.slice(0, Math.min(images.length, 2));
const aboutIntroSummary =
  "TGO 鲲鹏会是一个有边界的技术社群组织，通过城市分会、长期活动与同侪连接，让技术领导者持续学习、交流与共建。";
---

<BaseLayout title="关于我们 | TGO 鲲鹏会" description={officialAboutIntro.summary}>
  <main class="page-shell page-stack">
    <section class="section">
      <article class="panel about-intro-card">
        <h1>{officialAboutIntro.title}</h1>
        <p class="about-intro-summary">{aboutIntroSummary}</p>
      </article>
    </section>

    <section class="section about-section-list">
      {
        officialAboutSections.map((section, index) => {
          const externalLink = section.link?.href.startsWith("http");
          const visibleImages = getVisibleImages(section.images);

          return (
            <article class:list={["panel about-section-card", index % 2 === 1 && "is-reversed"]}>
              <div class:list={["about-section-media", visibleImages.length > 1 && "has-gallery"]}>
                {visibleImages.map((image) => <img src={image.src} alt={image.alt} loading="eager" />)}
              </div>

              <div class="about-section-copy">
                <h2>{section.title}</h2>
                {section.paragraphs.map((paragraph) => <p>{paragraph}</p>)}
                {section.link && (
                  <a class="text-link" href={section.link.href} target={externalLink ? "_blank" : undefined} rel={externalLink ? "noreferrer" : undefined}>
                    {section.link.label}
                  </a>
                )}
              </div>
            </article>
          );
        })
      }
    </section>

    <section class="section">
      <article class="panel about-cta-card">
        <div>
          <h2>了解加入方式</h2>
          <p class="card-copy">查看加入条件后提交申请，后续由工作人员继续审核与联系。</p>
        </div>

        <div class="about-cta-actions">
          <a class="button primary" href="/join">加入申请</a>
          <a class="text-link" href="/branches">分会董事会</a>
        </div>
      </article>
    </section>
  </main>
</BaseLayout>

<style>
  .about-section-list {
    display: grid;
    gap: 24px;
  }

  .about-intro-card {
    display: grid;
    gap: 14px;
    padding: clamp(24px, 3vw, 34px);
    background:
      radial-gradient(circle at top right, rgba(200, 161, 93, 0.14), transparent 28%),
      linear-gradient(180deg, rgba(255, 251, 243, 0.98), rgba(246, 238, 226, 0.96));
    border-color: rgba(157, 111, 49, 0.14);
  }

  .about-intro-card h1 {
    margin: 0;
    font-size: clamp(2rem, 4vw, 3rem);
  }

  .about-intro-summary {
    margin: 0;
    max-width: 52rem;
    color: var(--muted);
    line-height: 1.8;
  }

  .about-section-copy h2,
  .about-cta-card h2 {
    margin: 0;
  }

  .about-section-copy p,
  .about-cta-card p {
    margin-bottom: 0;
  }

  .about-section-card,
  .about-cta-card {
    display: grid;
    gap: 24px;
    align-items: center;
  }

  .about-section-card {
    grid-template-columns: minmax(0, 0.95fr) minmax(0, 1.05fr);
    padding: clamp(20px, 3vw, 28px);
  }

  .about-section-card.is-reversed {
    grid-template-columns: minmax(0, 1.05fr) minmax(0, 0.95fr);
  }

  .about-section-card.is-reversed .about-section-media {
    order: 2;
  }

  .about-section-card.is-reversed .about-section-copy {
    order: 1;
  }

  .about-section-media {
    display: grid;
    gap: 14px;
  }

  .about-section-media img {
    display: block;
    width: 100%;
    min-height: 220px;
    border-radius: 22px;
    object-fit: cover;
    background: rgba(255, 255, 255, 0.72);
    box-shadow: 0 20px 44px rgba(40, 28, 18, 0.12);
  }

  .about-section-media.has-gallery {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .about-section-copy {
    display: grid;
    gap: 14px;
    align-content: start;
  }

  .about-section-copy p {
    margin: 0;
    line-height: 1.82;
  }

  .about-cta-card {
    grid-template-columns: minmax(0, 1fr) auto;
    padding: clamp(22px, 3vw, 30px);
    background: linear-gradient(180deg, rgba(255, 251, 243, 0.98), rgba(246, 238, 226, 0.96));
  }

  .about-cta-actions {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    align-items: center;
    justify-content: flex-end;
  }

  @media (max-width: 980px) {
    .about-section-card,
    .about-section-card.is-reversed,
    .about-cta-card {
      grid-template-columns: 1fr;
    }

    .about-section-card.is-reversed .about-section-media,
    .about-section-card.is-reversed .about-section-copy {
      order: initial;
    }

    .about-cta-actions {
      justify-content: flex-start;
    }
  }

  @media (max-width: 640px) {
    .about-section-media.has-gallery {
      grid-template-columns: 1fr;
    }

    .about-section-media.has-gallery img:nth-child(n + 2) {
      display: none;
    }

    .about-section-media img {
      min-height: 180px;
    }
  }
</style>
