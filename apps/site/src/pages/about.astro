---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getAboutPage } from "../lib/public-api";

const page = await getAboutPage();
---

<BaseLayout title="关于我们 | TGO 鲲鹏会" description={page.hero.summary}>
  <main class="page-shell page-stack">
    <section class="hero">
      <div class="hero-card">
        <span class="eyebrow">{page.hero.eyebrow}</span>
        <h1>{page.hero.title}</h1>
        <p>{page.hero.summary}</p>
      </div>
    </section>

    <section class="section">
      <div class="grid grid-2">
        {
          page.sections.map((section) => (
            <article class="panel prose-panel">
              <div class="card-label">关于我们</div>
              <h2 class="card-title">{section.title}</h2>
              {section.body.map((paragraph) => <p>{paragraph}</p>)}
            </article>
          ))
        }
      </div>
    </section>
  </main>
</BaseLayout>
