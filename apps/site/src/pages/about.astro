---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getAboutPage, listBranches, listEvents, listMembers } from "../lib/public-api";

const [page, branches, members, events] = await Promise.all([getAboutPage(), listBranches(), listMembers(), listEvents()]);

const activityFormats = [
  {
    title: "私密小组活动",
    summary: "适合更高频、更稳定的小范围同侪交流，围绕真实问题持续复盘。"
  },
  {
    title: "年度团聚与区域聚会",
    summary: "把跨城市成员连接起来，让关系不只发生在一场活动之内。"
  },
  {
    title: "月度公开学习活动",
    summary: "以公开活动扩大主题影响力，同时继续保持质量、审核与组织节奏。"
  },
  {
    title: "全球经验对话",
    summary: "面向更广范围的技术领导者视角，吸收跨区域与跨行业的实践经验。"
  }
];
---

<BaseLayout title="关于我们 | TGO 鲲鹏会" description={page.hero.summary}>
  <main class="page-shell page-stack">
    <section class="hero">
      <div class="hero-card about-hero-card">
        <div class="about-hero-main">
          <span class="eyebrow">{page.hero.eyebrow}</span>
          <h1>{page.hero.title}</h1>
          <p>{page.hero.summary}</p>
        </div>

        <aside class="about-hero-aside">
          <article>
            <strong>{branches.length}</strong>
            <span>分会</span>
          </article>
          <article>
            <strong>{members.length}</strong>
            <span>公开成员</span>
          </article>
          <article>
            <strong>{events.length}</strong>
            <span>活动</span>
          </article>
        </aside>
      </div>
    </section>

    <section class="section">
      <div class="content-grid">
        {
          page.sections.map((section) => (
            <article class="panel prose-panel about-section-card">
              <div class="card-label">关于我们</div>
              <h2 class="card-title">{section.title}</h2>
              {section.body.map((paragraph) => <p>{paragraph}</p>)}
            </article>
          ))
        }
      </div>
    </section>

    <section class="section">
      <div class="section-head">
        <div>
          <div class="card-label">活动形式</div>
          <h2>社区价值通过持续的线下连接被放大</h2>
        </div>
      </div>

      <div class="activity-grid">
        {
          activityFormats.map((item) => (
            <article class="panel activity-card">
              <h3 class="card-title">{item.title}</h3>
              <p class="card-copy">{item.summary}</p>
            </article>
          ))
        }
      </div>
    </section>

    <section class="section">
      <div class="panel about-cta-panel">
        <div>
          <div class="card-label">下一步</div>
          <h2>如果你认同这样的组织方式，可以继续查看加入说明</h2>
          <p class="card-copy">
            先确认组织定位与加入方式，再决定是否提交正式申请；如果你更想先理解结构，也可以先浏览分会董事会与成员列表。
          </p>
        </div>
        <div class="about-cta-actions">
          <a class="button primary" href="/join">查看加入说明</a>
          <a class="button secondary" href="/branches">浏览分会董事会</a>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .about-hero-card {
    display: grid;
    gap: 22px;
    grid-template-columns: minmax(0, 1.2fr) minmax(260px, 0.8fr);
    background:
      radial-gradient(circle at top right, rgba(215, 179, 117, 0.16), transparent 24%),
      linear-gradient(180deg, rgba(255, 252, 246, 0.96), rgba(247, 241, 232, 0.94));
  }

  .about-hero-aside {
    display: grid;
    gap: 12px;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    align-content: start;
  }

  .about-hero-aside article {
    display: grid;
    gap: 4px;
    padding: 18px 14px;
    border-radius: 20px;
    background: rgba(255, 255, 255, 0.72);
    border: 1px solid rgba(31, 26, 23, 0.08);
    text-align: center;
  }

  .about-hero-aside strong {
    font-family: var(--font-display);
    font-size: 1.7rem;
  }

  .about-hero-aside span {
    color: var(--muted);
    font-size: 0.9rem;
  }

  .content-grid,
  .activity-grid {
    display: grid;
    gap: 18px;
  }

  .content-grid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .about-section-card {
    min-height: 100%;
  }

  .activity-grid {
    grid-template-columns: repeat(4, minmax(0, 1fr));
  }

  .activity-card {
    min-height: 100%;
    background: linear-gradient(180deg, rgba(255, 249, 239, 0.92), rgba(249, 242, 232, 0.96));
  }

  .about-cta-panel {
    display: flex;
    gap: 18px;
    align-items: flex-end;
    justify-content: space-between;
    background: linear-gradient(180deg, rgba(255, 249, 239, 0.96), rgba(245, 237, 226, 0.94));
  }

  .about-cta-panel h2 {
    margin: 8px 0 10px;
    font-size: clamp(1.6rem, 3vw, 2.2rem);
  }

  .about-cta-actions {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }

  @media (max-width: 1000px) {
    .about-hero-card,
    .content-grid,
    .activity-grid {
      grid-template-columns: 1fr;
    }

    .about-cta-panel {
      flex-direction: column;
      align-items: flex-start;
    }
  }

  @media (max-width: 720px) {
    .about-hero-aside {
      grid-template-columns: 1fr;
    }
  }
</style>
