---
import BaseLayout from "../layouts/BaseLayout.astro";
import { officialAboutIntro, officialAboutSections } from "../lib/official-content";

const getVisibleImages = (images: typeof officialAboutSections[number]["images"]) => images.slice(0, Math.min(images.length, 2));
---

<BaseLayout title="关于我们 | TGO 鲲鹏会" description={officialAboutIntro.summary}>
  <main class="page-shell page-stack">
    <section class="section">
      <article class="panel about-intro-card">
        <div class="about-intro-copy">
          <div class="card-label">{officialAboutIntro.label}</div>
          <h1>{officialAboutIntro.title}</h1>
          <p>{officialAboutIntro.summary}</p>
        </div>

        <div class="about-intro-lead">
          <div class="card-label">组织概览</div>
          <h2>{officialAboutIntro.leadTitle}</h2>
          <p>{officialAboutIntro.leadBody}</p>
        </div>
      </article>
    </section>

    <section class="section about-section-list">
      {
        officialAboutSections.map((section, index) => {
          const externalLink = section.link?.href.startsWith("http");
          const visibleImages = getVisibleImages(section.images);

          return (
            <article class:list={["panel about-section-card", index % 2 === 1 && "is-reversed"]}>
              <div class:list={["about-section-media", visibleImages.length > 1 && "has-gallery"]}>
                {visibleImages.map((image) => <img src={image.src} alt={image.alt} loading="eager" />)}
              </div>

              <div class="about-section-copy">
                <div class="about-section-index">{String(index + 1).padStart(2, "0")}</div>
                <h2>{section.title}</h2>
                {section.paragraphs.map((paragraph) => <p>{paragraph}</p>)}
                {section.link && (
                  <a class="text-link" href={section.link.href} target={externalLink ? "_blank" : undefined} rel={externalLink ? "noreferrer" : undefined}>
                    {section.link.label}
                  </a>
                )}
              </div>
            </article>
          );
        })
      }
    </section>

    <section class="section">
      <article class="panel about-cta-card">
        <div>
          <div class="card-label">加入 TGO</div>
          <h2>即刻申请加入 TGO 鲲鹏会</h2>
          <p class="card-copy">如果你希望进入一个长期、真实、面向科技领导者的学习社区，可以先查看加入说明，再提交申请信息。</p>
        </div>

        <div class="about-cta-actions">
          <a class="button primary" href="/join">查看加入申请</a>
          <a class="button secondary" href="/branches">浏览分会董事会</a>
        </div>
      </article>
    </section>
  </main>
</BaseLayout>

<style>
  .about-section-list {
    display: grid;
    gap: 24px;
  }

  .about-intro-card {
    display: grid;
    gap: 24px;
    grid-template-columns: minmax(0, 0.92fr) minmax(0, 1.08fr);
    padding: clamp(24px, 3vw, 34px);
    background:
      radial-gradient(circle at top right, rgba(200, 161, 93, 0.14), transparent 28%),
      linear-gradient(180deg, rgba(255, 251, 243, 0.98), rgba(246, 238, 226, 0.96));
    border-color: rgba(157, 111, 49, 0.14);
  }

  .about-intro-copy,
  .about-intro-lead {
    display: grid;
    gap: 12px;
    align-content: start;
  }

  .about-intro-copy h1 {
    margin: 0;
    font-size: clamp(2rem, 4vw, 3rem);
  }

  .about-intro-copy p,
  .about-intro-lead p {
    margin: 0;
    line-height: 1.82;
  }

  .about-intro-lead {
    padding: clamp(20px, 3vw, 28px);
    border-radius: 24px;
    background: rgba(255, 255, 255, 0.54);
    border: 1px solid rgba(157, 111, 49, 0.12);
  }

  .about-intro-lead h2,
  .about-section-copy h2,
  .about-cta-card h2 {
    margin: 0;
  }

  .about-section-copy p,
  .about-cta-card p {
    margin-bottom: 0;
  }

  .about-section-card,
  .about-cta-card {
    display: grid;
    gap: 24px;
    align-items: center;
  }

  .about-section-card {
    grid-template-columns: minmax(0, 0.95fr) minmax(0, 1.05fr);
    padding: clamp(20px, 3vw, 28px);
  }

  .about-section-card.is-reversed {
    grid-template-columns: minmax(0, 1.05fr) minmax(0, 0.95fr);
  }

  .about-section-card.is-reversed .about-section-media {
    order: 2;
  }

  .about-section-card.is-reversed .about-section-copy {
    order: 1;
  }

  .about-section-media {
    display: grid;
    gap: 14px;
  }

  .about-section-media img {
    display: block;
    width: 100%;
    min-height: 220px;
    border-radius: 22px;
    object-fit: cover;
    background: rgba(255, 255, 255, 0.72);
    box-shadow: 0 20px 44px rgba(40, 28, 18, 0.12);
  }

  .about-section-media.has-gallery {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .about-section-copy {
    display: grid;
    gap: 14px;
    align-content: start;
  }

  .about-section-index {
    display: inline-flex;
    align-items: center;
    width: fit-content;
    min-height: 34px;
    padding: 0 12px;
    border-radius: 999px;
    background: rgba(200, 161, 93, 0.12);
    color: var(--accent-strong);
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.08em;
  }

  .about-section-copy p {
    margin: 0;
    line-height: 1.82;
  }

  .about-cta-card {
    grid-template-columns: minmax(0, 1fr) auto;
    padding: clamp(22px, 3vw, 30px);
    background: linear-gradient(180deg, rgba(255, 251, 243, 0.98), rgba(246, 238, 226, 0.96));
  }

  .about-cta-actions {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    justify-content: flex-end;
  }

  @media (max-width: 980px) {
    .about-intro-card,
    .about-section-card,
    .about-section-card.is-reversed,
    .about-cta-card {
      grid-template-columns: 1fr;
    }

    .about-section-card.is-reversed .about-section-media,
    .about-section-card.is-reversed .about-section-copy {
      order: initial;
    }

    .about-cta-actions {
      justify-content: flex-start;
    }
  }

  @media (max-width: 640px) {
    .about-section-media.has-gallery {
      grid-template-columns: 1fr;
    }

    .about-section-media img {
      min-height: 180px;
    }
  }
</style>
