---
import BaseLayout from "../layouts/BaseLayout.astro";
import { officialAboutIntro, officialAboutSections } from "../lib/official-content";
---

<BaseLayout title="关于我们 | TGO 鲲鹏会" description={officialAboutIntro.summary}>
  <main class="page-shell page-stack">
    <section class="page-intro about-page-intro">
      <div class="page-intro-copy">
        <div class="card-label">{officialAboutIntro.label}</div>
        <h1>{officialAboutIntro.title}</h1>
        <p>{officialAboutIntro.summary}</p>
      </div>
    </section>

    <section class="section about-lead-section">
      <article class="panel about-lead-card">
        <div class="card-label">组织概览</div>
        <h2>{officialAboutIntro.leadTitle}</h2>
        <p>{officialAboutIntro.leadBody}</p>
      </article>
    </section>

    <section class="section about-section-list">
      {
        officialAboutSections.map((section, index) => {
          const externalLink = section.link?.href.startsWith("http");

          return (
            <article class:list={["panel about-section-card", index % 2 === 1 && "is-reversed"]}>
              <div class:list={["about-section-media", section.images.length > 1 && "has-gallery"]}>
                {section.images.map((image) => <img src={image.src} alt={image.alt} loading="lazy" />)}
              </div>

              <div class="about-section-copy">
                <div class="card-label">TGO 体验</div>
                <h2>{section.title}</h2>
                {section.paragraphs.map((paragraph) => <p>{paragraph}</p>)}
                {section.link && (
                  <a class="text-link" href={section.link.href} target={externalLink ? "_blank" : undefined} rel={externalLink ? "noreferrer" : undefined}>
                    {section.link.label}
                  </a>
                )}
              </div>
            </article>
          );
        })
      }
    </section>

    <section class="section">
      <article class="panel about-cta-card">
        <div>
          <div class="card-label">加入 TGO</div>
          <h2>即刻申请加入 TGO 鲲鹏会</h2>
          <p class="card-copy">如果你希望进入一个长期、真实、面向科技领导者的学习社区，可以先查看加入说明，再提交申请信息。</p>
        </div>

        <div class="about-cta-actions">
          <a class="button primary" href="/join">查看加入申请</a>
          <a class="button secondary" href="/branches">浏览分会董事会</a>
        </div>
      </article>
    </section>
  </main>
</BaseLayout>

<style>
  .about-page-intro,
  .about-section-list {
    display: grid;
    gap: 24px;
  }

  .about-page-intro {
    padding-bottom: 0;
  }

  .about-lead-card {
    padding: clamp(24px, 3vw, 32px);
    background: linear-gradient(180deg, rgba(255, 251, 243, 0.98), rgba(246, 238, 226, 0.96));
    border-color: rgba(157, 111, 49, 0.14);
  }

  .about-lead-card h2,
  .about-section-copy h2,
  .about-cta-card h2 {
    margin: 10px 0 0;
  }

  .about-lead-card p,
  .about-section-copy p,
  .about-cta-card p {
    margin-bottom: 0;
  }

  .about-section-card,
  .about-cta-card {
    display: grid;
    gap: 24px;
    align-items: center;
  }

  .about-section-card {
    grid-template-columns: minmax(0, 0.95fr) minmax(0, 1.05fr);
    padding: clamp(20px, 3vw, 28px);
  }

  .about-section-card.is-reversed {
    grid-template-columns: minmax(0, 1.05fr) minmax(0, 0.95fr);
  }

  .about-section-card.is-reversed .about-section-media {
    order: 2;
  }

  .about-section-card.is-reversed .about-section-copy {
    order: 1;
  }

  .about-section-media {
    display: grid;
    gap: 14px;
  }

  .about-section-media img {
    display: block;
    width: 100%;
    min-height: 220px;
    border-radius: 22px;
    object-fit: cover;
    background: rgba(255, 255, 255, 0.72);
    box-shadow: 0 20px 44px rgba(40, 28, 18, 0.12);
  }

  .about-section-media.has-gallery {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .about-section-media.has-gallery img:first-child:last-child,
  .about-section-media.has-gallery img:nth-child(3) {
    grid-column: 1 / -1;
  }

  .about-section-copy {
    display: grid;
    gap: 14px;
    align-content: start;
  }

  .about-section-copy p {
    margin: 0;
    line-height: 1.82;
  }

  .about-cta-card {
    grid-template-columns: minmax(0, 1fr) auto;
    padding: clamp(22px, 3vw, 30px);
    background: linear-gradient(180deg, rgba(255, 251, 243, 0.98), rgba(246, 238, 226, 0.96));
  }

  .about-cta-actions {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    justify-content: flex-end;
  }

  @media (max-width: 980px) {
    .about-section-card,
    .about-section-card.is-reversed,
    .about-cta-card {
      grid-template-columns: 1fr;
    }

    .about-section-card.is-reversed .about-section-media,
    .about-section-card.is-reversed .about-section-copy {
      order: initial;
    }

    .about-cta-actions {
      justify-content: flex-start;
    }
  }

  @media (max-width: 640px) {
    .about-section-media.has-gallery {
      grid-template-columns: 1fr;
    }

    .about-section-media img {
      min-height: 180px;
    }
  }
</style>
