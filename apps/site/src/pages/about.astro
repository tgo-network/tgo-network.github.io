---
import BaseLayout from "../layouts/BaseLayout.astro";
import { officialAboutIntro, officialAboutSections } from "../lib/official-content";

const getVisibleImages = (images: typeof officialAboutSections[number]["images"]) => images.slice(0, Math.min(images.length, 2));
---

<BaseLayout title="关于我们 | TGO 鲲鹏会" description={officialAboutIntro.summary}>
  <main class="page-shell page-stack about-page-shell">
    <section class="section">
      <article class="panel about-page-overview-card">
        <div class="about-page-overview-copy">
          <p class="page-eyebrow">关于我们</p>
          <h1>{officialAboutIntro.title}</h1>
          <p>{officialAboutIntro.summary}</p>
        </div>

        <div class="about-page-overview-side">
          <p class="about-page-overview-label">长期参与方式</p>
          <h2>{officialAboutIntro.leadTitle}</h2>
          <p>{officialAboutIntro.leadBody}</p>
        </div>
      </article>
    </section>

    <section class="section about-section-list">
      {
        officialAboutSections.map((section, index) => {
          const externalLink = section.link?.href.startsWith("http");
          const visibleImages = getVisibleImages(section.images);

          return (
            <article class:list={["panel about-section-card", index % 2 === 1 && "is-reversed"]}>
              <div class:list={["about-section-media", visibleImages.length > 1 && "has-gallery"]}>
                {visibleImages.map((image) => <img src={image.src} alt={image.alt} loading="lazy" />)}
              </div>

              <div class="about-section-copy">
                <h2>{section.title}</h2>
                {section.paragraphs.map((paragraph) => <p>{paragraph}</p>)}
                {section.link && (
                  <a class="text-link" href={section.link.href} target={externalLink ? "_blank" : undefined} rel={externalLink ? "noreferrer" : undefined}>
                    {section.link.label}
                  </a>
                )}
              </div>
            </article>
          );
        })
      }
    </section>

    <section class="section">
      <article class="panel about-cta-card">
        <div>
          <h2>了解加入方式</h2>
          <p class="card-copy">查看加入条件后提交申请，后续由工作人员继续审核与联系。</p>
        </div>

        <div class="about-cta-actions">
          <a class="button primary" href="/join">加入申请</a>
          <a class="button secondary" href="/faq">查看 FAQ</a>
        </div>
      </article>
    </section>
  </main>
</BaseLayout>

<style>
  .about-page-shell {
    padding-top: 10px;
    padding-bottom: 48px;
  }

  .about-section-list {
    display: grid;
    gap: 18px;
  }

  .about-page-overview-card {
    display: grid;
    gap: 24px;
    grid-template-columns: minmax(0, 1.04fr) minmax(300px, 0.96fr);
    align-items: start;
    padding: clamp(24px, 3vw, 32px);
    background: linear-gradient(180deg, rgba(255, 252, 246, 0.98), rgba(245, 238, 227, 0.92));
  }

  .about-page-overview-copy,
  .about-page-overview-side {
    display: grid;
    gap: 12px;
  }

  .about-page-overview-copy h1,
  .about-page-overview-side h2,
  .about-section-copy h2,
  .about-cta-card h2 {
    margin: 0;
  }

  .about-page-overview-copy h1 {
    font-size: clamp(2.1rem, 4vw, 3.3rem);
    line-height: 1.04;
  }

  .about-page-overview-copy p,
  .about-page-overview-side p,
  .about-section-copy p,
  .about-cta-card p {
    margin: 0;
    color: var(--muted);
    line-height: 1.84;
  }

  .about-page-overview-copy p:last-child {
    max-width: 42rem;
  }

  .about-page-overview-side {
    padding: 2px 0 0 22px;
    border-left: 1px solid rgba(27, 23, 19, 0.08);
  }

  .about-page-overview-label {
    color: var(--accent-strong);
    font-size: 0.8rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .about-section-card,
  .about-cta-card {
    display: grid;
    gap: 22px;
    align-items: center;
  }

  .about-section-card {
    grid-template-columns: minmax(0, 0.94fr) minmax(0, 1.06fr);
    padding: clamp(22px, 2.8vw, 30px);
    background: linear-gradient(180deg, rgba(255, 252, 246, 0.98), rgba(245, 238, 227, 0.92));
  }

  .about-section-card.is-reversed {
    grid-template-columns: minmax(0, 1.06fr) minmax(0, 0.94fr);
  }

  .about-section-card.is-reversed .about-section-media {
    order: 2;
  }

  .about-section-card.is-reversed .about-section-copy {
    order: 1;
  }

  .about-section-media {
    display: grid;
    gap: 14px;
  }

  .about-section-media img {
    display: block;
    width: 100%;
    height: clamp(240px, 24vw, 320px);
    border-radius: 18px;
    object-fit: cover;
    background: rgba(255, 255, 255, 0.72);
  }

  .about-section-media.has-gallery {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .about-section-media.has-gallery img {
    height: clamp(176px, 18vw, 220px);
  }

  .about-section-copy {
    display: grid;
    gap: 14px;
    align-content: start;
  }

  .about-section-copy p {
    max-width: 42rem;
  }

  .about-cta-card {
    grid-template-columns: minmax(0, 1fr) auto;
    padding: clamp(22px, 2.8vw, 30px);
    background: linear-gradient(180deg, rgba(255, 251, 243, 0.98), rgba(246, 238, 226, 0.96));
  }

  .about-cta-actions {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    align-items: center;
    justify-content: flex-end;
  }

  @media (max-width: 980px) {
    .about-page-overview-card,
    .about-section-card,
    .about-section-card.is-reversed,
    .about-cta-card {
      grid-template-columns: 1fr;
    }

    .about-page-overview-side {
      padding-left: 0;
      border-left: 0;
      border-top: 1px solid rgba(27, 23, 19, 0.08);
      padding-top: 18px;
    }

    .about-section-card.is-reversed .about-section-media,
    .about-section-card.is-reversed .about-section-copy {
      order: initial;
    }

    .about-cta-actions {
      justify-content: flex-start;
    }
  }

  @media (max-width: 720px) {
    .about-page-shell {
      padding-top: 4px;
    }

    .about-section-media.has-gallery {
      grid-template-columns: 1fr;
    }

    .about-section-media img,
    .about-section-media.has-gallery img {
      height: 210px;
    }
  }
</style>
