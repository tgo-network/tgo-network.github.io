---
import CollectionCard from "../../components/CollectionCard.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { formatCount, formatDate, formatDateRange } from "../../lib/format";
import { getCity, listCities } from "../../lib/public-api";

export const getStaticPaths = async () => {
  const cities = await listCities();

  return cities.map((city) => ({
    params: {
      slug: city.slug
    }
  }));
};

const slug = Astro.params.slug!;
const city = await getCity(slug);

if (!city) {
  throw new Error(`城市不存在：${slug}`);
}
---

<BaseLayout title={`${city.name} | 城市 | TGO Network`} description={city.summary}>
  <main class="page-shell page-stack">
    <section class="hero">
      <div class:list={["hero-card", { "hero-split": Boolean(city.coverImage), "hero-card-media": Boolean(city.coverImage) }]}>
        <div>
          <span class="eyebrow">城市详情</span>
          <h1>{city.name}</h1>
          <p>{city.summary}</p>
          <ul class="stat-row">
            <li>{formatCount(city.topicCount, "个主题")}</li>
            <li>{formatCount(city.articleCount, "篇文章")}</li>
            <li>{formatCount(city.eventCount, "场活动")}</li>
          </ul>
        </div>

        {
          city.coverImage && (
            <figure class="hero-figure">
              <img class="hero-image" src={city.coverImage.url} alt={city.coverImage.alt} />
            </figure>
          )
        }
      </div>
    </section>

    <section class="section detail-grid">
      <article class="panel prose-panel">
        <div class="card-label">城市叙事</div>
        <p>{city.body}</p>
      </article>

      <aside class="panel panel-soft">
        <div class="card-label">运营视角</div>
        <p class="card-copy">
          城市页是内容、活动与社群数据汇合的地方。它应该通过后台维护的关联关系保持更新，而不是依赖手工改模板。
        </p>
      </aside>
    </section>

    <section class="section">
      <div class="section-head">
        <div>
          <div class="card-label">精选文章</div>
          <h2>城市内容亮点</h2>
        </div>
      </div>
      <div class="grid grid-2">
        {
          city.featuredArticles.map((article) => (
            <CollectionCard
              href={`/articles/${article.slug}`}
              label={formatDate(article.publishedAt)}
              title={article.title}
              summary={article.excerpt}
              image={article.coverImage}
              meta={[article.authorName, article.city.name]}
            />
          ))
        }
      </div>
    </section>

    <section class="section">
      <div class="section-head">
        <div>
          <div class="card-label">近期活动</div>
          <h2>与这座城市绑定的公开活动页面</h2>
        </div>
      </div>
      <div class="grid grid-2">
        {
          city.upcomingEvents.map((event) => (
            <CollectionCard
              href={`/events/${event.slug}`}
              label={event.city.name}
              title={event.title}
              summary={event.summary}
              image={event.coverImage}
              meta={[formatDateRange(event.startsAt, event.endsAt), event.venueName]}
            />
          ))
        }
      </div>
    </section>

    <section class="section">
      <div class="section-head">
        <div>
          <div class="card-label">精选主题</div>
          <h2>定义这座城市页面的核心主题</h2>
        </div>
      </div>
      <div class="grid grid-3">
        {
          city.featuredTopics.map((topic) => (
            <CollectionCard
              href={`/topics/${topic.slug}`}
              label={formatCount(topic.articleCount, "篇文章")}
              title={topic.title}
              summary={topic.summary}
              image={topic.coverImage}
              meta={[formatCount(topic.eventCount, "场活动")]}
            />
          ))
        }
      </div>
    </section>
  </main>
</BaseLayout>
