---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Terms | TGO Network" description="Prototype terms notice for the TGO Network site.">
  <main class="page-shell page-stack">
    <section class="hero">
      <div class="hero-card">
        <span class="eyebrow">Static Page</span>
        <h1>Terms</h1>
        <p>
          The current implementation is a development-stage prototype for route structure, API contracts, and publishing
          workflows. Final legal terms should be reviewed and published through the content system before launch.
        </p>
      </div>
    </section>
  </main>
</BaseLayout>
