  <main class="page-shell page-stack">
    <section class="hero">
      <div class="hero-card">
        <span class="eyebrow">法律信息</span>
        <h1>使用条款</h1>
        <p>
          本页用于说明站点访问、内容使用、活动报名与相关服务的基本规则。
          正式版本的使用条款将由运营团队统一维护并发布。
        </p>
      </div>
    </section>
  </main>
</BaseLayout>
