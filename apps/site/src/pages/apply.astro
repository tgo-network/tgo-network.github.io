---
import { applicationTypeOptions } from "@tgo/shared";

import BaseLayout from "../layouts/BaseLayout.astro";
import { getPublicApiBaseUrl } from "../lib/public-api";

const apiBaseUrl = getPublicApiBaseUrl();
---

<BaseLayout title="申请 | TGO Network" description="接入共享申请 API 契约的公开申请表单。">
  <main class="page-shell page-stack">
    <section class="hero">
      <div class="hero-card hero-split">
        <div>
          <span class="eyebrow">公开表单</span>
          <h1>申请</h1>
          <p>
            这个表单会提交到 <code>/api/public/v1/applications</code>。当前它已经接入共享公开契约校验，并会返回演示回执，
            让前端流程可以提前和未来的正式后端保持一致。
          </p>
        </div>

        <aside class="panel panel-soft">
          <div class="card-label">这证明了什么</div>
          <ul class="meta-list">
            <li>共享的申请输入结构</li>
            <li>API 侧校验与友好的错误反馈</li>
            <li>静态 Astro 页面也能拥有真实提交流程</li>
          </ul>
        </aside>
      </div>
    </section>

    <section class="section">
      <form class="panel form-panel" data-application-form data-api-base={apiBaseUrl}>
        <div class="form-grid">
          <label>
            <span>申请类型</span>
            <select name="type" required>
              {applicationTypeOptions.map((option) => <option value={option.value}>{option.label}</option>)}
            </select>
          </label>

          <label>
            <span>姓名</span>
            <input name="name" type="text" required minlength="2" />
          </label>

          <label>
            <span>邮箱</span>
            <input name="email" type="email" required />
          </label>

          <label>
            <span>公司</span>
            <input name="company" type="text" />
          </label>

          <label>
            <span>城市</span>
            <input name="city" type="text" />
          </label>
        </div>

        <label>
          <span>申请说明</span>
          <textarea name="message" rows="6" required minlength="20"></textarea>
        </label>

        <div class="form-actions">
          <button class="button primary" type="submit">提交申请</button>
          <p class="form-status" data-form-status>已准备好对接公开 API 进行校验。</p>
        </div>
      </form>
    </section>
  </main>

  <script>
    const form = document.querySelector("[data-application-form]");
    const status = document.querySelector("[data-form-status]");

    if (form instanceof HTMLFormElement && status instanceof HTMLElement) {
      form.addEventListener("submit", async (event) => {
        event.preventDefault();
        status.textContent = "提交中...";

        const formData = new FormData(form);
        const payload = Object.fromEntries(formData.entries());
        const baseUrl = form.dataset.apiBase ?? "http://127.0.0.1:8787";

        try {
          const response = await fetch(new URL("/api/public/v1/applications", baseUrl), {
            method: "POST",
            headers: {
              "Content-Type": "application/json"
            },
            body: JSON.stringify(payload)
          });

          const result = await response.json();

          if (!response.ok) {
            const firstIssue = result.error?.details?.issues?.[0]?.message;
            status.textContent = firstIssue ?? result.error?.message ?? "申请提交失败，请稍后再试。";
            return;
          }

          status.textContent = `已收到申请，编号 ${result.data.id}。`;
          form.reset();
        } catch {
          status.textContent = "API 当前不可用，请先启动 apps/api 以测试完整流程。";
        }
      });
    }
  </script>
</BaseLayout>
