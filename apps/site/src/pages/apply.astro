---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="加入申请跳转中 | TGO 鲲鹏会" description="正在跳转至加入申请页面。">
  <main class="page-shell page-stack">
    <section class="hero">
      <div class="hero-card panel stack-sm">
        <span class="eyebrow">页面已合并</span>
        <h1>申请表已整合到加入申请页面</h1>
        <p>你可以在同一页面查看加入条件并直接提交申请资料。</p>
        <div class="hero-actions">
          <a class="button primary" href="/join#application-form">前往申请表</a>
          <a class="text-link" href="/join">查看加入申请</a>
        </div>
      </div>
    </section>
  </main>

  <script>
    window.location.replace("/join#application-form");
  </script>
</BaseLayout>
