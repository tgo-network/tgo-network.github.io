---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { listBranches } from "../../lib/public-api";

const branches = await listBranches();
const getBranchDisplayName = (branch: (typeof branches)[number]) => {
  const cityName = branch.cityName.trim();
  const normalizedName = branch.name.replace(/\s+/g, " ").trim();

  if (!cityName) {
    return normalizedName;
  }

  const duplicatedPrefix = `${cityName} `;

  if (normalizedName.startsWith(duplicatedPrefix)) {
    const remainder = normalizedName.slice(duplicatedPrefix.length).trim();

    if (remainder.startsWith(cityName)) {
      return remainder;
    }
  }

  return normalizedName;
};
---

<BaseLayout title="分会董事会 | TGO 鲲鹏会" description="查看各地分会董事会成员信息。">
  <main class="page-shell page-stack">
    <section class="section">
      <article class="panel branch-directory-intro">
        <div class="card-label">分会董事会</div>
        <h1>分会与董事会成员</h1>
      </article>
    </section>

    <section class="section branches-directory">
      <div class="branch-record-list">
        {
          branches.map((branch) => (
            <article id={branch.slug} class="panel branch-record">
              <div class="branch-record-head">
                <h2 class="branch-record-title">{getBranchDisplayName(branch)}</h2>
              </div>

              <div class="branch-board-grid">
                {
                  branch.boardMembers.map((member) => (
                    <article class="branch-board-card">
                      <div class="branch-board-media">
                        {
                          member.avatar ? (
                            <img class="branch-board-avatar" src={member.avatar.url} alt={member.avatar.alt} loading="lazy" />
                          ) : (
                            <div class="branch-board-avatar branch-board-avatar-fallback" aria-hidden="true">
                              {member.displayName.slice(0, 1)}
                            </div>
                          )
                        }
                      </div>

                      <div class="branch-board-copy">
                        <div class="card-label">{member.title}</div>
                        <h3>{member.displayName}</h3>
                        <p>{member.company}</p>
                      </div>
                    </article>
                  ))
                }
              </div>
            </article>
          ))
        }
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .branch-directory-intro {
    display: grid;
    gap: 10px;
    padding: clamp(24px, 3vw, 30px);
    background:
      radial-gradient(circle at top right, rgba(200, 161, 93, 0.14), transparent 26%),
      linear-gradient(180deg, rgba(255, 251, 244, 0.98), rgba(246, 239, 229, 0.96));
  }

  .branch-directory-intro h1 {
    margin: 0;
    font-size: clamp(2rem, 4vw, 3.1rem);
  }

  .branches-directory,
  .branch-record-list {
    display: grid;
    gap: 24px;
  }

  .branch-record-list {
    gap: 26px;
  }

  .branch-record {
    display: grid;
    gap: 20px;
    padding: clamp(22px, 3vw, 30px);
  }

  .branch-record-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
  }

  .branch-record-title {
    margin: 0;
    font-size: clamp(1.7rem, 3vw, 2.35rem);
  }

  .branch-board-grid {
    display: grid;
    gap: 18px;
    grid-template-columns: repeat(auto-fill, minmax(200px, 220px));
    justify-content: flex-start;
  }

  .branch-board-card {
    display: grid;
    gap: 14px;
    min-height: 100%;
    padding: 16px;
    border-radius: 22px;
    border: 1px solid rgba(31, 26, 23, 0.08);
    background: linear-gradient(180deg, rgba(255, 252, 246, 0.98), rgba(247, 240, 231, 0.96));
    transition: transform 180ms ease, border-color 180ms ease, box-shadow 180ms ease;
  }

  .branch-board-card:hover {
    transform: translateY(-3px);
    border-color: rgba(157, 111, 49, 0.24);
    box-shadow: 0 24px 42px rgba(40, 28, 18, 0.1);
  }

  .branch-board-media {
    overflow: hidden;
    border-radius: 18px;
    background: rgba(31, 26, 23, 0.06);
    aspect-ratio: 4 / 5;
  }

  .branch-board-avatar {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .branch-board-avatar-fallback {
    display: grid;
    place-items: center;
    height: 100%;
    background: linear-gradient(135deg, rgba(200, 161, 93, 0.94), rgba(157, 111, 49, 0.94));
    color: #fff7ef;
    font-family: var(--font-display);
    font-size: 1.6rem;
  }

  .branch-board-copy {
    display: grid;
    gap: 6px;
  }

  .branch-board-copy h3 {
    margin: 2px 0 0;
    font-size: 1.05rem;
  }

  .branch-board-copy p {
    margin: 0;
    color: var(--muted);
    line-height: 1.72;
    display: -webkit-box;
    overflow: hidden;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
  }

  @media (max-width: 640px) {
    .branch-board-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      justify-content: stretch;
    }
  }

  @media (max-width: 520px) {
    .branch-board-grid {
      grid-template-columns: 1fr;
    }

    .branch-board-card {
      grid-template-columns: 72px minmax(0, 1fr);
      align-items: center;
    }

    .branch-board-media {
      aspect-ratio: 1 / 1;
    }
  }
</style>
