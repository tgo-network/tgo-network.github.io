---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { listBranches } from "../../lib/public-api";

const branches = await listBranches();
const totalBoardMembers = branches.reduce((sum, branch) => sum + branch.boardMembers.length, 0);
---

<BaseLayout title="分会董事会 | TGO 鲲鹏会" description="查看各地分会与董事会成员信息。">
  <main class="page-shell page-stack">
    <section class="page-intro">
      <div class="page-intro-copy">
        <div class="card-label">分会董事会</div>
        <h1>分会与董事会成员</h1>
        <p>查看各地分会与董事会成员名单。</p>
      </div>
      <p class="page-intro-meta">{branches.length} 个分会 · {totalBoardMembers} 位董事会成员</p>
    </section>

    <section class="section branch-record-list">
      {
        branches.map((branch) => (
          <article id={branch.slug} class="panel branch-record">
            <div class="branch-record-head">
              <div>
                <div class="card-label">{branch.cityName}</div>
                <h2 class="branch-record-title">{branch.name}</h2>
              </div>
              <ul class="meta-list branch-record-meta">
                {branch.region && <li>{branch.region}</li>}
                <li>{branch.boardMembers.length} 位董事会成员</li>
              </ul>
            </div>

            {branch.summary && <p class="branch-record-summary">{branch.summary}</p>}

            <div class="branch-board-grid">
              {
                branch.boardMembers.map((member) => (
                  <article class="branch-board-card">
                    <div class="branch-board-head">
                      {
                        member.avatar ? (
                          <img class="branch-board-avatar" src={member.avatar.url} alt={member.avatar.alt} loading="lazy" />
                        ) : (
                          <div class="branch-board-avatar branch-board-avatar-fallback" aria-hidden="true">
                            {member.displayName.slice(0, 1)}
                          </div>
                        )
                      }

                      <div class="branch-board-copy">
                        <div class="card-label">{member.title}</div>
                        <h3>{member.displayName}</h3>
                        <p>{member.company}</p>
                      </div>
                    </div>
                  </article>
                ))
              }
            </div>
          </article>
        ))
      }
    </section>
  </main>
</BaseLayout>

<style>
  .branch-record-list {
    display: grid;
    gap: 22px;
  }

  .branch-record {
    display: grid;
    gap: 20px;
    padding: clamp(22px, 3vw, 30px);
  }

  .branch-record-head {
    display: flex;
    gap: 16px;
    justify-content: space-between;
    align-items: flex-start;
  }

  .branch-record-title {
    margin: 10px 0 0;
    font-size: clamp(1.7rem, 3vw, 2.4rem);
  }

  .branch-record-meta {
    margin-top: 0;
    justify-content: flex-end;
  }

  .branch-record-summary {
    margin: 0;
    color: var(--muted);
    line-height: 1.85;
  }

  .branch-board-grid {
    display: grid;
    gap: 16px;
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .branch-board-card {
    min-height: 100%;
    padding: 20px;
    border-radius: 22px;
    border: 1px solid rgba(31, 26, 23, 0.08);
    background: linear-gradient(180deg, rgba(255, 252, 246, 0.98), rgba(247, 240, 231, 0.96));
  }

  .branch-board-head {
    display: grid;
    gap: 14px;
    grid-template-columns: 72px minmax(0, 1fr);
    align-items: center;
  }

  .branch-board-avatar {
    width: 72px;
    height: 72px;
    border-radius: 22px;
    object-fit: cover;
    box-shadow: 0 16px 32px rgba(40, 28, 18, 0.12);
  }

  .branch-board-avatar-fallback {
    display: grid;
    place-items: center;
    background: linear-gradient(135deg, rgba(200, 161, 93, 0.94), rgba(157, 111, 49, 0.94));
    color: #fff7ef;
    font-family: var(--font-display);
    font-size: 1.4rem;
  }

  .branch-board-copy h3 {
    margin: 8px 0 6px;
    font-size: 1.2rem;
  }

  .branch-board-copy p {
    margin: 0;
    color: var(--muted);
    line-height: 1.7;
  }

  @media (max-width: 900px) {
    .branch-record-head,
    .branch-record-meta {
      flex-direction: column;
      align-items: flex-start;
    }

    .branch-board-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
