---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { sortByBranchOrder } from "../../lib/branch-order";
import { listBranches } from "../../lib/public-api";

const branches = sortByBranchOrder(await listBranches(), (branch) => branch);
const getBranchDisplayName = (branch: (typeof branches)[number]) => {
  const cityName = branch.cityName.trim();
  const normalizedName = branch.name.replace(/\s+/g, " ").trim();

  if (!cityName) {
    return normalizedName;
  }

  const duplicatedPrefix = `${cityName} `;

  if (normalizedName.startsWith(duplicatedPrefix)) {
    const remainder = normalizedName.slice(duplicatedPrefix.length).trim();

    if (remainder.startsWith(cityName)) {
      return remainder;
    }
  }

  return normalizedName;
};
---

<BaseLayout title="分会董事会 | TGO 鲲鹏会" description="查看各地分会董事会成员信息。">
  <main class="page-shell page-stack branch-directory-shell">
    <section class="section branch-directory-section">
      <div class="directory-header branch-directory-head">
        <p class="page-eyebrow">分会董事会</p>
        <h1>分会董事会</h1>
      </div>

      <div class="branch-record-list">
        {
          branches.map((branch) => (
            <article id={branch.slug} class="panel branch-record-card">
              <div class="branch-record-head">
                <h2 class="branch-record-title">{getBranchDisplayName(branch)}</h2>
              </div>

              <div class="branch-board-grid">
                {
                  branch.boardMembers.map((member) => (
                    <article class="branch-board-card">
                      <div class="branch-board-profile">
                        {
                          member.avatar ? (
                            <img class="branch-board-avatar" src={member.avatar.url} alt={member.avatar.alt} loading="lazy" />
                          ) : (
                            <div class="branch-board-avatar branch-board-avatar-fallback" aria-hidden="true">
                              {member.displayName.slice(0, 1)}
                            </div>
                          )
                        }

                        <div class="branch-board-copy">
                          <p class="branch-board-role">{member.title}</p>
                          <h3>{member.displayName}</h3>
                          <p class="branch-board-company">{member.company}</p>
                        </div>
                      </div>
                    </article>
                  ))
                }
              </div>
            </article>
          ))
        }
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .branch-directory-shell {
    padding-top: 10px;
    padding-bottom: 48px;
  }

  .branch-directory-section,
  .branch-record-list {
    display: grid;
    gap: 20px;
  }

  .branch-directory-head {
    padding-top: 6px;
  }

  .branch-record-card {
    display: grid;
    gap: 18px;
    padding: clamp(22px, 2.8vw, 30px);
    background: linear-gradient(180deg, rgba(255, 252, 246, 0.98), rgba(245, 238, 227, 0.92));
  }

  .branch-record-head h2,
  .branch-board-copy h3 {
    margin: 0;
  }

  .branch-record-head h2 {
    font-size: clamp(1.56rem, 2.4vw, 2.16rem);
    line-height: 1.12;
  }

  .branch-board-grid {
    display: grid;
    gap: 16px;
    grid-template-columns: repeat(auto-fit, minmax(248px, 1fr));
  }

  .branch-board-card {
    min-height: 100%;
    padding: 18px;
    border-radius: 20px;
    border: 1px solid rgba(27, 23, 19, 0.08);
    background: rgba(255, 255, 255, 0.72);
    transition: transform 180ms ease, border-color 180ms ease, box-shadow 180ms ease;
  }

  .branch-board-card:hover {
    transform: translateY(-2px);
    border-color: rgba(138, 106, 67, 0.18);
    box-shadow: 0 20px 40px rgba(35, 28, 21, 0.1);
  }

  .branch-board-profile {
    display: grid;
    gap: 14px;
    grid-template-columns: 72px minmax(0, 1fr);
    align-items: center;
  }

  .branch-board-avatar {
    width: 72px;
    height: 72px;
    border-radius: 18px;
    object-fit: cover;
    background: rgba(27, 23, 19, 0.06);
  }

  .branch-board-avatar-fallback {
    display: grid;
    place-items: center;
    border: 1px solid rgba(27, 23, 19, 0.08);
    background: linear-gradient(180deg, rgba(255, 254, 252, 0.96), rgba(239, 231, 220, 0.92));
    color: var(--accent-strong);
    font-family: var(--font-display);
    font-size: 1.46rem;
  }

  .branch-board-copy {
    display: grid;
    gap: 6px;
    align-content: start;
  }

  .branch-board-role {
    margin: 0;
    color: var(--accent-strong);
    font-size: 0.82rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .branch-board-company {
    margin: 0;
    color: var(--muted);
    line-height: 1.7;
  }

  @media (max-width: 720px) {
    .branch-directory-shell {
      padding-top: 4px;
    }

    .branch-board-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
