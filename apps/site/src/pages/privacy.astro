---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="隐私说明 | TGO 鲲鹏会" description="TGO 鲲鹏会站点隐私说明。">
  <main class="page-shell page-stack">
    <section class="hero">
      <div class="hero-card">
        <span class="eyebrow">法律信息</span>
        <h1>隐私说明</h1>
        <p>
          本页用于说明站点在浏览、申请与活动报名过程中涉及的信息处理规则。
          正式版本的隐私条款将由运营团队统一维护并发布。
        </p>
      </div>
    </section>
  </main>
</BaseLayout>
