---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Privacy | TGO Network" description="Prototype privacy notice for the TGO Network site.">
  <main class="page-shell page-stack">
    <section class="hero">
      <div class="hero-card">
        <span class="eyebrow">Static Page</span>
        <h1>Privacy</h1>
        <p>
          This prototype only stores demo content and validation receipts unless a real backend environment is configured.
          Once production systems are enabled, this page should be replaced with a full legal notice managed by staff.
        </p>
      </div>
    </section>
  </main>
</BaseLayout>
