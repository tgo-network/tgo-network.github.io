---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { orderBranchCities } from "../../lib/branch-order";
import { formatDateRange, formatRegistrationState } from "../../lib/format";
import { listEvents } from "../../lib/public-api";

const pageSize = 12;
const allEvents = await listEvents();
const normalizeSummary = (value: string) => value.replace(/\s+/g, " ").trim();
const getEventSummary = (value: string) => normalizeSummary(value) || "查看活动详情与报名信息。";
const getEventVenue = (value: string) => value.trim() || "地点待定";
const initialEvents = allEvents.slice(0, pageSize).map((event) => ({
  ...event,
  summary: getEventSummary(event.summary),
  venueName: getEventVenue(event.venueName)
}));
const initialMeta = {
  page: 1,
  pageCount: Math.max(1, Math.ceil(allEvents.length / pageSize)),
  cityOptions: orderBranchCities(Array.from(new Set(allEvents.map((event) => event.cityName).filter(Boolean))))
};
---

<BaseLayout title="活动 | TGO 鲲鹏会" description="查看各地分会活动与报名入口。">
  <main class="page-shell page-stack">
    <section class="section event-list-section">
      <div class="panel event-toolbar-panel toolbar-panel">
        <div class="event-toolbar-head">
          <div>
            <h1>各地分会活动</h1>
          </div>
        </div>

        <div class="filter-bar" data-event-filters>
          <button class="filter-chip is-active" type="button" data-city-filter="all">全部</button>
          {
            initialMeta.cityOptions.map((city) => (
              <button class="filter-chip" type="button" data-city-filter={city}>
                {city}
              </button>
            ))
          }
        </div>
      </div>

      <div class="event-grid" data-event-grid>
        {
          initialEvents.map((event) => (
            <article class="panel event-card">
              <a class="event-card-link" href={`/events/${event.slug}`}>
                <div class="event-card-media-shell">
                  {
                    event.coverImage ? (
                      <img class="event-card-media" src={event.coverImage.url} alt={event.coverImage.alt} loading="lazy" />
                    ) : (
                      <div class="event-card-placeholder">
                        <span>TGO 活动</span>
                        <strong>{event.cityName}</strong>
                      </div>
                    )
                  }
                </div>

                <div class="event-card-body">
                  <div class="event-card-head">
                    <div class="card-label">{event.cityName}</div>
                    <span class:list={["event-state", `event-state-${event.registrationState}`]}>
                      {formatRegistrationState(event.registrationState)}
                    </span>
                  </div>

                  <h2 class="event-card-title">{event.title}</h2>
                  <p class="event-card-summary">{event.summary}</p>

                  <div class="event-card-meta">
                    <p>{formatDateRange(event.startsAt, event.endsAt)}</p>
                    <p>{event.venueName}</p>
                  </div>

                  <span class="text-link">查看详情</span>
                </div>
              </a>
            </article>
          ))
        }
      </div>

      <div class="panel panel-soft empty-state" data-event-empty hidden={initialEvents.length > 0}>
        <div class="card-label">暂无活动</div>
        <p class="card-copy">当前城市下暂无可展示的活动。</p>
      </div>

      <div class="pagination-bar event-pagination-bar" data-event-pagination>
        <button class="button secondary pagination-button" type="button" data-event-page-prev disabled={initialMeta.page <= 1}>
          上一页
        </button>
        <button
          class="button secondary pagination-button"
          type="button"
          data-event-page-next
          disabled={initialMeta.page >= initialMeta.pageCount}
        >
          下一页
        </button>
      </div>
    </section>
  </main>

  <script define:vars={{ initialEvents: allEvents, pageSize }} is:inline>
    const events = Array.isArray(initialEvents) ? initialEvents : [];
    const filterRoot = document.querySelector("[data-event-filters]");
    const grid = document.querySelector("[data-event-grid]");
    const emptyState = document.querySelector("[data-event-empty]");
    const prevButton = document.querySelector("[data-event-page-prev]");
    const nextButton = document.querySelector("[data-event-page-next]");
    const buttons = filterRoot instanceof HTMLElement ? Array.from(filterRoot.querySelectorAll("[data-city-filter]")) : [];

    const escapeHtml = (value) =>
      String(value ?? "")
        .replaceAll("&", "&amp;")
        .replaceAll("<", "&lt;")
        .replaceAll(">", "&gt;")
        .replaceAll('"', "&quot;")
        .replaceAll("'", "&#39;");

    const normalizeSummary = (value) => String(value ?? "").replace(/\s+/g, " ").trim();
    const getEventSummary = (value) => normalizeSummary(value) || "查看活动详情与报名信息。";
    const getEventVenue = (value) => String(value ?? "").trim() || "地点待定";

    const formatRegistrationStateLabel = (state) => {
      switch (state) {
        case "open":
          return "开放报名";
        case "waitlist":
          return "候补中";
        case "closed":
          return "报名已关闭";
        case "not_open":
          return "暂未开放";
        default:
          return "状态待定";
      }
    };

    const formatEventDateRange = (startsAt, endsAt) => {
      const start = new Date(startsAt);
      const end = new Date(endsAt || startsAt);

      if (Number.isNaN(start.getTime()) || Number.isNaN(end.getTime())) {
        return "时间待定";
      }

      const formatDate = (value) =>
        new Intl.DateTimeFormat("zh-CN", {
          month: "numeric",
          day: "numeric",
          hour: "2-digit",
          minute: "2-digit"
        }).format(value);

      if (start.toDateString() === end.toDateString()) {
        return `${formatDate(start)} - ${new Intl.DateTimeFormat("zh-CN", {
          hour: "2-digit",
          minute: "2-digit"
        }).format(end)}`;
      }

      return `${formatDate(start)} - ${formatDate(end)}`;
    };

    const renderEventCard = (event) => {
      const summary = getEventSummary(event.summary);
      const venueName = getEventVenue(event.venueName);
      const media = event.coverImage
        ? `
          <img class="event-card-media" src="${escapeHtml(event.coverImage.url)}" alt="${escapeHtml(event.coverImage.alt)}" loading="lazy" />
        `
        : `
          <div class="event-card-placeholder">
            <span>TGO 活动</span>
            <strong>${escapeHtml(event.cityName || "活动")}</strong>
          </div>
        `;

      return `
        <article class="panel event-card">
          <a class="event-card-link" href="/events/${encodeURIComponent(event.slug)}">
            <div class="event-card-media-shell">
              ${media}
            </div>
            <div class="event-card-body">
              <div class="event-card-head">
                <div class="card-label">${escapeHtml(event.cityName)}</div>
                <span class="event-state event-state-${escapeHtml(event.registrationState)}">${formatRegistrationStateLabel(event.registrationState)}</span>
              </div>
              <h2 class="event-card-title">${escapeHtml(event.title)}</h2>
              <p class="event-card-summary">${escapeHtml(summary)}</p>
              <div class="event-card-meta">
                <p>${escapeHtml(formatEventDateRange(event.startsAt, event.endsAt))}</p>
                <p>${escapeHtml(venueName)}</p>
              </div>
              <span class="text-link">查看详情</span>
            </div>
          </a>
        </article>
      `;
    };

    const setButtonState = (activeCity) => {
      buttons.forEach((button) => {
        button.classList.toggle("is-active", button.dataset.cityFilter === activeCity);
      });
    };

    const syncLocation = (page, city) => {
      const search = new URLSearchParams(window.location.search);

      if (city === "all") {
        search.delete("city");
      } else {
        search.set("city", city);
      }

      if (page <= 1) {
        search.delete("page");
      } else {
        search.set("page", String(page));
      }

      const searchText = search.toString();
      const nextUrl = `${window.location.pathname}${searchText ? `?${searchText}` : ""}${window.location.hash}`;
      window.history.replaceState({}, "", nextUrl);
    };

    let currentPage = 1;
    let currentCity = "all";

    const getEventCity = (event) => event.cityName || "未标注城市";
    const getFilteredEvents = () =>
      currentCity === "all" ? events : events.filter((event) => getEventCity(event) === currentCity);

    const render = () => {
      if (!(grid instanceof HTMLElement) || !(emptyState instanceof HTMLElement)) {
        return;
      }

      const filteredEvents = getFilteredEvents();
      const pageCount = Math.max(1, Math.ceil(filteredEvents.length / pageSize));
      currentPage = Math.min(Math.max(currentPage, 1), pageCount);
      const startIndex = (currentPage - 1) * pageSize;
      const pageItems = filteredEvents.slice(startIndex, startIndex + pageSize);

      grid.innerHTML = pageItems.map((event) => renderEventCard(event)).join("");
      emptyState.hidden = pageItems.length > 0;

      if (prevButton instanceof HTMLButtonElement) {
        prevButton.disabled = currentPage <= 1;
      }

      if (nextButton instanceof HTMLButtonElement) {
        nextButton.disabled = currentPage >= pageCount;
      }

      syncLocation(currentPage, currentCity);
    };

    if (grid instanceof HTMLElement && emptyState instanceof HTMLElement) {
      const search = new URLSearchParams(window.location.search);
      const requestedCity = search.get("city") ?? "all";
      const requestedPage = Number.parseInt(search.get("page") ?? "1", 10);
      const initialCity = buttons.some((button) => button.dataset.cityFilter === requestedCity) ? requestedCity : "all";
      const initialPage = Number.isFinite(requestedPage) && requestedPage > 0 ? requestedPage : 1;

      currentCity = initialCity;
      currentPage = initialPage;
      setButtonState(currentCity);
      render();

      buttons.forEach((button) => {
        button.addEventListener("click", () => {
          currentCity = button.dataset.cityFilter ?? "all";
          currentPage = 1;
          setButtonState(currentCity);
          render();
        });
      });

      prevButton?.addEventListener("click", () => {
        if (currentPage > 1) {
          currentPage -= 1;
          render();
        }
      });

      nextButton?.addEventListener("click", () => {
        const filteredEvents = getFilteredEvents();
        const pageCount = Math.max(1, Math.ceil(filteredEvents.length / pageSize));

        if (currentPage < pageCount) {
          currentPage += 1;
          render();
        }
      });
    }
  </script>
</BaseLayout>

<style>
  .event-list-section,
  .event-toolbar-panel {
    display: grid;
    gap: 18px;
  }

  :global(.event-grid) {
    display: grid;
    gap: 18px;
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  :global(.event-card) {
    padding: 0;
    overflow: hidden;
  }

  :global(.event-card-link) {
    display: grid;
    min-height: 100%;
    grid-template-columns: 1fr;
    grid-template-rows: auto 1fr;
  }

  :global(.event-card-media-shell) {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 220px;
    padding: 0;
    overflow: hidden;
    border-bottom: 1px solid rgba(31, 26, 23, 0.08);
    background: rgba(255, 255, 255, 0.92);
  }

  :global(.event-card-media),
  :global(.event-card-placeholder) {
    display: block;
  }

  :global(.event-card-media) {
    width: auto;
    height: auto;
    max-width: 100%;
    max-height: min(260px, 24vw);
    border-radius: 0;
    background: rgba(255, 255, 255, 0.9);
  }

  :global(.event-card-placeholder) {
    display: grid;
    gap: 10px;
    place-content: center;
    width: 100%;
    min-height: 220px;
    padding: 20px;
    border-radius: 18px;
    color: var(--accent-ink);
    text-align: center;
  }

  :global(.event-card-placeholder span) {
    color: var(--accent-strong);
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  :global(.event-card-placeholder strong) {
    font-family: var(--font-display);
    font-size: 1.4rem;
    line-height: 1.3;
  }

  :global(.event-card-body) {
    display: grid;
    gap: 12px;
    padding: 20px 20px 22px;
    align-content: start;
    grid-template-rows: auto auto 1fr auto auto;
  }

  :global(.event-card-head) {
    display: flex;
    gap: 12px;
    align-items: flex-start;
    justify-content: space-between;
  }

  :global(.event-card-title) {
    margin: 0;
    font-size: 1.14rem;
    line-height: 1.5;
    min-height: 3em;
    display: -webkit-box;
    overflow: hidden;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
  }

  :global(.event-card-summary),
  :global(.event-card-meta p) {
    margin: 0;
    color: var(--muted);
    line-height: 1.72;
  }

  :global(.event-card-summary) {
    display: -webkit-box;
    overflow: hidden;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
    min-height: 3.45em;
  }

  :global(.event-card-meta) {
    display: grid;
    gap: 6px;
    padding-top: 2px;
  }

  :global(.event-state) {
    display: inline-flex;
    align-items: center;
    min-height: 32px;
    padding: 0 12px;
    border-radius: 999px;
    font-size: 0.84rem;
    font-weight: 700;
    white-space: nowrap;
  }

  :global(.event-state-open) {
    background: rgba(71, 148, 104, 0.14);
    color: #296847;
  }

  :global(.event-state-waitlist) {
    background: rgba(186, 134, 39, 0.16);
    color: #8a5a14;
  }

  :global(.event-state-closed),
  :global(.event-state-not_open) {
    background: rgba(108, 94, 85, 0.14);
    color: #5f5148;
  }

  :global(.event-card .text-link) {
    font-weight: 600;
  }

  @media (max-width: 1200px) {
    :global(.event-grid) {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 720px) {
    :global(.event-grid) {
      grid-template-columns: 1fr;
    }

    :global(.event-card-media-shell) {
      min-height: 190px;
    }

    :global(.event-card-media) {
      max-height: 220px;
    }
  }
</style>
