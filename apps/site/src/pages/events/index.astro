---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { formatDateRange, formatRegistrationState } from "../../lib/format";
import { getPublicApiBaseUrl, listEventPage } from "../../lib/public-api";

const initialEventPage = await listEventPage({ page: 1, pageSize: 24 });
const initialEvents = initialEventPage.items;
const initialMeta = initialEventPage.meta;
const apiBaseUrl = getPublicApiBaseUrl();
const closedLikeCount = initialMeta.registrationStateCounts.closed + initialMeta.registrationStateCounts.notOpen;
---

<BaseLayout title="活动 | TGO 鲲鹏会" description="查看近期活动、分会动态与公开报名入口。">
  <main class="page-shell page-stack">
    <section class="hero">
      <div class="hero-card event-hero-card">
        <div class="event-hero-main">
          <span class="eyebrow">活动</span>
          <h1>各地分会活动与公开报名入口</h1>
          <p>
            活动由工作人员后台发布，前台面向成员与访客展示城市、时间、地点、议程与报名状态。
            当前阶段活动支持开放报名，再由工作人员在后台进行审核确认。
          </p>
          <ul class="stat-row event-hero-stats">
            <li data-event-total>{initialMeta.total} 场活动</li>
            <li data-event-city-total>{initialMeta.cityOptions.length} 个城市</li>
            <li data-event-open-total>{initialMeta.registrationStateCounts.open} 场开放报名</li>
            <li data-event-waitlist-total>{initialMeta.registrationStateCounts.waitlist} 场候补中</li>
          </ul>
        </div>

        <aside class="event-hero-aside">
          <div>
            <div class="card-label card-label-on-dark">活动机制</div>
            <h2>公开报名 + 后台审核</h2>
            <p>
              当前活动保持开放提交，但是否通过、是否进入候补，以及后续联系与确认，
              都由工作人员在后台统一处理。
            </p>
          </div>

          <div class="event-hero-meta-grid">
            <article>
              <strong data-event-open-card>{initialMeta.registrationStateCounts.open}</strong>
              <span>开放报名</span>
            </article>
            <article>
              <strong data-event-waitlist-card>{initialMeta.registrationStateCounts.waitlist}</strong>
              <span>候补中</span>
            </article>
            <article>
              <strong data-event-closed-card>{closedLikeCount}</strong>
              <span>非开放</span>
            </article>
          </div>
        </aside>
      </div>
    </section>

    <section class="section">
      <div class="section-head">
        <div>
          <div class="card-label">活动形态</div>
          <h2>围绕技术管理者成长组织不同层次的线下交流</h2>
        </div>
      </div>

      <div class="format-grid">
        <article class="panel format-card">
          <div class="card-label">私密小组</div>
          <p class="card-copy">适合更高频、更稳定的小范围同侪交流，强调问题复盘与长期关系。</p>
        </article>
        <article class="panel format-card">
          <div class="card-label">闭门沙龙</div>
          <p class="card-copy">围绕技术战略、组织治理、工程效率等关键问题进行定向讨论。</p>
        </article>
        <article class="panel format-card">
          <div class="card-label">公开学习</div>
          <p class="card-copy">适合拓展外部连接与扩大触达范围，仍然保持主题与人群筛选。</p>
        </article>
        <article class="panel format-card">
          <div class="card-label">标杆走访</div>
          <p class="card-copy">通过进入企业现场获得更具体的组织观察、工程经验与业务协作启发。</p>
        </article>
      </div>
    </section>

    <section class="section">
      <div class="section-head section-head-stack">
        <div>
          <div class="card-label">城市筛选</div>
          <h2>按城市查看活动</h2>
        </div>
        <p class="section-note">活动默认按时间倒序展示，当前列表按 24 场一页加载，避免一次性展开全部历史活动。</p>
      </div>

      <div class="filter-bar" data-event-filters>
        <button class="filter-chip is-active" type="button" data-city-filter="all">全部城市</button>
        {
          initialMeta.cityOptions.map((city) => (
            <button class="filter-chip" type="button" data-city-filter={city}>
              {city}
            </button>
          ))
        }
      </div>
    </section>

    <section class="section" data-event-results-section>
      <div class="results-head">
        <div>
          <div class="card-label">活动列表</div>
          <h2>浏览已导入的公开活动</h2>
        </div>
        <p class="results-summary" data-event-page-summary>
          第 {initialMeta.page} / {initialMeta.pageCount} 页，当前显示 {initialEvents.length} 场，共 {initialMeta.total} 场
        </p>
      </div>

      <div class="event-grid" data-event-grid>
        {
          initialEvents.map((event) => (
            <article class="panel event-card">
              <a class="event-card-link" href={`/events/${event.slug}`}>
                {
                  event.coverImage && (
                    <div class="event-card-media-wrap">
                      <img class="event-card-media" src={event.coverImage.url} alt={event.coverImage.alt} loading="lazy" />
                    </div>
                  )
                }

                <div class="event-card-head">
                  <div>
                    <div class="card-label">{event.cityName}</div>
                    <h3 class="event-card-title">{event.title}</h3>
                  </div>
                  <span class:list={["event-state", `event-state-${event.registrationState}`]}>
                    {formatRegistrationState(event.registrationState)}
                  </span>
                </div>

                <p class="card-copy">{event.summary}</p>

                <ul class="event-meta-list">
                  <li>{formatDateRange(event.startsAt, event.endsAt)}</li>
                  <li>{event.venueName}</li>
                  {event.branch?.name && <li>{event.branch.name}</li>}
                </ul>

                <span class="text-link">查看活动详情</span>
              </a>
            </article>
          ))
        }
      </div>

      <div class="panel panel-soft empty-state" data-event-empty hidden={initialEvents.length > 0}>
        <div class="card-label">暂无结果</div>
        <p class="card-copy">当前城市筛选下还没有可展示的活动，请切换到其他城市继续查看。</p>
      </div>

      <div class="pagination-bar" data-event-pagination>
        <button class="button secondary pagination-button" type="button" data-event-page-prev disabled={initialMeta.page <= 1}>
          上一页
        </button>
        <span class="pagination-indicator" data-event-page-indicator>第 {initialMeta.page} / {initialMeta.pageCount} 页</span>
        <button
          class="button secondary pagination-button"
          type="button"
          data-event-page-next
          disabled={initialMeta.page >= initialMeta.pageCount}
        >
          下一页
        </button>
      </div>
    </section>
  </main>

  <script define:vars={{ apiBaseUrl, initialMeta, initialPageSize: initialMeta.pageSize, initialItemCount: initialEvents.length }} is:inline>
    const filterRoot = document.querySelector("[data-event-filters]");
    const grid = document.querySelector("[data-event-grid]");
    const emptyState = document.querySelector("[data-event-empty]");
    const prevButton = document.querySelector("[data-event-page-prev]");
    const nextButton = document.querySelector("[data-event-page-next]");
    const pageIndicator = document.querySelector("[data-event-page-indicator]");
    const pageSummary = document.querySelector("[data-event-page-summary]");
    const resultsSection = document.querySelector("[data-event-results-section]");
    const totalStat = document.querySelector("[data-event-total]");
    const cityTotalStat = document.querySelector("[data-event-city-total]");
    const openTotalStat = document.querySelector("[data-event-open-total]");
    const waitlistTotalStat = document.querySelector("[data-event-waitlist-total]");
    const openCard = document.querySelector("[data-event-open-card]");
    const waitlistCard = document.querySelector("[data-event-waitlist-card]");
    const closedCard = document.querySelector("[data-event-closed-card]");

    const buttons = filterRoot instanceof HTMLElement
      ? Array.from(filterRoot.querySelectorAll("[data-city-filter]"))
      : [];

    const escapeHtml = (value) =>
      String(value ?? "")
        .replaceAll("&", "&amp;")
        .replaceAll("<", "&lt;")
        .replaceAll(">", "&gt;")
        .replaceAll('"', "&quot;")
        .replaceAll("'", "&#39;");

    const formatRegistrationStateLabel = (state) => {
      switch (state) {
        case "open":
          return "开放报名";
        case "waitlist":
          return "候补中";
        case "closed":
          return "报名已关闭";
        case "not_open":
          return "暂未开放";
        default:
          return "状态待定";
      }
    };

    const formatEventDateRange = (startsAt, endsAt) => {
      const start = new Date(startsAt);
      const end = new Date(endsAt || startsAt);

      if (Number.isNaN(start.getTime()) || Number.isNaN(end.getTime())) {
        return "时间待定";
      }

      const formatDate = (value) =>
        new Intl.DateTimeFormat("zh-CN", {
          month: "numeric",
          day: "numeric",
          hour: "2-digit",
          minute: "2-digit"
        }).format(value);

      const sameDay = start.toDateString() === end.toDateString();

      if (sameDay) {
        return `${formatDate(start)} - ${new Intl.DateTimeFormat("zh-CN", {
          hour: "2-digit",
          minute: "2-digit"
        }).format(end)}`;
      }

      return `${formatDate(start)} - ${formatDate(end)}`;
    };

    const renderEventCard = (event) => {
      const coverImage = event.coverImage
        ? `
          <div class="event-card-media-wrap">
            <img class="event-card-media" src="${escapeHtml(event.coverImage.url)}" alt="${escapeHtml(event.coverImage.alt)}" loading="lazy" />
          </div>
        `
        : "";
      const branchTag = event.branch?.name ? `<li>${escapeHtml(event.branch.name)}</li>` : "";

      return `
        <article class="panel event-card">
          <a class="event-card-link" href="/events/${encodeURIComponent(event.slug)}">
            ${coverImage}
            <div class="event-card-head">
              <div>
                <div class="card-label">${escapeHtml(event.cityName)}</div>
                <h3 class="event-card-title">${escapeHtml(event.title)}</h3>
              </div>
              <span class="event-state event-state-${escapeHtml(event.registrationState)}">${formatRegistrationStateLabel(event.registrationState)}</span>
            </div>
            <p class="card-copy">${escapeHtml(event.summary)}</p>
            <ul class="event-meta-list">
              <li>${escapeHtml(formatEventDateRange(event.startsAt, event.endsAt))}</li>
              <li>${escapeHtml(event.venueName)}</li>
              ${branchTag}
            </ul>
            <span class="text-link">查看活动详情</span>
          </a>
        </article>
      `;
    };

    const setButtonState = (activeCity) => {
      buttons.forEach((button) => {
        button.classList.toggle("is-active", button.dataset.cityFilter === activeCity);
      });
    };

    const updateStats = (meta) => {
      if (totalStat instanceof HTMLElement) {
        totalStat.textContent = `${meta.total} 场活动`;
      }

      if (cityTotalStat instanceof HTMLElement) {
        cityTotalStat.textContent = `${meta.cityOptions.length} 个城市`;
      }

      if (openTotalStat instanceof HTMLElement) {
        openTotalStat.textContent = `${meta.registrationStateCounts.open} 场开放报名`;
      }

      if (waitlistTotalStat instanceof HTMLElement) {
        waitlistTotalStat.textContent = `${meta.registrationStateCounts.waitlist} 场候补中`;
      }

      if (openCard instanceof HTMLElement) {
        openCard.textContent = String(meta.registrationStateCounts.open);
      }

      if (waitlistCard instanceof HTMLElement) {
        waitlistCard.textContent = String(meta.registrationStateCounts.waitlist);
      }

      if (closedCard instanceof HTMLElement) {
        closedCard.textContent = String(meta.registrationStateCounts.closed + meta.registrationStateCounts.notOpen);
      }
    };

    const updatePagination = (meta, itemCount) => {
      if (pageIndicator instanceof HTMLElement) {
        pageIndicator.textContent = `第 ${meta.page} / ${meta.pageCount} 页`;
      }

      if (pageSummary instanceof HTMLElement) {
        pageSummary.textContent = `第 ${meta.page} / ${meta.pageCount} 页，当前显示 ${itemCount} 场，共 ${meta.total} 场`;
      }

      if (prevButton instanceof HTMLButtonElement) {
        prevButton.disabled = meta.page <= 1;
      }

      if (nextButton instanceof HTMLButtonElement) {
        nextButton.disabled = meta.page >= meta.pageCount;
      }
    };

    const renderGrid = (events) => {
      if (!(grid instanceof HTMLElement) || !(emptyState instanceof HTMLElement)) {
        return;
      }

      grid.innerHTML = events.map((event) => renderEventCard(event)).join("");
      emptyState.hidden = events.length > 0;
    };

    const setLoading = (loading) => {
      if (grid instanceof HTMLElement) {
        grid.toggleAttribute("aria-busy", loading);
      }

      if (prevButton instanceof HTMLButtonElement) {
        prevButton.disabled = loading || prevButton.disabled;
      }

      if (nextButton instanceof HTMLButtonElement) {
        nextButton.disabled = loading || nextButton.disabled;
      }

      buttons.forEach((button) => {
        button.disabled = loading;
      });
    };

    const buildApiUrl = (page, city) => {
      const url = new URL("/api/public/v1/events", apiBaseUrl);
      url.searchParams.set("page", String(page));
      url.searchParams.set("pageSize", String(initialPageSize));

      if (city !== "all") {
        url.searchParams.set("city", city);
      }

      return url;
    };

    const syncLocation = (page, city) => {
      const search = new URLSearchParams(window.location.search);

      if (city === "all") {
        search.delete("city");
      } else {
        search.set("city", city);
      }

      if (page <= 1) {
        search.delete("page");
      } else {
        search.set("page", String(page));
      }

      const nextQuery = search.toString();
      const nextUrl = `${window.location.pathname}${nextQuery ? `?${nextQuery}` : ""}${window.location.hash}`;
      window.history.replaceState({}, "", nextUrl);
    };

    let currentPage = initialMeta.page;
    let currentCity = "all";

    const fetchPage = async (page, city) => {
      const response = await fetch(buildApiUrl(page, city), {
        headers: {
          Accept: "application/json"
        }
      });

      if (!response.ok) {
        throw new Error(`Failed to load events: ${response.status}`);
      }

      const payload = await response.json();
      return {
        items: Array.isArray(payload.data) ? payload.data : [],
        meta: payload.meta ?? initialMeta
      };
    };

    const applyPage = async (page, city, options = {}) => {
      const { shouldScroll = false } = options;

      try {
        setLoading(true);
        const result = await fetchPage(page, city);
        currentPage = result.meta.page;
        currentCity = city;
        setButtonState(currentCity);
        renderGrid(result.items);
        updateStats(result.meta);
        updatePagination(result.meta, result.items.length);
        syncLocation(currentPage, currentCity);

        if (shouldScroll && resultsSection instanceof HTMLElement) {
          resultsSection.scrollIntoView({ behavior: "smooth", block: "start" });
        }
      } catch (error) {
        console.error(error);
      } finally {
        setLoading(false);
      }
    };

    if (filterRoot instanceof HTMLElement && grid instanceof HTMLElement && emptyState instanceof HTMLElement) {
      const search = new URLSearchParams(window.location.search);
      const requestedCity = search.get("city") ?? "all";
      const requestedPage = Number.parseInt(search.get("page") ?? "1", 10);
      const initialCity = buttons.some((button) => button.dataset.cityFilter === requestedCity) ? requestedCity : "all";
      const initialPage = Number.isFinite(requestedPage) && requestedPage > 0 ? requestedPage : 1;

      setButtonState(initialCity);
      updateStats(initialMeta);
      updatePagination(initialMeta, initialItemCount);
      currentCity = initialCity;
      currentPage = initialPage;

      if (initialCity !== "all" || initialPage !== 1) {
        applyPage(initialPage, initialCity);
      }

      buttons.forEach((button) => {
        button.addEventListener("click", () => {
          const nextCity = button.dataset.cityFilter ?? "all";
          applyPage(1, nextCity, { shouldScroll: true });
        });
      });

      prevButton?.addEventListener("click", () => {
        if (currentPage > 1) {
          applyPage(currentPage - 1, currentCity, { shouldScroll: true });
        }
      });

      nextButton?.addEventListener("click", () => {
        applyPage(currentPage + 1, currentCity, { shouldScroll: true });
      });
    }
  </script>
</BaseLayout>

<style>
  .event-hero-card {
    display: grid;
    gap: 22px;
    grid-template-columns: minmax(0, 1.2fr) minmax(300px, 0.8fr);
    background:
      radial-gradient(circle at top right, rgba(215, 179, 117, 0.18), transparent 24%),
      linear-gradient(135deg, #171717 0%, #201c17 100%);
    border-color: rgba(215, 179, 117, 0.14);
    color: #f8f1e8;
  }

  .event-hero-card h1,
  .event-hero-card h2 {
    color: #fff7ef;
  }

  .event-hero-card p,
  .event-hero-card .card-copy {
    color: rgba(248, 241, 232, 0.76);
  }

  .event-hero-card .eyebrow {
    color: #f1d5a0;
    border-color: rgba(215, 179, 117, 0.28);
    background: rgba(255, 255, 255, 0.06);
  }

  .event-hero-aside {
    display: grid;
    gap: 18px;
    padding: 22px;
    border-radius: 24px;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(215, 179, 117, 0.12);
  }

  .event-hero-meta-grid {
    display: grid;
    gap: 12px;
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .event-hero-meta-grid article {
    display: grid;
    gap: 4px;
    padding: 14px;
    border-radius: 18px;
    background: rgba(255, 255, 255, 0.06);
    text-align: center;
  }

  .event-hero-meta-grid strong {
    font-family: var(--font-display);
    font-size: 1.7rem;
    color: #fffdf8;
  }

  .event-hero-meta-grid span {
    color: rgba(248, 241, 232, 0.7);
    font-size: 0.9rem;
  }

  .event-hero-stats {
    margin-top: 24px;
  }

  .section-head-stack {
    align-items: flex-start;
  }

  .section-note {
    margin: 10px 0 0;
    color: var(--muted);
    max-width: 56ch;
  }

  .format-grid {
    display: grid;
    gap: 18px;
    grid-template-columns: repeat(4, minmax(0, 1fr));
  }

  .format-card {
    min-height: 100%;
    background: linear-gradient(180deg, rgba(255, 249, 239, 0.92), rgba(249, 242, 232, 0.96));
  }

  .filter-bar {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
  }

  .filter-chip {
    padding: 10px 16px;
    border-radius: 999px;
    border: 1px solid rgba(31, 26, 23, 0.1);
    background: rgba(255, 255, 255, 0.84);
    color: inherit;
    font: inherit;
    cursor: pointer;
    transition: transform 180ms ease, border-color 180ms ease, background 180ms ease;
  }

  .filter-chip:hover {
    transform: translateY(-1px);
    border-color: rgba(157, 111, 49, 0.32);
  }

  .filter-chip.is-active {
    background: linear-gradient(135deg, rgba(157, 111, 49, 0.95), rgba(200, 161, 93, 0.92));
    border-color: transparent;
    color: #fff7ef;
  }

  .results-head {
    display: flex;
    gap: 16px;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 18px;
  }

  .results-summary {
    margin: 0;
    color: var(--muted);
    font-size: 0.95rem;
  }

  .event-grid {
    display: grid;
    gap: 18px;
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .event-grid[aria-busy="true"] {
    opacity: 0.72;
    pointer-events: none;
  }

  .event-card {
    padding: 0;
    overflow: hidden;
  }

  .event-card-link {
    display: grid;
    gap: 0;
    height: 100%;
  }

  .event-card-media-wrap {
    border-bottom: 1px solid rgba(31, 26, 23, 0.08);
  }

  .event-card-media {
    display: block;
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
  }

  .event-card-head,
  .event-meta-list {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    justify-content: space-between;
  }

  .event-card-link > :not(.event-card-media-wrap) {
    padding-left: 24px;
    padding-right: 24px;
  }

  .event-card-head {
    align-items: flex-start;
    padding-top: 24px;
  }

  .event-card-title {
    margin: 10px 0 0;
    font-size: 1.4rem;
  }

  .event-state {
    display: inline-flex;
    align-items: center;
    min-height: 32px;
    padding: 0 12px;
    border-radius: 999px;
    font-size: 0.84rem;
    font-weight: 700;
    white-space: nowrap;
  }

  .event-state-open {
    background: rgba(71, 148, 104, 0.14);
    color: #296847;
  }

  .event-state-waitlist {
    background: rgba(186, 134, 39, 0.16);
    color: #8a5a14;
  }

  .event-state-closed,
  .event-state-not_open {
    background: rgba(108, 94, 85, 0.14);
    color: #5f5148;
  }

  .event-card .card-copy {
    margin: 16px 0 0;
  }

  .event-meta-list {
    list-style: none;
    margin: 18px 0 0;
    padding: 0 24px 22px;
  }

  .event-meta-list li {
    padding: 8px 12px;
    border-radius: 999px;
    border: 1px solid rgba(31, 26, 23, 0.08);
    background: rgba(255, 255, 255, 0.66);
    color: var(--muted);
    font-size: 0.92rem;
  }

  .event-card .text-link {
    padding-bottom: 24px;
    font-weight: 600;
  }

  .empty-state {
    margin-top: 18px;
  }

  .pagination-bar {
    display: flex;
    gap: 12px;
    justify-content: center;
    align-items: center;
    margin-top: 22px;
    flex-wrap: wrap;
  }

  .pagination-button {
    min-width: 118px;
    justify-content: center;
  }

  .pagination-indicator {
    color: var(--muted);
    font-size: 0.95rem;
  }

  @media (max-width: 1000px) {
    .event-hero-card,
    .event-grid,
    .format-grid {
      grid-template-columns: 1fr;
    }

    .results-head {
      flex-direction: column;
      align-items: flex-start;
    }
  }

  @media (max-width: 720px) {
    .event-hero-meta-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
