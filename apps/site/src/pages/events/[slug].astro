---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { formatDateRange, formatRegistrationState } from "../../lib/format";
import { shouldShowExternalRegistrationLink, stripEventDisplayUrls } from "../../lib/event-registration";
import { getEvent, getPublicWriteApiBaseUrl } from "../../lib/public-api";
import { getEventStaticPaths } from "../../lib/event-directory";
import { normalizeLegacyEventMarkdown, renderMarkdownToHtml } from "@tgo/shared";

export const getStaticPaths = async () =>
  (await getEventStaticPaths()).map(({ params }) => ({
    params,
    props: {
      slug: params.slug
    }
  }));

const slug = Astro.props.slug;
const event = await getEvent(slug);
const apiBaseUrl = getPublicWriteApiBaseUrl();

if (!event) {
  throw new Error(`活动不存在：${slug}`);
}

const registrationEnabled = event.registrationState === "open" || event.registrationState === "waitlist";
const registrationTitle = event.registrationState === "waitlist" ? "加入候补名单" : "活动报名";
const registrationSubmitLabel = event.registrationState === "waitlist" ? "加入候补" : "提交报名";
const branchName = event.branch?.name ?? `${event.cityName}活动`;
const eventLocation = event.venueAddress || event.venueName;
const sanitizedEventSummary = stripEventDisplayUrls(event.summary) || event.title;
const eventBodyMarkdown = normalizeLegacyEventMarkdown(event.body || sanitizedEventSummary);
const eventBodyHtml = renderMarkdownToHtml(eventBodyMarkdown || sanitizedEventSummary);
const registrationUrl = event.registrationUrl;
const showExternalRegistrationLink = shouldShowExternalRegistrationLink(event.registrationState, registrationUrl);
const registrationCopy =
  event.registrationState === "closed"
    ? "报名已结束，当前页面保留活动详情与议程信息，方便继续查看内容安排。"
    : event.registrationState === "not_open"
      ? "当前活动尚未开放报名，可先查看活动信息并等待后续开放通知。"
      : event.registrationState === "waitlist"
        ? "当前活动进入候补阶段，提交后会进入候补审核流程，由工作人员继续联系确认。"
        : "开放报名，提交后由工作人员审核，并继续联系确认是否通过或转入候补。";
const heroMetaItems = [formatDateRange(event.startsAt, event.endsAt), branchName, formatRegistrationState(event.registrationState)];
const eventFactItems = [
  {
    label: "时间",
    value: formatDateRange(event.startsAt, event.endsAt)
  },
  {
    label: "地点",
    value: eventLocation
  },
  {
    label: "所属分会",
    value: branchName
  },
  {
    label: "报名状态",
    value: formatRegistrationState(event.registrationState)
  }
];
const registrationNoticeTitle = event.registrationState === "closed" ? "状态说明" : event.registrationState === "not_open" ? "报名说明" : "审核说明";
const registrationSideNotes =
  event.registrationState === "closed"
    ? [
        "活动详情与议程继续保留，方便回看内容安排。",
        "如需关注同城后续活动，可返回活动列表继续浏览。",
        "报名已结束，后续安排以工作人员通知为准。"
      ]
    : event.registrationState === "not_open"
      ? [
          "当前页面用于活动预热，报名开放时间以后续通知为准。",
          "可以先阅读活动正文与议程，判断是否适合继续关注。",
          "报名开启后，成员与非成员都可在前台提交信息。"
        ]
      : event.registrationState === "waitlist"
        ? [
            "当前活动进入候补阶段，继续提交后会进入候补队列。",
            "建议补充公司、职称与关注议题，方便工作人员判断递补优先级。",
            "如有名额释放，工作人员会继续联系确认。"
          ]
        : [
            "活动对成员与非成员都开放提交，报名后进入工作人员审核流程。",
            "建议填写完整的公司、职称与参会诉求，方便更快完成审核。",
            "审核通过后，工作人员会继续联系并确认参与方式。"
          ];
---

<BaseLayout title={`${event.title} | 活动 | TGO 鲲鹏会`} description={sanitizedEventSummary}>
  <main class="page-shell page-stack detail-page-shell event-detail-shell">
    <section class="section">
      <article class:list={["panel detail-hero-card event-detail-head-card", !event.coverImage && "detail-hero-card-single"]}>
        <div class="detail-hero-copy">
          <h1>{event.title}</h1>
          <p class="detail-summary">{sanitizedEventSummary}</p>

          <div class="detail-meta-row event-detail-meta">
            {heroMetaItems.map((item) => <span class="detail-meta-item">{item}</span>)}
          </div>

          <div class="hero-actions event-detail-actions">
            {registrationEnabled && <a class="button primary" href="#event-registration">{registrationTitle}</a>}
            <a class="text-link" href="/events">返回活动列表</a>
          </div>
        </div>

        {
          event.coverImage && (
            <figure class="detail-hero-figure">
              <img class="detail-hero-image event-detail-image" src={event.coverImage.url} alt={event.coverImage.alt} />
            </figure>
          )
        }
      </article>
    </section>

    <section class="section">
      <div class="detail-content-grid event-detail-layout">
        <div class="event-main-stack">
          <article class="panel prose-panel detail-body-panel event-body-panel">
            <div class="event-body-content markdown-prose" set:html={eventBodyHtml}></div>
          </article>

          {
            event.agenda.length > 0 && (
              <article class="panel detail-section-card event-agenda-panel">
                <h2>议程安排</h2>
                <ul class="agenda-list">
                  {
                    event.agenda.map((item) => (
                      <li>
                        <strong>{item.time}</strong>
                        <span>{item.title}</span>
                        {item.speaker ? <em>{item.speaker}</em> : null}
                        {stripEventDisplayUrls(item.summary) ? <p>{stripEventDisplayUrls(item.summary)}</p> : null}
                      </li>
                    ))
                  }
                </ul>
              </article>
            )
          }
        </div>

        <aside class="detail-side-stack event-side-stack detail-sticky">
          <article class="panel detail-side-card event-info-panel">
            <h2>活动信息</h2>
            <div class="event-fact-grid">
              {
                eventFactItems.map((item) => (
                  <article class="event-fact-card">
                    <span>{item.label}</span>
                    <strong>{item.value}</strong>
                  </article>
                ))
              }
            </div>
          </article>
        </aside>
      </div>
    </section>

    <section class="section registration-shell" id="event-registration">
      <div class="panel detail-section-card registration-panel">
        <div class="registration-head">
          <div class="registration-head-top">
            <h2>{registrationTitle}</h2>
            <span class="detail-meta-item registration-state-chip">{formatRegistrationState(event.registrationState)}</span>
          </div>
          <p class="registration-copy">{registrationCopy}</p>
        </div>

        {
          registrationEnabled ? (
            <form class="form-panel" data-event-registration-form data-api-base={apiBaseUrl ?? undefined} data-event-slug={event.slug}>
              <div class="form-grid registration-form-grid">
                <label>
                  <span>姓名</span>
                  <input name="name" type="text" required minlength="2" />
                </label>

                <label>
                  <span>手机号</span>
                  <input name="phoneNumber" type="tel" required inputmode="tel" />
                </label>

                <label>
                  <span>微信号</span>
                  <input name="wechatId" type="text" />
                </label>

                <label>
                  <span>邮箱</span>
                  <input name="email" type="email" />
                </label>

                <label>
                  <span>公司</span>
                  <input name="company" type="text" />
                </label>

                <label>
                  <span>职称</span>
                  <input name="title" type="text" />
                </label>
              </div>

              <label>
                <span>补充信息</span>
                <textarea name="note" rows="4" placeholder="例如你的关注议题、参会目的，或你希望在活动中交流的问题。"></textarea>
              </label>

              <div class="form-actions registration-actions-row">
                <div class="registration-actions">
                  <button class="button primary" type="submit">{registrationSubmitLabel}</button>
                  {
                    showExternalRegistrationLink && (
                      <a class="text-link registration-backup-link" href={registrationUrl!} target="_blank" rel="noreferrer">
                        如页面提交异常，可改用外部报名入口
                      </a>
                    )
                  }
                </div>
                <p class="form-status" data-event-registration-status>请至少填写姓名和手机号，便于工作人员联系。</p>
              </div>
            </form>
          ) : (
            <div class="registration-note">
              <p>{event.registrationState === "closed" ? "这场活动的报名已经关闭。" : "报名暂未开放，请稍后再来查看。"}</p>
            </div>
          )
        }
      </div>

      <aside class="panel detail-side-card detail-sticky registration-side">
        <div>
          <h2>{registrationNoticeTitle}</h2>
          <div class="registration-note-cards">
            {registrationSideNotes.map((item) => <article class="registration-note-card">{item}</article>)}
          </div>
        </div>

        <div class="event-next-links">
          <a class="text-link" href="/events">返回活动列表</a>
          {event.branch && <a class="text-link" href={`/branches#${event.branch.slug}`}>查看所属分会</a>}
        </div>
      </aside>
    </section>
  </main>

  <script>
    const form = document.querySelector("[data-event-registration-form]");
    const status = document.querySelector("[data-event-registration-status]");

    if (form instanceof HTMLFormElement && status instanceof HTMLElement) {
      form.addEventListener("submit", async (submitEvent) => {
        submitEvent.preventDefault();
        status.textContent = "提交中...";

        const formData = new FormData(form);
        const payload = Object.fromEntries(
          Array.from(formData.entries()).filter(([, value]) => typeof value === "string" && value.trim().length > 0)
        );
        const baseUrl = form.dataset.apiBase;
        const eventSlug = form.dataset.eventSlug;

        if (!eventSlug) {
          status.textContent = "活动配置不完整。";
          return;
        }

        const requestUrl = baseUrl
          ? new URL(`/api/public/v1/events/${eventSlug}/registrations`, baseUrl)
          : `/api/public/v1/events/${eventSlug}/registrations`;

        try {
          const response = await fetch(requestUrl, {
            method: "POST",
            headers: {
              "Content-Type": "application/json"
            },
            body: JSON.stringify(payload)
          });

          const result = await response.json();

          if (!response.ok) {
            const firstIssue = result.error?.details?.issues?.[0]?.message;
            status.textContent = firstIssue ?? result.error?.message ?? "报名提交失败，请稍后再试。";
            return;
          }

          status.textContent = `${result.data.status === "waitlisted" ? "已加入候补名单" : "报名已提交"}，编号 ${result.data.id}。`;
          form.reset();
        } catch {
          status.textContent = "API 当前不可用，请先启动 apps/api 以测试完整报名流程。";
        }
      });
    }
  </script>
</BaseLayout>

<style>
  .event-main-stack,
  .registration-shell {
    display: grid;
    gap: 18px;
  }

  .event-main-stack {
    align-content: start;
  }

  .event-detail-layout {
    grid-template-columns: minmax(0, 1.08fr) minmax(280px, 0.92fr);
  }

  .event-body-panel {
    display: grid;
    padding: clamp(22px, 2.6vw, 32px);
  }

  .event-body-content {
    display: grid;
    gap: 18px;
  }

  .event-side-stack {
    gap: 16px;
  }

  .registration-shell {
    grid-template-columns: minmax(0, 1.08fr) minmax(320px, 0.92fr);
    align-items: start;
  }

  .event-info-panel,
  .event-agenda-panel,
  .registration-panel,
  .registration-side {
    gap: 16px;
  }

  .event-info-panel h2,
  .event-agenda-panel h2,
  .registration-head h2,
  .registration-side h2 {
    margin: 0;
  }

  .event-fact-card span,
  .registration-copy,
  .registration-note-card,
  .registration-note p {
    color: var(--muted);
    line-height: 1.82;
  }

  .registration-copy,
  .registration-note p {
    margin: 0;
  }

  .event-fact-grid {
    display: grid;
    gap: 12px;
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .event-fact-card {
    display: grid;
    gap: 6px;
    padding: 16px 18px;
    border-radius: 18px;
    border: 1px solid rgba(27, 23, 19, 0.08);
    background: rgba(255, 255, 255, 0.72);
  }

  .event-fact-card span {
    font-size: 0.84rem;
    letter-spacing: 0.04em;
  }

  .event-fact-card strong {
    line-height: 1.7;
  }

  .registration-head {
    display: grid;
    gap: 10px;
  }

  .registration-head-top {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
  }

  .event-agenda-panel .agenda-list li {
    gap: 8px;
    padding: 18px;
  }

  .registration-state-chip {
    white-space: nowrap;
  }

  .registration-form-grid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .registration-actions-row {
    align-items: flex-start;
  }

  .registration-actions {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }

  .registration-note-cards {
    display: grid;
    gap: 12px;
  }

  .registration-backup-link {
    align-self: center;
    font-size: 0.95rem;
  }

  .registration-note-card {
    padding: 14px 16px;
    border-radius: 18px;
    border: 1px solid rgba(27, 23, 19, 0.08);
    background: rgba(255, 255, 255, 0.72);
  }

  .event-next-links {
    display: grid;
    gap: 12px;
  }

  .markdown-prose :global(h2),
  .markdown-prose :global(h3),
  .markdown-prose :global(h4) {
    margin: 8px 0 0;
    color: var(--ink);
    line-height: 1.3;
  }

  .markdown-prose :global(h2) {
    font-size: clamp(1.45rem, 2vw, 1.8rem);
  }

  .markdown-prose :global(h3) {
    font-size: clamp(1.18rem, 1.6vw, 1.38rem);
  }

  .markdown-prose :global(p),
  .markdown-prose :global(li),
  .markdown-prose :global(blockquote) {
    color: var(--muted);
    line-height: 1.9;
  }

  .markdown-prose :global(ul),
  .markdown-prose :global(ol) {
    display: grid;
    gap: 10px;
    margin: 0;
    padding-left: 1.35rem;
  }

  .markdown-prose :global(blockquote) {
    margin: 0;
    padding: 16px 18px;
    border-left: 3px solid rgba(185, 138, 66, 0.7);
    border-radius: 18px;
    background: rgba(255, 248, 238, 0.78);
  }

  .markdown-prose :global(pre) {
    margin: 0;
    padding: 18px 20px;
    overflow-x: auto;
    border-radius: 18px;
    background: #191612;
    color: #f7efe2;
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.04);
  }

  .markdown-prose :global(code) {
    font-family: "SFMono-Regular", "Consolas", "Monaco", monospace;
    font-size: 0.92em;
  }

  .markdown-prose :global(:not(pre) > code) {
    padding: 0.15rem 0.42rem;
    border-radius: 999px;
    background: rgba(185, 138, 66, 0.14);
    color: var(--accent-strong);
  }

  .markdown-prose :global(pre code) {
    color: inherit;
  }

  .markdown-prose :global(img) {
    display: block;
    width: 100%;
    border-radius: 22px;
    object-fit: cover;
    box-shadow: var(--shadow);
  }

  .markdown-prose :global(a) {
    color: var(--accent-strong);
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 0.18em;
  }

  .markdown-prose :global(table) {
    display: block;
    width: 100%;
    overflow-x: auto;
    border-collapse: collapse;
    border-radius: 18px;
    background: rgba(255, 255, 255, 0.84);
  }

  .markdown-prose :global(th),
  .markdown-prose :global(td) {
    padding: 14px 16px;
    border-bottom: 1px solid rgba(27, 23, 19, 0.08);
    text-align: left;
    vertical-align: top;
  }

  .markdown-prose :global(th) {
    color: var(--ink);
    background: rgba(255, 248, 238, 0.88);
  }

  .markdown-prose :global(hr) {
    width: 100%;
    height: 1px;
    border: 0;
    background: rgba(27, 23, 19, 0.08);
  }

  @media (max-width: 1100px) {
    .registration-shell {
      grid-template-columns: 1fr;
    }

    .event-fact-grid {
      grid-template-columns: 1fr;
    }

    .registration-form-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 980px) {
    .event-detail-layout {
      grid-template-columns: 1fr;
    }

    .event-detail-image {
      min-height: 260px;
    }
  }

  @media (max-width: 720px) {
    .event-detail-image {
      min-height: 220px;
    }

    .registration-form-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
