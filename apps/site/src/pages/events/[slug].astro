---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { formatDateRange, formatRegistrationState } from "../../lib/format";
import { getEvent, getPublicApiBaseUrl, listEvents } from "../../lib/public-api";

export const getStaticPaths = async () => {
  const events = await listEvents();

  return events.map((event) => ({
    params: {
      slug: event.slug
    }
  }));
};

const slug = Astro.params.slug!;
const event = await getEvent(slug);
const apiBaseUrl = getPublicApiBaseUrl();
const registrationEnabled = event?.registrationState === "open" || event?.registrationState === "waitlist";
const registrationTitle = event?.registrationState === "waitlist" ? "加入候补名单" : "提交报名意向";
const registrationCopy =
  event?.registrationState === "waitlist"
    ? "这场活动目前已经比较满员，但你仍然可以留下联系方式；如果后续有空位，团队会把你转入正式参会名单。"
    : "提交一份轻量报名信息，方便运营团队评估报名需求、确认参会资格，并在后续同步活动安排。";
const registrationSubmitLabel = event?.registrationState === "waitlist" ? "加入候补" : "提交报名";

if (!event) {
  throw new Error(`活动不存在：${slug}`);
}
---

<BaseLayout title={`${event.title} | 活动 | TGO Network`} description={event.summary}>
  <main class="page-shell page-stack">
    <section class="hero">
      <div class:list={["hero-card", { "hero-split": Boolean(event.coverImage), "hero-card-media": Boolean(event.coverImage) }]}>
        <div>
          <span class="eyebrow">活动详情</span>
          <h1>{event.title}</h1>
          <p>{event.summary}</p>
          <ul class="stat-row">
            <li>{event.city.name}</li>
            <li>{event.venueName}</li>
            <li>{formatRegistrationState(event.registrationState)}</li>
          </ul>
        </div>

        {
          event.coverImage && (
            <figure class="hero-figure">
              <img class="hero-image" src={event.coverImage.url} alt={event.coverImage.alt} />
            </figure>
          )
        }
      </div>
    </section>

    <section class="section detail-grid">
      <article class="panel prose-panel">
        <div class="card-label">活动概览</div>
        <p>{event.body}</p>
        <p>{formatDateRange(event.startsAt, event.endsAt)}</p>
      </article>

      <aside class="panel panel-soft stack-sm">
        <div>
          <div class="card-label">议程</div>
          <ul class="agenda-list">
            {
              event.agenda.map((item) => (
                <li>
                  <strong>{item.time}</strong>
                  <span>{item.title}</span>
                  <em>{item.speaker}</em>
                </li>
              ))
            }
          </ul>
        </div>

        <div>
          <div class="card-label">关联主题</div>
          <div class="chip-row">
            {
              event.relatedTopics.map((topic) => (
                <a class="chip" href={`/topics/${topic.slug}`}>
                  {topic.title}
                </a>
              ))
            }
          </div>
        </div>
      </aside>
    </section>

    <section class="section registration-shell">
      <div class="panel registration-panel">
        <div class="card-label">报名</div>
        <h2>{registrationTitle}</h2>
        <p class="registration-copy">{registrationCopy}</p>

        {
          registrationEnabled ? (
            <form
              class="form-panel"
              data-event-registration-form
              data-api-base={apiBaseUrl}
              data-event-slug={event.slug}
              data-registration-state={event.registrationState}
            >
              <div class="form-grid">
                <label>
                  <span>姓名</span>
                  <input name="name" type="text" required minlength="2" />
                </label>

                <label>
                  <span>邮箱</span>
                  <input name="email" type="email" placeholder="name@example.com" />
                </label>

                <label>
                  <span>手机号</span>
                  <input name="phoneNumber" type="tel" inputmode="tel" placeholder="+86 138 0000 0000" />
                </label>

                <label>
                  <span>公司</span>
                  <input name="company" type="text" />
                </label>

                <label>
                  <span>职位</span>
                  <input name="jobTitle" type="text" />
                </label>
              </div>

              <div class="form-actions">
                <div class="registration-actions">
                  <button class="button primary" type="submit">{registrationSubmitLabel}</button>

                  {
                    event.registrationUrl && (
                      <a class="button secondary" href={event.registrationUrl} target="_blank" rel="noreferrer">
                        打开外部表单
                      </a>
                    )
                  }
                </div>

                <p class="form-status" data-event-registration-status>
                  请填写姓名，并至少保留一种联系方式。
                </p>
              </div>
            </form>
          ) : (
            <div class="registration-note">
              <p>
                {event.registrationState === "closed"
                  ? "这场活动的报名已经关闭。"
                  : "报名暂未开放，请在接近活动日期时再回来查看。"}
              </p>

              {
                event.registrationUrl && (
                  <a class="button secondary registration-inline-action" href={event.registrationUrl} target="_blank" rel="noreferrer">
                    打开外部表单
                  </a>
                )
              }
            </div>
          )
        }
      </div>

      <aside class="panel panel-soft registration-side">
        <div class="card-label">接下来会发生什么</div>
        <ul class="meta-list">
          <li>提交结果会进入工作人员后台。</li>
          <li>工作人员可以审批、拒绝、取消或转为候补。</li>
          <li>报名状态始终由 API 层统一维护。</li>
        </ul>
      </aside>
    </section>
  </main>

  <script>
    const form = document.querySelector("[data-event-registration-form]");
    const status = document.querySelector("[data-event-registration-status]");

    if (form instanceof HTMLFormElement && status instanceof HTMLElement) {
      form.addEventListener("submit", async (event) => {
        event.preventDefault();
        status.textContent = "提交中...";

        const formData = new FormData(form);
        const payload = Object.fromEntries(
          Array.from(formData.entries()).filter(([, value]) => typeof value === "string" && value.trim().length > 0)
        );
        const baseUrl = form.dataset.apiBase ?? "http://127.0.0.1:8787";
        const eventSlug = form.dataset.eventSlug;

        if (!eventSlug) {
          status.textContent = "活动配置不完整。";
          return;
        }

        try {
          const response = await fetch(new URL(`/api/public/v1/events/${eventSlug}/registrations`, baseUrl), {
            method: "POST",
            headers: {
              "Content-Type": "application/json"
            },
            body: JSON.stringify(payload)
          });

          const result = await response.json();

          if (!response.ok) {
            const firstIssue = result.error?.details?.issues?.[0]?.message;
            status.textContent = firstIssue ?? result.error?.message ?? "报名提交失败，请稍后再试。";
            return;
          }

          const receiptStatus = result.data?.status === "waitlisted" ? "已加入候补名单。" : "报名已提交。";
          status.textContent = `${receiptStatus} 参考编号 ${result.data.id}。`;
          form.reset();
        } catch {
          status.textContent = "API 当前不可用，请先启动 apps/api 以测试完整报名流程。";
        }
      });
    }
  </script>
</BaseLayout>

<style>
  .registration-shell {
    display: grid;
    grid-template-columns: minmax(0, 1.45fr) minmax(280px, 0.85fr);
    gap: 18px;
    align-items: start;
  }

  .registration-panel h2 {
    margin: 14px 0 10px;
    font-size: clamp(1.7rem, 3vw, 2.3rem);
  }

  .registration-copy {
    margin: 0 0 20px;
    max-width: 60ch;
  }

  .registration-actions {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }

  .registration-note p {
    margin: 0 0 18px;
  }

  .registration-inline-action {
    display: inline-flex;
  }

  .registration-side {
    min-height: 100%;
  }

  @media (max-width: 900px) {
    .registration-shell {
      grid-template-columns: 1fr;
    }

    .registration-actions {
      width: 100%;
    }
  }
</style>
