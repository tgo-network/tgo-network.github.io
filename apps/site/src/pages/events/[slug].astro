---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { formatDateRange, formatRegistrationState } from "../../lib/format";
import { getEvent, getPublicApiBaseUrl, listEvents } from "../../lib/public-api";

export const getStaticPaths = async () => {
  const events = await listEvents();

  return events.map((event) => ({
    params: {
      slug: event.slug
    }
  }));
};

const slug = Astro.params.slug!;
const event = await getEvent(slug);
const apiBaseUrl = getPublicApiBaseUrl();
const registrationEnabled = event?.registrationState === "open" || event?.registrationState === "waitlist";
const registrationTitle = event?.registrationState === "waitlist" ? "Join the waitlist" : "Register interest";
const registrationCopy =
  event?.registrationState === "waitlist"
    ? "This event is already busy, but you can still leave your details and the team can move you into confirmed attendance if space opens up."
    : "Submit a lightweight registration request so the operations team can review demand, confirm attendance, and follow up with practical event details.";
const registrationSubmitLabel = event?.registrationState === "waitlist" ? "Join waitlist" : "Submit registration";

if (!event) {
  throw new Error(`Event not found: ${slug}`);
}
---

<BaseLayout title={`${event.title} | Events | TGO Network`} description={event.summary}>
  <main class="page-shell page-stack">
    <section class="hero">
      <div class:list={["hero-card", { "hero-split": Boolean(event.coverImage), "hero-card-media": Boolean(event.coverImage) }]}>
        <div>
          <span class="eyebrow">Event Detail</span>
          <h1>{event.title}</h1>
          <p>{event.summary}</p>
          <ul class="stat-row">
            <li>{event.city.name}</li>
            <li>{event.venueName}</li>
            <li>{formatRegistrationState(event.registrationState)}</li>
          </ul>
        </div>

        {
          event.coverImage && (
            <figure class="hero-figure">
              <img class="hero-image" src={event.coverImage.url} alt={event.coverImage.alt} />
            </figure>
          )
        }
      </div>
    </section>

    <section class="section detail-grid">
      <article class="panel prose-panel">
        <div class="card-label">Event Overview</div>
        <p>{event.body}</p>
        <p>{formatDateRange(event.startsAt, event.endsAt)}</p>
      </article>

      <aside class="panel panel-soft stack-sm">
        <div>
          <div class="card-label">Agenda</div>
          <ul class="agenda-list">
            {
              event.agenda.map((item) => (
                <li>
                  <strong>{item.time}</strong>
                  <span>{item.title}</span>
                  <em>{item.speaker}</em>
                </li>
              ))
            }
          </ul>
        </div>

        <div>
          <div class="card-label">Related Topics</div>
          <div class="chip-row">
            {
              event.relatedTopics.map((topic) => (
                <a class="chip" href={`/topics/${topic.slug}`}>
                  {topic.title}
                </a>
              ))
            }
          </div>
        </div>
      </aside>
    </section>

    <section class="section registration-shell">
      <div class="panel registration-panel">
        <div class="card-label">Registration</div>
        <h2>{registrationTitle}</h2>
        <p class="registration-copy">{registrationCopy}</p>

        {
          registrationEnabled ? (
            <form
              class="form-panel"
              data-event-registration-form
              data-api-base={apiBaseUrl}
              data-event-slug={event.slug}
              data-registration-state={event.registrationState}
            >
              <div class="form-grid">
                <label>
                  <span>Name</span>
                  <input name="name" type="text" required minlength="2" />
                </label>

                <label>
                  <span>Email</span>
                  <input name="email" type="email" placeholder="name@example.com" />
                </label>

                <label>
                  <span>Phone number</span>
                  <input name="phoneNumber" type="tel" inputmode="tel" placeholder="+86 138 0000 0000" />
                </label>

                <label>
                  <span>Company</span>
                  <input name="company" type="text" />
                </label>

                <label>
                  <span>Job title</span>
                  <input name="jobTitle" type="text" />
                </label>
              </div>

              <div class="form-actions">
                <div class="registration-actions">
                  <button class="button primary" type="submit">{registrationSubmitLabel}</button>

                  {
                    event.registrationUrl && (
                      <a class="button secondary" href={event.registrationUrl} target="_blank" rel="noreferrer">
                        Open external form
                      </a>
                    )
                  }
                </div>

                <p class="form-status" data-event-registration-status>
                  Share your name plus at least one contact method.
                </p>
              </div>
            </form>
          ) : (
            <div class="registration-note">
              <p>
                {event.registrationState === "closed"
                  ? "Registration has already closed for this event."
                  : "Registration is not open yet. Check back closer to the event date."}
              </p>

              {
                event.registrationUrl && (
                  <a class="button secondary registration-inline-action" href={event.registrationUrl} target="_blank" rel="noreferrer">
                    Open external form
                  </a>
                )
              }
            </div>
          )
        }
      </div>

      <aside class="panel panel-soft registration-side">
        <div class="card-label">What happens next</div>
        <ul class="meta-list">
          <li>Submissions land in the staff admin console.</li>
          <li>Staff can approve, reject, cancel, or waitlist attendees.</li>
          <li>Registration state stays owned by the API layer.</li>
        </ul>
      </aside>
    </section>
  </main>

  <script>
    const form = document.querySelector("[data-event-registration-form]");
    const status = document.querySelector("[data-event-registration-status]");

    if (form instanceof HTMLFormElement && status instanceof HTMLElement) {
      form.addEventListener("submit", async (event) => {
        event.preventDefault();
        status.textContent = "Submitting...";

        const formData = new FormData(form);
        const payload = Object.fromEntries(
          Array.from(formData.entries()).filter(([, value]) => typeof value === "string" && value.trim().length > 0)
        );
        const baseUrl = form.dataset.apiBase ?? "http://127.0.0.1:8787";
        const eventSlug = form.dataset.eventSlug;

        if (!eventSlug) {
          status.textContent = "Event configuration is incomplete.";
          return;
        }

        try {
          const response = await fetch(new URL(`/api/public/v1/events/${eventSlug}/registrations`, baseUrl), {
            method: "POST",
            headers: {
              "Content-Type": "application/json"
            },
            body: JSON.stringify(payload)
          });

          const result = await response.json();

          if (!response.ok) {
            const firstIssue = result.error?.details?.issues?.[0]?.message;
            status.textContent = firstIssue ?? result.error?.message ?? "Unable to submit the registration.";
            return;
          }

          const receiptStatus = result.data?.status === "waitlisted" ? "Added to the waitlist." : "Registration submitted.";
          status.textContent = `${receiptStatus} Reference ${result.data.id}.`;
          form.reset();
        } catch {
          status.textContent = "The API is currently unavailable. Start apps/api to test the full registration flow.";
        }
      });
    }
  </script>
</BaseLayout>

<style>
  .registration-shell {
    display: grid;
    grid-template-columns: minmax(0, 1.45fr) minmax(280px, 0.85fr);
    gap: 18px;
    align-items: start;
  }

  .registration-panel h2 {
    margin: 14px 0 10px;
    font-size: clamp(1.7rem, 3vw, 2.3rem);
  }

  .registration-copy {
    margin: 0 0 20px;
    max-width: 60ch;
  }

  .registration-actions {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }

  .registration-note p {
    margin: 0 0 18px;
  }

  .registration-inline-action {
    display: inline-flex;
  }

  .registration-side {
    min-height: 100%;
  }

  @media (max-width: 900px) {
    .registration-shell {
      grid-template-columns: 1fr;
    }

    .registration-actions {
      width: 100%;
    }
  }
</style>
