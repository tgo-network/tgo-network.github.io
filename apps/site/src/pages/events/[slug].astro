---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { formatDateRange, formatRegistrationState } from "../../lib/format";
import { getEvent, getPublicApiBaseUrl, listEvents } from "../../lib/public-api";

export const getStaticPaths = async () => {
  const events = await listEvents();

  return events.map((event) => ({
    params: {
      slug: event.slug
    }
  }));
};

type EventBodySection = {
  title: string;
  items: string[];
};

type EventContentBlock = {
  paragraphs: string[];
  bullets: string[];
};

type AudienceCard = {
  title: string;
  summary: string;
};

const slug = Astro.params.slug!;
const event = await getEvent(slug);
const apiBaseUrl = getPublicApiBaseUrl();

if (!event) {
  throw new Error(`活动不存在：${slug}`);
}

const registrationEnabled = event.registrationState === "open" || event.registrationState === "waitlist";
const registrationTitle = event.registrationState === "waitlist" ? "加入候补名单" : "提交报名意向";
const registrationSubmitLabel = event.registrationState === "waitlist" ? "加入候补" : "提交报名";
const branchName = event.branch?.name ?? `${event.cityName}活动`;

const eventBodyHeadingPatterns = [
  /^活动简介$/,
  /^活动流程$/,
  /^参会须知$/,
  /^谁该来.*参与.*$/,
  /^活动亮点$/,
  /^适合谁(?:参加)?$/,
  /^适合人群$/,
  /^报名方式$/,
  /^报名链接$/,
  /^温馨提示$/,
  /^参会标准$/,
  /^非会员申请标准$/
];

const stripListMarker = (value: string) => value.replace(/^[•●▪■◆★⭐-]\s*/, "").replace(/^\d+[、.．)]\s*/, "").trim();
const isPureUrl = (value: string) => /^https?:\/\/\S+$/i.test(value);
const isHeadingLine = (value: string) => eventBodyHeadingPatterns.some((pattern) => pattern.test(value));

const eventBodySections = event.body
  .replace(/\r/g, "")
  .split("\n")
  .map((line) => line.trim())
  .filter(Boolean)
  .reduce<EventBodySection[]>((sections, line) => {
    if (isHeadingLine(line)) {
      const previous = sections.at(-1);

      if (previous?.title !== line) {
        sections.push({
          title: line,
          items: []
        });
      }

      return sections;
    }

    if (sections.length === 0) {
      sections.push({
        title: "活动简介",
        items: []
      });
    }

    const currentSection = sections[sections.length - 1]!;

    if (line !== currentSection.title) {
      currentSection.items.push(line);
    }

    return sections;
  }, []);

const createContentBlock = (items: string[]): EventContentBlock => {
  const paragraphs: string[] = [];
  const bullets: string[] = [];

  for (const item of items) {
    const trimmed = item.trim();

    if (!trimmed || isPureUrl(trimmed)) {
      continue;
    }

    if (/^[•●▪■◆★⭐-]/.test(trimmed) || /^\d+[、.．)]/.test(trimmed)) {
      bullets.push(stripListMarker(trimmed));
      continue;
    }

    paragraphs.push(trimmed);
  }

  return {
    paragraphs,
    bullets
  };
};

const createAudienceCards = (items: string[]): AudienceCard[] => {
  const cards: { title: string; details: string[] }[] = [];
  let currentCard: { title: string; details: string[] } | null = null;

  const pushCurrentCard = () => {
    if (!currentCard) {
      return;
    }

    cards.push(currentCard);
    currentCard = null;
  };

  for (const item of items) {
    const cleaned = item.trim();

    if (!cleaned || isPureUrl(cleaned)) {
      continue;
    }

    const isCardTitle = cleaned.startsWith("🦞") || /^(如果你是|适合|面向)/.test(cleaned);

    if (isCardTitle) {
      pushCurrentCard();
      currentCard = {
        title: cleaned.replace(/^🦞\s*/, "").trim(),
        details: []
      };
      continue;
    }

    if (!currentCard) {
      currentCard = {
        title: "适合参与的人",
        details: []
      };
    }

    currentCard.details.push(stripListMarker(cleaned));
  }

  pushCurrentCard();

  return cards
    .map((card) => ({
      title: card.title,
      summary: card.details.join(" ").trim()
    }))
    .filter((card) => card.title && card.summary);
};

const bodyLinks = Array.from(event.body.matchAll(/https?:\/\/\S+/gi)).map(([value]) =>
  value.replace(/[)）。，；、]+$/g, "")
);
const registrationUrl = event.registrationUrl ?? bodyLinks[0] ?? null;
const narrativeSections = eventBodySections.filter(
  (section) =>
    section.items.length > 0 &&
    !/^活动流程$/.test(section.title) &&
    !/^参会须知$/.test(section.title) &&
    !/^报名方式$/.test(section.title) &&
    !/^报名链接$/.test(section.title) &&
    !/^参会标准$/.test(section.title) &&
    !/^非会员申请标准$/.test(section.title) &&
    !/^谁该来.*参与.*$/.test(section.title) &&
    !/^适合/.test(section.title)
);
const introSection = narrativeSections[0] ?? {
  title: "活动介绍",
  items: [event.summary]
};
const introContent = createContentBlock(introSection.items);
const additionalNarrativeSections = narrativeSections.slice(1).map((section) => ({
  title: section.title,
  content: createContentBlock(section.items)
}));
const audienceSectionItems = eventBodySections
  .filter((section) => /^谁该来.*参与.*$/.test(section.title) || /^适合/.test(section.title))
  .flatMap((section) => section.items);
const audienceCards = createAudienceCards(audienceSectionItems);
const fallbackAudienceCards = [
  {
    title: "开放报名",
    summary: "活动对成员与非成员都开放报名，提交后统一进入工作人员后台审核。"
  },
  {
    title: "资料完整更容易通过",
    summary: "建议补充公司、职称和参会诉求，方便工作人员更快判断是否匹配活动定位。"
  },
  {
    title: "审核后继续联系",
    summary: "审核结果可能为通过、拒绝或候补，工作人员会继续跟进后续安排。"
  }
];
const displayedAudienceCards = audienceCards.length > 0 ? audienceCards : fallbackAudienceCards;
const registrationNoticeItems = Array.from(
  new Set(
    eventBodySections
      .filter(
        (section) =>
          /^参会须知$/.test(section.title) ||
          /^报名方式$/.test(section.title) ||
          /^参会标准$/.test(section.title) ||
          /^非会员申请标准$/.test(section.title)
      )
      .flatMap((section) => section.items)
      .map((item) => stripListMarker(item))
      .filter((item) => item && !isPureUrl(item))
  )
);
const registrationSideNotes =
  registrationNoticeItems.length > 0
    ? registrationNoticeItems
    : [
        "提交后会进入工作人员后台，由工作人员统一审核。",
        "审核结果可能为通过、拒绝或转为候补。",
        "审核通过后，工作人员会进一步联系并确认参与信息。"
      ];
const registrationSteps = [
  {
    step: "01",
    title: "填写资料",
    summary: "至少填写姓名与手机号，最好补充公司、职称与参会诉求。"
  },
  {
    step: "02",
    title: "进入审核",
    summary: "报名信息会进入工作人员后台，由工作人员统一审核与联系。"
  },
  {
    step: "03",
    title: "确认结果",
    summary: "工作人员会根据活动定位、报名信息与容量，决定通过、拒绝或转候补。"
  }
];
---

<BaseLayout title={`${event.title} | 活动 | TGO 鲲鹏会`} description={event.summary}>
  <main class="page-shell page-stack">
    <section class="hero">
      <div class="hero-card event-detail-hero">
        <div class="event-detail-main">
          <span class="eyebrow">活动详情</span>
          <h1>{event.title}</h1>
          <p class="event-detail-lead">{event.summary}</p>
          <ul class="stat-row">
            <li>{branchName}</li>
            <li>{formatRegistrationState(event.registrationState)}</li>
            <li>{event.venueName}</li>
          </ul>
        </div>

        <aside class="event-detail-side">
          <div class="detail-side-block">
            <div class="card-label card-label-on-dark">活动信息</div>
            <ul class="detail-side-list">
              <li>
                <span>时间</span>
                <strong>{formatDateRange(event.startsAt, event.endsAt)}</strong>
              </li>
              <li>
                <span>地点</span>
                <strong>{event.venueAddress || event.venueName}</strong>
              </li>
              <li>
                <span>城市</span>
                <strong>{event.cityName}</strong>
              </li>
              <li>
                <span>报名状态</span>
                <strong>{formatRegistrationState(event.registrationState)}</strong>
              </li>
            </ul>
          </div>

          {
            event.coverImage && (
              <figure class="event-detail-figure">
                <img class="event-detail-image" src={event.coverImage.url} alt={event.coverImage.alt} />
              </figure>
            )
          }
        </aside>
      </div>
    </section>

    <section class="section event-detail-grid">
      <article class="panel prose-panel event-body-panel">
        <div class="card-label">活动内容</div>
        <h2 class="card-title">{introSection.title === "活动简介" ? "活动介绍" : introSection.title}</h2>
        {(introContent.paragraphs.length > 0 ? introContent.paragraphs : [event.summary]).map((paragraph) => <p>{paragraph}</p>)}

        {
          introContent.bullets.length > 0 && (
            <ul class="event-rich-list">
              {introContent.bullets.map((item) => <li>{item}</li>)}
            </ul>
          )
        }

        {
          additionalNarrativeSections.length > 0 && (
            <div class="event-section-stack">
              {
                additionalNarrativeSections.map((section) => (
                  <section class="event-section-block">
                    <h3>{section.title}</h3>
                    {section.content.paragraphs.map((paragraph) => <p>{paragraph}</p>)}
                    {
                      section.content.bullets.length > 0 && (
                        <ul class="event-rich-list event-rich-list-compact">
                          {section.content.bullets.map((item) => <li>{item}</li>)}
                        </ul>
                      )
                    }
                  </section>
                ))
              }
            </div>
          )
        }
      </article>

      <div class="event-side-stack">
        <article class="panel panel-soft audience-panel">
          <div class="card-label">参与说明</div>
          <div class="audience-card-grid">
            {
              displayedAudienceCards.map((item) => (
                <article class="audience-card">
                  <h3>{item.title}</h3>
                  <p>{item.summary}</p>
                </article>
              ))
            }
          </div>
        </article>

        {
          event.agenda.length > 0 && (
            <article class="panel panel-soft agenda-panel">
              <div class="card-label">议程安排</div>
              <ul class="agenda-list">
                {
                  event.agenda.map((item) => (
                    <li>
                      <strong>{item.time}</strong>
                      <span>{item.title}</span>
                      {item.speaker ? <em>{item.speaker}</em> : null}
                      {item.summary ? <p>{item.summary}</p> : null}
                    </li>
                  ))
                }
              </ul>
            </article>
          )
        }
      </div>
    </section>

    <section class="section registration-shell">
      <div class="panel registration-panel">
        <div class="card-label">活动报名</div>
        <h2>{registrationTitle}</h2>
        <p class="registration-copy">活动对外开放报名，提交后由工作人员审核，并继续联系确认是否通过或转入候补。</p>

        <div class="registration-process-grid">
          {
            registrationSteps.map((item) => (
              <article class="registration-process-card">
                <span>{item.step}</span>
                <strong>{item.title}</strong>
                <p>{item.summary}</p>
              </article>
            ))
          }
        </div>

        {
          registrationEnabled ? (
            <form class="form-panel" data-event-registration-form data-api-base={apiBaseUrl} data-event-slug={event.slug}>
              <div class="form-grid">
                <label>
                  <span>姓名</span>
                  <input name="name" type="text" required minlength="2" />
                </label>

                <label>
                  <span>手机号</span>
                  <input name="phoneNumber" type="tel" required inputmode="tel" />
                </label>

                <label>
                  <span>微信号</span>
                  <input name="wechatId" type="text" />
                </label>

                <label>
                  <span>邮箱</span>
                  <input name="email" type="email" />
                </label>

                <label>
                  <span>公司</span>
                  <input name="company" type="text" />
                </label>

                <label>
                  <span>职称</span>
                  <input name="title" type="text" />
                </label>
              </div>

              <label>
                <span>补充信息</span>
                <textarea name="note" rows="5" placeholder="例如你的关注议题、参会目的，或你希望在活动中交流的问题。"></textarea>
              </label>

              <div class="form-actions">
                <div class="registration-actions">
                  <button class="button primary" type="submit">{registrationSubmitLabel}</button>
                  {registrationUrl && <a class="button secondary" href={registrationUrl} target="_blank" rel="noreferrer">打开外部表单</a>}
                </div>
                <p class="form-status" data-event-registration-status>请至少填写姓名和手机号，便于工作人员联系。</p>
              </div>
            </form>
          ) : (
            <div class="registration-note">
              <p>{event.registrationState === "closed" ? "这场活动的报名已经关闭。" : "报名暂未开放，请稍后再来查看。"}</p>
              {registrationUrl && <a class="button secondary" href={registrationUrl} target="_blank" rel="noreferrer">打开外部表单</a>}
            </div>
          )
        }
      </div>

      <aside class="panel panel-soft registration-side">
        <div>
          <div class="card-label">报名须知</div>
          <div class="registration-note-list">
            {registrationSideNotes.map((item) => <article class="registration-note-card">{item}</article>)}
          </div>
        </div>

        <div>
          <div class="card-label">建议填写内容</div>
          <p class="card-copy">建议补充公司、职称与参会诉求，便于工作人员更快完成审核与联系。</p>
        </div>

        <div class="event-next-links">
          <a class="button secondary" href="/events">返回活动列表</a>
          {event.branch && <a class="button secondary" href={`/branches#${event.branch.slug}`}>查看所属分会</a>}
          <a class="button secondary" href="/join">了解加入申请</a>
        </div>
      </aside>
    </section>
  </main>

  <script>
    const form = document.querySelector("[data-event-registration-form]");
    const status = document.querySelector("[data-event-registration-status]");

    if (form instanceof HTMLFormElement && status instanceof HTMLElement) {
      form.addEventListener("submit", async (submitEvent) => {
        submitEvent.preventDefault();
        status.textContent = "提交中...";

        const formData = new FormData(form);
        const payload = Object.fromEntries(
          Array.from(formData.entries()).filter(([, value]) => typeof value === "string" && value.trim().length > 0)
        );
        const baseUrl = form.dataset.apiBase ?? "http://127.0.0.1:8787";
        const eventSlug = form.dataset.eventSlug;

        if (!eventSlug) {
          status.textContent = "活动配置不完整。";
          return;
        }

        try {
          const response = await fetch(new URL(`/api/public/v1/events/${eventSlug}/registrations`, baseUrl), {
            method: "POST",
            headers: {
              "Content-Type": "application/json"
            },
            body: JSON.stringify(payload)
          });

          const result = await response.json();

          if (!response.ok) {
            const firstIssue = result.error?.details?.issues?.[0]?.message;
            status.textContent = firstIssue ?? result.error?.message ?? "报名提交失败，请稍后再试。";
            return;
          }

          status.textContent = `${result.data.status === "waitlisted" ? "已加入候补名单" : "报名已提交"}，编号 ${result.data.id}。`;
          form.reset();
        } catch {
          status.textContent = "API 当前不可用，请先启动 apps/api 以测试完整报名流程。";
        }
      });
    }
  </script>
</BaseLayout>

<style>
  .event-detail-hero {
    display: grid;
    gap: 28px;
    grid-template-columns: minmax(0, 1.2fr) minmax(320px, 420px);
    background:
      radial-gradient(circle at top right, rgba(215, 179, 117, 0.16), transparent 24%),
      linear-gradient(135deg, #171717 0%, #211d18 100%);
    border-color: rgba(215, 179, 117, 0.14);
    color: #f8f1e8;
  }

  .event-detail-hero h1,
  .event-detail-hero h2,
  .event-detail-hero h3 {
    color: #fff7ef;
  }

  .event-detail-hero p {
    color: rgba(248, 241, 232, 0.76);
  }

  .event-detail-hero .eyebrow {
    color: #f1d5a0;
    border-color: rgba(215, 179, 117, 0.28);
    background: rgba(255, 255, 255, 0.06);
  }

  .event-detail-main h1 {
    margin: 0;
    max-width: 16ch;
    font-size: clamp(2.9rem, 5.6vw, 4.9rem);
    line-height: 1.02;
    text-wrap: balance;
  }

  .event-detail-lead {
    max-width: 62ch;
    font-size: 1.02rem;
    line-height: 1.8;
  }

  .event-detail-main,
  .event-detail-side,
  .event-side-stack,
  .registration-side,
  .event-next-links,
  .audience-card-grid,
  .event-section-stack {
    display: grid;
    gap: 18px;
  }

  .registration-process-grid {
    display: grid;
    gap: 16px;
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .detail-side-block {
    padding: 20px 22px;
    border-radius: 24px;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(215, 179, 117, 0.14);
  }

  .event-detail-side {
    position: sticky;
    top: 104px;
  }

  .detail-side-list {
    display: grid;
    gap: 14px;
    list-style: none;
    padding: 0;
    margin: 18px 0 0;
  }

  .detail-side-list li {
    display: grid;
    gap: 4px;
  }

  .detail-side-list span {
    color: rgba(248, 241, 232, 0.6);
    font-size: 0.84rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .detail-side-list strong {
    color: #fff7ef;
    font-weight: 600;
    line-height: 1.6;
  }

  .event-detail-figure {
    margin: 0;
  }

  .event-detail-image {
    display: block;
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    border-radius: 24px;
    box-shadow: var(--shadow-strong);
  }

  .event-detail-grid,
  .registration-shell {
    display: grid;
    gap: 18px;
    grid-template-columns: minmax(0, 1.15fr) minmax(0, 0.85fr);
  }

  .event-body-panel {
    min-height: 100%;
    background: linear-gradient(180deg, rgba(255, 252, 246, 0.96), rgba(247, 241, 232, 0.94));
  }

  .event-body-panel .card-title {
    margin: 10px 0 14px;
  }

  .event-body-panel p {
    max-width: 68ch;
    line-height: 1.86;
  }

  .event-body-panel p:first-of-type {
    font-size: 1.08rem;
    color: var(--ink);
  }

  .event-section-block h3,
  .audience-card h3 {
    margin: 0;
    font-size: 1.06rem;
  }

  .event-section-block p:last-child,
  .audience-card p:last-child {
    margin-bottom: 0;
  }

  .event-rich-list {
    display: grid;
    gap: 12px;
    margin: 0 0 6px;
    padding-left: 20px;
    color: var(--ink);
  }

  .event-rich-list li {
    line-height: 1.76;
  }

  .event-rich-list-compact {
    margin-top: 12px;
  }

  .audience-panel {
    align-content: start;
    background: linear-gradient(180deg, rgba(255, 249, 239, 0.96), rgba(245, 237, 226, 0.94));
  }

  .audience-card-grid {
    margin-top: 16px;
  }

  .audience-card {
    padding: 16px 18px;
    border-radius: 20px;
    border: 1px solid rgba(31, 26, 23, 0.08);
    background: rgba(255, 255, 255, 0.58);
  }

  .audience-card p {
    margin: 10px 0 0;
    color: var(--muted);
    line-height: 1.76;
  }

  .agenda-panel {
    min-height: 100%;
  }

  .registration-panel h2 {
    margin: 14px 0 10px;
    font-size: clamp(1.7rem, 3vw, 2.3rem);
  }

  .registration-copy {
    margin: 0 0 20px;
  }

  .registration-process-card {
    display: grid;
    gap: 8px;
    padding: 18px;
    border-radius: 20px;
    background: rgba(255, 249, 239, 0.92);
    border: 1px solid rgba(31, 26, 23, 0.08);
  }

  .registration-process-card span {
    color: var(--accent-strong);
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.08em;
  }

  .registration-process-card strong {
    line-height: 1.5;
  }

  .registration-process-card p {
    margin: 0;
    color: var(--muted);
    font-size: 0.92rem;
    line-height: 1.7;
  }

  .registration-actions {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }

  .vertical-list {
    display: grid;
    gap: 10px;
  }

  .registration-side {
    align-content: start;
    position: sticky;
    top: 104px;
    background: linear-gradient(180deg, rgba(255, 250, 242, 0.96), rgba(246, 239, 229, 0.94));
  }

  .event-next-links {
    margin-top: 16px;
  }

  .registration-note-list {
    display: grid;
    gap: 10px;
    margin-top: 16px;
  }

  .registration-note-card {
    padding: 14px 16px;
    border-radius: 18px;
    border: 1px solid rgba(31, 26, 23, 0.08);
    background: rgba(255, 255, 255, 0.62);
    color: var(--muted);
    line-height: 1.72;
  }

  .registration-note p {
    margin: 0 0 16px;
  }

  @media (max-width: 980px) {
    .event-detail-hero,
    .event-detail-grid,
    .registration-shell,
    .registration-process-grid {
      grid-template-columns: 1fr;
    }

    .event-detail-side,
    .registration-side {
      position: static;
    }
  }
</style>
