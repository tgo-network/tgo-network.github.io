---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { formatDateRange, formatRegistrationState } from "../../lib/format";
import { getEvent, getPublicApiBaseUrl, listEvents } from "../../lib/public-api";

export const getStaticPaths = async () => {
  const events = await listEvents();

  return events.map((event) => ({
    params: {
      slug: event.slug
    }
  }));
};

const slug = Astro.params.slug!;
const event = await getEvent(slug);
const apiBaseUrl = getPublicApiBaseUrl();

if (!event) {
  throw new Error(`活动不存在：${slug}`);
}

const registrationEnabled = event.registrationState === "open" || event.registrationState === "waitlist";
const registrationTitle = event.registrationState === "waitlist" ? "加入候补名单" : "提交报名意向";
const registrationSubmitLabel = event.registrationState === "waitlist" ? "加入候补" : "提交报名";
const branchName = event.branch?.name ?? `${event.cityName}活动`;
const eventBodyBlocks = event.body
  .replace(/\r/g, "")
  .split(/\n{2,}/)
  .flatMap((block) => block.split("\n"))
  .map((block) => block.trim())
  .filter(Boolean);

const participationNotes = [
  "活动对成员与非成员都开放报名。",
  "报名信息会进入工作人员后台审核。",
  "建议补充公司、职称和参会诉求，便于工作人员判断。"
];

const registrationSideNotes = [
  "提交后会进入工作人员后台，由工作人员统一审核。",
  "审核结果可能为通过、拒绝或转为候补。",
  "审核通过后，工作人员会进一步联系并确认参与信息。"
];

const registrationSteps = [
  {
    step: "01",
    title: "填写资料",
    summary: "至少填写姓名与手机号，最好补充公司、职称与参会诉求。"
  },
  {
    step: "02",
    title: "进入审核",
    summary: "报名信息会进入工作人员后台，由工作人员统一审核与联系。"
  },
  {
    step: "03",
    title: "确认结果",
    summary: "工作人员会根据活动定位、报名信息与容量，决定通过、拒绝或转候补。"
  }
];
---

<BaseLayout title={`${event.title} | 活动 | TGO 鲲鹏会`} description={event.summary}>
  <main class="page-shell page-stack">
    <section class="hero">
      <div class="hero-card event-detail-hero">
        <div class="event-detail-main">
          <span class="eyebrow">活动详情</span>
          <h1>{event.title}</h1>
          <p class="event-detail-lead">{event.summary}</p>
          <ul class="stat-row">
            <li>{branchName}</li>
            <li>{formatRegistrationState(event.registrationState)}</li>
            <li>{event.venueName}</li>
          </ul>
        </div>

        <aside class="event-detail-side">
          <div class="detail-side-block">
            <div class="card-label card-label-on-dark">活动信息</div>
            <ul class="detail-side-list">
              <li>
                <span>时间</span>
                <strong>{formatDateRange(event.startsAt, event.endsAt)}</strong>
              </li>
              <li>
                <span>地点</span>
                <strong>{event.venueAddress || event.venueName}</strong>
              </li>
              <li>
                <span>城市</span>
                <strong>{event.cityName}</strong>
              </li>
              <li>
                <span>报名状态</span>
                <strong>{formatRegistrationState(event.registrationState)}</strong>
              </li>
            </ul>
          </div>

          {
            event.coverImage && (
              <figure class="event-detail-figure">
                <img class="event-detail-image" src={event.coverImage.url} alt={event.coverImage.alt} />
              </figure>
            )
          }
        </aside>
      </div>
    </section>

    <section class="section event-detail-grid">
      <article class="panel prose-panel event-body-panel">
        <div class="card-label">活动概览</div>
        <h2 class="card-title">活动详情</h2>
        {(eventBodyBlocks.length > 0 ? eventBodyBlocks : [event.summary]).map((paragraph) => <p>{paragraph}</p>)}
        <ul class="meta-list">
          <li>{branchName}</li>
          <li>{event.cityName}</li>
          <li>{event.venueName}</li>
        </ul>
      </article>

      <div class="event-side-stack">
        <article class="panel panel-soft audience-panel">
          <div class="card-label">参与说明</div>
          <ul class="audience-list">
            {participationNotes.map((item) => <li>{item}</li>)}
          </ul>
        </article>

        {
          event.agenda.length > 0 && (
            <article class="panel panel-soft agenda-panel">
              <div class="card-label">议程安排</div>
              <ul class="agenda-list">
                {
                  event.agenda.map((item) => (
                    <li>
                      <strong>{item.time}</strong>
                      <span>{item.title}</span>
                      <em>{item.speaker}</em>
                      <p>{item.summary}</p>
                    </li>
                  ))
                }
              </ul>
            </article>
          )
        }
      </div>
    </section>

    <section class="section registration-shell">
      <div class="panel registration-panel">
        <div class="card-label">活动报名</div>
        <h2>{registrationTitle}</h2>
        <p class="registration-copy">
          当前活动采用开放报名。提交后会进入工作人员后台审核，工作人员可根据活动定位、报名信息与活动容量确认是否通过、拒绝或转为候补。
        </p>

        <div class="registration-process-grid">
          {
            registrationSteps.map((item) => (
              <article class="registration-process-card">
                <span>{item.step}</span>
                <strong>{item.title}</strong>
                <p>{item.summary}</p>
              </article>
            ))
          }
        </div>

        {
          registrationEnabled ? (
            <form class="form-panel" data-event-registration-form data-api-base={apiBaseUrl} data-event-slug={event.slug}>
              <div class="form-grid">
                <label>
                  <span>姓名</span>
                  <input name="name" type="text" required minlength="2" />
                </label>

                <label>
                  <span>手机号</span>
                  <input name="phoneNumber" type="tel" required inputmode="tel" />
                </label>

                <label>
                  <span>微信号</span>
                  <input name="wechatId" type="text" />
                </label>

                <label>
                  <span>邮箱</span>
                  <input name="email" type="email" />
                </label>

                <label>
                  <span>公司</span>
                  <input name="company" type="text" />
                </label>

                <label>
                  <span>职称</span>
                  <input name="title" type="text" />
                </label>
              </div>

              <label>
                <span>补充信息</span>
                <textarea name="note" rows="5" placeholder="例如你的关注议题、参会目的，或你希望在活动中交流的问题。"></textarea>
              </label>

              <div class="form-actions">
                <div class="registration-actions">
                  <button class="button primary" type="submit">{registrationSubmitLabel}</button>
                  {event.registrationUrl && <a class="button secondary" href={event.registrationUrl} target="_blank" rel="noreferrer">打开外部表单</a>}
                </div>
                <p class="form-status" data-event-registration-status>请至少填写姓名和手机号，便于工作人员联系。</p>
              </div>
            </form>
          ) : (
            <div class="registration-note">
              <p>{event.registrationState === "closed" ? "这场活动的报名已经关闭。" : "报名暂未开放，请稍后再来查看。"}</p>
              {event.registrationUrl && <a class="button secondary" href={event.registrationUrl} target="_blank" rel="noreferrer">打开外部表单</a>}
            </div>
          )
        }
      </div>

      <aside class="panel panel-soft registration-side">
        <div>
          <div class="card-label">审核方式</div>
          <ul class="meta-list vertical-list">
            {registrationSideNotes.map((item) => <li>{item}</li>)}
          </ul>
        </div>

        <div>
          <div class="card-label">建议填写内容</div>
          <p class="card-copy">
            如果你能补充当前职责、所在团队规模、关注议题或参会目的，工作人员会更容易判断这场活动是否适合你。
          </p>
        </div>

        <div class="event-next-links">
          <a class="button secondary" href="/events">返回活动列表</a>
          {event.branch && <a class="button secondary" href={`/branches#${event.branch.slug}`}>查看所属分会</a>}
          <a class="button secondary" href="/join">了解加入申请</a>
        </div>
      </aside>
    </section>
  </main>

  <script>
    const form = document.querySelector("[data-event-registration-form]");
    const status = document.querySelector("[data-event-registration-status]");

    if (form instanceof HTMLFormElement && status instanceof HTMLElement) {
      form.addEventListener("submit", async (submitEvent) => {
        submitEvent.preventDefault();
        status.textContent = "提交中...";

        const formData = new FormData(form);
        const payload = Object.fromEntries(
          Array.from(formData.entries()).filter(([, value]) => typeof value === "string" && value.trim().length > 0)
        );
        const baseUrl = form.dataset.apiBase ?? "http://127.0.0.1:8787";
        const eventSlug = form.dataset.eventSlug;

        if (!eventSlug) {
          status.textContent = "活动配置不完整。";
          return;
        }

        try {
          const response = await fetch(new URL(`/api/public/v1/events/${eventSlug}/registrations`, baseUrl), {
            method: "POST",
            headers: {
              "Content-Type": "application/json"
            },
            body: JSON.stringify(payload)
          });

          const result = await response.json();

          if (!response.ok) {
            const firstIssue = result.error?.details?.issues?.[0]?.message;
            status.textContent = firstIssue ?? result.error?.message ?? "报名提交失败，请稍后再试。";
            return;
          }

          status.textContent = `${result.data.status === "waitlisted" ? "已加入候补名单" : "报名已提交"}，编号 ${result.data.id}。`;
          form.reset();
        } catch {
          status.textContent = "API 当前不可用，请先启动 apps/api 以测试完整报名流程。";
        }
      });
    }
  </script>
</BaseLayout>

<style>
  .event-detail-hero {
    display: grid;
    gap: 22px;
    grid-template-columns: minmax(0, 1.08fr) minmax(320px, 0.92fr);
    background:
      radial-gradient(circle at top right, rgba(215, 179, 117, 0.16), transparent 24%),
      linear-gradient(135deg, #171717 0%, #211d18 100%);
    border-color: rgba(215, 179, 117, 0.14);
    color: #f8f1e8;
  }

  .event-detail-hero h1,
  .event-detail-hero h2 {
    color: #fff7ef;
  }

  .event-detail-hero p {
    color: rgba(248, 241, 232, 0.76);
  }

  .event-detail-hero .eyebrow {
    color: #f1d5a0;
    border-color: rgba(215, 179, 117, 0.28);
    background: rgba(255, 255, 255, 0.06);
  }

  .event-detail-main h1 {
    max-width: 11ch;
    line-height: 1.01;
  }

  .event-detail-lead {
    max-width: 58ch;
    font-size: 1.04rem;
    line-height: 1.84;
  }

  .event-detail-main,
  .event-detail-side,
  .event-side-stack,
  .registration-side,
  .event-next-links {
    display: grid;
    gap: 18px;
  }

  .registration-process-grid {
    display: grid;
    gap: 16px;
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .detail-side-block {
    padding: 22px;
    border-radius: 24px;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(215, 179, 117, 0.14);
  }

  .event-detail-side {
    position: sticky;
    top: 104px;
  }

  .detail-side-list {
    display: grid;
    gap: 14px;
    list-style: none;
    padding: 0;
    margin: 18px 0 0;
  }

  .detail-side-list li {
    display: grid;
    gap: 4px;
  }

  .detail-side-list span {
    color: rgba(248, 241, 232, 0.6);
    font-size: 0.84rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .detail-side-list strong {
    color: #fff7ef;
    font-weight: 600;
    line-height: 1.6;
  }

  .event-detail-figure {
    margin: 0;
  }

  .event-detail-image {
    display: block;
    width: 100%;
    aspect-ratio: 16 / 10;
    object-fit: cover;
    border-radius: 24px;
    box-shadow: var(--shadow-strong);
  }

  .event-detail-grid,
  .registration-shell {
    display: grid;
    gap: 18px;
    grid-template-columns: minmax(0, 1.15fr) minmax(0, 0.85fr);
  }

  .event-body-panel {
    min-height: 100%;
    background: linear-gradient(180deg, rgba(255, 252, 246, 0.96), rgba(247, 241, 232, 0.94));
  }

  .event-body-panel p {
    max-width: 68ch;
    line-height: 1.88;
  }

  .event-body-panel p:first-of-type {
    font-size: 1.08rem;
    color: var(--ink);
  }

  .audience-panel {
    align-content: start;
    background: linear-gradient(180deg, rgba(255, 249, 239, 0.96), rgba(245, 237, 226, 0.94));
  }

  .audience-list {
    display: grid;
    gap: 12px;
    list-style: none;
    margin: 16px 0 0;
    padding: 0;
  }

  .audience-list li {
    padding: 16px;
    border-radius: 18px;
    border: 1px solid rgba(31, 26, 23, 0.08);
    background: rgba(255, 255, 255, 0.58);
    color: var(--muted);
    line-height: 1.8;
  }

  .agenda-panel {
    min-height: 100%;
  }

  .registration-panel h2 {
    margin: 14px 0 10px;
    font-size: clamp(1.7rem, 3vw, 2.3rem);
  }

  .registration-copy {
    margin: 0 0 20px;
  }

  .registration-process-card {
    display: grid;
    gap: 8px;
    padding: 18px;
    border-radius: 20px;
    background: rgba(255, 249, 239, 0.92);
    border: 1px solid rgba(31, 26, 23, 0.08);
  }

  .registration-process-card span {
    color: var(--accent-strong);
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.08em;
  }

  .registration-process-card strong {
    line-height: 1.5;
  }

  .registration-process-card p {
    margin: 0;
    color: var(--muted);
    font-size: 0.92rem;
    line-height: 1.7;
  }

  .registration-actions {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }

  .vertical-list {
    display: grid;
    gap: 10px;
  }

  .registration-side {
    align-content: start;
    position: sticky;
    top: 104px;
  }

  .event-next-links {
    margin-top: 16px;
  }

  .registration-note p {
    margin: 0 0 16px;
  }

  @media (max-width: 980px) {
    .event-detail-hero,
    .event-detail-grid,
    .registration-shell,
    .registration-process-grid {
      grid-template-columns: 1fr;
    }

    .event-detail-side,
    .registration-side {
      position: static;
    }
  }
</style>
