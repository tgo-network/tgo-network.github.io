---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { formatDateRange, formatRegistrationState } from "../../lib/format";
import { shouldShowExternalRegistrationLink } from "../../lib/event-registration";
import { getEvent, getPublicApiBaseUrl, listEvents } from "../../lib/public-api";

export const getStaticPaths = async () => {
  const events = await listEvents();

  return events.map((event) => ({
    params: {
      slug: event.slug
    }
  }));
};

type EventBodySection = {
  title: string;
  items: string[];
};

type EventContentBlock = {
  paragraphs: string[];
  bullets: string[];
};

type AudienceCard = {
  title: string;
  summary: string;
};

const slug = Astro.params.slug!;
const event = await getEvent(slug);
const apiBaseUrl = getPublicApiBaseUrl();

if (!event) {
  throw new Error(`活动不存在：${slug}`);
}

const registrationEnabled = event.registrationState === "open" || event.registrationState === "waitlist";
const registrationTitle = event.registrationState === "waitlist" ? "加入候补名单" : "活动报名";
const registrationSubmitLabel = event.registrationState === "waitlist" ? "加入候补" : "提交报名";
const branchName = event.branch?.name ?? `${event.cityName}活动`;
const eventLocation = event.venueAddress || event.venueName;

const eventBodyHeadingPatterns = [
  /^活动简介$/,
  /^活动流程$/,
  /^参会须知$/,
  /^谁该来.*参与.*$/,
  /^活动亮点$/,
  /^适合谁(?:参加)?$/,
  /^适合人群$/,
  /^报名方式$/,
  /^报名链接$/,
  /^温馨提示$/,
  /^参会标准$/,
  /^非会员申请标准$/
];

const stripListMarker = (value: string) => value.replace(/^[•●▪■◆★⭐-]\s*/, "").replace(/^\d+[、.．)]\s*/, "").trim();
const isPureUrl = (value: string) => /^https?:\/\/\S+$/i.test(value);
const isHeadingLine = (value: string) => eventBodyHeadingPatterns.some((pattern) => pattern.test(value));

const eventBodySections = event.body
  .replace(/\r/g, "")
  .split("\n")
  .map((line) => line.trim())
  .filter(Boolean)
  .reduce<EventBodySection[]>((sections, line) => {
    if (isHeadingLine(line)) {
      const previous = sections.at(-1);

      if (previous?.title !== line) {
        sections.push({
          title: line,
          items: []
        });
      }

      return sections;
    }

    if (sections.length === 0) {
      sections.push({
        title: "活动简介",
        items: []
      });
    }

    const currentSection = sections[sections.length - 1]!;

    if (line !== currentSection.title) {
      currentSection.items.push(line);
    }

    return sections;
  }, []);

const createContentBlock = (items: string[]): EventContentBlock => {
  const paragraphs: string[] = [];
  const bullets: string[] = [];

  for (const item of items) {
    const trimmed = item.trim();

    if (!trimmed || isPureUrl(trimmed)) {
      continue;
    }

    if (/^[•●▪■◆★⭐-]/.test(trimmed) || /^\d+[、.．)]/.test(trimmed)) {
      bullets.push(stripListMarker(trimmed));
      continue;
    }

    paragraphs.push(trimmed);
  }

  return {
    paragraphs,
    bullets
  };
};

const createAudienceCards = (items: string[]): AudienceCard[] => {
  const cards: { title: string; details: string[] }[] = [];
  let currentCard: { title: string; details: string[] } | null = null;

  const pushCurrentCard = () => {
    if (!currentCard) {
      return;
    }

    cards.push(currentCard);
    currentCard = null;
  };

  for (const item of items) {
    const cleaned = item.trim();

    if (!cleaned || isPureUrl(cleaned)) {
      continue;
    }

    const isCardTitle = cleaned.startsWith("🦞") || /^(如果你是|适合|面向)/.test(cleaned);

    if (isCardTitle) {
      pushCurrentCard();
      currentCard = {
        title: cleaned.replace(/^🦞\s*/, "").trim(),
        details: []
      };
      continue;
    }

    if (!currentCard) {
      currentCard = {
        title: "适合参与的人",
        details: []
      };
    }

    currentCard.details.push(stripListMarker(cleaned));
  }

  pushCurrentCard();

  return cards
    .map((card) => ({
      title: card.title,
      summary: card.details.join(" ").trim()
    }))
    .filter((card) => card.title && card.summary);
};

const registrationUrl = event.registrationUrl;
const showExternalRegistrationLink = shouldShowExternalRegistrationLink(event.registrationState, registrationUrl);
const narrativeSections = eventBodySections.filter(
  (section) =>
    section.items.length > 0 &&
    !/^活动流程$/.test(section.title) &&
    !/^参会须知$/.test(section.title) &&
    !/^报名方式$/.test(section.title) &&
    !/^报名链接$/.test(section.title) &&
    !/^参会标准$/.test(section.title) &&
    !/^非会员申请标准$/.test(section.title) &&
    !/^谁该来.*参与.*$/.test(section.title) &&
    !/^适合/.test(section.title)
);
const introSection = narrativeSections[0] ?? {
  title: "活动介绍",
  items: [event.summary]
};
const introContent = createContentBlock(introSection.items);
const additionalNarrativeSections = narrativeSections.slice(1).map((section) => ({
  title: section.title,
  content: createContentBlock(section.items)
}));
const audienceSectionItems = eventBodySections
  .filter((section) => /^谁该来.*参与.*$/.test(section.title) || /^适合/.test(section.title))
  .flatMap((section) => section.items);
const audienceCards = createAudienceCards(audienceSectionItems);
const fallbackAudienceCards = [
  {
    title: "开放报名",
    summary: "活动对成员与非成员都开放报名，提交后统一进入工作人员后台审核。"
  },
  {
    title: "资料完整更容易通过",
    summary: "建议补充公司、职称和参会诉求，方便工作人员更快判断是否匹配活动定位。"
  },
  {
    title: "审核后继续联系",
    summary: "审核结果可能为通过、拒绝或候补，工作人员会继续跟进后续安排。"
  }
];
const displayedAudienceCards = audienceCards.length > 0 ? audienceCards : fallbackAudienceCards;
const registrationNoticeItems = Array.from(
  new Set(
    eventBodySections
      .filter(
        (section) =>
          /^参会须知$/.test(section.title) ||
          /^报名方式$/.test(section.title) ||
          /^参会标准$/.test(section.title) ||
          /^非会员申请标准$/.test(section.title)
      )
      .flatMap((section) => section.items)
      .map((item) => stripListMarker(item))
      .filter((item) => item && !isPureUrl(item))
  )
);
const registrationSideNotes =
  registrationNoticeItems.length > 0
    ? registrationNoticeItems
    : [
        "提交后会进入工作人员后台，由工作人员统一审核。",
        "审核结果可能为通过、拒绝或转为候补。",
        "审核通过后，工作人员会进一步联系并确认参与信息。"
      ];
const registrationNoticeLabel = registrationNoticeItems.length > 0 ? "报名须知" : "审核说明";
const visibleRegistrationSideNotes = registrationSideNotes.slice(0, 3);
const heroMetaItems = [formatDateRange(event.startsAt, event.endsAt), branchName, formatRegistrationState(event.registrationState)];
const eventFactItems = [
  {
    label: "时间",
    value: formatDateRange(event.startsAt, event.endsAt)
  },
  {
    label: "地点",
    value: eventLocation
  },
  {
    label: "所属分会",
    value: branchName
  },
  {
    label: "报名状态",
    value: formatRegistrationState(event.registrationState)
  }
];
---

<BaseLayout title={`${event.title} | 活动 | TGO 鲲鹏会`} description={event.summary}>
  <main class="page-shell page-stack detail-page-shell event-detail-shell">
    <section class="section">
      <article class:list={["panel detail-hero-card event-detail-head-card", !event.coverImage && "detail-hero-card-single"]}>
        <div class="detail-hero-copy">
          <p class="page-eyebrow">活动</p>
          <h1>{event.title}</h1>
          <p class="detail-summary">{event.summary}</p>

          <div class="detail-meta-row event-detail-meta">
            {heroMetaItems.map((item) => <span class="detail-meta-item">{item}</span>)}
          </div>

          <div class="hero-actions event-detail-actions">
            {registrationEnabled && <a class="button primary" href="#event-registration">{registrationTitle}</a>}
            <a class="text-link" href="/events">返回活动列表</a>
          </div>
        </div>

        {
          event.coverImage && (
            <figure class="detail-hero-figure">
              <img class="detail-hero-image event-detail-image" src={event.coverImage.url} alt={event.coverImage.alt} />
            </figure>
          )
        }
      </article>
    </section>

    <section class="section">
      <div class="detail-content-grid event-detail-layout">
        <div class="event-main-stack">
          <article class="panel prose-panel detail-body-panel event-body-panel">
            <h2 class="card-title">{introSection.title === "活动简介" ? "活动介绍" : introSection.title}</h2>
            {(introContent.paragraphs.length > 0 ? introContent.paragraphs : [event.summary]).map((paragraph) => <p>{paragraph}</p>)}

            {
              introContent.bullets.length > 0 && (
                <ul class="event-rich-list">
                  {introContent.bullets.map((item) => <li>{item}</li>)}
                </ul>
              )
            }

            {
              additionalNarrativeSections.length > 0 && (
                <div class="event-section-stack">
                  {
                    additionalNarrativeSections.map((section) => (
                      <section class="event-section-block">
                        <h3>{section.title}</h3>
                        {section.content.paragraphs.map((paragraph) => <p>{paragraph}</p>)}
                        {
                          section.content.bullets.length > 0 && (
                            <ul class="event-rich-list event-rich-list-compact">
                              {section.content.bullets.map((item) => <li>{item}</li>)}
                            </ul>
                          )
                        }
                      </section>
                    ))
                  }
                </div>
              )
            }
          </article>

          {
            event.agenda.length > 0 && (
              <article class="panel detail-section-card event-agenda-panel">
                <h2>议程安排</h2>
                <ul class="agenda-list">
                  {
                    event.agenda.map((item) => (
                      <li>
                        <strong>{item.time}</strong>
                        <span>{item.title}</span>
                        {item.speaker ? <em>{item.speaker}</em> : null}
                        {item.summary ? <p>{item.summary}</p> : null}
                      </li>
                    ))
                  }
                </ul>
              </article>
            )
          }
        </div>

        <div class="detail-side-stack event-side-stack">
          <article class="panel detail-side-card event-info-panel">
            <h2>活动信息</h2>
            <div class="event-fact-grid">
              {
                eventFactItems.map((item) => (
                  <article class="event-fact-card">
                    <span>{item.label}</span>
                    <strong>{item.value}</strong>
                  </article>
                ))
              }
            </div>
          </article>

          <article class="panel detail-side-card audience-panel">
            <h2>适合参与</h2>
            <div class="audience-card-grid">
              {
                displayedAudienceCards.map((item) => (
                  <article class="audience-card">
                    <h3>{item.title}</h3>
                    <p>{item.summary}</p>
                  </article>
                ))
              }
            </div>
          </article>

        </div>
      </div>
    </section>

    <section class="section registration-shell" id="event-registration">
      <div class="panel detail-section-card registration-panel">
        <div class="registration-head">
          <div class="registration-head-top">
            <h2>{registrationTitle}</h2>
            <span class="detail-meta-item registration-state-chip">{formatRegistrationState(event.registrationState)}</span>
          </div>
          <p class="registration-copy">开放报名，提交后由工作人员审核，并继续联系确认是否通过或转入候补。</p>
        </div>

        {
          registrationEnabled ? (
            <form class="form-panel" data-event-registration-form data-api-base={apiBaseUrl} data-event-slug={event.slug}>
              <div class="form-grid registration-form-grid">
                <label>
                  <span>姓名</span>
                  <input name="name" type="text" required minlength="2" />
                </label>

                <label>
                  <span>手机号</span>
                  <input name="phoneNumber" type="tel" required inputmode="tel" />
                </label>

                <label>
                  <span>微信号</span>
                  <input name="wechatId" type="text" />
                </label>

                <label>
                  <span>邮箱</span>
                  <input name="email" type="email" />
                </label>

                <label>
                  <span>公司</span>
                  <input name="company" type="text" />
                </label>

                <label>
                  <span>职称</span>
                  <input name="title" type="text" />
                </label>
              </div>

              <label>
                <span>补充信息</span>
                <textarea name="note" rows="4" placeholder="例如你的关注议题、参会目的，或你希望在活动中交流的问题。"></textarea>
              </label>

              <div class="form-actions registration-actions-row">
                <div class="registration-actions">
                  <button class="button primary" type="submit">{registrationSubmitLabel}</button>
                  {
                    showExternalRegistrationLink && (
                      <a class="text-link registration-backup-link" href={registrationUrl!} target="_blank" rel="noreferrer">
                        如页面提交异常，可改用外部报名入口
                      </a>
                    )
                  }
                </div>
                <p class="form-status" data-event-registration-status>请至少填写姓名和手机号，便于工作人员联系。</p>
              </div>
            </form>
          ) : (
            <div class="registration-note">
              <p>{event.registrationState === "closed" ? "这场活动的报名已经关闭。" : "报名暂未开放，请稍后再来查看。"}</p>
            </div>
          )
        }
      </div>

      <aside class="panel detail-side-card detail-sticky registration-side">
        <div>
          <h2>{registrationNoticeLabel}</h2>
          <div class="registration-note-cards">
            {visibleRegistrationSideNotes.map((item) => <article class="registration-note-card">{item}</article>)}
          </div>
        </div>

        <div class="event-next-links">
          <a class="text-link" href="/events">返回活动列表</a>
          {event.branch && <a class="text-link" href={`/branches#${event.branch.slug}`}>查看所属分会</a>}
        </div>
      </aside>
    </section>
  </main>

  <script>
    const form = document.querySelector("[data-event-registration-form]");
    const status = document.querySelector("[data-event-registration-status]");

    if (form instanceof HTMLFormElement && status instanceof HTMLElement) {
      form.addEventListener("submit", async (submitEvent) => {
        submitEvent.preventDefault();
        status.textContent = "提交中...";

        const formData = new FormData(form);
        const payload = Object.fromEntries(
          Array.from(formData.entries()).filter(([, value]) => typeof value === "string" && value.trim().length > 0)
        );
        const baseUrl = form.dataset.apiBase ?? "http://127.0.0.1:8787";
        const eventSlug = form.dataset.eventSlug;

        if (!eventSlug) {
          status.textContent = "活动配置不完整。";
          return;
        }

        try {
          const response = await fetch(new URL(`/api/public/v1/events/${eventSlug}/registrations`, baseUrl), {
            method: "POST",
            headers: {
              "Content-Type": "application/json"
            },
            body: JSON.stringify(payload)
          });

          const result = await response.json();

          if (!response.ok) {
            const firstIssue = result.error?.details?.issues?.[0]?.message;
            status.textContent = firstIssue ?? result.error?.message ?? "报名提交失败，请稍后再试。";
            return;
          }

          status.textContent = `${result.data.status === "waitlisted" ? "已加入候补名单" : "报名已提交"}，编号 ${result.data.id}。`;
          form.reset();
        } catch {
          status.textContent = "API 当前不可用，请先启动 apps/api 以测试完整报名流程。";
        }
      });
    }
  </script>
</BaseLayout>

<style>
  .event-main-stack,
  .registration-shell,
  .audience-card-grid,
  .event-section-stack {
    display: grid;
    gap: 18px;
  }

  .event-main-stack {
    align-content: start;
  }

  .registration-shell {
    grid-template-columns: minmax(0, 1.08fr) minmax(320px, 0.92fr);
    align-items: start;
  }

  .event-registration-prompt,
  .event-info-panel,
  .audience-panel,
  .event-agenda-panel,
  .registration-panel,
  .registration-side {
    gap: 16px;
  }

  .event-info-panel h2,
  .audience-panel h2,
  .event-agenda-panel h2,
  .registration-head h2,
  .registration-side h2 {
    margin: 0;
  }

  .event-fact-card span,
  .event-rich-list li,
  .audience-card p,
  .registration-copy,
  .registration-note-card,
  .registration-note p {
    color: var(--muted);
    line-height: 1.82;
  }

  .registration-copy,
  .registration-note p {
    margin: 0;
  }

  .event-body-panel p:first-of-type {
    color: var(--ink);
    font-size: 1.05rem;
  }

  .event-section-block {
    display: grid;
    gap: 12px;
  }

  .event-section-block h3,
  .audience-card h3 {
    margin: 0;
    font-size: 1.06rem;
  }

  .event-rich-list {
    display: grid;
    gap: 10px;
    margin: 0;
    padding-left: 18px;
  }

  .event-fact-grid {
    display: grid;
    gap: 12px;
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .event-fact-card,
  .audience-card {
    display: grid;
    gap: 6px;
    padding: 16px 18px;
    border-radius: 18px;
    border: 1px solid rgba(27, 23, 19, 0.08);
    background: rgba(255, 255, 255, 0.72);
  }

  .event-fact-card span {
    font-size: 0.84rem;
    letter-spacing: 0.04em;
  }

  .event-fact-card strong {
    line-height: 1.7;
  }

  .registration-head {
    display: grid;
    gap: 10px;
  }

  .registration-head-top {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
  }

  .event-agenda-panel .agenda-list li {
    gap: 8px;
    padding: 18px;
  }

  .registration-state-chip {
    white-space: nowrap;
  }

  .registration-form-grid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .registration-actions-row {
    align-items: flex-start;
  }

  .registration-actions {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }

  .registration-note-cards {
    display: grid;
    gap: 12px;
  }

  .registration-backup-link {
    align-self: center;
    font-size: 0.95rem;
  }

  .registration-note-card {
    padding: 14px 16px;
    border-radius: 18px;
    border: 1px solid rgba(27, 23, 19, 0.08);
    background: rgba(255, 255, 255, 0.72);
  }

  .event-next-links {
    display: grid;
    gap: 12px;
  }

  @media (max-width: 1100px) {
    .registration-shell {
      grid-template-columns: 1fr;
    }

    .event-fact-grid {
      grid-template-columns: 1fr;
    }

    .registration-form-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 720px) {
    .event-detail-image {
      min-height: 220px;
    }

    .registration-form-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
