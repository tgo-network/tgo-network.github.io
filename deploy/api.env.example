APP_ENV=production
APP_VERSION=2026.03.28
GIT_SHA=replace-with-commit-sha
LOG_FORMAT=json

DATABASE_URL=postgres://postgres:postgres@db.example.internal:5432/tgo_network
BETTER_AUTH_SECRET=replace-with-a-long-random-secret
BETTER_AUTH_URL=https://api.example.com
PUBLIC_API_BASE_URL=https://api.example.com
CORS_ALLOWED_ORIGINS=https://www.example.com,https://admin.example.com
INTERNAL_API_TOKEN=replace-with-an-internal-job-token

S3_ENDPOINT=
S3_REGION=us-east-1
S3_BUCKET=tgo-network-production
S3_ACCESS_KEY_ID=replace-with-storage-access-key
S3_SECRET_ACCESS_KEY=replace-with-storage-secret-key
S3_FORCE_PATH_STYLE=false
S3_PUBLIC_BASE_URL=https://assets.example.com

ASSET_UPLOAD_EXPIRES_IN_SECONDS=900
PUBLIC_WRITE_RATE_LIMIT_WINDOW_SECONDS=300
PUBLIC_APPLICATION_RATE_LIMIT_MAX=8
PUBLIC_EVENT_REGISTRATION_RATE_LIMIT_MAX=12
ASSET_IMAGE_MAX_DIMENSION=12000
ASSET_IMAGE_MAX_PIXELS=40000000
