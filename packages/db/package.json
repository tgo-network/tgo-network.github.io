{
  "name": "@tgo/db",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.seed.json --noEmit",
    "generate": "drizzle-kit generate",
    "migrate": "drizzle-kit migrate",
    "studio": "drizzle-kit studio",
    "seed": "node --env-file=../../.env --import tsx src/seed.ts",
    "import:tgo-infoq": "node --env-file=../../.env --import tsx src/import-tgo-infoq.ts",
    "cleanup:demo-events": "node --env-file=../../.env --import tsx src/cleanup-demo-events.ts",
    "sync-homepage:tgo-infoq": "node --env-file=../../.env --import tsx src/sync-tgo-infoq-homepage.ts"
  },
  "dependencies": {
    "@tgo/shared": "workspace:*",
    "drizzle-orm": "^0.41.0",
    "pg": "^8.13.3"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/pg": "^8.15.1",
    "drizzle-kit": "^0.30.4",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
