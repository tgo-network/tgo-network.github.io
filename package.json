{
  "name": "tgo-network",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.8.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "env COREPACK_HOME=\"$PWD/.corepack\" corepack pnpm -r --parallel --filter @tgo/site --filter @tgo/admin --filter @tgo/api dev",
    "dev:site": "env COREPACK_HOME=\"$PWD/.corepack\" corepack pnpm --filter @tgo/site dev",
    "dev:admin": "env COREPACK_HOME=\"$PWD/.corepack\" corepack pnpm --filter @tgo/admin dev",
    "dev:api": "env COREPACK_HOME=\"$PWD/.corepack\" corepack pnpm --filter @tgo/api dev",
    "dev:demos": "node scripts/serve-design-demos.mjs",
    "infra:up": "docker compose up -d",
    "infra:up:storage": "docker compose --profile storage up -d minio minio-create-bucket",
    "infra:down": "docker compose down",
    "infra:logs": "docker compose logs -f postgres minio minio-create-bucket",
    "build": "env COREPACK_HOME=\"$PWD/.corepack\" corepack pnpm -r --if-present build",
    "typecheck": "env COREPACK_HOME=\"$PWD/.corepack\" corepack pnpm -r --if-present typecheck",
    "test": "env COREPACK_HOME=\"$PWD/.corepack\" corepack pnpm -r --if-present test",
    "test:api": "env COREPACK_HOME=\"$PWD/.corepack\" corepack pnpm --filter @tgo/api test:integration",
    "test:admin": "env COREPACK_HOME=\"$PWD/.corepack\" corepack pnpm --filter @tgo/admin test",
    "test:site": "env COREPACK_HOME=\"$PWD/.corepack\" corepack pnpm --filter @tgo/site test",
    "test:e2e": "node scripts/run-e2e.mjs",
    "test:e2e:screenshots": "node scripts/run-e2e.mjs --config=playwright.screenshots.config.ts",
    "test:e2e:screenshots:headed": "node scripts/run-e2e.mjs --config=playwright.screenshots.config.ts --headed",
    "test:e2e:headed": "node scripts/run-e2e.mjs --headed",
    "test:e2e:install": "playwright install chromium",
    "data:fetch:tgo-infoq": "python3 scripts/scrape_tgo_infoq.py",
    "data:convert:members": "python3 scripts/convert_members_workbook.py",
    "db:import:tgo-infoq": "env COREPACK_HOME=\"$PWD/.corepack\" corepack pnpm --filter @tgo/db import:tgo-infoq",
    "db:import:members": "env COREPACK_HOME=\"$PWD/.corepack\" corepack pnpm --filter @tgo/db import:members",
    "db:cleanup:demo-events": "env COREPACK_HOME=\"$PWD/.corepack\" corepack pnpm --filter @tgo/db cleanup:demo-events",
    "db:sync-homepage:tgo-infoq": "env COREPACK_HOME=\"$PWD/.corepack\" corepack pnpm --filter @tgo/db sync-homepage:tgo-infoq",
    "env:check:api": "env COREPACK_HOME=\"$PWD/.corepack\" corepack pnpm --filter @tgo/api validate-env",
    "docker:build:api": "docker build -f apps/api/Dockerfile -t tgo-api .",
    "lint": "env COREPACK_HOME=\"$PWD/.corepack\" corepack pnpm -r --if-present lint",
    "db:generate": "env COREPACK_HOME=\"$PWD/.corepack\" corepack pnpm --filter @tgo/db generate",
    "db:migrate": "env COREPACK_HOME=\"$PWD/.corepack\" corepack pnpm --filter @tgo/db migrate",
    "db:seed": "env COREPACK_HOME=\"$PWD/.corepack\" corepack pnpm --filter @tgo/db seed",
    "auth:bootstrap-admin": "env COREPACK_HOME=\"$PWD/.corepack\" corepack pnpm --filter @tgo/api bootstrap-admin",
    "bootstrap:dev": "npm run db:migrate && npm run db:seed && npm run auth:bootstrap-admin",
    "bootstrap:tgo-infoq": "npm run db:migrate && npm run db:seed && npm run db:cleanup:demo-events && npm run data:convert:members && npm run db:import:tgo-infoq && npm run db:import:members && npm run db:sync-homepage:tgo-infoq && npm run auth:bootstrap-admin"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0"
  }
}
